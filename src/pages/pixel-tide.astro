---
import BaseLayout from "../layouts/BaseLayout.astro";
import PixelTide from "../components/PixelTide.tsx";
const title = "Pixel Tide — stanwood.dev";
---

<BaseLayout
  title={title}
  description="Waves of colored pixels wash in and out on a beach. Click to build sandcastles the tide slowly erodes. No winning, just vibes."
  slug="pixel-tide"
  favicon="/favicon-pixel-tide.svg"
  themeColor="#1a1520"
  fontsUrl="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Space+Grotesk:wght@500;700&family=Press+Start+2P&display=swap"
  schemaCategory="GameApplication"
>
  <Fragment slot="head">
    <style>
      body {
        font-family: 'Inter', system-ui, sans-serif;
        min-height: 100vh;
        color: #fef0e0;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        background: #1a1520;
      }

      .hero-banner {
        position: relative;
        width: 100%;
        height: 200px;
        border-radius: 1rem;
        overflow: hidden;
        margin-top: 1.5rem;
        box-shadow: 0 4px 30px rgba(232, 149, 106, 0.15);
      }
      .hero-banner img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        image-rendering: auto;
      }
      .hero-gradient {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 60%;
        background: linear-gradient(to top, #1a1520, rgba(26, 21, 32, 0.5) 60%, transparent);
        pointer-events: none;
      }
      @media (min-width: 640px) {
        .hero-banner { height: 280px; }
      }
    </style>
  </Fragment>

  <a href="#main-content" class="skip-nav">Skip to content</a>

  <main id="main-content" class="mx-auto max-w-3xl px-6 pt-12 pb-24">
    <!-- Nav -->
    <div class="flex items-center">
      <a href="/" class="retro-back" style="color: #e8956a;">&larr; stanwood.dev</a>
    </div>

    <!-- Hero -->
    <div class="hero-banner">
      <img src="/images/pixel-tide.webp" alt="Pixel art sunset beach with sandcastles and waves" loading="lazy" decoding="async" width="800" height="449" />
      <div class="hero-gradient"></div>
    </div>

    <!-- Header -->
    <header class="relative z-10 -mt-6 mb-6 text-center">
      <div class="flex items-center justify-center gap-3">
        <div
          class="flex items-center justify-center w-12 h-12 rounded-2xl shadow-lg"
          style="background: linear-gradient(135deg, #e8956a, #5bb5d5); box-shadow: 0 8px 24px rgba(232, 149, 106, 0.3);"
        >
          <svg class="w-6 h-6 text-[#1a1520]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" />
          </svg>
        </div>
        <div>
          <h1
            class="text-xl sm:text-2xl font-extrabold tracking-tight"
            style="font-family: 'Press Start 2P', monospace; background: linear-gradient(135deg, #f5c6a0, #e8956a, #d4805a); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"
          >
            Pixel Tide
          </h1>
        </div>
      </div>
      <p class="mt-3 text-sm tracking-wide" style="color: rgba(245, 198, 160, 0.5);">a day at the beach from the comfort of your home</p>
    </header>

    <!-- Description -->
    <section class="mb-8 text-center max-w-xl mx-auto">
      <p class="text-sm leading-relaxed" style="color: rgba(245, 198, 160, 0.65);">
        A pixel beach that runs on its own. Click anywhere on the sand to place a sandcastle — the tide will slowly creep in and wash it away. Four themes, seagulls, tide physics. No score, no goal, no winning. Just waves.
      </p>
    </section>

    <!-- Game -->
    <PixelTide client:idle />

    <!-- Tips -->
    <section class="mt-10 pt-8" style="border-top: 1px solid rgba(245, 198, 160, 0.1);">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
        <div>
          <p class="text-2xl mb-2">🏖️</p>
          <p class="text-xs leading-snug" style="color: rgba(245, 198, 160, 0.5);">Click dry sand to drop a castle. The closer to the water, the faster it goes.</p>
        </div>
        <div>
          <p class="text-2xl mb-2">🌊</p>
          <p class="text-xs leading-snug" style="color: rgba(245, 198, 160, 0.5);">The tide rises and falls on its own ~15-second cycle. Watch the indicator.</p>
        </div>
        <div>
          <p class="text-2xl mb-2">🏰</p>
          <p class="text-xs leading-snug" style="color: rgba(245, 198, 160, 0.5);">Castles erode block by block from the base up. Towers collapse when support disappears.</p>
        </div>
        <div>
          <p class="text-2xl mb-2">🎨</p>
          <p class="text-xs leading-snug" style="color: rgba(245, 198, 160, 0.5);">Switch themes — Tropical, Sunset, Arctic, or Night — to change the whole mood.</p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
