---
import BaseLayout from "../layouts/BaseLayout.astro";
import PixelTideApp from "../components/PixelTide.tsx";
const title = "Pixel Tide — stanwood.dev";
---

<BaseLayout
  title={title}
  description="Waves of colored pixels wash in and out on a beach. Click to build sandcastles the tide slowly erodes. No winning, just vibes."
  slug="pixel-tide"
  favicon="/favicon-pixel-tide.svg"
  themeColor="#1a1520"
  fontsUrl="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Space+Grotesk:wght@500;700&family=Press+Start+2P&display=swap"
  schemaCategory="GameApplication"
>
  <Fragment slot="head">
    <style>
      body {
        font-family: 'Inter', system-ui, sans-serif;
        min-height: 100vh;
        color: #fef0e0;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        background: #1a1520;
      }

      .hero-banner {
        position: relative;
        width: 100%;
        height: 200px;
        border-radius: 1rem;
        overflow: hidden;
        margin-top: 1.5rem;
        box-shadow: 0 4px 30px rgba(232, 149, 106, 0.15);
      }
      .hero-banner img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        image-rendering: auto;
      }
      .hero-gradient {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 60%;
        background: linear-gradient(to top, #1a1520, rgba(26, 21, 32, 0.5) 60%, transparent);
        pointer-events: none;
      }
      @media (min-width: 640px) {
        .hero-banner { height: 280px; }
      }

      /* ── Tips cards ── */
      .tips-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        max-width: 640px;
        margin: 0 auto;
      }
      @media (min-width: 540px) {
        .tips-grid { grid-template-columns: repeat(4, 1fr); }
      }
      .tip-card {
        border: 1px solid rgba(245, 198, 160, 0.12);
        border-radius: 6px;
        padding: 10px 10px 12px;
        background: rgba(232, 149, 106, 0.05);
        text-align: center;
      }
      .tip-icon { font-size: 1.2rem; margin-bottom: 6px; display: block; }
      .tip-title {
        font-family: 'Press Start 2P', monospace;
        font-size: 0.42rem;
        color: rgba(245, 198, 160, 0.65);
        letter-spacing: 0.04em;
        margin-bottom: 5px;
        display: block;
      }
      .tip-body {
        font-size: 0.65rem;
        color: rgba(245, 198, 160, 0.45);
        line-height: 1.5;
      }

      /* ── Behind the Waves cards ── */
      .behind-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }
      @media (max-width: 540px) {
        .behind-grid { grid-template-columns: 1fr; }
      }
      .behind-card {
        border: 1px solid rgba(245, 198, 160, 0.1);
        border-radius: 8px;
        padding: 14px 14px 16px;
        background: rgba(232, 149, 106, 0.05);
      }
      .behind-card-title {
        font-size: 0.7rem;
        font-weight: 600;
        color: rgba(245, 198, 160, 0.7);
        margin-bottom: 6px;
        letter-spacing: 0.02em;
        font-family: 'Space Grotesk', sans-serif;
      }
      .behind-card-body {
        font-size: 0.65rem;
        color: rgba(245, 198, 160, 0.45);
        line-height: 1.65;
      }

      /* ── Beach gallery ── */
      .beach-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }
      @media (max-width: 540px) {
        .beach-grid { grid-template-columns: 1fr; }
      }
      .beach-card {
        position: relative;
        border: 1px solid rgba(245, 198, 160, 0.12);
        border-radius: 10px;
        padding: 14px 14px 16px;
        background: rgba(232, 149, 106, 0.04);
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        gap: 10px;
        transition: border-color 0.18s, background 0.18s, transform 0.18s;
      }
      .beach-card:hover,
      .beach-card:focus-visible {
        border-color: rgba(245, 198, 160, 0.32);
        background: rgba(232, 149, 106, 0.08);
        transform: translateY(-1px);
        outline: none;
      }
      .beach-card.is-active {
        border-color: rgba(232, 149, 106, 0.55);
        background: rgba(232, 149, 106, 0.12);
        box-shadow: 0 0 0 1px rgba(232, 149, 106, 0.35) inset;
      }
      .beach-swatches {
        display: flex;
        gap: 0;
        height: 36px;
        border-radius: 6px;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.25);
      }
      .beach-swatches > span {
        flex: 1;
        display: block;
      }
      .beach-card-row {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 8px;
      }
      .beach-card-name {
        font-family: 'Press Start 2P', monospace;
        font-size: 0.55rem;
        letter-spacing: 0.05em;
        color: rgba(245, 198, 160, 0.85);
      }
      .beach-card-active {
        font-size: 0.55rem;
        color: rgba(232, 149, 106, 0.7);
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }
      .beach-card-vibe {
        font-size: 0.7rem;
        color: rgba(245, 198, 160, 0.55);
        line-height: 1.5;
        margin: 0;
      }
      .beach-card-cta {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.6rem;
        color: rgba(245, 198, 160, 0.35);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        margin-top: auto;
      }
      .beach-card:hover .beach-card-cta,
      .beach-card:focus-visible .beach-card-cta {
        color: rgba(245, 198, 160, 0.7);
      }

      /* ── Real-tide wonders gallery ── */
      .wonder-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }
      @media (max-width: 540px) {
        .wonder-grid { grid-template-columns: 1fr; }
      }
      .wonder-card {
        position: relative;
        border: 1px solid rgba(245, 198, 160, 0.12);
        border-radius: 10px;
        padding: 0;
        background: rgba(232, 149, 106, 0.04);
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }
      .wonder-svg-wrap {
        width: 100%;
        aspect-ratio: 16 / 9;
        background: rgba(26, 21, 32, 0.5);
        border-bottom: 1px solid rgba(245, 198, 160, 0.08);
        display: block;
      }
      .wonder-svg-wrap svg {
        display: block;
        width: 100%;
        height: 100%;
      }
      .wonder-body {
        padding: 12px 14px 14px;
        display: flex;
        flex-direction: column;
        gap: 4px;
      }
      .wonder-row {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 8px;
      }
      .wonder-name {
        font-family: 'Press Start 2P', monospace;
        font-size: 0.55rem;
        letter-spacing: 0.04em;
        color: rgba(245, 198, 160, 0.85);
        line-height: 1.3;
      }
      .wonder-range {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.7rem;
        font-weight: 700;
        color: #e8956a;
        white-space: nowrap;
      }
      .wonder-place {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.6rem;
        color: rgba(245, 198, 160, 0.45);
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .wonder-fact {
        font-size: 0.7rem;
        color: rgba(245, 198, 160, 0.55);
        line-height: 1.5;
        margin: 4px 0 0;
      }

      /* ── Vs your beach scale strip ── */
      .scale-strip {
        margin-top: 14px;
        padding: 14px 16px;
        border: 1px dashed rgba(245, 198, 160, 0.18);
        border-radius: 8px;
        background: rgba(232, 149, 106, 0.03);
        font-size: 0.7rem;
        color: rgba(245, 198, 160, 0.55);
        line-height: 1.6;
      }
      .scale-strip strong {
        color: rgba(245, 198, 160, 0.85);
        font-weight: 600;
      }
    </style>
  </Fragment>

  <a href="#main-content" class="skip-nav">Skip to content</a>

  <main id="main-content" class="mx-auto max-w-3xl px-6 pt-12 pb-24">
    <!-- Nav -->
    <div class="flex items-center">
      <a href="/" class="retro-back" style="color: #e8956a;">&larr; stanwood.dev</a>
    </div>

    <!-- Hero -->
    <div class="hero-banner">
      <img src="/images/pixel-tide.webp" alt="Pixel art sunset beach with sandcastles and waves" loading="lazy" decoding="async" width="800" height="449" />
      <div class="hero-gradient"></div>
    </div>

    <!-- Header -->
    <header class="relative z-10 -mt-6 mb-6 text-center">
      <div class="flex items-center justify-center gap-3">
        <div
          class="flex items-center justify-center w-12 h-12 rounded-2xl shadow-lg"
          style="background: linear-gradient(135deg, #e8956a, #5bb5d5); box-shadow: 0 8px 24px rgba(232, 149, 106, 0.3);"
        >
          <svg class="w-6 h-6 text-[#1a1520]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" />
          </svg>
        </div>
        <div>
          <h1
            class="text-xl sm:text-2xl font-extrabold tracking-tight"
            style="font-family: 'Press Start 2P', monospace; background: linear-gradient(135deg, #f5c6a0, #e8956a, #d4805a); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"
          >
            Pixel Tide
          </h1>
        </div>
      </div>
      <p class="mt-3 text-sm tracking-wide" style="color: rgba(245, 198, 160, 0.5);">a day at the beach from the comfort of your home</p>
    </header>

    <!-- Description -->
    <section class="mb-8 text-center max-w-xl mx-auto">
      <p class="text-sm leading-relaxed" style="color: rgba(245, 198, 160, 0.65);">
        A pixel beach that runs on its own. Click anywhere on the sand to place a sandcastle — the tide will slowly creep in and wash it away. Four themes, seagulls, tide physics. No score, no goal, no winning. Just waves.
      </p>
    </section>

    <!-- Game -->
    <PixelTideApp client:idle />

    <!-- Tips -->
    <section class="mt-10 pt-8" style="border-top: 1px solid rgba(245, 198, 160, 0.1);">
      <h2 class="text-xs font-bold uppercase tracking-widest mb-5" style="color: rgba(245, 198, 160, 0.35); font-family: 'Space Grotesk', sans-serif;">How to Play</h2>
      <div class="tips-grid">
        <div class="tip-card">
          <span class="tip-icon">🏖️</span>
          <span class="tip-title">Build a Castle</span>
          <span class="tip-body">Click dry sand to place a castle. Closer to the waterline means faster erosion — risky spots are more fun.</span>
        </div>
        <div class="tip-card">
          <span class="tip-icon">🌊</span>
          <span class="tip-title">Watch the Tide</span>
          <span class="tip-body">The tide rises and falls on its own ~15-second cycle. Watch the indicator to time your builds.</span>
        </div>
        <div class="tip-card">
          <span class="tip-icon">🏰</span>
          <span class="tip-title">Erosion</span>
          <span class="tip-body">Blocks under the waterline erode first. Towers collapse when their base disappears — tall and thin falls fastest.</span>
        </div>
        <div class="tip-card">
          <span class="tip-icon">🎨</span>
          <span class="tip-title">Themes & Speed</span>
          <span class="tip-body">Four themes (Tropical, Sunset, Arctic, Night) and three speeds — Calm, Normal, Surge. Share copies a link with your exact settings.</span>
        </div>
      </div>
    </section>

    <!-- Pick your beach -->
    <section class="mt-10 pt-8" style="border-top: 1px solid rgba(245, 198, 160, 0.1);">
      <div class="flex items-baseline justify-between mb-5 gap-3 flex-wrap">
        <h2 class="text-xs font-bold uppercase tracking-widest" style="color: rgba(245, 198, 160, 0.35); font-family: 'Space Grotesk', sans-serif;">Pick your beach</h2>
        <span class="text-[10px]" style="color: rgba(245, 198, 160, 0.3); font-family: 'Space Grotesk', sans-serif;">tap to load it above</span>
      </div>
      <div class="beach-grid">
        <a href="?theme=tropical" class="beach-card" data-theme="tropical" aria-label="Switch to Tropical theme">
          <div class="beach-swatches" aria-hidden="true">
            <span style="background:#F5E6C8;"></span>
            <span style="background:#C4A97D;"></span>
            <span style="background:#5BB5D5;"></span>
            <span style="background:#2E86AB;"></span>
            <span style="background:#D4A76A;"></span>
          </div>
          <div class="beach-card-row">
            <span class="beach-card-name">Tropical</span>
            <span class="beach-card-active" data-active-label hidden>now playing</span>
          </div>
          <p class="beach-card-vibe">Bright midday sun. Crystal water, pale sand, the noisiest seagulls of the bunch.</p>
          <span class="beach-card-cta">Open this beach →</span>
        </a>
        <a href="?theme=sunset" class="beach-card" data-theme="sunset" aria-label="Switch to Sunset theme">
          <div class="beach-swatches" aria-hidden="true">
            <span style="background:#F0D9A0;"></span>
            <span style="background:#C49060;"></span>
            <span style="background:#E8956A;"></span>
            <span style="background:#C05050;"></span>
            <span style="background:#D4A76A;"></span>
          </div>
          <div class="beach-card-row">
            <span class="beach-card-name">Sunset</span>
            <span class="beach-card-active" data-active-label hidden>now playing</span>
          </div>
          <p class="beach-card-vibe">Golden hour. Warm waves and long shadows pulling everything sideways.</p>
          <span class="beach-card-cta">Open this beach →</span>
        </a>
        <a href="?theme=arctic" class="beach-card" data-theme="arctic" aria-label="Switch to Arctic theme">
          <div class="beach-swatches" aria-hidden="true">
            <span style="background:#E8E8F0;"></span>
            <span style="background:#A0A0B8;"></span>
            <span style="background:#5588AA;"></span>
            <span style="background:#1A4060;"></span>
            <span style="background:#C0C0D0;"></span>
          </div>
          <div class="beach-card-row">
            <span class="beach-card-name">Arctic</span>
            <span class="beach-card-active" data-active-label hidden>now playing</span>
          </div>
          <p class="beach-card-vibe">Cold-water coast. Pale sand, blue-grey tide, castles that look carved from ice.</p>
          <span class="beach-card-cta">Open this beach →</span>
        </a>
        <a href="?theme=night" class="beach-card" data-theme="night" aria-label="Switch to Night theme">
          <div class="beach-swatches" aria-hidden="true">
            <span style="background:#4A4050;"></span>
            <span style="background:#302830;"></span>
            <span style="background:#2A3060;"></span>
            <span style="background:#141830;"></span>
            <span style="background:#686070;"></span>
          </div>
          <div class="beach-card-row">
            <span class="beach-card-name">Night</span>
            <span class="beach-card-active" data-active-label hidden>now playing</span>
          </div>
          <p class="beach-card-vibe">Moonlit shore. Quiet, slow, and the foam catches starlight on its way out.</p>
          <span class="beach-card-cta">Open this beach →</span>
        </a>
      </div>
      <p class="mt-4 text-[10px] text-center" style="color: rgba(245, 198, 160, 0.3);">Add <code style="color: rgba(245, 198, 160, 0.5);">&amp;speed=calm</code>, <code style="color: rgba(245, 198, 160, 0.5);">normal</code>, or <code style="color: rgba(245, 198, 160, 0.5);">surge</code> to any link to set the tide pace.</p>
    </section>

    <!-- Real Tide Wonders -->
    <section class="mt-10 pt-8" style="border-top: 1px solid rgba(245, 198, 160, 0.1);">
      <div class="flex items-baseline justify-between mb-5 gap-3 flex-wrap">
        <h2 class="text-xs font-bold uppercase tracking-widest" style="color: rgba(245, 198, 160, 0.35); font-family: 'Space Grotesk', sans-serif;">Real Tide Wonders</h2>
        <span class="text-[10px]" style="color: rgba(245, 198, 160, 0.3); font-family: 'Space Grotesk', sans-serif;">tides that eat beaches</span>
      </div>
      <p class="text-xs leading-relaxed mb-5" style="color: rgba(245, 198, 160, 0.5); max-width: 540px;">
        Pixel Tide compresses ~12 hours of real tide into a 15-second loop. Out in the world, some coasts swing
        so far between high and low that the beach itself disappears twice a day. Here are six of the most
        extreme.
      </p>

      <div class="wonder-grid">
        <!-- Bay of Fundy -->
        <article class="wonder-card">
          <div class="wonder-svg-wrap">
            <svg viewBox="0 0 320 180" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Bay of Fundy with tall tide range">
              <rect width="320" height="180" fill="#1a1520"/>
              <rect x="0" y="120" width="320" height="60" fill="#2e4a5a"/>
              <rect x="0" y="156" width="320" height="24" fill="#1a3548"/>
              <line x1="20" y1="40" x2="20" y2="156" stroke="#e8956a" stroke-width="1.5" stroke-dasharray="3 3"/>
              <polygon points="14,40 26,40 20,32" fill="#e8956a"/>
              <polygon points="14,156 26,156 20,164" fill="#e8956a"/>
              <text x="32" y="46" font-family="'Space Grotesk', sans-serif" font-size="9" fill="#e8956a">HIGH</text>
              <text x="32" y="160" font-family="'Space Grotesk', sans-serif" font-size="9" fill="#e8956a">LOW</text>
              <rect x="180" y="92" width="50" height="64" fill="#3d2a1f"/>
              <rect x="186" y="98" width="6" height="6" fill="#f5c6a0"/>
              <rect x="200" y="98" width="6" height="6" fill="#f5c6a0"/>
              <rect x="214" y="98" width="6" height="6" fill="#f5c6a0"/>
              <rect x="186" y="112" width="6" height="6" fill="#f5c6a0"/>
              <rect x="200" y="112" width="6" height="6" fill="#f5c6a0"/>
              <rect x="214" y="112" width="6" height="6" fill="#f5c6a0"/>
              <rect x="244" y="116" width="60" height="40" fill="#4a3525"/>
              <text x="160" y="20" font-family="'Press Start 2P', monospace" font-size="7" fill="#f5c6a0" text-anchor="middle">53 ft swing</text>
            </svg>
          </div>
          <div class="wonder-body">
            <div class="wonder-row">
              <span class="wonder-name">Bay of Fundy</span>
              <span class="wonder-range">53 ft</span>
            </div>
            <p class="wonder-place">Nova Scotia / New Brunswick</p>
            <p class="wonder-fact">The world record. 160 billion tonnes of water flow in and out twice a day — more than every river on Earth combined. Boats sit on mud six hours later.</p>
          </div>
        </article>

        <!-- Bristol Channel -->
        <article class="wonder-card">
          <div class="wonder-svg-wrap">
            <svg viewBox="0 0 320 180" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Bristol Channel with second-highest tides">
              <rect width="320" height="180" fill="#1a1520"/>
              <path d="M0,140 Q80,138 160,142 T320,140 L320,180 L0,180 Z" fill="#2a4252"/>
              <rect x="0" y="156" width="320" height="24" fill="#5a4528"/>
              <rect x="40" y="80" width="80" height="76" fill="#2a2a35"/>
              <rect x="46" y="86" width="6" height="6" fill="#ffd966"/>
              <rect x="60" y="86" width="6" height="6" fill="#ffd966"/>
              <rect x="74" y="86" width="6" height="6" fill="#ffd966"/>
              <rect x="88" y="86" width="6" height="6" fill="#ffd966"/>
              <rect x="46" y="100" width="6" height="6" fill="#ffd966"/>
              <rect x="74" y="100" width="6" height="6" fill="#ffd966"/>
              <rect x="46" y="114" width="6" height="6" fill="#ffd966"/>
              <rect x="60" y="114" width="6" height="6" fill="#ffd966"/>
              <rect x="46" y="128" width="6" height="6" fill="#ffd966"/>
              <rect x="88" y="128" width="6" height="6" fill="#ffd966"/>
              <path d="M150,140 Q160,128 170,140" fill="none" stroke="#5bb5d5" stroke-width="2"/>
              <path d="M180,140 Q195,124 210,140" fill="none" stroke="#5bb5d5" stroke-width="2"/>
              <path d="M220,140 Q235,130 250,140" fill="none" stroke="#5bb5d5" stroke-width="2"/>
              <text x="160" y="20" font-family="'Press Start 2P', monospace" font-size="7" fill="#f5c6a0" text-anchor="middle">49 ft swing</text>
            </svg>
          </div>
          <div class="wonder-body">
            <div class="wonder-row">
              <span class="wonder-name">Bristol Channel</span>
              <span class="wonder-range">49 ft</span>
            </div>
            <p class="wonder-place">England / Wales</p>
            <p class="wonder-fact">A funnel-shaped estuary that squeezes the Atlantic into a narrowing channel — physics amplifies the tide to nearly five-story heights. Powers the world's first tidal-energy plant.</p>
          </div>
        </article>

        <!-- Mont-Saint-Michel -->
        <article class="wonder-card">
          <div class="wonder-svg-wrap">
            <svg viewBox="0 0 320 180" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Mont-Saint-Michel surrounded by tide">
              <rect width="320" height="180" fill="#1a1520"/>
              <rect x="0" y="120" width="320" height="60" fill="#3a4a5e"/>
              <rect x="0" y="146" width="320" height="34" fill="#5a6a7a" opacity="0.6"/>
              <polygon points="160,40 130,140 190,140" fill="#3d3325"/>
              <polygon points="160,40 145,80 175,80" fill="#5a4a35"/>
              <rect x="156" y="28" width="8" height="14" fill="#c4a05a"/>
              <polygon points="156,28 164,28 160,20" fill="#ffd966"/>
              <rect x="142" y="100" width="4" height="8" fill="#c4a05a"/>
              <rect x="174" y="100" width="4" height="8" fill="#c4a05a"/>
              <rect x="158" y="92" width="4" height="8" fill="#c4a05a"/>
              <line x1="40" y1="135" x2="60" y2="135" stroke="#a0b8c8" stroke-width="1"/>
              <line x1="80" y1="138" x2="100" y2="138" stroke="#a0b8c8" stroke-width="1"/>
