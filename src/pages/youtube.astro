---
// src/pages/youtube.astro
// Stanford queue + Around the internet. Both are launchpads — click to open
// on YouTube (Stanford disabled embedding, so no in-page player).

import fs from 'node:fs';
import path from 'node:path';

const dataPath = path.join(process.cwd(), 'public', 'yt', 'videos.json');
let data: any = { queue: [], series: [], built_at: null };
if (fs.existsSync(dataPath)) {
  data = JSON.parse(fs.readFileSync(dataPath, 'utf-8'));
}

const broaderPath = path.join(process.cwd(), 'public', 'yt', 'broader.json');
let broader: any = { queue: [], pool: [], built_at: null, channel_count: 0 };
if (fs.existsSync(broaderPath)) {
  broader = JSON.parse(fs.readFileSync(broaderPath, 'utf-8'));
}

const byRecency = (a: any, b: any) =>
  new Date(b.published_at).getTime() - new Date(a.published_at).getTime();
broader.queue = [...(broader.queue ?? [])].sort(byRecency);
broader.pool = [...(broader.pool ?? [])].sort(byRecency);

function fmtDuration(seconds: number) {
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  return h > 0 ? `${h}h${String(m).padStart(2, '0')}` : `${m}m`;
}

function fmtAgo(iso: string) {
  const then = new Date(iso).getTime();
  const days = Math.floor((Date.now() - then) / 86400000);
  if (days === 0) return 'today';
  if (days < 7) return `${days}d ago`;
  if (days < 30) return `${Math.floor(days / 7)}w ago`;
  return `${Math.floor(days / 30)}mo ago`;
}

const builtAt = data.built_at
  ? new Date(data.built_at).toLocaleString('en-US', { month: 'short', day: 'numeric' })
  : 'never';

const broaderBuiltAt = broader.built_at
  ? new Date(broader.built_at).toLocaleString('en-US', { month: 'short', day: 'numeric' })
  : 'never';

const topSeries = data.series?.[0] ?? null;
const restSeries = (data.series ?? []).slice(1);

// Series where videos are independent (seminars, talk series) — show newest first.
// Sequential courses (lectures 1, 2, 3...) stay in original order.
const REVERSE_ORDER_KEYS = new Set(['CS547', 'Robotics Seminar']);

function seriesVideos(series: any) {
  const vids = series.video_ids
    .map((id: string) => data.queue.find((v: any) => v.id === id))
    .filter(Boolean);
  if (REVERSE_ORDER_KEYS.has(series.key)) {
    return [...vids].sort((a: any, b: any) =>
      new Date(b.published_at).getTime() - new Date(a.published_at).getTime()
    );
  }
  return vids;
}
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>YouTube Queue · stanwood.dev</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Permanent+Marker&family=Space+Mono:wght@400;700&display=swap"
    rel="stylesheet"
  />
  <script is:inline>
    (function () {
      try {
        if (localStorage.getItem('yt-gate-v1') === 'meow') {
          document.documentElement.classList.add('yt-unlocked');
        }
      } catch {}
    })();
  </script>
  <style is:global>
    :root {
      --bg: #fdf6e3;
      --ink: #1a1a1a;
      --paper: #ffffff;
      --hot: #ff3b30;
      --cool: #0a84ff;
      --lime: #b8e986;
      --border: 3px solid var(--ink);
      --shadow: 6px 6px 0 var(--ink);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      padding: 2rem 1rem;
      background: var(--bg);
      color: var(--ink);
      font-family: 'Space Mono', monospace;
      font-size: 15px;
      line-height: 1.5;
    }
    .wrap { max-width: 1100px; margin: 0 auto; }

    /* Password gate */
    html:not(.yt-unlocked) .wrap { display: none; }
    html.yt-unlocked #yt-gate { display: none; }
    #yt-gate {
      max-width: 360px;
      margin: 4rem auto;
      padding: 2rem 1.5rem;
      background: var(--paper);
      border: var(--border);
      box-shadow: var(--shadow);
      text-align: center;
    }
    #yt-gate h2 {
      font-family: 'Permanent Marker', cursive;
      font-size: 1.6rem;
      margin: 0 0 1rem;
    }
    #yt-gate input {
      width: 100%;
      padding: .6rem .8rem;
      border: var(--border);
      font-family: 'Space Mono', monospace;
      font-size: 1rem;
      background: var(--bg);
      color: var(--ink);
    }
    #yt-gate input:focus { outline: none; background: var(--paper); }
    #yt-gate.shake { animation: gate-shake 0.3s; }
    @keyframes gate-shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-8px); }
      75% { transform: translateX(8px); }
    }
    h1 {
      font-family: 'Permanent Marker', cursive;
      font-size: clamp(2.4rem, 6vw, 3.6rem);
      margin: 0 0 .25rem;
      line-height: 1;
      letter-spacing: -0.02em;
    }
    .subtitle {
      font-size: 0.85rem;
      color: #555;
      margin: 0 0 2rem;
    }
    .subtitle a { color: var(--cool); }

    h2 {
      font-family: 'Permanent Marker', cursive;
      font-size: 1.8rem;
      margin: 2.5rem 0 .5rem;
    }
    h2:first-of-type { margin-top: 0; }

    .series {
      border: var(--border);
      background: var(--paper);
      box-shadow: var(--shadow);
      margin-bottom: 1.5rem;
      padding: 1rem 1.25rem;
    }
    .series[hidden] { display: none; }
    .series-head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1rem;
      margin-bottom: .5rem;
      flex-wrap: wrap;
    }
    .series-name {
      font-family: 'Permanent Marker', cursive;
      font-size: 1.3rem;
    }
    .series-meta { font-size: 0.75rem; color: #666; }
    .score-chip {
      display: inline-block;
      background: var(--lime);
      border: 2px solid var(--ink);
      padding: 1px 6px;
      font-size: 0.7rem;
      font-weight: 700;
      margin-left: .5rem;
    }
    .score-chip.low { background: #fff; color: #999; }
    ul.videos { list-style: none; margin: 0; padding: 0; }
    ul.videos li {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      padding: .5rem 0;
      border-top: 1px dashed #ccc;
      cursor: pointer;
    }
    ul.videos li:first-child { border-top: none; }
    ul.videos li:hover { background: #faf0d0; }
    ul.videos li.watched,
    ul.videos li.hidden-row { display: none; }
    .vtitle { flex: 1; font-size: 0.9rem; }
    .vmeta { font-size: 0.75rem; color: #666; white-space: nowrap; }
    .row-btns { display: flex; gap: 4px; }
    .mark-btn {
      border: 1px solid #999;
      background: transparent;
      font-size: 0.7rem;
      padding: 2px 6px;
      cursor: pointer;
      font-family: inherit;
    }
    .mark-btn:hover { background: var(--hot); color: var(--paper); border-color: var(--hot); }

    .empty {
      padding: 2rem;
      text-align: center;
      background: var(--paper);
      border: var(--border);
    }

    /* Around the internet */
    .broader-intro {
      margin: 0 0 1rem;
      font-size: 0.85rem;
      color: #555;
    }
    .broader-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1rem;
    }
    .bcard {
      background: var(--paper);
      border: var(--border);
      box-shadow: var(--shadow);
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: var(--ink);
      position: relative;
      transition: transform 0.05s ease;
    }
    .bcard:hover { transform: translate(-2px, -2px); box-shadow: 8px 8px 0 var(--ink); }
    .bcard.hidden { display: none; }
    .bcard-thumb {
      aspect-ratio: 16 / 9;
      background: #000 center/cover no-repeat;
      border-bottom: 2px solid var(--ink);
      position: relative;
    }
    .bcard-dur {
      position: absolute;
      bottom: 6px;
      right: 6px;
      background: var(--ink);
      color: var(--paper);
      font-size: 0.7rem;
      padding: 1px 5px;
      font-weight: 700;
    }
    .bcard-body { padding: .65rem .75rem .75rem; flex: 1; display: flex; flex-direction: column; }
    .bcard-title {
      font-size: 0.9rem;
      font-weight: 700;
      line-height: 1.3;
      margin: 0 0 .35rem;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .bcard-meta {
      font-size: 0.72rem;
      color: #666;
      margin-top: auto;
      display: flex;
      justify-content: space-between;
      gap: .5rem;
    }
    .bcard-chan { font-weight: 700; color: #333; }
    .explore-badge {
      position: absolute;
      top: 6px;
      left: 6px;
      background: var(--lime);
      border: 2px solid var(--ink);
      font-size: 0.65rem;
      font-weight: 700;
      padding: 1px 5px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .series-badge {
      position: absolute;
      bottom: 6px;
      left: 6px;
      background: #ffd86b;
      border: 2px solid var(--ink);
      font-size: 0.65rem;
      font-weight: 700;
      padding: 1px 5px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .bhide {
      position: absolute;
      top: 6px;
      right: 6px;
      background: var(--paper);
      border: 2px solid var(--ink);
      font-size: 0.7rem;
      font-weight: 700;
      padding: 1px 6px;
      cursor: pointer;
      font-family: inherit;
      opacity: 0;
      transition: opacity 0.1s ease;
    }
    .bcard:hover .bhide { opacity: 1; }
    .bhide:hover { background: var(--hot); color: var(--paper); }
    .bhide.like { right: 40px; }
    .bhide.like:hover { background: var(--lime); color: var(--ink); }

    .footer {
      margin-top: 3rem;
      padding-top: 1rem;
      border-top: 1px dashed var(--ink);
      font-size: 0.75rem;
      color: #666;
      text-align: center;
    }
  </style>
</head>
<body>
  <div id="yt-gate">
    <h2>🐱</h2>
    <form id="yt-gate-form">
      <input id="yt-gate-input" type="password" autocomplete="off" autofocus />
    </form>
  </div>
  <div class="wrap">
    <h1>stanford queue</h1>
    <p class="subtitle">
      auto-ranked lectures from
      <a href="https://www.youtube.com/@stanfordonline" target="_blank" rel="noopener">@stanfordonline</a>
      · last 6 months · built {builtAt} · click any row to open on youtube
    </p>

    {data.queue.length === 0 && (
      <div class="empty">
        <p>queue is empty — the pipeline hasn't run yet, or yt-dlp is having a bad day.</p>
      </div>
    )}

    {topSeries && (() => {
      const videos = seriesVideos(topSeries);
      return (
        <div class="series" data-series={topSeries.key}>
          <div class="series-head">
            <div>
              <span class="series-name">{topSeries.display_name}</span>
              <span class={`score-chip ${topSeries.best_score >= 3 ? '' : 'low'}`}>
                score {topSeries.best_score}
              </span>
            </div>
            <span class="series-meta">
              {topSeries.video_count} {topSeries.video_count === 1 ? 'video' : 'videos'}
            </span>
          </div>
          <ul class="videos">
            {videos.map((v: any) => (
              <li data-video-id={v.id} data-video-url={v.url || `https://www.youtube.com/watch?v=${v.id}&autoplay=1`}>
                <span class="vtitle">
                  {v.lecture_num != null ? `#${v.lecture_num} · ` : ''}
                  {v.title.replace(/^Stanford\s+[A-Z]+\d+[A-Z]?\s*\|?\s*/i, '').replace(/^[^:|]+[:|]\s*/, '')}
                </span>
                <span class="vmeta">
                  {fmtDuration(v.duration)} · {fmtAgo(v.published_at)}
                </span>
                <span class="row-btns">
                  <button class="mark-btn" data-toggle-watched={v.id} title="toggle watched">✓</button>
                  <button class="mark-btn" data-hide-stanford={v.id} title="hide everywhere">×</button>
                </span>
              </li>
            ))}
          </ul>
        </div>
      );
    })()}

    {broader.queue.length > 0 && (
      <>
        <h2>around the internet</h2>
        <p class="broader-intro">
          recent uploads from curated CS / AI / HCI / future-tech channels
        </p>
        <div class="broader-grid" id="broader-grid">
          {broader.queue.map((v: any) => (
            <a
              class="bcard"
              href={v.url}
              target="_blank"
              rel="noopener"
              data-broader-id={v.id}
              data-published-at={v.published_at}
              data-series-key={v.series_key || ''}
              data-episode-number={v.episode_number != null ? String(v.episode_number) : ''}
            >
              <div class="bcard-thumb" style={v.thumb ? `background-image:url(${v.thumb})` : ''}>
                {v.exploration && <span class="explore-badge">explore</span>}
                {v.series_key && <span class="series-badge">series · ep {v.episode_number}</span>}
                <button class="bhide like" data-mark-broader={v.id} data-action="like" title={v.series_key ? 'follow series (adds a block below)' : 'liked / watched'}>✓</button>
                <button class="bhide" data-mark-broader={v.id} data-action="pass" title={v.series_key ? 'hide series forever' : 'pass / hide'}>×</button>
                <span class="bcard-dur">{fmtDuration(v.duration)}</span>
              </div>
              <div class="bcard-body">
                <p class="bcard-title">{v.title}</p>
                <div class="bcard-meta">
                  <span class="bcard-chan">{v.channel_title}</span>
                  <span>{fmtAgo(v.published_at)}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
        <div id="followed-series-container"></div>
      </>
    )}

    {restSeries.length > 0 && (
      <>
        <h2>more from the queue</h2>
        {restSeries.map((s: any) => {
          const videos = seriesVideos(s);
          if (videos.length === 0) return null;
          const showScore = s.best_score >= 3;
          return (
            <div class="series" data-series={s.key}>
              <div class="series-head">
                <div>
                  <span class="series-name">{s.display_name}</span>
                  <span class={`score-chip ${showScore ? '' : 'low'}`}>
                    score {s.best_score}
                  </span>
                </div>
                <span class="series-meta">
                  {s.video_count} {s.video_count === 1 ? 'video' : 'videos'}
                </span>
              </div>
              <ul class="videos">
                {videos.map((v: any) => (
                  <li data-video-id={v.id} data-video-url={v.url || `https://www.youtube.com/watch?v=${v.id}&autoplay=1`}>
                    <span class="vtitle">
                      {v.lecture_num != null ? `#${v.lecture_num} · ` : ''}
                      {v.title.replace(/^Stanford\s+[A-Z]+\d+[A-Z]?\s*\|?\s*/i, '').replace(/^[^:|]+[:|]\s*/, '')}
                    </span>
                    <span class="vmeta">
                      {fmtDuration(v.duration)} · {fmtAgo(v.published_at)}
                    </span>
                    <span class="row-btns">
                      <button class="mark-btn" data-toggle-watched={v.id} title="toggle watched">✓</button>
                      <button class="mark-btn" data-hide-stanford={v.id} title="hide everywhere">×</button>
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          );
        })}
      </>
    )}

    <div class="footer">
      click any row or card to open on youtube · ✓ marks watched · × hides it everywhere (future builds too)
    </div>
  </div>

  <!-- Broader reserve pool, consumed client-side when visible count drops below 10 -->
  <script type="application/json" id="broader-pool" set:html={JSON.stringify(broader.pool || [])}></script>
  <script type="application/json" id="broader-series-episodes" set:html={JSON.stringify(broader.series_episodes || {})}></script>

  <script is:inline>
    // ---- Password gate ----
    (function () {
      const form = document.getElementById('yt-gate-form');
      const input = document.getElementById('yt-gate-input');
      const gate = document.getElementById('yt-gate');
      if (!form || !input || !gate) return;
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        if (input.value.trim().toLowerCase() === 'meow') {
          try { localStorage.setItem('yt-gate-v1', 'meow'); } catch {}
          document.documentElement.classList.add('yt-unlocked');
        } else {
          gate.classList.remove('shake');
          void gate.offsetWidth;
          gate.classList.add('shake');
          input.value = '';
        }
      });
    })();

    // ---- Mark-sync: tell the Mini about likes + passes (drops from feed +
    // future builds, feeds back into scoring). ----
    const MARK_API_URL = 'https://stephens-mac-mini.tailcac25b.ts.net/api/mark';
    function sendMark(id, kind, action) {
      try {
        fetch(MARK_API_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, kind, action }),
          keepalive: true,
        }).catch(() => {});
      } catch {}
    }

    // One-shot: flush existing localStorage state to the Mini so feed.xml
    // drops items already marked before /api/mark existed. Runs once per browser.
    const SYNC_FLAG = 'mark-sync-v1';
    function bootstrapSync() {
      if (localStorage.getItem(SYNC_FLAG)) return;
      try {
        const watched = JSON.parse(localStorage.getItem('stanford-queue-watched-v1') || '[]');
        const sHidden = JSON.parse(localStorage.getItem('stanford-hidden-v1') || '[]');
        const bHidden = JSON.parse(localStorage.getItem('broader-hidden-v1') || '[]');
        watched.forEach(id => sendMark(id, 'stanford', 'like'));
        sHidden.forEach(id => sendMark(id, 'stanford', 'pass'));
        bHidden.forEach(id => sendMark(id, 'broader', 'pass'));
        localStorage.setItem(SYNC_FLAG, String(Date.now()));
      } catch {}
    }
    bootstrapSync();

    // ---- Stanford: watched state + auto-hide watched-out series ----
    const WATCHED_KEY = 'stanford-queue-watched-v1';
    const STANFORD_HIDDEN_KEY = 'stanford-hidden-v1';

    function getWatched() {
      try { return new Set(JSON.parse(localStorage.getItem(WATCHED_KEY) || '[]')); }
      catch { return new Set(); }
    }
    function saveWatched(set) {
      localStorage.setItem(WATCHED_KEY, JSON.stringify([...set]));
    }
    function toggleWatched(id) {
      const w = getWatched();
      const adding = !w.has(id);
      if (adding) w.add(id); else w.delete(id);
      saveWatched(w);
      if (adding) sendMark(id, 'stanford', 'like');
      renderWatched();
    }
    function getStanfordHidden() {
      try { return new Set(JSON.parse(localStorage.getItem(STANFORD_HIDDEN_KEY) || '[]')); }
      catch { return new Set(); }
    }
    function saveStanfordHidden(set) {
      localStorage.setItem(STANFORD_HIDDEN_KEY, JSON.stringify([...set]));
    }
    function hideStanford(id) {
      const h = getStanfordHidden();
      h.add(id);
      saveStanfordHidden(h);
      sendMark(id, 'stanford', 'pass');
      renderWatched();
    }
    function renderWatched() {
      const w = getWatched();
      const hidden = getStanfordHidden();
      document.querySelectorAll('li[data-video-id]').forEach(li => {
        li.classList.toggle('watched', w.has(li.dataset.videoId));
        li.classList.toggle('hidden-row', hidden.has(li.dataset.videoId));
      });
      // Hide any series whose videos are all watched or hidden
      document.querySelectorAll('.series').forEach(s => {
        const lis = s.querySelectorAll('li[data-video-id]');
        const allGone = lis.length > 0 && [...lis].every(li =>
          li.classList.contains('watched') || li.classList.contains('hidden-row')
        );
        s.hidden = allGone;
      });
    }

    // Row click → open on YouTube (autoplay). Ignore clicks on the row buttons.
    document.querySelectorAll('li[data-video-id]').forEach(li => {
      li.addEventListener('click', (e) => {
        if (e.target.closest('[data-toggle-watched]') || e.target.closest('[data-hide-stanford]')) return;
        const url = li.dataset.videoUrl;
        if (url) window.open(url, '_blank', 'noopener');
      });
    });
    document.querySelectorAll('[data-toggle-watched]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleWatched(btn.dataset.toggleWatched);
      });
    });
    document.querySelectorAll('[data-hide-stanford]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        hideStanford(btn.dataset.hideStanford);
      });
    });

    renderWatched();

    // ---- Around the internet: hide + refill from reserve pool ----
    const BROADER_HIDDEN_KEY = 'broader-hidden-v1';
    const BROADER_FOLLOWED_SERIES_KEY = 'broader-followed-series-v1';
    const BROADER_BANNED_SERIES_KEY = 'broader-banned-series-v1';
    const POOL = JSON.parse(document.getElementById('broader-pool').textContent) || [];
    const SERIES_EPISODES = JSON.parse(document.getElementById('broader-series-episodes').textContent) || {};

    function getSet(key) {
      try { return new Set(JSON.parse(localStorage.getItem(key) || '[]')); }
      catch { return new Set(); }
    }
    function saveSet(key, set) {
      localStorage.setItem(key, JSON.stringify([...set]));
    }
    const getBroaderHidden = () => getSet(BROADER_HIDDEN_KEY);
    const saveBroaderHidden = (s) => saveSet(BROADER_HIDDEN_KEY, s);
    const getFollowedSeries = () => getSet(BROADER_FOLLOWED_SERIES_KEY);
    const saveFollowedSeries = (s) => saveSet(BROADER_FOLLOWED_SERIES_KEY, s);
    const getBannedSeries = () => getSet(BROADER_BANNED_SERIES_KEY);
    const saveBannedSeries = (s) => saveSet(BROADER_BANNED_SERIES_KEY, s);

    function renderBroaderHidden() {
      const h = getBroaderHidden();
      const banned = getBannedSeries();
      document.querySelectorAll('[data-broader-id]').forEach(card => {
        const byId = h.has(card.dataset.broaderId);
        const bySeries = card.dataset.seriesKey && banned.has(card.dataset.seriesKey);
        card.classList.toggle('hidden', byId || bySeries);
      });
    }

    function fmtDurationJS(seconds) {
      const h = Math.floor(seconds / 3600);
      const m = Math.floor((seconds % 3600) / 60);
      return h > 0 ? `${h}h${String(m).padStart(2, '0')}` : `${m}m`;
    }
    function fmtAgoJS(iso) {
      const days = Math.floor((Date.now() - new Date(iso).getTime()) / 86400000);
      if (days === 0) return 'today';
      if (days < 7) return `${days}d ago`;
      if (days < 30) return `${Math.floor(days / 7)}w ago`;
      return `${Math.floor(days / 30)}mo ago`;
    }
    function escapeHTML(s) {
      return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    }
    function buildCard(v) {
      const a = document.createElement('a');
      a.className = 'bcard';
      a.href = v.url;
      a.target = '_blank';
      a.rel = 'noopener';
      a.dataset.broaderId = v.id;
      a.dataset.publishedAt = v.published_at;
      if (v.series_key) a.dataset.seriesKey = v.series_key;
      if (v.episode_number != null) a.dataset.episodeNumber = String(v.episode_number);
      const thumbStyle = v.thumb ? `background-image:url(${v.thumb})` : '';
      const safeId = escapeHTML(v.id);
      const seriesBadge = v.series_key
        ? `<span class="series-badge">series · ep ${v.episode_number}</span>` : '';
      const likeTitle = v.series_key ? 'follow series (adds a block below)' : 'liked / watched';
      const passTitle = v.series_key ? 'hide series forever' : 'pass / hide';
      a.innerHTML = `
        <div class="bcard-thumb" style="${thumbStyle}">
          ${v.exploration ? '<span class="explore-badge">explore</span>' : ''}
          ${seriesBadge}
          <button class="bhide like" data-mark-broader="${safeId}" data-action="like" title="${likeTitle}">✓</button>
          <button class="bhide" data-mark-broader="${safeId}" data-action="pass" title="${passTitle}">×</button>
          <span class="bcard-dur">${fmtDurationJS(v.duration)}</span>
        </div>
        <div class="bcard-body">
          <p class="bcard-title">${escapeHTML(v.title)}</p>
          <div class="bcard-meta">
            <span class="bcard-chan">${escapeHTML(v.channel_title)}</span>
            <span>${fmtAgoJS(v.published_at)}</span>
          </div>
        </div>
      `;
      a.querySelectorAll('[data-mark-broader]').forEach(wireMarkButton);
      return a;
    }

    function wireMarkButton(btn) {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const id = btn.dataset.markBroader;
        const action = btn.dataset.action || 'pass';
        const card = btn.closest('[data-broader-id]');
        const seriesKey = card && card.dataset.seriesKey;

        if (seriesKey) {
          if (action === 'like') {
            const f = getFollowedSeries();
            f.add(seriesKey);
            saveFollowedSeries(f);
          } else {
            const b = getBannedSeries();
            b.add(seriesKey);
            saveBannedSeries(b);
          }
          sendMark(id, 'broader', action);
          renderFollowedSeries();
          renderBroaderHidden();
          refillIfNeeded();
          return;
        }

        const h = getBroaderHidden();
        h.add(id);
        saveBroaderHidden(h);
        sendMark(id, 'broader', action);
        renderBroaderHidden();
        refillIfNeeded();
      });
    }

    function renderFollowedSeries() {
      const container = document.getElementById('followed-series-container');
      if (!container) return;
      const followed = getFollowedSeries();
      const watched = getWatched();
      const stanfordHidden = getStanfordHidden();
      container.innerHTML = '';
      followed.forEach(key => {
        const eps = SERIES_EPISODES[key];
        if (!eps || eps.length === 0) return;
        const section = document.createElement('div');
        section.className = 'series';
        section.dataset.series = key;
        const channelTitle = eps[0].channel_title || 'series';
        const head = document.createElement('div');
        head.className = 'series-head';
        head.innerHTML = `
          <div>
            <span class="series-name">${escapeHTML(channelTitle)}</span>
            <span class="score-chip">followed</span>
          </div>
          <span class="series-meta">${eps.length} ${eps.length === 1 ? 'video' : 'videos'} · <button class="mark-btn" data-unfollow-series="${escapeHTML(key)}" title="unfollow">×</button></span>
        `;
        const ul = document.createElement('ul');
        ul.className = 'videos';
        eps.forEach(v => {
          const li = document.createElement('li');
          li.dataset.videoId = v.id;
          li.dataset.videoUrl = v.url;
          if (watched.has(v.id)) li.classList.add('watched');
          if (stanfordHidden.has(v.id)) li.classList.add('hidden-row');
          const ep = v.episode_number != null ? `#${v.episode_number} · ` : '';
          li.innerHTML = `
            <span class="vtitle">${ep}${escapeHTML(v.title)}</span>
            <span class="vmeta">${fmtDurationJS(v.duration)} · ${fmtAgoJS(v.published_at)}</span>
            <span class="row-btns">
              <button class="mark-btn" data-toggle-watched="${escapeHTML(v.id)}" title="toggle watched">✓</button>
              <button class="mark-btn" data-hide-stanford="${escapeHTML(v.id)}" title="hide everywhere">×</button>
            </span>
          `;
          li.addEventListener('click', (e) => {
            if (e.target.closest('[data-toggle-watched]') || e.target.closest('[data-hide-stanford]')) return;
            window.open(v.url, '_blank', 'noopener');
          });
          ul.appendChild(li);
        });
        section.appendChild(head);
        section.appendChild(ul);
        container.appendChild(section);
      });
      container.querySelectorAll('[data-toggle-watched]').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          toggleWatched(btn.dataset.toggleWatched);
        });
      });
      container.querySelectorAll('[data-hide-stanford]').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          hideStanford(btn.dataset.hideStanford);
        });
      });
      container.querySelectorAll('[data-unfollow-series]').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const key = btn.dataset.unfollowSeries;
          const f = getFollowedSeries();
          f.delete(key);
          saveFollowedSeries(f);
          renderFollowedSeries();
        });
      });
    }

    function refillIfNeeded() {
      const grid = document.getElementById('broader-grid');
      if (!grid) return;
      const visible = grid.querySelectorAll('.bcard:not(.hidden)').length;
      // Keep at least 10 visible, and always round up to a multiple of 4
      // so the last row is full.
      const minTarget = Math.max(visible < 10 ? visible + 10 : visible, 10);
      const target = Math.ceil(minTarget / 4) * 4;
      if (target <= visible || POOL.length === 0) return;
      const needed = target - visible;
      const hidden = getBroaderHidden();
      const banned = getBannedSeries();
      const followed = getFollowedSeries();
      const seenSeriesOnGrid = new Set(
        Array.from(grid.querySelectorAll('[data-series-key]'))
          .map(el => el.dataset.seriesKey)
          .filter(Boolean)
      );
      let added = 0;
      while (added < needed && POOL.length > 0) {
        const v = POOL.shift();
        if (hidden.has(v.id)) continue;
        if (v.series_key && (banned.has(v.series_key) || followed.has(v.series_key) || seenSeriesOnGrid.has(v.series_key))) continue;
        if (v.series_key) seenSeriesOnGrid.add(v.series_key);
        const card = buildCard(v);
        const newTs = new Date(v.published_at).getTime();
        const existing = Array.from(grid.querySelectorAll('.bcard'));
        const before = existing.find(el => {
          const ts = new Date(el.dataset.publishedAt || 0).getTime();
          return ts < newTs;
        });
        if (before) grid.insertBefore(card, before);
        else grid.appendChild(card);
        added++;
      }
    }

    // Wire up any pre-rendered mark buttons
    document.querySelectorAll('[data-mark-broader]').forEach(wireMarkButton);
    renderFollowedSeries();
    renderBroaderHidden();
    refillIfNeeded();
  </script>
</body>
</html>
