---
import BaseLayout from "../layouts/BaseLayout.astro";
import VibeCheck from "../components/vibe-check/VibeCheck.tsx";
const title = "Vibe Check — stanwood.dev";
---

<BaseLayout
  title={title}
  description="Paste a URL, get a stylish AI-generated vibe rating. Design critique meets internet astrology."
  slug="vibe-check"
  favicon="/favicon-vc.svg"
  themeColor="#1A1612"
  fontsUrl="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Cabin:wght@400;500;600;700&family=Permanent+Marker&display=swap"
  schemaCategory="WebApplication"
>
  <Fragment slot="head">
    <style is:global>
      /* ─── Vibe Check Theme ─────────────────────────────────────── */
      :root {
        --vc-bg: #FAF8F3;
        --vc-card-bg: #FFFDF9;
        --vc-ink: #1A1612;
        --vc-gray: #5E5244;
        --vc-light-gray: #9C8E7E;
        --vc-border: #E0D8CC;
        --vc-border-dark: #C8BFB2;
        --vc-accent: #C04830;
        --vc-accent-light: #E8D5C8;
        --vc-stamp: #C04830;
        --vc-grade-a: #2D7A3A;
        --vc-grade-b: #4A7A6E;
        --vc-grade-c: #8A7A2D;
        --vc-grade-d: #B85C2A;
        --vc-grade-f: #C04830;
      }

      body {
        font-family: 'Cabin', system-ui, sans-serif;
        background: var(--vc-bg);
        color: var(--vc-ink);
        margin: 0;
      }

      /* ─── Animations ─────────────────────────────────────────── */
      @keyframes vcFadeIn {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes vcFadeOut {
        from { opacity: 1; }
        to   { opacity: 0; }
      }
      @keyframes vcScan {
        0%   { top: 0; opacity: 0; }
        10%  { opacity: 1; }
        90%  { opacity: 1; }
        100% { top: 100%; opacity: 0; }
      }
      @keyframes vcStampIn {
        0%   { transform: scale(2) rotate(-15deg); opacity: 0; }
        60%  { transform: scale(0.95) rotate(-3deg); opacity: 1; }
        100% { transform: scale(1) rotate(-4deg); opacity: 1; }
      }

      .vc-fade-in { animation: vcFadeIn 0.3s ease-out; }
      .vc-fade-out { animation: vcFadeOut 0.2s ease-out; }

      /* ─── Layout ─────────────────────────────────────────────── */
      .vc-page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .vc-header {
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .vc-back {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        color: var(--vc-light-gray);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: color 0.15s;
      }
      .vc-back:hover { color: var(--vc-ink); }
      .vc-back svg { width: 16px; height: 16px; }

      .vc-brand {
        font-family: 'Space Mono', monospace;
        font-weight: 700;
        font-size: 1rem;
        color: var(--vc-accent);
        letter-spacing: -0.02em;
      }

      .vc-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem 1.5rem 4rem;
      }

      .vc-app {
        width: 100%;
        max-width: 560px;
      }

      /* ─── Form / Idle State ──────────────────────────────────── */
      .vc-form-container {
        text-align: center;
      }

      .vc-title {
        font-family: 'Permanent Marker', cursive;
        font-size: 2.5rem;
        color: var(--vc-ink);
        margin: 0 0 0.25rem;
        letter-spacing: -0.02em;
        line-height: 1.1;
      }
      @media (min-width: 480px) {
        .vc-title { font-size: 3.2rem; }
      }

      .vc-subtitle {
        font-family: 'Space Mono', monospace;
        font-size: 0.85rem;
        color: var(--vc-light-gray);
        margin: 0 0 2.5rem;
      }

      .vc-form {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }
      @media (min-width: 480px) {
        .vc-form {
          flex-direction: row;
          gap: 0.5rem;
        }
      }

      .vc-input {
        flex: 1;
        padding: 0.85rem 1rem;
        border: 2px solid var(--vc-border);
        border-radius: 10px;
        font-family: 'Space Mono', monospace;
        font-size: 1rem;
        color: var(--vc-ink);
        background: var(--vc-card-bg);
        transition: border-color 0.15s;
        box-sizing: border-box;
      }
      .vc-input:focus {
        outline: none;
        border-color: var(--vc-accent);
        box-shadow: 0 0 0 3px rgba(192, 72, 48, 0.1);
      }
      .vc-input::placeholder {
        color: var(--vc-border-dark);
      }

      .vc-btn-primary {
        padding: 0.85rem 1.75rem;
        border: 2px solid var(--vc-ink);
        border-radius: 10px;
        background: var(--vc-ink);
        color: var(--vc-bg);
        font-family: 'Space Mono', monospace;
        font-size: 0.85rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.15s;
        white-space: nowrap;
      }
      .vc-btn-primary:hover {
        background: var(--vc-accent);
        border-color: var(--vc-accent);
      }
      .vc-btn-primary:active { transform: scale(0.98); }
      .vc-btn-primary:disabled {
        opacity: 0.3;
        cursor: not-allowed;
      }

      .vc-btn-secondary {
        padding: 0.5rem 1.25rem;
        border: 1.5px solid var(--vc-border);
        border-radius: 8px;
        background: var(--vc-card-bg);
        color: var(--vc-gray);
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        cursor: pointer;
        transition: all 0.15s;
        margin-top: 0.5rem;
      }
      .vc-btn-secondary:hover {
        border-color: var(--vc-accent);
        color: var(--vc-accent);
      }

      /* ─── Examples ───────────────────────────────────────────── */
      .vc-examples {
        margin-top: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        flex-wrap: wrap;
      }

      .vc-examples-label {
        font-family: 'Space Mono', monospace;
        font-size: 0.75rem;
        color: var(--vc-light-gray);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .vc-example-btn {
        padding: 0.3rem 0.7rem;
        border: 1.5px solid var(--vc-border);
        border-radius: 999px;
        background: transparent;
        color: var(--vc-gray);
        font-family: 'Space Mono', monospace;
        font-size: 0.75rem;
        cursor: pointer;
        transition: all 0.15s;
      }
      .vc-example-btn:hover {
        border-color: var(--vc-accent);
        color: var(--vc-accent);
        background: rgba(192, 72, 48, 0.04);
      }

      /* ─── Error ──────────────────────────────────────────────── */
      .vc-error {
        margin-top: 1.5rem;
        padding: 1rem 1.25rem;
        background: #fef2f2;
        border: 1.5px solid #fecaca;
        border-radius: 10px;
        text-align: center;
      }
      .vc-error p {
        color: #b91c1c;
        font-size: 0.85rem;
        margin: 0 0 0.75rem;
      }

      /* ─── Loading State ──────────────────────────────────────── */
      .vc-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        padding: 4rem 0;
        animation: vcFadeIn 0.3s ease-out;
      }

      .vc-scanner {
        width: 80px;
        height: 80px;
        border: 2px solid var(--vc-border);
        border-radius: 8px;
        position: relative;
        overflow: hidden;
        background: var(--vc-card-bg);
      }
      .vc-scanner-line {
        position: absolute;
        left: 4px;
        right: 4px;
        height: 2px;
        background: var(--vc-accent);
        border-radius: 1px;
        animation: vcScan 1.8s ease-in-out infinite;
      }

      .vc-loading-text {
        font-family: 'Space Mono', monospace;
        font-size: 0.85rem;
        color: var(--vc-gray);
        text-align: center;
        transition: opacity 0.2s;
        min-height: 1.5em;
      }

      /* ─── Scorecard ──────────────────────────────────────────── */
      .vc-scorecard {
        background: var(--vc-card-bg);
        border: 2px solid var(--vc-border);
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(26, 22, 18, 0.08);
        animation: vcFadeIn 0.4s ease-out;
      }

      .vc-card-header {
        background: var(--vc-ink);
        color: var(--vc-bg);
        padding: 0.6rem 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .vc-card-label {
        font-family: 'Space Mono', monospace;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      .vc-card-meta {
        padding: 0.75rem 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px dashed var(--vc-border);
      }
      .vc-card-url {
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        color: var(--vc-gray);
        word-break: break-all;
      }
      .vc-card-run {
        font-family: 'Space Mono', monospace;
        font-size: 0.6rem;
        color: var(--vc-light-gray);
        white-space: nowrap;
        margin-left: 1rem;
      }

      /* ─── Verdict ────────────────────────────────────────────── */
      .vc-verdict-section {
        padding: 1.5rem 1.25rem;
        text-align: center;
      }

      .vc-overall-grade {
        font-family: 'Permanent Marker', cursive;
        font-size: 4rem;
        line-height: 1;
        margin-bottom: 0.25rem;
      }

      .vc-overall-vibe {
        font-family: 'Permanent Marker', cursive;
        font-size: 1.35rem;
        color: var(--vc-ink);
        margin: 0;
        line-height: 1.3;
      }
      @media (min-width: 480px) {
        .vc-overall-vibe { font-size: 1.5rem; }
      }

      /* ─── Dotted Divider ─────────────────────────────────────── */
      .vc-dotted-divider {
        border-top: 2px dashed var(--vc-border);
        margin: 0 1.25rem;
      }

      /* ─── Category Rows ──────────────────────────────────────── */
      .vc-categories {
        padding: 1.25rem;
      }

      .vc-category-row {
        padding: 0.65rem 0;
      }
      .vc-category-row + .vc-category-row {
        border-top: 1px solid var(--vc-border);
      }

      .vc-category-left {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.2rem;
      }

      .vc-category-label {
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--vc-light-gray);
        min-width: 90px;
      }

      .vc-category-grade {
        font-family: 'Permanent Marker', cursive;
        font-size: 1.1rem;
      }

      .vc-category-note {
        font-size: 0.85rem;
        color: var(--vc-gray);
        margin: 0;
        line-height: 1.5;
      }

      /* ─── Main Read & Nudge ──────────────────────────────────── */
      .vc-main-read,
      .vc-nudge {
        padding: 1.25rem;
      }

      .vc-section-label {
        font-family: 'Space Mono', monospace;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--vc-light-gray);
        margin: 0 0 0.5rem;
      }

      .vc-main-read-text {
        font-size: 0.9rem;
        color: var(--vc-ink);
        line-height: 1.65;
        margin: 0;
      }

      .vc-nudge-text {
        font-size: 0.85rem;
        color: var(--vc-gray);
        line-height: 1.55;
        margin: 0;
        font-style: italic;
      }

      /* ─── Stamp Footer ──────────────────────────────────────── */
      .vc-stamp-footer {
        padding: 1.5rem 1.25rem;
        text-align: center;
      }

      .vc-stamp {
        display: inline-block;
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--vc-stamp);
        border: 2.5px solid var(--vc-stamp);
        border-radius: 6px;
        padding: 0.45rem 1rem;
        transform: rotate(-4deg);
        opacity: 0.8;
        animation: vcStampIn 0.5s ease-out 0.2s both;
      }

      .vc-stamp-sub {
        font-family: 'Space Mono', monospace;
        font-size: 0.6rem;
        color: var(--vc-light-gray);
        margin: 0.75rem 0 0;
      }

      /* ─── Check Another ──────────────────────────────────────── */
      .vc-btn-another {
        display: block;
        width: 100%;
        padding: 0.85rem;
        border: none;
        border-top: 2px solid var(--vc-border);
        background: transparent;
        color: var(--vc-gray);
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.15s;
        text-transform: lowercase;
      }
      .vc-btn-another:hover {
        background: var(--vc-bg);
        color: var(--vc-accent);
      }
    </style>
  </Fragment>

  <div class="vc-page">
    <a href="#main-content" class="skip-nav">Skip to content</a>

    <header class="vc-header">
      <a href="/" class="vc-back" aria-label="Back to stanwood.dev">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
        stanwood.dev
      </a>
      <span class="vc-brand">// vibe-check</span>
    </header>

    <main id="main-content" class="vc-main">
      <div class="vc-app">
        <VibeCheck client:idle />
      </div>
    </main>
  </div>
</BaseLayout>
