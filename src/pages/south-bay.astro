---
import BaseLayout from "../layouts/BaseLayout.astro";
import SignalApp from "../components/south-bay/SignalApp.tsx";
const title = "South Bay Signal — stanwood.dev";
---

<BaseLayout
  title={title}
  description="Local sports scores, events, and government updates for Campbell, Cupertino, Los Gatos, Mountain View, Saratoga, Sunnyvale, San Jose, Santa Clara, Los Altos, Palo Alto, and Milpitas."
  slug="south-bay"
  themeColor="#F7F8FA"
  fontsUrl="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
  schemaCategory="WebApplication"
  schemaName="South Bay Signal"
>
  <Fragment slot="head">
    <style is:global>
      :root {
        --sb-bg: #FAF9F6;
        --sb-card: #FFFFFF;
        --sb-ink: #1A1A1A;
        --sb-muted: #555555;
        --sb-light: #888888;
        --sb-border: #C8C4BC;
        --sb-border-light: #E5E2DB;
        --sb-rule: #1A1A1A;
        --sb-primary: #1A1A1A;
        --sb-primary-light: #F0EFEC;
        --sb-accent: #C0392B;
        --sb-accent-light: #FDEEEC;
        --sb-live: #C0392B;
        --sb-win: #1A1A1A;
        --sb-loss: #999999;
        --sb-radius: 2px;
        --sb-shadow: none;
        --sb-shadow-hover: 0 2px 8px rgba(0, 0, 0, 0.08);
        --sb-max-width: 960px;
        --sb-serif: 'Playfair Display', Georgia, 'Times New Roman', serif;
        --sb-sans: 'Inter', system-ui, -apple-system, sans-serif;
      }

      body {
        font-family: var(--sb-sans);
        background: var(--sb-bg);
        color: var(--sb-ink);
        margin: 0;
        -webkit-font-smoothing: antialiased;
      }

      /* ── Masthead ── */
      .sb-header {
        background: var(--sb-bg);
        padding: 24px 24px 0;
        text-align: center;
        border-bottom: none;
      }
      .sb-header-inner {
        max-width: var(--sb-max-width);
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
      }
      .sb-brand {
        text-decoration: none;
        color: var(--sb-ink);
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .sb-brand-icon { display: none; }
      .sb-brand-name {
        font-family: var(--sb-serif);
        font-size: 36px;
        font-weight: 900;
        letter-spacing: -0.01em;
        text-transform: none;
        color: var(--sb-ink);
        line-height: 1.1;
      }
      .sb-date {
        font-size: 12px;
        color: var(--sb-muted);
        font-weight: 400;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        margin-top: 4px;
      }
      .sb-masthead-rule {
        display: block;
        max-width: var(--sb-max-width);
        margin: 16px auto 0;
        border: none;
        border-top: 3px double var(--sb-rule);
      }

      /* ── Nav tabs ── */
      .sb-nav {
        background: var(--sb-bg);
        border-bottom: 1px solid var(--sb-border);
        padding: 0 24px;
        position: sticky;
        top: 0;
        z-index: 99;
      }
      .sb-nav-inner {
        max-width: var(--sb-max-width);
        margin: 0 auto;
        display: flex;
        justify-content: center;
        gap: 0;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
      }
      .sb-nav-inner::-webkit-scrollbar { display: none; }
      .sb-tab {
        padding: 10px 24px;
        font-family: var(--sb-sans);
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--sb-muted);
        border: none;
        background: none;
        cursor: pointer;
        white-space: nowrap;
        border-bottom: 2px solid transparent;
        transition: color 0.15s, border-color 0.15s;
      }
      .sb-tab:hover { color: var(--sb-ink); }
      .sb-tab--active {
        color: var(--sb-ink);
        border-bottom-color: var(--sb-ink);
      }
      .sb-tab--disabled {
        color: var(--sb-light);
        cursor: default;
        position: relative;
      }
      .sb-tab--disabled::after {
        content: "soon";
        font-size: 8px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--sb-accent);
        margin-left: 6px;
        vertical-align: super;
      }

      /* ── Filter bar ── */
      .sb-filters {
        background: var(--sb-card);
        border-bottom: 1px solid var(--sb-border-light);
        padding: 12px 24px;
      }
      .sb-filters-inner {
        max-width: var(--sb-max-width);
        margin: 0 auto;
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
      }
      .sb-filter-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--sb-muted);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-right: 4px;
      }
      .sb-city-pill {
        font-size: 12px;
        font-weight: 500;
        padding: 4px 10px;
        border-radius: 100px;
        border: 1px solid var(--sb-border);
        background: var(--sb-card);
        color: var(--sb-muted);
        cursor: pointer;
        transition: all 0.15s;
        white-space: nowrap;
      }
      .sb-city-pill:hover {
        border-color: var(--sb-primary);
        color: var(--sb-primary);
      }
      .sb-city-pill--active {
        background: var(--sb-primary);
        border-color: var(--sb-primary);
        color: white;
      }
      .sb-city-pill--all {
        font-weight: 600;
      }

      /* ── Content area ── */
      .sb-main {
        max-width: var(--sb-max-width);
        margin: 0 auto;
        padding: 24px;
      }

      /* ── Section headers ── */
      .sb-section-header {
        display: flex;
        align-items: baseline;
        gap: 12px;
        margin-bottom: 20px;
        border-bottom: 1px solid var(--sb-border);
        padding-bottom: 8px;
      }
      .sb-section-title {
        font-family: var(--sb-serif);
        font-size: 22px;
        font-weight: 700;
        text-transform: none;
        letter-spacing: -0.01em;
        color: var(--sb-ink);
      }
      .sb-section-line {
        display: none;
      }
      .sb-league-group {
        margin-bottom: 28px;
      }
      .sb-league-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--sb-muted);
        margin-bottom: 10px;
        padding-bottom: 6px;
        border-bottom: 1px solid var(--sb-border-light);
      }

      /* ── Game cards ── */
      .sb-games-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 0;
        border-top: 1px solid var(--sb-border-light);
      }
      .sb-game-card {
        background: var(--sb-card);
        border: 1px solid var(--sb-border-light);
        border-top: none;
        border-radius: 0;
        padding: 14px 16px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        transition: background 0.15s;
      }
      .sb-game-card:first-child {
        border-top: 1px solid var(--sb-border-light);
      }
      .sb-game-card:hover {
        background: var(--sb-primary-light);
        box-shadow: none;
      }
      .sb-game-card--live {
        border-left: 3px solid var(--sb-live);
        padding-left: 13px;
      }
      .sb-game-status {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .sb-game-time {
        font-size: 12px;
        font-weight: 500;
        color: var(--sb-muted);
      }
      .sb-live-badge {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--sb-live);
        display: flex;
        align-items: center;
        gap: 5px;
      }
      .sb-live-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--sb-live);
        animation: sb-pulse 2s infinite;
      }
      @keyframes sb-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
      }
      .sb-broadcast {
        font-size: 11px;
        color: var(--sb-light);
        font-weight: 500;
      }
      .sb-game-teams {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .sb-team-row {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .sb-team-logo {
        width: 24px;
        height: 24px;
        object-fit: contain;
        flex-shrink: 0;
      }
      .sb-team-name {
        flex: 1;
        font-size: 14px;
        font-weight: 600;
        color: var(--sb-ink);
      }
      .sb-team-name--south-bay {
        color: var(--sb-primary);
      }
      .sb-team-record {
        font-size: 12px;
        color: var(--sb-light);
        font-weight: 400;
        margin-left: 4px;
      }
      .sb-team-score {
        font-family: 'Space Mono', monospace;
        font-size: 18px;
        font-weight: 700;
        min-width: 32px;
        text-align: right;
      }
      .sb-team-score--winner { color: var(--sb-ink); }
      .sb-team-score--loser { color: var(--sb-light); }

      /* ── Overview placeholders ── */
      .sb-overview-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 1px;
        background: var(--sb-border-light);
        border: 1px solid var(--sb-border-light);
        border-radius: var(--sb-radius);
        overflow: hidden;
      }
      .sb-overview-section {
        background: var(--sb-card);
        padding: 24px;
      }
      .sb-overview-section h3 {
        font-family: var(--sb-serif);
        font-size: 16px;
        font-weight: 700;
        text-transform: none;
        letter-spacing: 0;
        color: var(--sb-ink);
        margin: 0 0 8px 0;
      }

      /* ── Empty / loading states ── */
      .sb-empty {
        text-align: center;
        padding: 48px 24px;
        color: var(--sb-muted);
      }
      .sb-empty-title {
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 4px;
      }
      .sb-empty-sub {
        font-size: 13px;
        color: var(--sb-light);
      }
      .sb-loading {
        text-align: center;
        padding: 48px 24px;
      }
      .sb-spinner {
        width: 28px;
        height: 28px;
        border: 3px solid var(--sb-border-light);
        border-top-color: var(--sb-primary);
        border-radius: 50%;
        animation: sb-spin 0.7s linear infinite;
        margin: 0 auto 12px;
      }
      @keyframes sb-spin {
        to { transform: rotate(360deg); }
      }
      .sb-loading-text {
        font-size: 13px;
        color: var(--sb-muted);
      }

      /* ── Digest cards ── */
      .sb-digest-card {
        background: var(--sb-card);
        border: 1px solid var(--sb-border-light);
        padding: 24px;
        margin-bottom: 16px;
      }
      .sb-digest-header {
        display: flex;
        align-items: baseline;
        gap: 8px;
        margin-bottom: 4px;
      }
      .sb-digest-city {
        font-family: var(--sb-serif);
        font-size: 18px;
        font-weight: 700;
        color: var(--sb-ink);
      }
      .sb-digest-body {
        font-size: 12px;
        color: var(--sb-light);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-weight: 600;
      }
      .sb-digest-date {
        font-size: 13px;
        color: var(--sb-muted);
        margin-bottom: 12px;
      }
      .sb-digest-summary {
        font-size: 14px;
        line-height: 1.6;
        color: var(--sb-ink);
        margin: 0 0 12px 0;
      }
      .sb-digest-topics {
        margin: 0 0 16px 0;
        padding-left: 18px;
        font-size: 13px;
        line-height: 1.7;
        color: var(--sb-muted);
      }
      .sb-digest-topics li { margin-bottom: 2px; }
      .sb-digest-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 12px;
        padding-top: 12px;
        border-top: 1px solid var(--sb-border-light);
      }
      .sb-digest-next {
        color: var(--sb-muted);
      }
      .sb-digest-source {
        color: var(--sb-muted);
        text-decoration: none;
        font-weight: 500;
      }
      .sb-digest-source:hover { text-decoration: underline; }
      .sb-digest-loading {
        text-align: center;
        padding: 32px;
        background: var(--sb-card);
        border: 1px solid var(--sb-border-light);
        margin-bottom: 16px;
      }
      .sb-digest-error {
        padding: 16px 20px;
        background: var(--sb-accent-light);
        border: 1px solid var(--sb-border-light);
        margin-bottom: 16px;
        font-size: 13px;
        color: var(--sb-accent);
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .sb-digest-error button {
        padding: 4px 12px;
        background: none;
        border: 1px solid var(--sb-accent);
        color: var(--sb-accent);
        cursor: pointer;
        font-size: 12px;
        font-weight: 600;
      }
      .sb-gov-upcoming {
        padding: 20px;
        font-size: 13px;
        color: var(--sb-muted);
        text-align: center;
      }

      /* ── Coming soon state ── */
      .sb-coming-soon {
        text-align: center;
        padding: 64px 24px;
      }
      .sb-coming-soon-icon {
        font-size: 28px;
        margin-bottom: 12px;
        opacity: 0.5;
      }
      .sb-coming-soon-title {
        font-family: var(--sb-serif);
        font-size: 20px;
        font-weight: 700;
        color: var(--sb-ink);
        margin-bottom: 4px;
      }
      .sb-coming-soon-sub {
        font-size: 13px;
        color: var(--sb-muted);
      }

      /* ── Technology section ── */
      .tech-view {
        display: flex;
        flex-direction: column;
        gap: 32px;
      }

      /* Header */
      .tech-header {
        border-bottom: 3px double var(--sb-border);
        padding-bottom: 20px;
      }
      .tech-header-eyebrow {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--sb-muted);
        margin-bottom: 4px;
      }
      .tech-header-title {
        font-family: var(--sb-serif);
        font-size: 36px;
        font-weight: 900;
        letter-spacing: -0.02em;
        color: var(--sb-ink);
        margin: 0 0 8px 0;
        line-height: 1.1;
      }
      .tech-header-subtitle {
        font-size: 15px;
        color: var(--sb-muted);
        margin: 0 0 10px 0;
        line-height: 1.5;
        max-width: 600px;
      }
      .tech-header-note {
        font-size: 11px;
        color: var(--sb-light);
        letter-spacing: 0.03em;
      }

      /* Pulse strip */
      .tech-pulse {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1px;
        background: var(--sb-border-light);
        border: 1px solid var(--sb-border-light);
      }
      .tech-pulse-item {
        background: var(--sb-card);
        padding: 16px 20px;
      }
      .tech-pulse-value {
        font-family: var(--sb-serif);
        font-size: 22px;
        font-weight: 800;
        color: var(--sb-ink);
        line-height: 1.1;
        margin-bottom: 3px;
      }
      .tech-pulse-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--sb-muted);
        margin-bottom: 4px;
      }
      .tech-pulse-note {
        font-size: 12px;
        color: var(--sb-light);
        line-height: 1.4;
      }

      /* Section wrapper */
      .tech-section {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }
      .tech-section-head {
        display: flex;
        align-items: baseline;
        gap: 12px;
        border-bottom: 1px solid var(--sb-border);
        padding-bottom: 8px;
      }
      .tech-section-title {
        font-family: var(--sb-serif);
        font-size: 20px;
        font-weight: 700;
        color: var(--sb-ink);
        margin: 0;
      }
      .tech-section-note {
        font-size: 12px;
        color: var(--sb-light);
      }

      /* Chart */
      .tech-chart-wrap {
        background: var(--sb-card);
        border: 1px solid var(--sb-border-light);
        padding: 20px 8px 12px 0;
      }
      .tech-chart-legend {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
        font-size: 11px;
      }
      .tech-legend-up { color: #16a34a; font-weight: 600; }
      .tech-legend-down { color: #dc2626; font-weight: 600; }
      .tech-legend-note { color: var(--sb-light); margin-left: auto; }

      /* Company grid */
      .tech-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1px;
        background: var(--sb-border-light);
        border: 1px solid var(--sb-border-light);
      }

      /* Company card */
      .tech-card {
        background: var(--sb-card);
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .tech-card:hover {
        background: var(--sb-primary-light);
      }
      .tech-card-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 8px;
      }
      .tech-card-identity {
        display: flex;
        align-items: baseline;
        gap: 6px;
        flex-wrap: wrap;
      }
      .tech-card-name {
        font-family: var(--sb-serif);
        font-size: 17px;
        font-weight: 700;
        color: var(--sb-ink);
        line-height: 1.2;
      }
      .tech-card-ticker {
        font-size: 11px;
        font-weight: 600;
        color: var(--sb-light);
        letter-spacing: 0.04em;
        font-family: 'Space Mono', monospace;
      }
      .tech-card-meta {
        display: flex;
        align-items: center;
        gap: 5px;
        flex-wrap: wrap;
        font-size: 12px;
        color: var(--sb-muted);
      }
      .tech-card-city { font-weight: 500; }
      .tech-card-dot { color: var(--sb-border); }
      .tech-card-category {
        background: var(--sb-primary-light);
        border: 1px solid var(--sb-border-light);
        padding: 1px 6px;
        border-radius: 2px;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--sb-muted);
      }
      .tech-card-headcount {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        color: var(--sb-muted);
      }
      .tech-card-desc {
        font-size: 13px;
        color: var(--sb-ink);
        line-height: 1.5;
        margin: 0;
      }
      .tech-card-trend-note {
        font-size: 12px;
        color: var(--sb-muted);
        font-style: italic;
      }
      .tech-card-highlights {
        margin: 4px 0 0 0;
        padding-left: 16px;
        font-size: 12px;
        color: var(--sb-muted);
        line-height: 1.6;
      }
      .tech-card-highlights li { margin-bottom: 2px; }

      /* Trend badges */
      .tech-trend {
        font-size: 11px;
        font-weight: 700;
        white-space: nowrap;
        padding: 2px 6px;
        border-radius: 2px;
        flex-shrink: 0;
      }
      .tech-trend--up {
        color: #15803d;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
      }
      .tech-trend--down {
        color: #b91c1c;
        background: #fef2f2;
        border: 1px solid #fecaca;
      }
      .tech-trend--flat {
        color: var(--sb-muted);
        background: var(--sb-primary-light);
        border: 1px solid var(--sb-border-light);
      }

      /* Footer note */
      .tech-footer-note {
        font-size: 11px;
        color: var(--sb-light);
        line-height: 1.6;
        padding-top: 16px;
        border-top: 1px solid var(--sb-border-light);
      }

      /* ── Footer ── */
      .sb-footer {
        max-width: var(--sb-max-width);
        margin: 0 auto;
        padding: 32px 24px;
        text-align: center;
        font-size: 11px;
        color: var(--sb-light);
        border-top: 3px double var(--sb-border);
        letter-spacing: 0.02em;
      }
      .sb-footer a {
        color: var(--sb-muted);
        text-decoration: none;
      }
      .sb-footer a:hover { text-decoration: underline; }

      /* ── Responsive ── */
      @media (max-width: 640px) {
        .sb-header { padding: 20px 16px 0; }
        .sb-brand-name { font-size: 26px; }
        .sb-masthead-rule { margin: 12px 16px 0; }
        .sb-nav { padding: 0 16px; }
        .sb-tab { padding: 10px 16px; font-size: 11px; }
        .sb-filters { padding: 10px 16px; }
        .sb-main { padding: 20px 16px; }
        .sb-section-title { font-size: 18px; }
        .sb-games-grid { grid-template-columns: 1fr; }
        .sb-overview-grid { grid-template-columns: 1fr; }

        /* Tech section mobile */
        .tech-header-title { font-size: 28px; }
        .tech-pulse { grid-template-columns: repeat(2, 1fr); }
        .tech-grid { grid-template-columns: 1fr; }
        .tech-section-head { flex-direction: column; gap: 2px; }
        .tech-legend-note { display: none; }
        .tech-chart-wrap { overflow-x: auto; }
      }
    </style>
  </Fragment>

  <SignalApp client:load />
</BaseLayout>
