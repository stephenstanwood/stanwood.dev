---
import BaseLayout from "../layouts/BaseLayout.astro";
import SwimWorkout from "../components/SwimWorkout.tsx";
const title = "Lap Lab — stanwood.dev";
---

<BaseLayout
  title={title}
  description="Generate custom swim workouts for any duration, pace, and skill level. Sets, drills, and intervals built around your goals — just pick a time and hit the pool."
  slug="swim"
  favicon="/favicon-swim.svg"
  themeColor="#0d9488"
  schemaCategory="HealthApplication"
  schemaName="Lap Lab"
>
  <Fragment slot="head">
    <style>
      body {
        font-family: 'Inter', system-ui, sans-serif;
        background-color: #f5f0eb;
        color: rgb(15 23 42);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* ── Fade-in animation for workout generation ── */
      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .animate-fadeIn {
        animation: fadeIn 0.4s ease-out;
      }

      /* ── Hero section ── */
      .hero-container {
        position: relative;
        width: 100%;
        height: 280px;
        overflow: hidden;
        border-radius: 1.25rem;
        margin-top: 1rem;
      }
      @media (min-width: 640px) {
        .hero-container {
          height: 340px;
        }
      }
      .hero-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
      .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to bottom,
          rgba(245, 240, 235, 0) 0%,
          rgba(245, 240, 235, 0) 40%,
          rgba(245, 240, 235, 0.6) 70%,
          rgba(245, 240, 235, 1) 100%
        );
        pointer-events: none;
      }
      .hero-title-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 2rem 1.5rem 1.25rem;
        pointer-events: none;
      }

      /* ── Pool-themed accent bar ── */
      .lane-divider {
        height: 4px;
        background: repeating-linear-gradient(
          90deg,
          #0d9488 0px,
          #0d9488 20px,
          #f5f0eb 20px,
          #f5f0eb 28px,
          #e11d48 28px,
          #e11d48 48px,
          #f5f0eb 48px,
          #f5f0eb 56px
        );
        border-radius: 2px;
      }

      /* ── Sandstone card surface ── */
      .card-sandstone {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(13, 148, 136, 0.1);
        border-radius: 1.25rem;
      }

      /* ── Print styles: clean single-page PDF ── */
      @media print {
        /* Hide everything except the print workout */
        body > * { display: none !important; }
        body { background: white !important; margin: 0 !important; padding: 0 !important; }

        .print-workout {
          display: block !important;
          position: fixed;
          top: 0; left: 0; right: 0;
          padding: 32px 40px !important;
          max-width: 100% !important;
          font-size: 11pt;
        }

        /* Prevent page breaks inside sections */
        .print-workout > div { break-inside: avoid; }

        @page {
          size: letter;
          margin: 0.5in;
        }
      }
    </style>
  </Fragment>

  <a href="#main-content" class="skip-nav">Skip to content</a>

  <!-- Subtle lane divider at very top -->
  <div class="lane-divider"></div>

  <main id="main-content" class="mx-auto max-w-2xl px-6 pt-8 pb-24 print:hidden">
    <!-- Nav -->
    <div class="flex items-center">
      <a href="/" class="retro-back">&larr; stanwood.dev</a>
    </div>

    <!-- Hero Image -->
    <div class="hero-container">
      <img
        src="/images/lap-lab.webp"
        alt="Aerial view of a turquoise swimming pool with lane dividers"
        class="hero-image"
        loading="lazy"
        decoding="async"
        width="1280"
        height="720"
      />
      <div class="hero-overlay"></div>
      <div class="hero-title-overlay">
        <div class="flex items-center gap-3">
          <div class="flex items-center justify-center w-11 h-11 rounded-xl bg-teal-600/90 backdrop-blur-sm shadow-lg shadow-teal-900/20">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
            </svg>
          </div>
          <div>
            <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900">
              Lap Lab
            </h1>
          </div>
        </div>
      </div>
    </div>

    <!-- Header copy -->
    <header class="mt-3">
      <p class="text-teal-700/60 text-sm font-medium uppercase tracking-wider">swim workout generator</p>
      <p class="mt-3 text-stone-500 leading-relaxed">
        Pick your duration, pace, and pool type. We'll build you a workout with a warmup, main set, and cooldown.
        Don't love it? Shuffle until you do.
      </p>

      <!-- Pace reference guide -->
      <div class="mt-5 rounded-xl border border-teal-100 bg-white/60 backdrop-blur-sm p-4">
        <p class="text-xs font-bold uppercase tracking-wider text-stone-400 mb-3">Pace guide — per 100</p>
        <div class="grid grid-cols-3 gap-2 text-center text-xs">
          <div class="rounded-lg bg-amber-50 border border-amber-100 p-2.5">
            <div class="font-bold text-amber-800 text-sm">2:00 – 2:30</div>
            <div class="text-amber-700 mt-0.5">Casual / Fitness</div>
            <div class="text-stone-400 mt-1 leading-tight">Recreational lap swimmer</div>
          </div>
          <div class="rounded-lg bg-teal-50 border border-teal-100 p-2.5">
            <div class="font-bold text-teal-800 text-sm">1:35 – 1:55</div>
            <div class="text-teal-700 mt-0.5">Intermediate</div>
            <div class="text-stone-400 mt-1 leading-tight">Regular training, masters</div>
          </div>
          <div class="rounded-lg bg-sky-50 border border-sky-100 p-2.5">
            <div class="font-bold text-sky-800 text-sm">1:10 – 1:30</div>
            <div class="text-sky-700 mt-0.5">Competitive</div>
            <div class="text-stone-400 mt-1 leading-tight">Club / collegiate speed</div>
          </div>
        </div>
        <p class="mt-3 text-[11px] text-stone-400 leading-relaxed">
          Yards pools (SCY) run slightly faster — subtract ~5 sec from your meters pace to start.
          Some workouts include a pull buoy, kickboard, or fins — bring them if you have them.
        </p>
      </div>

      <!-- Lane divider decoration -->
      <div class="lane-divider mt-5"></div>
    </header>

    <!-- App -->
    <SwimWorkout client:idle />
  </main>

  <!-- Print target (React renders here too) -->
</BaseLayout>
