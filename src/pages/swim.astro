---
import BaseLayout from "../layouts/BaseLayout.astro";
import SwimWorkout from "../components/SwimWorkout.tsx";
const title = "Lap Lab — stanwood.dev";
---

<BaseLayout
  title={title}
  description="Lap Lab — Generate custom swim workouts for any duration and pace."
  slug="swim"
  favicon="/favicon-swim.svg"
  themeColor="#0f172a"
  schemaCategory="HealthApplication"
  schemaName="Lap Lab"
>
  <Fragment slot="head">
    <style>
      body {
        font-family: 'Inter', system-ui, sans-serif;
        background-color: rgb(248 250 252);
        color: rgb(15 23 42);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* ── Fade-in animation for workout generation ── */
      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .animate-fadeIn {
        animation: fadeIn 0.4s ease-out;
      }

      /* ── Decorative chevron band at the top ── */
      .chevron-band {
        background:
          linear-gradient(135deg, transparent 33.33%, currentColor 33.33%, currentColor 66.66%, transparent 66.66%),
          linear-gradient(225deg, transparent 33.33%, currentColor 33.33%, currentColor 66.66%, transparent 66.66%);
        background-size: 24px 12px;
        height: 6px;
      }

      /* ── Print styles: clean single-page PDF ── */
      @media print {
        /* Hide everything except the print workout */
        body > * { display: none !important; }
        body { background: white !important; margin: 0 !important; padding: 0 !important; }

        .print-workout {
          display: block !important;
          position: fixed;
          top: 0; left: 0; right: 0;
          padding: 32px 40px !important;
          max-width: 100% !important;
          font-size: 11pt;
        }

        /* Prevent page breaks inside sections */
        .print-workout > div { break-inside: avoid; }

        @page {
          size: letter;
          margin: 0.5in;
        }
      }
    </style>
  </Fragment>

  <a href="#main-content" class="skip-nav">Skip to content</a>
  <!-- Retro chevron band across the top -->
  <div class="chevron-band text-teal-400"></div>

  <main id="main-content" class="mx-auto max-w-2xl px-6 pt-12 pb-24 print:hidden">
    <!-- Nav -->
    <div class="flex items-center">
      <a href="/" class="retro-back">&larr; stanwood.dev</a>
    </div>

    <!-- Header -->
    <header class="mt-10">
      <div class="flex items-center gap-3">
        <div class="flex items-center justify-center w-12 h-12 rounded-2xl bg-gradient-to-br from-teal-400 to-cyan-500 shadow-lg shadow-teal-200/50">
          <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
          </svg>
        </div>
        <div>
          <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900">
            Lap Lab
          </h1>
          <p class="text-slate-400 text-sm font-medium -mt-0.5">swim workout generator</p>
        </div>
      </div>
      <p class="mt-4 text-slate-500 leading-relaxed">
        Pick your duration, pace, and pool type. We'll build you a workout with a warmup, main set, and cooldown.
        Don't love it? Shuffle until you do.
      </p>

      <!-- Wave decoration -->
      <svg class="mt-6 w-full h-6 text-teal-100" viewBox="0 0 1200 40" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0 20 Q150 0 300 20 T600 20 T900 20 T1200 20 V40 H0 Z" fill="currentColor" opacity="0.5">
          <animate attributeName="d" dur="4s" repeatCount="indefinite"
            values="M0 20 Q150 0 300 20 T600 20 T900 20 T1200 20 V40 H0 Z;
                    M0 20 Q150 40 300 20 T600 20 T900 20 T1200 20 V40 H0 Z;
                    M0 20 Q150 0 300 20 T600 20 T900 20 T1200 20 V40 H0 Z" />
        </path>
        <path d="M0 25 Q200 10 400 25 T800 25 T1200 25 V40 H0 Z" fill="currentColor" opacity="0.3">
          <animate attributeName="d" dur="5s" repeatCount="indefinite"
            values="M0 25 Q200 10 400 25 T800 25 T1200 25 V40 H0 Z;
                    M0 25 Q200 35 400 25 T800 25 T1200 25 V40 H0 Z;
                    M0 25 Q200 10 400 25 T800 25 T1200 25 V40 H0 Z" />
        </path>
      </svg>
    </header>

    <!-- App -->
    <SwimWorkout client:idle />
  </main>

  <!-- Print target (React renders here too) -->
</BaseLayout>
