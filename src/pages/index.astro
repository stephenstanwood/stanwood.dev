  <script>
    // ── Fisher-Yates shuffle ──
    function shuffle(container: HTMLElement, selector = ':scope > *') {
      const kids = [...container.querySelectorAll(selector)] as HTMLElement[];
      for (let i = kids.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [kids[i], kids[j]] = [kids[j], kids[i]];
      }
      kids.forEach((el, i) => {
        container.appendChild(el);
        el.style.opacity = '0';
        el.style.animation = `fadeIn 0.4s ease ${0.05 + i * 0.06}s forwards`;
      });
      container.classList.add('shuffled');
    }

    // Shuffle featured + projects
    const featRow = document.getElementById('feat-row');
    const projRow = document.getElementById('proj-row');
    if (featRow) shuffle(featRow, ':scope > .feat-card');
    if (projRow) {
      // Full shuffle — all tiles treated equally
      const tileSelector = ':scope > .proj-tile, :scope > astro-island, :scope > [data-pinned]';
      shuffle(projRow, tileSelector);

      // If last tile is alone on its row (count % 3 !== 0), stretch it full-width
      const tiles = [...projRow.querySelectorAll(tileSelector)] as HTMLElement[];
      if (tiles.length % 3 !== 0) {
        const lastTile = tiles[tiles.length - 1];
        const tile = lastTile.classList.contains('proj-tile') ? lastTile : lastTile.querySelector('.proj-tile');
        if (tile) tile.classList.add('last-full');
      }
    }

    // ── Terminal typewriter ──
    const termOutput = document.getElementById('term-output');
    const termPairs: [string, string][] = [
      ['uptime', `${Math.floor((Date.now() - new Date('2026-03-01').getTime()) / 86400000)}d since launch`],
      ['curl wttr.in/campbell', '…'],
      ['git log --oneline -1', 'one more commit...'],
      ['echo $MOOD', 'optimistic'],
      ['ping localhost', '0.01ms — still here'],
      ['ls projects/ | wc -l', '15 and counting'],
      ['cat /dev/motivation', 'keep shipping'],
      ['git diff --stat', '3 files changed, +42 -0'],
      ['date +"%A"', 'another good day to build'],
    ];

    // Shuffle terminal commands (Fisher-Yates)
    for (let i = termPairs.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [termPairs[i], termPairs[j]] = [termPairs[j], termPairs[i]];
    }

    // Find the weather entry and patch with real data
    const weatherEntry = termPairs.find(p => p[0].includes('wttr'));
    fetch('/api/weather')
      .then(r => r.json())
      .then(d => { if (d.weather && weatherEntry) weatherEntry[1] = d.weather; })
      .catch(() => { if (weatherEntry) weatherEntry[1] = '☀️  nice out there'; });

    let termIdx = 0;
    const MAX_VISIBLE = 4;

    function trimLines() {
      const lines = termOutput!.querySelectorAll('.line');
      if (lines.length > MAX_VISIBLE) {
        const first = lines[0] as HTMLElement;
        first.style.opacity = '0';
        first.style.transform = 'translateY(-8px)';
        first.style.transition = 'all 0.25s';
        setTimeout(() => first.remove(), 250);
      }
    }

    function addLine(text: string, cls: string) {
      trimLines();
      const line = document.createElement('div');
      line.className = 'line ' + cls;
      line.textContent = text;
      termOutput!.appendChild(line);
    }

    async function typeCmd(text: string): Promise<void> {
      trimLines();
      const line = document.createElement('div');
      line.className = 'line cmd';
      const span = document.createElement('span');
      line.appendChild(span);
      const cursor = document.createElement('span');
      cursor.className = 'term-cursor';
      line.appendChild(cursor);
      termOutput!.appendChild(line);

      for (let i = 0; i < text.length; i++) {
        span.textContent += text[i];
        await new Promise(r => setTimeout(r, 40 + Math.random() * 35));
      }
      cursor.remove();
    }

    async function termLoop() {
      while (true) {
        const [cmd, out] = termPairs[termIdx];
        await typeCmd(cmd);
        await new Promise(r => setTimeout(r, 300));
        addLine(out, 'out');
        termIdx = (termIdx + 1) % termPairs.length;
        await new Promise(r => setTimeout(r, 2200));
      }
    }

    termLoop();
  </script>
