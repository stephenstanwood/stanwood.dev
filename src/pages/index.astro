    <!-- Footer -->
    <div class="footer-row">
      <div class="footer-chem">
        <ChemFormula compact client:visible />
      </div>
      <div class="footer-location">
        <span class="footer-loc-sub">based in beautiful</span>
        <span class="footer-loc-title">campbell, ca</span>
      </div>
    </div>
  </div>

  <script>

    // ── Spacer tile cycle ──
    const spacerMessages: [string, string][] = [
      ['have a great day', '🙂'],
      ['$ repeat', '█'],
      ['~ refactoring for fun', ''],
      ['keep shipping', '🚀'],
      ['one more commit...', ''],
      ['what if we tried this...', '💡'],
    ];
    const spacerMsg = document.getElementById('spacer-msg');
    const spacerIcon = document.getElementById('spacer-icon');
    if (spacerMsg && spacerIcon) {
      let si = 0;
      setInterval(() => {
        si = (si + 1) % spacerMessages.length;
        spacerMsg.style.opacity = '0';
        spacerIcon.style.opacity = '0';
        setTimeout(() => {
          spacerMsg.textContent = spacerMessages[si][0];
          spacerIcon.textContent = spacerMessages[si][1];
          spacerMsg.style.opacity = '1';
          spacerIcon.style.opacity = '1';
        }, 300);
      }, 4000);
      spacerMsg.style.transition = 'opacity 0.3s';
      spacerIcon.style.transition = 'opacity 0.3s';
    }

    // ── Terminal typewriter ──
    const termOutput = document.getElementById('term-output');
    const termPairs: [string, string][] = [
      ['uptime', `${Math.floor((Date.now() - new Date('2026-03-01').getTime()) / 86400000)}d since launch`],
      ['curl wttr.in/campbell', '…'],
      ['git log --oneline -1', 'one more commit...'],
      ['echo $MOOD', 'optimistic'],
      ['ping localhost', '0.01ms — still here'],
      ['ls projects/ | wc -l', '15 and counting'],
      ['cat /dev/motivation', 'keep shipping'],
      ['git diff --stat', '3 files changed, +42 -0'],
      ['date +"%A"', 'another good day to build'],
    ];

    // Shuffle terminal commands (Fisher-Yates)
    for (let i = termPairs.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [termPairs[i], termPairs[j]] = [termPairs[j], termPairs[i]];
    }

    // Find the weather entry and patch with real data
    const weatherEntry = termPairs.find(p => p[0].includes('wttr'));
    fetch('/api/weather')
      .then(r => r.json())
      .then(d => { if (d.weather && weatherEntry) weatherEntry[1] = d.weather; })
      .catch(() => { if (weatherEntry) weatherEntry[1] = '☀️  nice out there'; });

    let termIdx = 0;
    const MAX_VISIBLE = 4;

    function trimLines() {
      const lines = termOutput!.querySelectorAll('.line');
      if (lines.length > MAX_VISIBLE) {
        const first = lines[0] as HTMLElement;
        first.style.opacity = '0';
        first.style.transform = 'translateY(-8px)';
        first.style.transition = 'all 0.25s';
        setTimeout(() => first.remove(), 250);
      }
    }

    function addLine(text: string, cls: string) {
      trimLines();
      const line = document.createElement('div');
      line.className = 'line ' + cls;
      line.textContent = text;
      termOutput!.appendChild(line);
    }

    async function typeCmd(text: string): Promise<void> {
      trimLines();
      const line = document.createElement('div');
      line.className = 'line cmd';
      const span = document.createElement('span');
      line.appendChild(span);
      const cursor = document.createElement('span');
      cursor.className = 'term-cursor';
      line.appendChild(cursor);
      termOutput!.appendChild(line);

      for (let i = 0; i < text.length; i++) {
        span.textContent += text[i];
        await new Promise(r => setTimeout(r, 40 + Math.random() * 35));
      }
      cursor.remove();
    }

    async function termLoop() {
      while (true) {
        const [cmd, out] = termPairs[termIdx];
        await typeCmd(cmd);
        await new Promise(r => setTimeout(r, 300));
        addLine(out, 'out');
        termIdx = (termIdx + 1) % termPairs.length;
        await new Promise(r => setTimeout(r, 2200));
      }
    }

    termLoop();

    // ── Email copy-to-clipboard ──
    const copyBtn = document.getElementById('copy-email');
    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        navigator.clipboard.writeText('stephen@stanwood.dev').then(() => {
          const orig = copyBtn.textContent;
          copyBtn.textContent = '✓ copied!';
          setTimeout(() => { copyBtn.textContent = orig; }, 1500);
        });
      });
    }
  </script>
</BaseLayout>
