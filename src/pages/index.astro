---
import BaseLayout from "../layouts/BaseLayout.astro";
import ChemFormula from "../components/ChemFormula";
import ShipClockTile from "../components/ShipClockTile.tsx";
import AIRadarTile from "../components/AIRadarTile.tsx";
import AestheticWeatherTile from "../components/AestheticWeatherTile.tsx";
import AIStatusTile from "../components/AIStatusTile.tsx";
import WhichModelTile from "../components/WhichModelTile.tsx";

const featured = [
  {
    href: "https://nbanow.app",
    external: true,
    emoji: "🏀",
    tag: "Sports · Live",
    title: "NBA Now",
    desc: "The best NBA game to watch right now. Live scores ranked by watchability — no more flipping channels.",
    bg: "#e8f5ff",
    image: "/images/nba-now.webp",
  },
  {
    href: "/show-swipe",
    emoji: "🍿",
    tag: "Entertainment · Discovery",
    title: "Show Swipe",
    desc: "Swipe through movie and TV trailers. Right for yes, left for pass. It learns what you like.",
    bg: "#1a1a2e",
    dark: true,
    image: "/images/show-swipe.webp",
  },
  {
    href: "/nearest-coffee",
    emoji: "☕",
    tag: "Utility · Location",
    title: "Nearest Coffee",
    desc: "The nearest open coffee shop. That's it.",
    bg: "#efffea",
    image: "/images/nearest-coffee.webp",
  },
];

const projects = [
  { href: "/wtwtw", emoji: "📺", name: "What to Watch This Week", tag: "best game each night", image: "/images/wtwtw.webp" },
  { href: "/mlb-gamerank", emoji: "⚾", name: "MLB GameRank", tag: "best game right now", image: "/images/mlb-gamerank.webp" },
  { href: "/swim", emoji: "🏊", name: "Lap Lab", tag: "swim workout generator", image: "/images/lap-lab.webp" },
  { href: "/tldr", emoji: "📄", name: "TL;DR", tag: "pdf → short version", image: "/images/tldr.webp" },
  { href: "/green-light", emoji: "🟢", name: "Green Light", tag: "know what to order", image: "/images/green-light.webp" },
  { href: "/nearest-fun", emoji: "🛝", name: "FunFinder", tag: "kids activities nearby", image: "/images/nearest-fun.webp" },
  { href: "/idea-shuffler", emoji: "🎲", name: "Idea Shuffler", tag: "browse without pressure", image: "/images/idea-shuffler.webp" },
  { href: "/pixel-tide", emoji: "🌊", name: "Pixel Tide", tag: "no winning, just vibes", image: "/images/pixel-tide.webp" },
  { href: "/pixel-aquarium", emoji: "🐠", name: "Pixel Aquarium", tag: "little fish, big vibes", image: "/images/pixel-aquarium.webp" },
];
---

<BaseLayout
  title="Stephen Stanwood — stanwood.dev"
  description="Building tools to make life simpler & more fun."
  slug=""
  themeColor="#fffef5"
  fontsUrl="https://fonts.googleapis.com/css2?family=Bangers&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Cabin:ital,wght@0,400;0,700;1,400&family=Permanent+Marker&display=swap"
  schemaType="WebSite"
  schemaName="stanwood.dev"
>
  <Fragment slot="head">
    <link rel="manifest" href="/manifest.json" />
    <style is:global>
      * { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg: #fffef5;
        --ink: #111;
        --yellow: #f5e642;
        --orange: #ff5c1a;
        --blue: #1a4fff;
        --green: #1db842;
        --pink: #ff3aac;
        --pixel: 3px;
      }

      html { scroll-behavior: smooth; }

      body {
        background: var(--bg);
        color: var(--ink);
        font-family: 'Cabin', sans-serif;
        font-size: 15px;
        line-height: 1.5;
        overflow-x: hidden;
      }

      /* ── pixel border utils ── */
      .px-border {
        border: var(--pixel) solid var(--ink);
        box-shadow: 4px 4px 0 var(--ink);
      }

      /* ── ticker ── */
      .ticker-wrap {
        background: var(--ink);
        color: var(--yellow);
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        letter-spacing: 0.05em;
        padding: 8px 0;
        overflow: hidden;
        white-space: nowrap;
        position: relative;
        cursor: default;
      }
      .ticker-wrap:hover .ticker-inner {
        animation-play-state: paused;
      }
      .ticker-inner {
        display: inline-block;
        animation: ticker 45s linear infinite;
      }
      .ticker-sep { margin: 0 32px; opacity: 0.4; }
      @keyframes ticker {
        from { transform: translateX(0); }
        to   { transform: translateX(-50%); }
      }

      /* ── main grid ── */
      .grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 16px;
        padding: 24px 24px 0;
        max-width: 1100px;
        margin: 0 auto;
      }

      /* ── identity block ── */
      .id-block {
        grid-column: 1 / 7;
        background: var(--yellow);
        padding: 28px;
        border: var(--pixel) solid var(--ink);
        box-shadow: 6px 6px 0 var(--ink);
        position: relative;
        animation: fadeIn 0.4s ease;
      }
      .id-block .stamp {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        background: var(--ink);
        color: var(--yellow);
        display: inline-block;
        padding: 3px 8px;
        margin-bottom: 12px;
      }
      .id-block h1 {
        font-family: 'Permanent Marker', cursive;
        font-size: 42px;
        line-height: 1.0;
        margin-bottom: 8px;
        letter-spacing: -1px;
      }
      .id-block .tagline {
        font-family: 'Cabin', sans-serif;
        font-size: 15px;
        font-style: italic;
        color: #333;
        margin-bottom: 20px;
        max-width: 340px;
      }
      .link-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
      }
      .retro-link {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        text-decoration: none;
        color: var(--ink);
        border: 2px solid var(--ink);
        padding: 4px 10px;
        background: white;
        transition: background 0.1s, transform 0.1s, box-shadow 0.1s;
        box-shadow: 2px 2px 0 var(--ink);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
      }
      .retro-link:hover {
        background: var(--ink);
        color: var(--yellow);
        transform: translate(-1px,-1px);
        box-shadow: 3px 3px 0 var(--orange);
      }

      /* ── avatar block ── */
      .avatar-block {
        grid-column: 7 / 10;
        background: var(--blue);
        border: var(--pixel) solid var(--ink);
        box-shadow: 6px 6px 0 var(--ink);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 24px 16px;
        gap: 12px;
        animation: fadeIn 0.4s ease 0.05s both;
      }
      .avatar-circle {
        width: 88px;
        height: 88px;
        border-radius: 50%;
        border: 3px solid white;
        background: #1a3acc;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Permanent Marker', cursive;
        font-size: 28px;
        color: white;
        overflow: hidden;
      }
      .avatar-circle img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .avatar-name {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        color: white;
        text-align: center;
        letter-spacing: 0.05em;
      }
      .avatar-loc {
        font-size: 11px;
        color: rgba(255,255,255,0.6);
        font-family: 'Space Mono', monospace;
        text-align: center;
      }

      /* ── terminal banner ── */
      .banner-block {
        grid-column: 10 / 13;
        background: #0a0a0a;
        border: var(--pixel) solid var(--ink);
        box-shadow: 6px 6px 0 var(--ink);
        padding: 16px;
        display: flex;
        flex-direction: column;
        cursor: default;
        animation: fadeIn 0.4s ease 0.1s both;
        position: relative;
        overflow: hidden;
        font-family: 'Space Mono', monospace;
      }
      .term-bar {
        display: flex;
        gap: 5px;
        margin-bottom: 12px;
      }
      .term-dot {
        width: 8px; height: 8px;
        border-radius: 50%;
      }
      .term-dot.r { background: #ff5f57; }
      .term-dot.y { background: #ffbd2e; }
      .term-dot.g { background: #28c840; }
      .term-prompt {
        color: #28c840;
        font-size: 11px;
        line-height: 1.7;
        min-height: 6em;
      }
      .term-prompt .line.cmd::before {
        content: '$ ';
        color: #555;
      }
      .term-prompt .line.out {
        color: #888;
      }
      .term-cursor {
        display: inline-block;
        width: 7px;
        height: 14px;
        background: #28c840;
        vertical-align: text-bottom;
        margin-left: 1px;
        animation: blink 0.8s step-end infinite;
      }
      @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
      .term-status {
        margin-top: auto;
        padding-top: 8px;
        font-size: 9px;
        color: #444;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      /* ── section label ── */
      .section-label {
        grid-column: 1 / -1;
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #888;
        padding-top: 8px;
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .section-label::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #ddd;
      }

      /* ── featured row ── */
      .feat-row {
        grid-column: 1 / -1;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        opacity: 0;
        transition: opacity 0.15s ease;
      }
      .feat-row.shuffled { opacity: 1; }

      .feat-card {
        background: white;
        border: var(--pixel) solid var(--ink);
        box-shadow: 5px 5px 0 var(--ink);
        padding: 0;
        text-decoration: none;
        color: var(--ink);
        display: flex;
        flex-direction: column;
        transition: transform 0.1s, box-shadow 0.1s, background 0.1s;
        position: relative;
        overflow: hidden;
      }
      .feat-card:hover {
        transform: translate(-2px, -2px);
        box-shadow: 7px 7px 0 var(--ink);
      }
      .feat-card:hover .feat-img {
        transform: scale(1.05);
      }
      .feat-img {
        width: 100%;
        height: 140px;
        object-fit: cover;
        display: block;
        border-bottom: var(--pixel) solid var(--ink);
        transition: transform 0.3s ease;
      }
      .feat-body {
        padding: 18px 20px 20px;
        display: flex;
        flex-direction: column;
        flex: 1;
      }
      .feat-emoji {
        font-size: 32px;
        margin-bottom: 10px;
        display: inline-block;
        transition: transform 0.2s;
      }
      .feat-tag {
        font-family: 'Space Mono', monospace;
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #888;
        margin-bottom: 6px;
      }
      .feat-title {
        font-family: 'Cabin', sans-serif;
        font-weight: 700;
        font-size: 17px;
        margin-bottom: 8px;
        line-height: 1.2;
      }
      .feat-desc {
        font-size: 12px;
        color: #444;
        line-height: 1.55;
        flex: 1;
      }
      .feat-arrow {
        align-self: flex-end;
        margin-top: 14px;
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        color: #888;
        transition: color 0.15s;
      }
      .feat-card:hover .feat-arrow { color: var(--orange); }
      .feat-card--dark { color: #f0f0f0; border-color: #333; box-shadow: 5px 5px 0 #333; }
      .feat-card--dark .feat-tag { color: #999; }
      .feat-card--dark .feat-desc { color: #bbb; }
      .feat-card--dark .feat-arrow { color: #666; }
      .feat-card--dark:hover .feat-arrow { color: #e85d4a; }
      .feat-card--dark:hover { border-color: #555; box-shadow: 7px 7px 0 #555; }

      /* ── project tiles row ── */
      .proj-row {
        grid-column: 1 / -1;
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        grid-auto-rows: min-content;
        gap: 16px;
        opacity: 0;
        transition: opacity 0.15s ease;
      }
      .proj-row.shuffled { opacity: 1; }
      .proj-row > style,
      .proj-row > script { display: none; }

      .proj-tile {
        grid-column: span 2;
        background: white;
        border: 2px solid var(--ink);
        box-shadow: 3px 3px 0 var(--ink);
        padding: 14px 16px;
        text-decoration: none;
        color: var(--ink);
        display: flex;
        align-items: center;
        gap: 10px;
        transition: transform 0.1s, box-shadow 0.1s;
      }
      .proj-tile:hover {
        transform: translate(-1px, -1px);
        box-shadow: 4px 4px 0 var(--ink);
        background: var(--yellow);
      }
      .proj-tile:hover .proj-emoji {
        transform: rotate(-12deg) scale(1.2);
      }
      .proj-emoji {
        font-size: 20px;
        flex-shrink: 0;
        transition: transform 0.2s;
      }
      .proj-info { min-width: 0; }
      .proj-name {
        font-weight: 700;
        font-size: 13px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .proj-tag {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        color: #888;
      }

      /* ── image-enhanced tiles ── */
      .proj-tile.has-img {
        flex-direction: column;
        align-items: stretch;
        padding: 0;
        overflow: hidden;
      }
      .proj-tile.has-img .proj-img {
        width: 100%;
        min-height: 100px;
        flex: 1;
        object-fit: cover;
        display: block;
        border-bottom: 2px solid var(--ink);
      }
      .proj-tile.has-img .proj-emoji {
        display: none;
      }
      .proj-tile.has-img .proj-info {
        padding: 8px 14px;
      }
      /* last tile stretches full width if alone on its row */
      .proj-tile.last-full {
        grid-column: 1 / -1;
      }

      /* ship clock wrapper inherits standard tile sizing */
      .sct-pin .proj-tile {
        height: 100%;
      }

      /* ── ship clock receipt tile ── */
      .sct-tile {
        flex-direction: column;
        align-items: stretch;
        gap: 0;
        padding: 0;
        cursor: default;
        background: #fff;
        border: 2px dashed #ccc;
        box-shadow: none;
        overflow: hidden;
      }
      .proj-tile.sct-tile:hover {
        background: #fff !important;
        transform: none !important;
        box-shadow: none !important;
        border-color: #ccc;
      }
      .sct-inner {
        padding: 16px 18px 14px;
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      .sct-logo {
        font-family: 'Permanent Marker', cursive;
        font-size: 22px;
        text-align: center;
        color: #111;
        line-height: 1.1;
        padding-bottom: 2px;
      }
      .sct-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        width: 100%;
        padding-bottom: 6px;
        border-bottom: 1px dashed #ddd;
        margin-bottom: 2px;
      }
      .sct-store {
        font-family: 'Space Mono', monospace;
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: #666;
      }
      .sct-elapsed {
        font-family: 'Space Mono', monospace;
        font-size: 9px;
        color: #999;
        margin-left: auto;
      }
      .sct-row {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        color: #666;
        line-height: 1.6;
      }
      .sct-row-label {
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .sct-row-value {
        color: #333;
        font-weight: 700;
        text-align: right;
      }
      .sct-divider {
        border: none;
        border-top: 1px dashed #ddd;
        margin: 4px 0;
      }
      .sct-blurb {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        line-height: 1.5;
        padding-top: 2px;
      }
      .sct-project {
        color: #ff5c1a;
        font-weight: 700;
      }
      .sct-desc {
        color: #555;
      }
      .sct-barcode {
        display: flex;
        align-items: stretch;
        height: 28px;
        padding: 0 18px;
        gap: 0;
        margin-top: 4px;
      }
      .sct-bar {
        background: #333;
        height: 100%;
        display: block;
        flex: var(--w);
      }
      .sct-gap {
        background: transparent;
        height: 100%;
        display: block;
        flex: var(--w);
      }
      .sct-footer {
        font-family: 'Space Mono', monospace;
        font-size: 8px;
        text-align: center;
        color: #bbb;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 6px 0 10px;
      }

      /* ── aesthetic weather tile ── */
      .proj-tile.aw-tile {
        flex-direction: column;
        align-items: stretch;
        gap: 0;
        padding: 0;
        overflow: hidden;
        border: 2px solid var(--ink);
        box-shadow: 3px 3px 0 var(--ink);
        transition: transform 0.1s, box-shadow 0.1s;
      }
      .proj-tile.aw-tile:hover {
        transform: translate(-1px, -1px);
        box-shadow: 4px 4px 0 var(--ink);
      }
      .aw-inner {
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-height: 120px;
        justify-content: center;
      }
      .aw-label {
        font-family: 'Space Mono', monospace;
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #888;
      }
      .aw-emoji {
        letter-spacing: 0;
      }
      .aw-title {
        font-family: 'Permanent Marker', cursive;
        font-size: 17px;
        line-height: 1.1;
        color: #111;
      }
      .aw-subtitle {
        font-family: 'Cabin', sans-serif;
        font-style: italic;
        font-size: 11px;
        color: #555;
        line-height: 1.3;
      }
      .aw-meta {
        font-family: 'Space Mono', monospace;
        font-size: 9px;
        color: #999;
        margin-top: 4px;
      }
      .aw-loading {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        color: #bbb;
        text-align: center;
        padding: 40px 0;
      }
      /* dark variant for night day-types */
      .aw-tile[data-dark] .aw-label { color: rgba(255,255,255,0.5); }
      .aw-tile[data-dark] .aw-title { color: #f0f0f0; }
      .aw-tile[data-dark] .aw-subtitle { color: rgba(255,255,255,0.7); }
      .aw-tile[data-dark] .aw-meta { color: rgba(255,255,255,0.5); }

      /* ── AI status tile pin ── */
      .ais-pin .proj-tile {
        height: 100%;
      }

      /* ── AI status tile ── */
      .ais-tile {
        flex-direction: column;
        align-items: stretch;
        gap: 0;
        padding: 0;
        overflow: hidden;
        cursor: default;
        background: #fff;
      }
      .proj-tile.ais-tile:hover {
        transform: none !important;
        box-shadow: 3px 3px 0 var(--ink) !important;
      }
      .ais-tile--out .ais-head,
      .ais-tile--out .ais-body {
        opacity: 0;
        transition: opacity 0.2s ease;
      }

      /* White zone: logo + name + status */
      .ais-head {
        padding: 14px 16px 10px;
        display: flex;
        align-items: center;
        gap: 12px;
        background: #fff;
        min-height: 68px;
      }
      .ais-logo {
        display: flex;
        align-items: center;
        flex-shrink: 0;
      }
      .ais-head-text {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .ais-name {
        font-family: 'Cabin', sans-serif;
        font-weight: 700;
        font-size: 16px;
        color: var(--ink);
        letter-spacing: 0.02em;
      }
      .ais-status-row {
        display: flex;
        align-items: center;
        gap: 5px;
      }
      .ais-pulse {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        flex-shrink: 0;
        animation: aisPulse 2s ease-in-out infinite;
      }
      @keyframes aisPulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
      }
      .ais-status-label {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }

      /* Brand color zone: summary + footer */
      .ais-body {
        flex: 1;
        padding: 10px 16px 10px;
        display: flex;
        flex-direction: column;
        gap: 6px;
        color: #fff;
        transition: background 0.3s ease;
      }
      .ais-summary {
        font-size: 12px;
        line-height: 1.4;
        opacity: 0.9;
      }
      .ais-incident {
        font-family: 'Space Mono', monospace;
        font-size: 9px;
        line-height: 1.4;
        opacity: 0.7;
      }

      /* Footer: dots + meta */
      .ais-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: auto;
        padding-top: 4px;
      }
      .ais-dots {
        display: flex;
        gap: 6px;
      }
      .ais-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        border: 1.5px solid rgba(255,255,255,0.35);
        background: transparent;
        padding: 0;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s;
      }
      .ais-dot:hover {
        border-color: rgba(255,255,255,0.7);
      }
      .ais-dot--active {
        background: #fff;
        border-color: #fff;
      }
      .ais-meta {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .ais-checked {
