---
import BaseLayout from "../layouts/BaseLayout.astro";

const featured = [
  {
    href: "https://nbanow.app",
    external: true,
    emoji: "🏀",
    tag: "Sports · Live",
    title: "NBA Now",
    desc: "The best NBA game to watch right now. Live scores ranked by watchability — no more flipping channels.",
    bg: "#e8f5ff",
  },
  {
    href: "/wtwtw",
    emoji: "📺",
    tag: "Sports · Weekly",
    title: "What to Watch This Week",
    desc: "Pick your teams and your time zone. Get the best game each night.",
    bg: "#fff0e8",
  },
  {
    href: "/nearest-coffee",
    emoji: "☕",
    tag: "Utility · Location",
    title: "Nearest Coffee",
    desc: "The nearest open coffee shop. That's it.",
    bg: "#efffea",
  },
];

const projects = [
  { href: "/mlb-gamerank", emoji: "⚾", name: "MLB GameRank", tag: "best game right now" },
  { href: "/swim", emoji: "🏊", name: "Lap Lab", tag: "swim workout generator" },
  { href: "/tldr", emoji: "📄", name: "TL;DR", tag: "pdf → short version" },
  { href: "/green-light", emoji: "🟢", name: "Green Light", tag: "know what to order" },
  { href: "/nearest-fun", emoji: "🛝", name: "Nearest Fun", tag: "kids activities nearby" },
  { href: "/idea-shuffler", emoji: "🎲", name: "Idea Shuffler", tag: "browse without pressure" },
  { href: "/pixel-tide", emoji: "🌊", name: "Pixel Tide", tag: "no winning, just vibes" },
  { href: "/pixel-aquarium", emoji: "🐠", name: "Pixel Aquarium", tag: "little fish, big vibes" },
];
---

<BaseLayout
  title="Stephen Stanwood — stanwood.dev"
  description="Building tools to make life simpler & more fun."
  slug=""
  themeColor="#fffef5"
  fontsUrl="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Cabin:ital,wght@0,400;0,700;1,400&family=Permanent+Marker&display=swap"
  schemaType="WebSite"
  schemaName="stanwood.dev"
>
  <Fragment slot="head">
    <link rel="manifest" href="/manifest.json" />
    <style is:global>
      * { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg: #fffef5;
        --ink: #111;
        --yellow: #f5e642;
        --orange: #ff5c1a;
        --blue: #1a4fff;
        --green: #1db842;
        --pink: #ff3aac;
        --pixel: 3px;
      }

      html { scroll-behavior: smooth; }

      body {
        background: var(--bg);
        color: var(--ink);
        font-family: 'Cabin', sans-serif;
        font-size: 15px;
        line-height: 1.5;
        overflow-x: hidden;
      }

      /* ── pixel border utils ── */
      .px-border {
        border: var(--pixel) solid var(--ink);
        box-shadow: 4px 4px 0 var(--ink);
      }

      /* ── ticker ── */
      .ticker-wrap {
        background: var(--ink);
        color: var(--yellow);
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        letter-spacing: 0.05em;
        padding: 8px 0;
        overflow: hidden;
        white-space: nowrap;
        position: relative;
        cursor: default;
      }
      .ticker-wrap:hover .ticker-inner {
        animation-play-state: paused;
      }
      .ticker-inner {
        display: inline-block;
        animation: ticker 45s linear infinite;
      }
      .ticker-sep { margin: 0 32px; opacity: 0.4; }
      @keyframes ticker {
        from { transform: translateX(0); }
        to   { transform: translateX(-50%); }
      }

      /* ── main grid ── */
      .grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 16px;
        padding: 24px 24px 0;
        max-width: 1100px;
        margin: 0 auto;
      }

      /* ── identity block ── */
      .id-block {
        grid-column: 1 / 7;
        background: var(--yellow);
        padding: 28px;
        border: var(--pixel) solid var(--ink);
        box-shadow: 6px 6px 0 var(--ink);
        position: relative;
        animation: fadeIn 0.4s ease;
      }
      .id-block .stamp {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        background: var(--ink);
        color: var(--yellow);
        display: inline-block;
        padding: 3px 8px;
        margin-bottom: 12px;
      }
      .id-block h1 {
        font-family: 'Permanent Marker', cursive;
        font-size: 42px;
        line-height: 1.0;
        margin-bottom: 8px;
        letter-spacing: -1px;
      }
      .id-block .tagline {
        font-family: 'Cabin', sans-serif;
        font-size: 15px;
        font-style: italic;
        color: #333;
        margin-bottom: 20px;
        max-width: 340px;
      }
      .link-row {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }
      .retro-link {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        text-decoration: none;
        color: var(--ink);
        border: 2px solid var(--ink);
        padding: 4px 10px;
        background: white;
        transition: background 0.1s, transform 0.1s, box-shadow 0.1s;
        box-shadow: 2px 2px 0 var(--ink);
        display: inline-flex;
        align-items: center;
        gap: 5px;
      }
      .retro-link:hover {
        background: var(--ink);
        color: var(--yellow);
        transform: translate(-1px,-1px);
        box-shadow: 3px 3px 0 var(--orange);
      }

      /* ── avatar block ── */
      .avatar-block {
        grid-column: 7 / 10;
        background: var(--blue);
        border: var(--pixel) solid var(--ink);
        box-shadow: 6px 6px 0 var(--ink);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 24px 16px;
        gap: 12px;
        animation: fadeIn 0.4s ease 0.05s both;
      }
      .avatar-circle {
        width: 88px;
        height: 88px;
        border-radius: 50%;
        border: 3px solid white;
        background: #1a3acc;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Permanent Marker', cursive;
        font-size: 28px;
        color: white;
        overflow: hidden;
      }
      .avatar-circle img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .avatar-name {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        color: white;
        text-align: center;
        letter-spacing: 0.05em;
      }
      .avatar-loc {
        font-size: 11px;
        color: rgba(255,255,255,0.6);
        font-family: 'Space Mono', monospace;
        text-align: center;
      }

      /* ── terminal banner ── */
      .banner-block {
        grid-column: 10 / 13;
        background: #0a0a0a;
        border: var(--pixel) solid var(--ink);
        box-shadow: 6px 6px 0 var(--ink);
        padding: 16px;
        display: flex;
        flex-direction: column;
        cursor: default;
        animation: fadeIn 0.4s ease 0.1s both;
        position: relative;
        overflow: hidden;
        font-family: 'Space Mono', monospace;
      }
      .term-bar {
        display: flex;
        gap: 5px;
        margin-bottom: 12px;
      }
      .term-dot {
        width: 8px; height: 8px;
        border-radius: 50%;
      }
      .term-dot.r { background: #ff5f57; }
      .term-dot.y { background: #ffbd2e; }
      .term-dot.g { background: #28c840; }
      .term-prompt {
        color: #28c840;
        font-size: 11px;
        line-height: 1.7;
        min-height: 6em;
      }
      .term-prompt .line.cmd::before {
        content: '$ ';
        color: #555;
      }
      .term-prompt .line.out {
        color: #888;
      }
      .term-cursor {
        display: inline-block;
        width: 7px;
        height: 14px;
        background: #28c840;
        vertical-align: text-bottom;
        margin-left: 1px;
        animation: blink 0.8s step-end infinite;
      }
      @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
      .term-status {
        margin-top: auto;
        padding-top: 8px;
        font-size: 9px;
        color: #444;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      /* ── section label ── */
      .section-label {
        grid-column: 1 / -1;
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #888;
        padding-top: 8px;
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .section-label::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #ddd;
      }

      /* ── featured row ── */
      .feat-row {
        grid-column: 1 / -1;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        opacity: 0;
        transition: opacity 0.15s ease;
      }
      .feat-row.shuffled { opacity: 1; }

      .feat-card {
        background: white;
        border: var(--pixel) solid var(--ink);
        box-shadow: 5px 5px 0 var(--ink);
        padding: 22px;
        text-decoration: none;
        color: var(--ink);
        display: flex;
        flex-direction: column;
        transition: transform 0.1s, box-shadow 0.1s, background 0.1s;
        position: relative;
      }
      .feat-card:hover {
        transform: translate(-2px, -2px);
        box-shadow: 7px 7px 0 var(--ink);
      }
      .feat-card:hover .feat-emoji {
        transform: scale(1.3) rotate(-8deg);
      }
      .feat-emoji {
        font-size: 32px;
        margin-bottom: 10px;
        display: inline-block;
        transition: transform 0.2s;
      }
      .feat-tag {
        font-family: 'Space Mono', monospace;
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #888;
        margin-bottom: 6px;
      }
      .feat-title {
        font-family: 'Cabin', sans-serif;
        font-weight: 700;
        font-size: 17px;
        margin-bottom: 8px;
        line-height: 1.2;
      }
      .feat-desc {
        font-size: 12px;
        color: #444;
        line-height: 1.55;
        flex: 1;
      }
      .feat-arrow {
        align-self: flex-end;
        margin-top: 14px;
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        color: #888;
        transition: color 0.15s;
      }
      .feat-card:hover .feat-arrow { color: var(--orange); }

      /* ── project tiles row ── */
      .proj-row {
        grid-column: 1 / -1;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        opacity: 0;
        transition: opacity 0.15s ease;
      }
      .proj-row.shuffled { opacity: 1; }

      .proj-tile {
        background: white;
        border: 2px solid var(--ink);
        box-shadow: 3px 3px 0 var(--ink);
        padding: 14px 16px;
        text-decoration: none;
        color: var(--ink);
        display: flex;
        align-items: center;
        gap: 10px;
        transition: transform 0.1s, box-shadow 0.1s;
      }
      .proj-tile:hover {
        transform: translate(-1px, -1px);
        box-shadow: 4px 4px 0 var(--ink);
        background: var(--yellow);
      }
      .proj-tile:hover .proj-emoji {
        transform: rotate(-12deg) scale(1.2);
      }
      .proj-emoji {
        font-size: 20px;
        flex-shrink: 0;
        transition: transform 0.2s;
      }
      .proj-info { min-width: 0; }
      .proj-name {
        font-weight: 700;
        font-size: 13px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .proj-tag {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        color: #888;
      }

      /* ── footer ── */
      .footer-row {
        grid-column: 1 / -1;
        border-top: 2px solid var(--ink);
        padding: 24px 0 40px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 8px;
      }
      .footer-sig {
        font-family: 'Permanent Marker', cursive;
        font-size: 16px;
        color: #333;
      }
      .footer-mono {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        color: #aaa;
        letter-spacing: 0.08em;
      }

      /* ── pixel dot util ── */
      .px-dot {
        display: inline-block;
        width: 8px; height: 8px;
        background: currentColor;
        margin: 0 3px;
        vertical-align: middle;
      }

      /* ── animations ── */
      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .grid > * { animation: fadeIn 0.4s ease both; }
      .grid > *:nth-child(1) { animation-delay: 0.05s; }
      .grid > *:nth-child(2) { animation-delay: 0.10s; }
      .grid > *:nth-child(3) { animation-delay: 0.15s; }
      .grid > *:nth-child(4) { animation-delay: 0.20s; }
      .grid > *:nth-child(5) { animation-delay: 0.25s; }
      .grid > *:nth-child(n+6) { animation-delay: 0.3s; }

      /* ── responsive ── */
      @media (max-width: 700px) {
        .grid { grid-template-columns: 1fr 1fr; gap: 12px; padding: 12px 12px 0; }
        .id-block { grid-column: 1 / -1; }
        .avatar-block { grid-column: 1 / 2; }
        .banner-block { grid-column: 2 / 3; }
        .section-label { grid-column: 1 / -1; }
        .feat-row { grid-template-columns: 1fr; }
        .proj-row { grid-template-columns: 1fr 1fr; }
        .footer-row { flex-direction: column; gap: 10px; text-align: center; }
        .id-block h1 { font-size: 32px; }
      }

      /* ── reduced motion ── */
      @media (prefers-reduced-motion: reduce) {
        .ticker-inner { animation: none !important; }
        .banner-inner { transition: none !important; }
        .banner-blink { animation: none !important; }
      }
    </style>
    <noscript><style>.feat-row, .proj-row { opacity: 1 !important; }</style></noscript>
  </Fragment>

  <!-- Ticker -->
  <div class="ticker-wrap" title="hover to pause">
    <div class="ticker-inner">
      &nbsp;&nbsp;&nbsp;stanwood.dev
      <span class="ticker-sep">◆</span>
      building tools to make life simpler & more fun
      <span class="ticker-sep">◆</span>
      campbell, california
      <span class="ticker-sep">◆</span>
      one more commit...
      <span class="ticker-sep">◆</span>
      that looks cool!
      <span class="ticker-sep">◆</span>
      what if we tried this...
      <span class="ticker-sep">◆</span>
      wait, what just happened?
      <span class="ticker-sep">◆</span>
      let's try this out
      <span class="ticker-sep">◆</span>
      &nbsp;&nbsp;&nbsp;stanwood.dev
      <span class="ticker-sep">◆</span>
      building tools to make life simpler & more fun
      <span class="ticker-sep">◆</span>
      campbell, california
      <span class="ticker-sep">◆</span>
      one more commit...
      <span class="ticker-sep">◆</span>
      that looks cool!
      <span class="ticker-sep">◆</span>
      what if we tried this...
      <span class="ticker-sep">◆</span>
      wait, what just happened?
      <span class="ticker-sep">◆</span>
      let's try this out
      <span class="ticker-sep">◆</span>
    </div>
  </div>

  <div class="grid">
    <!-- Identity -->
    <div class="id-block">
      <div class="stamp">stanwood.dev</div>
      <h1>Stephen<br>Stanwood</h1>
      <p class="tagline">Building tools to make life simpler & more fun.</p>
      <div class="link-row">
        <a class="retro-link" href="https://github.com/stephenstanwood" target="_blank" rel="noopener">
          ⌥ GitHub
        </a>
        <a class="retro-link" href="https://bsky.app/profile/stephenstanwood.bsky.social" target="_blank" rel="noopener">
          ☁ Bluesky
        </a>
        <a class="retro-link" href="https://www.midjourney.com/explore?user_id=ad5d707e-4dc7-42e2-a7c8-056f4b89724f" target="_blank" rel="noopener">
          ✦ Midjourney
        </a>
        <a class="retro-link" href="mailto:stephen@stanwood.dev">
          ✉ Email
        </a>
      </div>
    </div>

    <!-- Avatar -->
    <div class="avatar-block">
      <div class="avatar-circle">
        <img src="/headshot.png" alt="Stephen Stanwood" onerror="this.style.display='none';this.parentElement.textContent='SS';" />
      </div>
      <div class="avatar-name">Stephen Stanwood</div>
      <div class="avatar-loc">📍 Silicon Valley</div>
    </div>

    <!-- Terminal card -->
    <div class="banner-block" id="terminal">
      <div class="term-bar">
        <span class="term-dot r"></span>
        <span class="term-dot y"></span>
        <span class="term-dot g"></span>
      </div>
      <div class="term-prompt" id="term-output"></div>
      <div class="term-status">stanwood.dev</div>
    </div>

    <!-- Featured -->
    <div class="section-label">⭐ featured</div>

    <div id="feat-row" class="feat-row">
      {featured.map((f) => (
        <a
          class="feat-card"
          href={f.href}
          style={`background: ${f.bg};`}
          {...(f.external ? { target: "_blank", rel: "noopener" } : {})}
        >
          <span class="feat-emoji">{f.emoji}</span>
          <div class="feat-tag">{f.tag}</div>
          <div class="feat-title">{f.title}</div>
          <div class="feat-desc">{f.desc}</div>
          <div class="feat-arrow">open →</div>
        </a>
      ))}
    </div>

    <!-- All projects -->
    <div class="section-label">all projects</div>

    <div id="proj-row" class="proj-row">
      {projects.map((p) => (
        <a class="proj-tile" href={p.href}>
          <span class="proj-emoji">{p.emoji}</span>
          <div class="proj-info">
            <div class="proj-name">{p.name}</div>
            <div class="proj-tag">{p.tag}</div>
          </div>
        </a>
      ))}
    </div>

    <!-- Footer -->
    <div class="footer-row">
      <span class="footer-sig">powered by coffee and chlorine ☕</span>
      <span class="footer-mono">stanwood.dev <span class="px-dot" style="color:#ccc"></span> campbell, california</span>
    </div>
  </div>

  <script>
    // ── Fisher-Yates shuffle ──
    function shuffle(container: HTMLElement) {
      const kids = [...container.children] as HTMLElement[];
      for (let i = kids.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [kids[i], kids[j]] = [kids[j], kids[i]];
      }
      kids.forEach((el, i) => {
        container.appendChild(el);
        el.style.opacity = '0';
        el.style.animation = `fadeIn 0.4s ease ${0.05 + i * 0.06}s forwards`;
      });
      container.classList.add('shuffled');
    }

    // Shuffle featured + projects
    const featRow = document.getElementById('feat-row');
    const projRow = document.getElementById('proj-row');
    if (featRow) shuffle(featRow);
    if (projRow) shuffle(projRow);

    // ── Terminal typewriter ──
    const termOutput = document.getElementById('term-output');
    const termPairs: [string, string][] = [
      ['uptime', '42d caffeinated'],
      ['curl wttr.in/campbell', '…'],
      ['git log --oneline -1', 'one more commit...'],
      ['echo $MOOD', 'optimistic'],
      ['ping localhost', '0.01ms — still here'],
      ['ls projects/ | wc -l', '11 and counting'],
      ['cat /dev/motivation', 'keep shipping'],
      ['git diff --stat', '3 files changed, +42 -0'],
      ['date +"%A"', 'another good day to build'],
    ];

    // Shuffle terminal commands (Fisher-Yates)
    for (let i = termPairs.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [termPairs[i], termPairs[j]] = [termPairs[j], termPairs[i]];
    }

    // Find the weather entry and patch with real data
    const weatherEntry = termPairs.find(p => p[0].includes('wttr'));
    fetch('/api/weather')
      .then(r => r.json())
      .then(d => { if (d.weather && weatherEntry) weatherEntry[1] = d.weather; })
      .catch(() => { if (weatherEntry) weatherEntry[1] = '☀️  nice out there'; });

    let termIdx = 0;
    const MAX_VISIBLE = 4;

    function trimLines() {
      const lines = termOutput!.querySelectorAll('.line');
      if (lines.length > MAX_VISIBLE) {
        const first = lines[0] as HTMLElement;
        first.style.opacity = '0';
        first.style.transform = 'translateY(-8px)';
        first.style.transition = 'all 0.25s';
        setTimeout(() => first.remove(), 250);
      }
    }

    function addLine(text: string, cls: string) {
      trimLines();
      const line = document.createElement('div');
      line.className = 'line ' + cls;
      line.textContent = text;
      termOutput!.appendChild(line);
    }

    async function typeCmd(text: string): Promise<void> {
      trimLines();
      const line = document.createElement('div');
      line.className = 'line cmd';
      const span = document.createElement('span');
      line.appendChild(span);
      const cursor = document.createElement('span');
      cursor.className = 'term-cursor';
      line.appendChild(cursor);
      termOutput!.appendChild(line);

      for (let i = 0; i < text.length; i++) {
        span.textContent += text[i];
        await new Promise(r => setTimeout(r, 40 + Math.random() * 35));
      }
      cursor.remove();
    }

    async function termLoop() {
      while (true) {
        const [cmd, out] = termPairs[termIdx];
        await typeCmd(cmd);
        await new Promise(r => setTimeout(r, 300));
        addLine(out, 'out');
        termIdx = (termIdx + 1) % termPairs.length;
        await new Promise(r => setTimeout(r, 2200));
      }
    }

    termLoop();
  </script>
</BaseLayout>
