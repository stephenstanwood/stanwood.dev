              </div>
              <span class="type-badge mt-0.5 bg-cyan-400/15 text-cyan-300 ring-1 ring-cyan-400/20">Web App</span>
            </div>
          </div>
        </a>

        <!-- ═══ Nearest Coffee — Compact text ═══ -->
        <a href="/nearest-coffee" class="bento-card card-compact">
          <div class="card-border" style="background: linear-gradient(135deg, #8BAA80, #4A5E44, #6ECF8E, #8BAA80);"></div>
          <div class="card-inner">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-2xl">☕</span>
                  <h2 class="text-xl font-bold" style="font-family: 'Space Grotesk', sans-serif;">Nearest Coffee</h2>
                </div>
