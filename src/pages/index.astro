              </div>
              <span class="type-badge mt-0.5 bg-[#8BAA80]/15 text-[#A3C296] ring-1 ring-[#8BAA80]/20">Web App</span>
            </div>
          </div>
        </a>

        <!-- ═══ Nearest Fun — Compact text ═══ -->
        <a href="/nearest-fun" class="bento-card card-compact">
          <div class="card-border" style="background: linear-gradient(135deg, #7C9FFF, #FFB74D, #6ECF8E, #7C9FFF);"></div>
          <div class="card-inner">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-2xl">🛝</span>
                  <h2 class="text-xl font-bold" style="font-family: 'Space Grotesk', sans-serif;">Nearest Fun</h2>
                </div>
                <p class="text-sm text-[#9DB8FF]/80">Kids activities, rain or shine</p>
              </div>
              <span class="type-badge mt-0.5 bg-[#7C9FFF]/15 text-[#9DB8FF] ring-1 ring-[#7C9FFF]/20">Web App</span>
            </div>
          </div>
        </a>

        <!-- ═══ Idea Shuffler — Compact text ═══ -->
        <a href="/idea-shuffler" class="bento-card card-compact">
          <div class="card-border" style="background: linear-gradient(135deg, #ff6b9d, #ff9a56, #ffd93d, #c850c0);"></div>
          <div class="card-inner">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-2xl">🎲</span>
                  <h2 class="text-xl font-bold" style="font-family: 'Space Grotesk', sans-serif;">Idea Shuffler</h2>
                </div>
                <p class="text-sm text-pink-300/80">All the inspiration, none of the pressure</p>
              </div>
              <span class="type-badge mt-0.5 bg-pink-400/15 text-pink-300 ring-1 ring-pink-400/20">Web App</span>
            </div>
          </div>
        </a>

      </section>

      <!-- ── Footer ── -->
      <footer class="animate-fade-in mt-20 text-center" style="animation-delay: 0.8s;">
        <div class="mb-4 flex items-center justify-center gap-6">
          <a
            href="https://github.com/stephenstanwood"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-2 text-sm text-white/40 transition-colors hover:text-white"
