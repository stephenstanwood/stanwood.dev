        <!-- ═══ Pixel Tide — Compact text ═══ -->
        <a href="/pixel-tide" class="bento-card card-compact">
          <div class="card-border" style="background: linear-gradient(135deg, #00b4d8, #f4a261, #e0c097, #00b4d8);"></div>
