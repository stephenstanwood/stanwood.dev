              </div>
              <span class="type-badge mt-0.5 bg-emerald-400/15 text-emerald-300 ring-1 ring-emerald-400/20">Web App</span>
            </div>
          </div>
        </a>

        <!-- ═══ TL;DR — Compact text ═══ -->
        <a href="/tldr" class="bento-card card-compact">
          <div class="card-border" style="background: linear-gradient(135deg, #667eea, #00d2ff, #43e97b, #667eea);"></div>
          <div class="card-inner">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="flex items-center gap-2 mb-1">
