                  <p class="text-xs text-amber-300/80">The best game to watch right now</p>
                </div>
                <span class="type-badge bg-amber-400/15 text-amber-300 ring-1 ring-amber-400/20">Web App</span>
              </div>
            </div>
          </div>
        </a>

        <!-- ═══ Pixel Aquarium — Screenshot standard ═══ -->
        <a href="/pixel-aquarium" class="bento-card card-std">
          <div class="card-border" style="background: linear-gradient(135deg, #00d2ff, #43e97b, #ffd93d, #ff6b9d);"></div>
          <div class="card-inner">
            <div class="card-screenshot">
              <img src="/screenshots/pixel-aquarium.png" alt="Pixel Aquarium with colorful fish swimming" loading="lazy" />
              <div class="screenshot-overlay"></div>
