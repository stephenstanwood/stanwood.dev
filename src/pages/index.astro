            <div class="p-4">
              <div class="flex items-center justify-between gap-3">
                <div>
                  <div class="flex items-center gap-2 mb-0.5">
                    <span class="text-lg">🐠</span>
                    <h2 class="text-lg font-bold" style="font-family: 'Space Grotesk', sans-serif;">Pixel Aquarium</h2>
                  </div>
                  <p class="text-xs text-cyan-300/80">Little pixel fish, big pixel vibes</p>
                </div>
                <span class="type-badge bg-cyan-400/15 text-cyan-300 ring-1 ring-cyan-400/20">Game</span>
              </div>
            </div>
          </div>
        </a>

        <!-- ═══ Lap Lab — Compact text ═══ -->
        <a href="/swim" class="bento-card card-compact">
