              </div>
              <span class="type-badge mt-0.5 bg-emerald-400/15 text-emerald-300 ring-1 ring-emerald-400/20">Web App</span>
            </div>
          </div>
        </a>

        <!-- ═══ WTWTW — Compact text ═══ -->
        <a href="/wtwtw" class="bento-card card-compact">
          <div class="card-border" style="background: linear-gradient(135deg, #00d2ff, #667eea, #c850c0, #ff6b9d);"></div>
          <div class="card-inner">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-2xl">📺</span>
                  <h2 class="text-xl font-bold" style="font-family: 'Space Grotesk', sans-serif;">WTWTW</h2>
                </div>
                <p class="text-sm text-cyan-300/80">What to watch this week</p>
