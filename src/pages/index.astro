---
import "../styles/global.css";
const title = "Stephen Stanwood — stanwood.dev";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="Projects I'm tinkering with. :)" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Projects I'm tinkering with." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://stanwood.dev/" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content="Projects I'm tinkering with." />
    <meta property="og:image" content="https://stanwood.dev/api/og?page=index" />
    <meta name="twitter:image" content="https://stanwood.dev/api/og?page=index" />
    <link rel="canonical" href="https://stanwood.dev/" />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "stanwood.dev",
        "url": "https://stanwood.dev",
        "description": "Projects I'm tinkering with.",
        "author": { "@type": "Person", "name": "Stephen Stanwood" }
      }
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0f0c29" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />

    <style>
      /* ── Bento grid ── */
      .bento {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
      }
      @media (min-width: 640px) {
        .bento {
          grid-template-columns: repeat(2, 1fr);
          gap: 1.25rem;
        }
        .bento-wide { grid-column: span 2; }
      }

      /* ── Card base ── */
      .bento-card {
        position: relative;
        display: block;
        overflow: hidden;
        border-radius: 1.5rem;
        padding: 1px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }
      .bento-card:hover {
        transform: scale(1.02);
      }
      .bento-card .card-border {
        position: absolute;
        inset: 0;
        border-radius: 1.5rem;
        opacity: 0.5;
        transition: opacity 0.3s ease;
      }
      .bento-card:hover .card-border {
        opacity: 1;
      }
      .bento-card .card-inner {
        position: relative;
        border-radius: 1.5rem;
        background: rgba(0, 0, 0, 0.2);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
      }

      /* ── Screenshot cards ── */
      .card-screenshot {
        overflow: hidden;
        border-radius: 1.5rem 1.5rem 0 0;
        position: relative;
      }
      .card-screenshot img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
      }
      .bento-card:hover .card-screenshot img {
        transform: scale(1.08);
      }
      .card-screenshot .screenshot-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.2) 40%, transparent 70%);
        pointer-events: none;
      }

      /* ── Hero screenshot (wide card) ── */
      .card-hero .card-screenshot {
        height: 280px;
      }
      @media (min-width: 640px) {
        .card-hero .card-screenshot {
          height: 340px;
        }
      }
      .card-hero .card-text {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 1.5rem;
        z-index: 2;
      }

      /* ── Standard screenshot card ── */
      .card-std .card-screenshot {
        height: 180px;
      }
      @media (min-width: 640px) {
        .card-std .card-screenshot {
          height: 200px;
        }
      }

      /* ── Compact text-only cards ── */
      .card-compact .card-inner {
        padding: 1.25rem 1.5rem;
      }
      @media (min-width: 640px) {
        .card-compact .card-inner {
          padding: 1.5rem 1.75rem;
        }
      }

      /* ── Type badge ── */
      .type-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.7rem;
        font-weight: 600;
        white-space: nowrap;
        flex-shrink: 0;
      }

      /* ── Staggered entry animation ── */
      .bento > * {
        opacity: 0;
        animation: slideUp 0.6s ease forwards;
      }
      .bento > *:nth-child(1) { animation-delay: 0.05s; }
      .bento > *:nth-child(2) { animation-delay: 0.1s; }
      .bento > *:nth-child(3) { animation-delay: 0.15s; }
      .bento > *:nth-child(4) { animation-delay: 0.2s; }
      .bento > *:nth-child(5) { animation-delay: 0.25s; }
      .bento > *:nth-child(6) { animation-delay: 0.3s; }
      .bento > *:nth-child(7) { animation-delay: 0.35s; }
      .bento > *:nth-child(8) { animation-delay: 0.4s; }
      .bento > *:nth-child(9) { animation-delay: 0.45s; }
      .bento > *:nth-child(10) { animation-delay: 0.5s; }
      .bento > *:nth-child(11) { animation-delay: 0.55s; }

      @keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
      }
    </style>
  </head>

  <body class="min-h-screen overflow-x-hidden text-white antialiased" style="font-family: 'Inter', sans-serif;">
    <a href="#projects" class="skip-nav">Skip to projects</a>

    <!-- ── Animated gradient background ── -->
    <div
      class="animate-gradient fixed inset-0 -z-10"
      style="background: linear-gradient(135deg, #0f0c29, #302b63, #24243e, #0d324d, #7b2869, #302b63, #0f0c29);"
    ></div>

    <!-- ── Floating blobs for depth (hidden on mobile for performance) ── -->
    <div class="hidden sm:block fixed inset-0 -z-5 overflow-hidden pointer-events-none" aria-hidden="true">
      <div
        class="animate-float-slow animate-pulse-glow absolute -top-32 -right-32 h-[500px] w-[500px] rounded-full opacity-30"
        style="background: radial-gradient(circle, #00d2ff 0%, transparent 70%);"
      ></div>
      <div
        class="animate-float absolute -bottom-40 -left-40 h-[600px] w-[600px] rounded-full opacity-25"
        style="background: radial-gradient(circle, #ff6b9d 0%, #c850c0 40%, transparent 70%);"
      ></div>
      <div
        class="animate-float-slow absolute top-1/2 right-1/4 h-[350px] w-[350px] rounded-full opacity-20"
        style="background: radial-gradient(circle, #ff9a56 0%, transparent 70%); animation-delay: 3s;"
      ></div>
      <div
        class="animate-float absolute top-1/3 -left-20 h-[280px] w-[280px] rounded-full opacity-20"
        style="background: radial-gradient(circle, #667eea 0%, transparent 70%); animation-delay: 2s;"
      ></div>
    </div>

    <!-- ── Geometric decorations (hidden on mobile) ── -->
    <div class="hidden sm:block fixed inset-0 -z-4 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="animate-spin-slow absolute top-20 right-[15%] h-32 w-32 rounded-full border-2 border-white/10"></div>
      <div class="animate-spin-slow absolute bottom-40 left-[10%] h-24 w-24 rounded-full border border-dashed border-white/8" style="animation-direction: reverse; animation-duration: 30s;"></div>
      <div class="animate-float absolute top-[60%] right-[8%] h-4 w-4 rotate-45 bg-white/10" style="animation-delay: 1s;"></div>
      <div class="animate-float absolute top-[20%] left-[20%] h-3 w-3 rotate-45 bg-cyan-400/15" style="animation-delay: 4s;"></div>
    </div>

    <!-- ── Content ── -->
    <div class="relative mx-auto max-w-3xl px-5 py-16 sm:py-24">

      <!-- ── Hero ── -->
      <header class="animate-slide-up mb-16 text-center">
        <button
          id="status-badge"
          class="group mb-6 inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm text-white/90 cursor-pointer transition-all duration-300 hover:scale-105 active:scale-95"
          style="background: rgba(255,255,255,0.08); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.15); box-shadow: 0 0 20px rgba(0,210,255,0.15), 0 0 40px rgba(200,80,192,0.1);"
        >
          <span class="relative flex h-2.5 w-2.5">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-emerald-400"></span>
          </span>
          <span id="status-text" class="transition-all duration-300">building something new</span>
        </button>

        <script>
          const phrases = [
            "building something new",
            "probably refactoring",
            "one more commit...",
            "let's try this out",
            "that looks cool!",
            "what if we tried this...",
            "wait, what just happened?",
          ];
          let idx = 0;
          const btn = document.getElementById("status-badge");
          const txt = document.getElementById("status-text");
          btn.addEventListener("click", () => {
            idx = (idx + 1) % phrases.length;
            txt.style.opacity = "0";
            txt.style.transform = "translateY(-4px)";
            setTimeout(() => {
              txt.textContent = phrases[idx];
              txt.style.opacity = "1";
              txt.style.transform = "translateY(0)";
            }, 200);
          });
        </script>

        <h1
          class="text-5xl sm:text-7xl lg:text-8xl font-black tracking-tight leading-[0.9]"
          style="font-family: 'Space Grotesk', sans-serif;"
        >
          <span
            class="animate-shimmer inline-block bg-clip-text text-transparent"
            style="background-image: linear-gradient(90deg, #fff 0%, #00d2ff 25%, #ff6b9d 50%, #ff9a56 75%, #fff 100%);"
          >
            Stephen
          </span>
          <br />
          <span
            class="animate-shimmer inline-block bg-clip-text text-transparent"
            style="background-image: linear-gradient(90deg, #fff 0%, #ff9a56 25%, #c850c0 50%, #00d2ff 75%, #fff 100%); animation-delay: -1.5s;"
          >
            Stanwood
          </span>
        </h1>

        <p class="mx-auto mt-6 max-w-md text-lg text-white/80">
          Building tools to make life simpler & more fun
        </p>
      </header>

      <!-- ── Bento grid ── -->
      <section id="projects" class="bento">

        <!-- ═══ NBA Now — Hero screenshot, wide ═══ -->
        <a href="/nba-now" class="bento-card card-hero bento-wide" style="--glow: rgba(255,107,43,0.15);">
          <div class="card-border" style="background: linear-gradient(135deg, #ff6b2b, #ff3b5c, #22d3ee, #ff6b2b);"></div>
          <div class="card-inner">
            <div class="card-screenshot">
              <img src="/screenshots/nba-now.png" alt="NBA Now app showing live game scores" loading="eager" />
              <div class="screenshot-overlay"></div>
            </div>
            <div class="card-text">
              <div class="flex items-end justify-between gap-4">
                <div>
                  <div class="flex items-center gap-2 mb-1">
                    <span class="text-2xl">🏀</span>
                    <h2 class="text-2xl sm:text-3xl font-bold" style="font-family: 'Space Grotesk', sans-serif;">
                      NBA Now
                    </h2>
                  </div>
                  <p class="text-sm text-orange-300/90">Live scores ranked by watchability</p>
                </div>
                <span class="type-badge bg-orange-400/15 text-orange-300 ring-1 ring-orange-400/20">Web App</span>
              </div>
            </div>
          </div>
        </a>

        <!-- ═══ MLB GameRank — Screenshot standard ═══ -->
        <a href="/mlb-gamerank" class="bento-card card-std">
          <div class="card-border" style="background: linear-gradient(135deg, #15803d, #d97706, #dc2626, #15803d);"></div>
          <div class="card-inner">
            <div class="card-screenshot">
              <img src="/screenshots/mlb-gamerank.png" alt="MLB GameRank scoreboard" loading="lazy" />
              <div class="screenshot-overlay"></div>
            </div>
            <div class="p-4">
              <div class="flex items-center justify-between gap-3">
                <div>
                  <div class="flex items-center gap-2 mb-0.5">
                    <span class="text-lg">⚾</span>
                    <h2 class="text-lg font-bold" style="font-family: 'Space Grotesk', sans-serif;">MLB GameRank</h2>
