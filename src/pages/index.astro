import ChemFormula from "../components/ChemFormula";
import ShipClockTile from "../components/ShipClockTile.tsx";
import AIRadarTile from "../components/AIRadarTile.tsx";
import AestheticWeatherTile from "../components/AestheticWeatherTile.tsx";

import WhichModelTile from "../components/WhichModelTile.tsx";
import RedesignRolodexTile from "../components/RedesignRolodexTile.tsx";
import NearestCoffeeTile from "../components/NearestCoffeeTile.tsx";

const featured = [
  {
