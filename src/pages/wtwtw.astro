---
import BaseLayout from "../layouts/BaseLayout.astro";
import WTWTW from "../components/WTWTW.tsx";
const title = "WTWTW — stanwood.dev";

// Month-driven league phases so the "Active right now" badges never go stale.
// Single source of truth: rendered server-side (build month) and re-checked
// client-side (view month) via define:vars below.
const PHASES: Record<string, Record<number, string>> = {
  mlb: { 3: "MLB spring training", 4: "MLB regular season", 5: "MLB regular season", 6: "MLB regular season", 7: "MLB regular season", 8: "MLB regular season", 9: "MLB regular season", 10: "MLB postseason" },
  nba: { 1: "NBA regular season", 2: "NBA regular season", 3: "NBA regular season", 4: "NBA playoffs", 5: "NBA playoffs", 6: "NBA Finals", 10: "NBA regular season", 11: "NBA regular season", 12: "NBA regular season" },
  nhl: { 1: "NHL regular season", 2: "NHL regular season", 3: "NHL regular season", 4: "NHL playoffs", 5: "NHL playoffs", 6: "Stanley Cup Final", 10: "NHL regular season", 11: "NHL regular season", 12: "NHL regular season" },
};
const activeNote = (count: number, firstLeague?: string) =>
  count === 3
    ? "All three leagues are live right now — prime time for WTWTW."
    : count === 2
      ? "Two of the three leagues are in season right now."
      : count === 1
        ? `Only the ${firstLeague?.toUpperCase()} is going right now — the nightly pick pulls from one league until the others tip off.`
        : "Between seasons right now — check back when the leagues tip off.";
const buildMonth = new Date().getMonth() + 1;
const activeLeagues = Object.entries(PHASES).filter(([, m]) => m[buildMonth]);
const activeNoteText = activeNote(activeLeagues.length, activeLeagues[0]?.[0]);
---

<BaseLayout
  title={title}
  description="Pick your favorite teams across MLB, NBA, and NHL, and get a nightly recommendation for the best game worth watching. Scores, matchups, and drama — ranked live."
  slug="wtwtw"
  favicon="/favicon-wtwtw.svg"
  themeColor="#0d1117"
  fontsUrl="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
  schemaCategory="SportsApplication"
  schemaName="What To Watch This Week"
>
  <Fragment slot="head">
    <style>
      body {
        font-family: 'Inter', system-ui, sans-serif;
        background: #0d1117;
        min-height: 100vh;
        position: relative;
        color: #f0e6d6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* warm ambient glow from above */
      body::before {
        content: '';
        position: fixed;
        top: -30%;
        left: 50%;
        transform: translateX(-50%);
        width: 140%;
        height: 70%;
        background: radial-gradient(ellipse, rgba(180, 120, 50, 0.08) 0%, rgba(120, 80, 30, 0.04) 40%, transparent 70%);
        pointer-events: none;
        z-index: 0;
      }

      .wtwtw-main { position: relative; z-index: 1; }

      .oswald { font-family: 'Oswald', sans-serif; }
      .mono { font-family: 'JetBrains Mono', monospace; }

      /* hero image container */
      .wtwtw-hero {
        position: relative;
        width: 100%;
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 2rem;
        aspect-ratio: 21 / 9;
        box-shadow:
          0 4px 30px rgba(180, 120, 50, 0.12),
          0 0 60px rgba(180, 120, 50, 0.06);
      }

      .wtwtw-hero img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      /* gradient overlay on hero */
      .wtwtw-hero::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to bottom,
          rgba(13, 17, 23, 0) 0%,
          rgba(13, 17, 23, 0.15) 40%,
          rgba(13, 17, 23, 0.7) 75%,
          rgba(13, 17, 23, 0.95) 100%
        );
        pointer-events: none;
      }

      /* hero title overlay */
      .wtwtw-hero-title {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 2;
        padding: 1.5rem 1.5rem 1.25rem;
      }

      .wtwtw-hero-title h1 {
        font-family: 'Oswald', sans-serif;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #f5e6d0;
        text-shadow: 0 2px 20px rgba(180, 120, 50, 0.3);
      }

      .wtwtw-hero-subtitle {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(210, 170, 110, 0.6);
        margin-top: 0.25rem;
      }

      /* warm vignette at page edges */
      body::after {
        content: '';
        position: fixed;
        inset: 0;
        background: radial-gradient(ellipse at center, transparent 50%, rgba(13, 17, 23, 0.4) 100%);
        pointer-events: none;
        z-index: 0;
      }

      /* staggered entrance for schedule cards */
      @keyframes fadeSlideIn {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      @keyframes heroFadeIn {
        from { opacity: 0; transform: scale(1.02); }
        to   { opacity: 1; transform: scale(1); }
      }

      .wtwtw-hero {
        animation: heroFadeIn 1s ease-out both;
      }

      /* ── League badges ── */
      .league-badge {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.1em;
        padding: 4px 10px;
        border-radius: 4px;
        border: 1px solid rgba(210, 170, 110, 0.2);
        color: rgba(210, 170, 110, 0.55);
        background: rgba(210, 170, 110, 0.06);
      }
      .league-badge[data-league="mlb"] { border-color: rgba(200, 60, 60, 0.3); color: rgba(220, 100, 90, 0.7); background: rgba(200, 60, 60, 0.06); }
      .league-badge[data-league="nba"] { border-color: rgba(200, 100, 20, 0.3); color: rgba(220, 140, 60, 0.7); background: rgba(200, 100, 20, 0.06); }
      .league-badge[data-league="nhl"] { border-color: rgba(80, 150, 210, 0.3); color: rgba(110, 170, 220, 0.7); background: rgba(80, 150, 210, 0.06); }

      @keyframes activePulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.4; transform: scale(0.8); }
      }

      /* ── How it works ── */
      .how-it-works {
        border: 1px solid rgba(210, 170, 110, 0.1);
        border-radius: 10px;
        padding: 18px 20px;
        background: rgba(255, 255, 255, 0.02);
      }
      .how-steps {
        display: flex;
        flex-direction: column;
        gap: 14px;
      }
      .how-step {
        display: flex;
        align-items: flex-start;
        gap: 14px;
      }
      .how-num {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        font-weight: 700;
        color: rgba(210, 170, 110, 0.3);
        letter-spacing: 0.05em;
        padding-top: 2px;
        flex-shrink: 0;
        width: 20px;
      }
      .how-title {
        font-family: 'Oswald', sans-serif;
        font-size: 14px;
        font-weight: 600;
        color: rgba(245, 230, 208, 0.75);
        margin-bottom: 2px;
      }
      .how-body {
        font-size: 12px;
        color: rgba(210, 170, 110, 0.4);
        line-height: 1.5;
      }

      /* ── Three leagues, three vibes ── */
      .vibes-eyebrow {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 14px;
      }
      .vibes-eyebrow-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(210, 170, 110, 0.35);
      }
      .vibes-eyebrow-tag {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(180, 120, 50, 0.45);
        padding: 2px 8px;
        border: 1px solid rgba(180, 120, 50, 0.18);
        border-radius: 4px;
        background: rgba(180, 120, 50, 0.05);
      }
      .vibes-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
      }
      @media (max-width: 640px) {
        .vibes-grid { grid-template-columns: 1fr; }
      }
      .vibe-card {
        background: rgba(255, 255, 255, 0.025);
        border: 1px solid rgba(210, 170, 110, 0.12);
        border-radius: 12px;
        padding: 14px 14px 16px;
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .vibe-card[data-league="mlb"] { border-top: 3px solid rgba(200, 60, 60, 0.55); }
      .vibe-card[data-league="nba"] { border-top: 3px solid rgba(200, 100, 20, 0.55); }
      .vibe-card[data-league="nhl"] { border-top: 3px solid rgba(80, 150, 210, 0.55); }
      .vibe-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 8px;
      }
      .vibe-name {
        font-family: 'Oswald', sans-serif;
        font-size: 1.05rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        color: rgba(245, 230, 208, 0.95);
        text-transform: uppercase;
      }
      .vibe-emoji {
        font-size: 1rem;
        line-height: 1;
        opacity: 0.75;
      }
      .vibe-tagline {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.05em;
        color: rgba(210, 170, 110, 0.55);
        line-height: 1.5;
        font-style: italic;
        margin-top: -4px;
      }
      .vibe-rows {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-top: 4px;
      }
      .vibe-row {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .vibe-row-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 9px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(210, 170, 110, 0.35);
      }
      .vibe-row-value {
        font-size: 12px;
        line-height: 1.5;
        color: rgba(245, 230, 208, 0.75);
      }
      .vibe-row-value strong {
        color: rgba(245, 230, 208, 0.95);
        font-weight: 600;
      }
      .vibe-foot {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.04em;
        color: rgba(210, 170, 110, 0.32);
        text-align: center;
        margin-top: 12px;
        line-height: 1.6;
      }

      /* ── Starter team kits ── */
      .packs-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
      }
      @media (max-width: 640px) {
        .packs-grid { grid-template-columns: 1fr; }
      }
      .pack-card {
        background: rgba(255, 255, 255, 0.025);
        border: 1px solid rgba(210, 170, 110, 0.12);
        border-radius: 12px;
        padding: 13px 14px 14px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        position: relative;
      }
      .pack-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 28px;
        height: 3px;
        background: linear-gradient(90deg, rgba(200, 60, 60, 0.6), rgba(200, 100, 20, 0.6), rgba(80, 150, 210, 0.6));
        border-radius: 12px 0 12px 0;
      }
      .pack-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 8px;
      }
      .pack-name {
        font-family: 'Oswald', sans-serif;
        font-size: 0.95rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        color: rgba(245, 230, 208, 0.95);
        text-transform: uppercase;
        line-height: 1.1;
      }
      .pack-count {
        font-family: 'JetBrains Mono', monospace;
        font-size: 9px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(210, 170, 110, 0.4);
        white-space: nowrap;
      }
      .pack-tag {
        font-family: 'JetBrains Mono', monospace;
        font-size: 9px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: rgba(210, 170, 110, 0.55);
        font-style: italic;
      }
      .pack-body {
        font-size: 12px;
        line-height: 1.55;
        color: rgba(245, 230, 208, 0.72);
      }
      .pack-body strong {
        color: rgba(245, 230, 208, 0.95);
        font-weight: 600;
      }

      /* ── Example schedule preview ── */
      .example-eyebrow {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 12px;
      }
      .example-eyebrow-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(210, 170, 110, 0.35);
      }
      .example-eyebrow-tag {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(180, 120, 50, 0.45);
        padding: 2px 8px;
        border: 1px solid rgba(180, 120, 50, 0.18);
        border-radius: 4px;
        background: rgba(180, 120, 50, 0.05);
      }
      .example-day {
        background: #111D32;
        border-radius: 16px;
        padding: 18px 20px;
        margin-bottom: 12px;
        position: relative;
        border-left: 4px solid #1a2744;
      }
      .example-day-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 12px;
      }
      .example-day-label {
        font-family: 'Oswald', sans-serif;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: rgba(255, 255, 255, 0.7);
      }
      .example-day-date {
        margin-left: 8px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        font-weight: 400;
        text-transform: none;
        letter-spacing: 0;
        color: rgba(255, 255, 255, 0.25);
      }
      .example-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 999px;
        background: rgba(34, 197, 94, 0.15);
        color: #22c55e;
        border: 1px solid rgba(34, 197, 94, 0.3);
      }
      .example-status-dot {
        display: inline-block;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #22c55e;
        animation: activePulse 2s ease-in-out infinite;
      }
      .example-game-name {
        font-family: 'Oswald', sans-serif;
        font-size: 1.25rem;
        font-weight: 700;
        color: #fff;
        line-height: 1.2;
      }
      .example-meta-row {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 8px;
      }
      .example-time {
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        color: rgba(255, 255, 255, 0.5);
      }
      .example-team-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 600;
      }
      .example-team-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
      }
      .example-broadcast {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        font-weight: 500;
        padding: 2px 8px;
        border-radius: 4px;
        background: rgba(255, 255, 255, 0.07);
        color: rgba(255, 255, 255, 0.45);
        border: 1px solid rgba(255, 255, 255, 0.1);
      }
      .example-score-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 10px;
        padding: 8px 14px;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
      }
      .example-score-team {
        display: flex;
        align-items: center;
        gap: 8px;
        flex: 1;
      }
      .example-score-team--home { justify-content: flex-end; }
      .example-score-abbr {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.35);
        min-width: 28px;
      }
      .example-score-num {
        font-family: 'Oswald', sans-serif;
        font-size: 18px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.9);
      }
      .example-score-num--losing { color: rgba(255, 255, 255, 0.35); }
      .example-score-dash {
        color: rgba(255, 255, 255, 0.15);
        font-size: 12px;
      }
      .example-also {
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
      }
      .example-also-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.2);
        margin-bottom: 6px;
      }
      .example-also-row {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
      }
      .example-also-name {
        font-family: 'Oswald', sans-serif;
        font-size: 13px;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.5);
      }
      .example-also-time {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        color: rgba(255, 255, 255, 0.3);
      }
      .example-empty-day {
        background: #0f1a2e;
        border-left-color: #1a2744;
      }
      .example-empty-msg {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.35);
      }
      .example-overlay-tag {
        position: absolute;
        top: 12px;
        right: 12px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 9px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(180, 120, 50, 0.5);
        padding: 2px 6px;
        background: rgba(13, 17, 23, 0.6);
        border-radius: 3px;
      }
      .example-footnote {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        color: rgba(210, 170, 110, 0.3);
        text-align: center;
        margin-top: 10px;
        line-height: 1.6;
      }

      /* ── Year in WTWTW ── */
      .year-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 8px;
      }
      @media (max-width: 760px) {
        .year-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      }
      @media (max-width: 380px) {
        .year-grid { grid-template-columns: minmax(0, 1fr); }
      }
      .year-card {
        background: rgba(255, 255, 255, 0.025);
        border: 1px solid rgba(210, 170, 110, 0.12);
        border-radius: 10px;
        padding: 11px 12px 12px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        min-height: 172px;
      }
      .year-card--peak {
        background: rgba(180, 120, 50, 0.06);
        border-color: rgba(180, 120, 50, 0.28);
      }
      .year-card--quiet {
        opacity: 0.78;
      }
      .year-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 6px;
      }
      .year-month {
        font-family: 'Oswald', sans-serif;
        font-size: 0.92rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        color: rgba(245, 230, 208, 0.95);
        text-transform: uppercase;
        line-height: 1;
      }
      .year-tag {
        font-family: 'JetBrains Mono', monospace;
        font-size: 8.5px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: rgba(180, 120, 50, 0.55);
        white-space: nowrap;
      }
      .year-card--peak .year-tag {
        color: rgba(230, 175, 95, 0.95);
      }
      .year-leagues {
        display: flex;
        flex-direction: column;
        gap: 5px;
      }
      .year-league {
        display: grid;
        grid-template-columns: 28px 24px minmax(0, 1fr);
        align-items: center;
        gap: 6px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 9.5px;
        letter-spacing: 0.04em;
      }
      .year-league-name {
        text-transform: uppercase;
        font-weight: 700;
        color: rgba(245, 230, 208, 0.55);
      }
      .year-league[data-league="mlb"] .year-league-name { color: rgba(220, 100, 90, 0.9); }
      .year-league[data-league="nba"] .year-league-name { color: rgba(220, 140, 60, 0.9); }
      .year-league[data-league="nhl"] .year-league-name { color: rgba(110, 170, 220, 0.9); }
      .year-pips {
        display: inline-flex;
        gap: 2px;
        justify-content: flex-start;
      }
      .year-pip {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: rgba(245, 230, 208, 0.1);
      }
      .year-league[data-league="mlb"] .year-pip--on { background: rgba(220, 100, 90, 0.55); }
      .year-league[data-league="mlb"] .year-pip--peak { background: rgba(220, 100, 90, 0.95); }
      .year-league[data-league="nba"] .year-pip--on { background: rgba(220, 140, 60, 0.55); }
      .year-league[data-league="nba"] .year-pip--peak { background: rgba(220, 140, 60, 0.95); }
      .year-league[data-league="nhl"] .year-pip--on { background: rgba(110, 170, 220, 0.55); }
      .year-league[data-league="nhl"] .year-pip--peak { background: rgba(110, 170, 220, 0.95); }
      .year-league-label {
        font-size: 9.5px;
        line-height: 1.3;
        color: rgba(245, 230, 208, 0.5);
        word-break: break-word;
      }
      .year-marquee {
        margin-top: auto;
        padding-top: 8px;
