---
import BaseLayout from "../layouts/BaseLayout.astro";
import WTWTW from "../components/WTWTW.tsx";
const title = "WTWTW — stanwood.dev";
---

<BaseLayout
  title={title}
  description="Pick your favorite teams across MLB, NBA, and NHL, and get a nightly recommendation for the best game worth watching. Scores, matchups, and drama — ranked live."
  slug="wtwtw"
  favicon="/favicon-wtwtw.svg"
  themeColor="#0d1117"
  fontsUrl="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
  schemaCategory="SportsApplication"
  schemaName="What To Watch This Week"
>
  <Fragment slot="head">
    <style>
      body {
        font-family: 'Inter', system-ui, sans-serif;
        background: #0d1117;
        min-height: 100vh;
        position: relative;
        color: #f0e6d6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* warm ambient glow from above */
      body::before {
        content: '';
        position: fixed;
        top: -30%;
        left: 50%;
        transform: translateX(-50%);
        width: 140%;
        height: 70%;
        background: radial-gradient(ellipse, rgba(180, 120, 50, 0.08) 0%, rgba(120, 80, 30, 0.04) 40%, transparent 70%);
        pointer-events: none;
        z-index: 0;
      }

      main { position: relative; z-index: 1; }

      .oswald { font-family: 'Oswald', sans-serif; }
      .mono { font-family: 'JetBrains Mono', monospace; }

      /* hero image container */
      .wtwtw-hero {
        position: relative;
        width: 100%;
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 2rem;
        aspect-ratio: 21 / 9;
        box-shadow:
          0 4px 30px rgba(180, 120, 50, 0.12),
          0 0 60px rgba(180, 120, 50, 0.06);
      }

      .wtwtw-hero img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      /* gradient overlay on hero */
      .wtwtw-hero::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to bottom,
          rgba(13, 17, 23, 0) 0%,
          rgba(13, 17, 23, 0.15) 40%,
          rgba(13, 17, 23, 0.7) 75%,
          rgba(13, 17, 23, 0.95) 100%
        );
        pointer-events: none;
      }

      /* hero title overlay */
      .wtwtw-hero-title {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 2;
        padding: 1.5rem 1.5rem 1.25rem;
      }

      .wtwtw-hero-title h1 {
        font-family: 'Oswald', sans-serif;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #f5e6d0;
        text-shadow: 0 2px 20px rgba(180, 120, 50, 0.3);
      }

      .wtwtw-hero-subtitle {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(210, 170, 110, 0.6);
        margin-top: 0.25rem;
      }

      /* warm vignette at page edges */
      body::after {
        content: '';
        position: fixed;
        inset: 0;
        background: radial-gradient(ellipse at center, transparent 50%, rgba(13, 17, 23, 0.4) 100%);
        pointer-events: none;
        z-index: 0;
      }

      /* staggered entrance for schedule cards */
      @keyframes fadeSlideIn {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      @keyframes heroFadeIn {
        from { opacity: 0; transform: scale(1.02); }
        to   { opacity: 1; transform: scale(1); }
      }

      .wtwtw-hero {
        animation: heroFadeIn 1s ease-out both;
      }

      /* ── League badges ── */
      .league-badge {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.1em;
        padding: 4px 10px;
        border-radius: 4px;
        border: 1px solid rgba(210, 170, 110, 0.2);
        color: rgba(210, 170, 110, 0.55);
        background: rgba(210, 170, 110, 0.06);
      }
      .league-badge[data-league="mlb"] { border-color: rgba(200, 60, 60, 0.3); color: rgba(220, 100, 90, 0.7); background: rgba(200, 60, 60, 0.06); }
      .league-badge[data-league="nba"] { border-color: rgba(200, 100, 20, 0.3); color: rgba(220, 140, 60, 0.7); background: rgba(200, 100, 20, 0.06); }
      .league-badge[data-league="nhl"] { border-color: rgba(80, 150, 210, 0.3); color: rgba(110, 170, 220, 0.7); background: rgba(80, 150, 210, 0.06); }

      @keyframes activePulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.4; transform: scale(0.8); }
      }

      /* ── How it works ── */
      .how-it-works {
        border: 1px solid rgba(210, 170, 110, 0.1);
        border-radius: 10px;
        padding: 18px 20px;
        background: rgba(255, 255, 255, 0.02);
      }
      .how-steps {
        display: flex;
        flex-direction: column;
        gap: 14px;
      }
      .how-step {
        display: flex;
        align-items: flex-start;
        gap: 14px;
      }
      .how-num {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        font-weight: 700;
        color: rgba(210, 170, 110, 0.3);
        letter-spacing: 0.05em;
        padding-top: 2px;
        flex-shrink: 0;
        width: 20px;
      }
      .how-title {
        font-family: 'Oswald', sans-serif;
        font-size: 14px;
        font-weight: 600;
        color: rgba(245, 230, 208, 0.75);
        margin-bottom: 2px;
      }
      .how-body {
        font-size: 12px;
        color: rgba(210, 170, 110, 0.4);
        line-height: 1.5;
      }

      /* ── Three leagues, three vibes ── */
      .vibes-eyebrow {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 14px;
      }
      .vibes-eyebrow-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(210, 170, 110, 0.35);
      }
      .vibes-eyebrow-tag {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(180, 120, 50, 0.45);
        padding: 2px 8px;
        border: 1px solid rgba(180, 120, 50, 0.18);
        border-radius: 4px;
        background: rgba(180, 120, 50, 0.05);
      }
      .vibes-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
      }
      @media (max-width: 640px) {
        .vibes-grid { grid-template-columns: 1fr; }
      }
      .vibe-card {
        background: rgba(255, 255, 255, 0.025);
        border: 1px solid rgba(210, 170, 110, 0.12);
        border-radius: 12px;
        padding: 14px 14px 16px;
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .vibe-card[data-league="mlb"] { border-top: 3px solid rgba(200, 60, 60, 0.55); }
      .vibe-card[data-league="nba"] { border-top: 3px solid rgba(200, 100, 20, 0.55); }
      .vibe-card[data-league="nhl"] { border-top: 3px solid rgba(80, 150, 210, 0.55); }
      .vibe-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 8px;
      }
      .vibe-name {
        font-family: 'Oswald', sans-serif;
        font-size: 1.05rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        color: rgba(245, 230, 208, 0.95);
        text-transform: uppercase;
      }
      .vibe-emoji {
        font-size: 1rem;
        line-height: 1;
        opacity: 0.75;
      }
      .vibe-tagline {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.05em;
        color: rgba(210, 170, 110, 0.55);
        line-height: 1.5;
        font-style: italic;
        margin-top: -4px;
      }
      .vibe-rows {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-top: 4px;
      }
      .vibe-row {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .vibe-row-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 9px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(210, 170, 110, 0.35);
      }
      .vibe-row-value {
        font-size: 12px;
        line-height: 1.5;
        color: rgba(245, 230, 208, 0.75);
      }
      .vibe-row-value strong {
        color: rgba(245, 230, 208, 0.95);
        font-weight: 600;
      }
      .vibe-foot {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.04em;
        color: rgba(210, 170, 110, 0.32);
        text-align: center;
        margin-top: 12px;
        line-height: 1.6;
      }

      /* ── Example schedule preview ── */
      .example-eyebrow {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 12px;
      }
      .example-eyebrow-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(210, 170, 110, 0.35);
      }
      .example-eyebrow-tag {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(180, 120, 50, 0.45);
        padding: 2px 8px;
        border: 1px solid rgba(180, 120, 50, 0.18);
        border-radius: 4px;
        background: rgba(180, 120, 50, 0.05);
      }
      .example-day {
        background: #111D32;
        border-radius: 16px;
        padding: 18px 20px;
        margin-bottom: 12px;
        position: relative;
        border-left: 4px solid #1a2744;
      }
      .example-day-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 12px;
      }
      .example-day-label {
        font-family: 'Oswald', sans-serif;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: rgba(255, 255, 255, 0.7);
      }
      .example-day-date {
        margin-left: 8px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        font-weight: 400;
        text-transform: none;
        letter-spacing: 0;
        color: rgba(255, 255, 255, 0.25);
      }
      .example-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 999px;
        background: rgba(34, 197, 94, 0.15);
        color: #22c55e;
        border: 1px solid rgba(34, 197, 94, 0.3);
      }
      .example-status-dot {
        display: inline-block;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #22c55e;
        animation: activePulse 2s ease-in-out infinite;
      }
      .example-status--scheduled {
        background: rgba(255, 255, 255, 0.05);
        color: rgba(255, 255, 255, 0.4);
        border-color: rgba(255, 255, 255, 0.1);
      }
      .example-game-name {
        font-family: 'Oswald', sans-serif;
        font-size: 1.25rem;
        font-weight: 700;
        color: #fff;
        line-height: 1.2;
      }
      .example-meta-row {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 8px;
      }
      .example-time {
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        color: rgba(255, 255, 255, 0.5);
      }
      .example-team-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 600;
      }
      .example-team-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
      }
      .example-broadcast {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        font-weight: 500;
        padding: 2px 8px;
        border-radius: 4px;
        background: rgba(255, 255, 255, 0.07);
        color: rgba(255, 255, 255, 0.45);
        border: 1px solid rgba(255, 255, 255, 0.1);
      }
      .example-score-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 10px;
        padding: 8px 14px;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
      }
      .example-score-team {
        display: flex;
        align-items: center;
        gap: 8px;
        flex: 1;
      }
      .example-score-team--home { justify-content: flex-end; }
      .example-score-abbr {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.35);
        min-width: 28px;
      }
      .example-score-num {
        font-family: 'Oswald', sans-serif;
        font-size: 18px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.9);
      }
      .example-score-num--losing { color: rgba(255, 255, 255, 0.35); }
      .example-score-dash {
        color: rgba(255, 255, 255, 0.15);
        font-size: 12px;
      }
      .example-also {
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
      }
      .example-also-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.2);
        margin-bottom: 6px;
      }
      .example-also-row {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
      }
      .example-also-name {
        font-family: 'Oswald', sans-serif;
        font-size: 13px;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.5);
      }
      .example-also-time {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        color: rgba(255, 255, 255, 0.3);
      }
      .example-empty-day {
        background: #0f1a2e;
        border-left-color: #1a2744;
      }
      .example-empty-msg {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.35);
      }
      .example-overlay-tag {
        position: absolute;
        top: 12px;
        right: 12px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 9px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(180, 120, 50, 0.5);
        padding: 2px 6px;
        background: rgba(13, 17, 23, 0.6);
        border-radius: 3px;
      }
      .example-footnote {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        color: rgba(210, 170, 110, 0.3);
        text-align: center;
        margin-top: 10px;
        line-height: 1.6;
      }
    </style>
  </Fragment>

  <a href="#main-content" class="skip-nav">Skip to content</a>
  <main id="main-content" class="mx-auto max-w-2xl px-6 pt-16 pb-24">
    <div class="flex items-center">
      <a
        href="/"
        class="retro-back"
      >
        &larr; stanwood.dev
      </a>
    </div>

    <!-- Hero banner -->
    <div class="wtwtw-hero mt-8">
      <img
        src="/images/wtwtw.webp"
        alt="A cozy living room at night with a massive TV showing a stadium, sports memorabilia, and warm ambient lighting"
        loading="lazy"
        decoding="async"
        width="1200"
        height="514"
      />
      <div class="wtwtw-hero-title">
        <h1 class="text-5xl sm:text-6xl">WTWTW</h1>
        <p class="wtwtw-hero-subtitle">What to Watch This Week</p>
      </div>
    </div>

    <!-- Description -->
    <p class="oswald text-sm leading-relaxed mb-6" style="color: rgba(210,170,110,0.55);">
      Pick up to 10 teams across MLB, NBA, and NHL. Every day this week, WTWTW surfaces the one game most worth watching — ranked by how much you care about the teams playing. No noise, just tonight's pick.
    </p>

    <!-- League badges -->
    <div class="flex gap-2 mb-6 flex-wrap">
      <span class="league-badge" data-league="mlb">MLB</span>
      <span class="league-badge" data-league="nba">NBA</span>
      <span class="league-badge" data-league="nhl">NHL</span>
    </div>

    <!-- How it works -->
    <div class="how-it-works mb-8">
      <p class="mono text-xs mb-3" style="color: rgba(210,170,110,0.35); letter-spacing: 0.1em; text-transform: uppercase;">How it works</p>
      <div class="how-steps">
        <div class="how-step">
          <span class="how-num">01</span>
          <div>
            <p class="how-title">Pick your teams</p>
            <p class="how-body">Choose up to 10 teams you actually care about — sorted by priority.</p>
          </div>
        </div>
        <div class="how-step">
          <span class="how-num">02</span>
          <div>
            <p class="how-title">We pull the schedule</p>
            <p class="how-body">Games from 5 PM to 11:30 PM are fetched live from ESPN for the next 7 days.</p>
          </div>
        </div>
        <div class="how-step">
          <span class="how-num">03</span>
          <div>
            <p class="how-title">7 nights, ranked</p>
            <p class="how-body">One pick per night for the next week — your highest-priority team with a game that evening wins the slot. Drag your team list to change the ranking.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- What's on now -->
    <div class="how-it-works mb-8" style="border-color: rgba(34,197,94,0.2); background: rgba(34,197,94,0.04);">
      <div class="flex items-center gap-2 mb-3">
        <span class="mono text-xs" style="color: rgba(34,197,94,0.6); letter-spacing: 0.1em; text-transform: uppercase;">Active right now</span>
        <span style="display:inline-block; width:7px; height:7px; border-radius:50%; background:#22c55e; animation: activePulse 2s ease-in-out infinite;"></span>
      </div>
      <div class="flex gap-2 flex-wrap">
        <span class="league-badge" data-league="mlb">MLB regular season</span>
        <span class="league-badge" data-league="nba">NBA playoffs</span>
        <span class="league-badge" data-league="nhl">NHL playoffs</span>
      </div>
      <p class="mono" style="font-size: 11px; color: rgba(210,170,110,0.3); margin-top: 10px; line-height: 1.5;">All three leagues are in season simultaneously — prime time for WTWTW.</p>
    </div>

    <!-- Three leagues, three vibes -->
    <section class="mb-8" aria-label="What each league feels like to watch">
      <div class="vibes-eyebrow">
        <span class="vibes-eyebrow-label">Three leagues, three vibes</span>
        <span class="vibes-eyebrow-tag">cross-sport guide</span>
      </div>
      <p class="text-xs leading-relaxed mb-4" style="color: rgba(210, 170, 110, 0.5);">
        Picking teams across leagues you don't follow as closely? Here's what you're signing up for when WTWTW puts each one on your screen.
      </p>

      <div class="vibes-grid">
        <!-- MLB -->
        <article class="vibe-card" data-league="mlb">
          <div class="vibe-head">
            <span class="vibe-name">MLB</span>
            <span class="vibe-emoji" aria-hidden="true">⚾</span>
          </div>
          <p class="vibe-tagline">slow burn, late spike</p>
          <div class="vibe-rows">
            <div class="vibe-row">
              <span class="vibe-row-label">Length</span>
              <span class="vibe-row-value">~3 hrs · extras can run long</span>
            </div>
            <div class="vibe-row">
              <span class="vibe-row-label">Score range</span>
              <span class="vibe-row-value">2–8 runs · <strong>1-run finishes are common</strong></span>
            </div>
            <div class="vibe-row">
              <span class="vibe-row-label">Drama beats</span>
              <span class="vibe-row-value">Late innings, runners on with two outs, walk-off range</span>
            </div>
            <div class="vibe-row">
              <span class="vibe-row-label">Rhythm</span>
              <span class="vibe-row-value">Breath between pitches — lets the tension build</span>
            </div>
            <div class="vibe-row">
              <span class="vibe-row-label">Where it lives</span>
              <span class="vibe-row-value">ESPN, FOX, Apple TV+, MLB.tv, regional networks (YES, SNLA)</span>
            </div>
          </div>
        </article>

        <!-- NBA -->
        <article class="vibe-card" data-league="nba">
          <div class="vibe-head">
            <span class="vibe-name">NBA</span>
            <span class="vibe-emoji" aria-hidden="true">🏀</span>
          </div>
          <p class="vibe-tagline">closing minutes are the show</p>
          <div class="vibe-rows">
            <div class="vibe-row">
              <span class="vibe-row-label">Length</span>
              <span class="vibe-row-value">~2.5 hrs · 5-min OT each round</span>
            </div>
            <div class="vibe-row">
              <span class="vibe-row-label">Score range</span>
              <span class="vibe-row-value">95–125 a side · <strong>blowouts split from nail-biters early</strong></span>
            </div>
            <div class="vibe-row">
              <span class="vibe-row-label">Drama beats</span>
              <span class="vibe-row-value">Last 5 min of Q4 — clutch time. Free throws, full timeouts, intentional fouls</span>
            </div>
            <div class="vibe-row">
              <span class="vibe-row-label">Rhythm</span>
              <span class="vibe-row-value">Constant scoring, TV breaks every few minutes</span>
            </div>
            <div class="vibe-row">
              <span class="vibe-row-label">Where it lives</span>
              <span class="vibe-row-value">ESPN, ABC, TNT, NBA TV; playoffs go national</span>
            </div>
          </div>
        </article>

        <!-- NHL -->
        <article class="vibe-card" data-league="nhl">
          <div class="vibe-head">
            <span class="vibe-name">NHL</span>
            <span class="vibe-emoji" aria-hidden="true">🏒</span>
          </div>
          <p class="vibe-tagline">tight all night, sudden death</p>
          <div class="vibe-rows">
            <div class="vibe-row">
              <span class="vibe-row-label">Length</span>
