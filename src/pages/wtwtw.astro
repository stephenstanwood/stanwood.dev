    <script is:inline define:vars={{ PHASES }}>
      // Re-check against the viewer's current month so the badges stay accurate
      // between deploys (the server-rendered version uses the build month).
      const month = new Date().getMonth() + 1;
      const active = Object.entries(PHASES).filter(([, m]) => m[month]);
      const badges = document.getElementById("active-leagues");
      const note = document.getElementById("active-leagues-note");
      if (badges && note) {
        badges.innerHTML = active
          .map(([league, m]) => `<span class="league-badge" data-league="${league}">${m[month]}</span>`)
          .join("");
        note.textContent =
          active.length === 3
            ? "All three leagues are live right now — prime time for WTWTW."
            : active.length === 2
              ? "Two of the three leagues are in season right now."
              : active.length === 1
                ? `Only the ${active[0][0].toUpperCase()} is going right now — the nightly pick pulls from one league until the others tip off.`
                : "Between seasons right now — check back when the leagues tip off.";
      }
    </script>

