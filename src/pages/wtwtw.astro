---
import "../styles/global.css";
import WTWTW from "../components/WTWTW.tsx";
const title = "WTWTW — stanwood.dev";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta
      name="description"
      content="What To Watch This Week — Pick your teams and get the best game to watch each night."
    />
    <meta property="og:title" content="WTWTW — stanwood.dev" />
    <meta property="og:description" content="What To Watch This Week — Pick your teams and get the best game to watch each night." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://stanwood.dev/wtwtw" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="WTWTW — stanwood.dev" />
    <meta name="twitter:description" content="What To Watch This Week — Pick your teams and get the best game to watch each night." />
    <link rel="canonical" href="https://stanwood.dev/wtwtw" />
    <link rel="icon" type="image/svg+xml" href="/favicon-wtwtw.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: 'Inter', system-ui, sans-serif;
        background: #0A1628;
        min-height: 100vh;
        position: relative;
      }

      /* subtle radial glow */
      body::before {
        content: '';
        position: fixed;
        top: -20%;
        left: 50%;
        transform: translateX(-50%);
        width: 120%;
        height: 60%;
        background: radial-gradient(ellipse, rgba(29, 66, 138, 0.15) 0%, transparent 70%);
        pointer-events: none;
        z-index: 0;
      }

      main { position: relative; z-index: 1; }

      .oswald { font-family: 'Oswald', sans-serif; }
      .mono { font-family: 'JetBrains Mono', monospace; }

      /* staggered entrance for schedule cards */
      @keyframes fadeSlideIn {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
      }
    </style>
  </head>

  <body class="text-white antialiased">
    <a href="#main-content" class="skip-nav">Skip to content</a>
    <main id="main-content" class="mx-auto max-w-2xl px-6 pt-16 pb-24">
      <div class="flex items-center">
        <a
          href="/"
          class="text-sm font-medium text-white/30 hover:text-white transition-colors"
        >
          &larr; Home
        </a>
      </div>

      <header class="mt-10">
        <h1 class="text-5xl sm:text-6xl font-bold tracking-tight text-white oswald uppercase">
          WTWTW
        </h1>
      </header>

      <WTWTW client:idle />
    </main>
  </body>
</html>
