---
import BaseLayout from "../layouts/BaseLayout.astro";
import WTWTW from "../components/WTWTW.tsx";
const title = "WTWTW — stanwood.dev";
---

<BaseLayout
  title={title}
  description="Pick your teams and get the best game to watch each night."
  slug="wtwtw"
  favicon="/favicon-wtwtw.svg"
  themeColor="#111318"
  fontsUrl="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
  schemaCategory="SportsApplication"
  schemaName="What To Watch This Week"
>
  <Fragment slot="head">
    <style>
      body {
        font-family: 'Inter', system-ui, sans-serif;
        background: #0A1628;
        min-height: 100vh;
        position: relative;
        color: white;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* subtle radial glow */
      body::before {
        content: '';
        position: fixed;
        top: -20%;
        left: 50%;
        transform: translateX(-50%);
        width: 120%;
        height: 60%;
        background: radial-gradient(ellipse, rgba(29, 66, 138, 0.15) 0%, transparent 70%);
        pointer-events: none;
        z-index: 0;
      }

      main { position: relative; z-index: 1; }

      .oswald { font-family: 'Oswald', sans-serif; }
      .mono { font-family: 'JetBrains Mono', monospace; }

      /* staggered entrance for schedule cards */
      @keyframes fadeSlideIn {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
      }
    </style>
  </Fragment>

  <a href="#main-content" class="skip-nav">Skip to content</a>
  <main id="main-content" class="mx-auto max-w-2xl px-6 pt-16 pb-24">
    <div class="flex items-center">
      <a
        href="/"
        class="retro-back"
      >
        &larr; stanwood.dev
      </a>
    </div>

    <header class="mt-10">
      <h1 class="text-5xl sm:text-6xl font-bold tracking-tight text-white oswald uppercase">
        WTWTW
      </h1>
    </header>

    <WTWTW client:idle />
  </main>
</BaseLayout>
