      .wm-dir-sort {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: 13px;
        font-weight: 600;
        padding: 6px 28px 6px 12px;
        border: 1.5px solid var(--wm-ink);
        background: var(--wm-bg);
        color: var(--wm-ink);
        border-radius: 6px;
        cursor: pointer;
        appearance: none;
        -webkit-appearance: none;
        background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%23111' stroke-width='1.5' fill='none' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
        background-repeat: no-repeat;
        background-position: right 10px center;
      }
      .wm-dir-sort:focus {
        outline: 2px solid var(--wm-purple);
        outline-offset: 1px;
      }

      .wm-dir-sort-hint {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        color: var(--wm-light);
      }

      .wm-dir-count {
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        color: var(--wm-muted);
        margin: 0 0 14px;
        padding-left: 4px;
      }
      .wm-dir-count strong {
        color: var(--wm-ink);
        font-weight: 700;
      }

      .wm-dir-empty {
        text-align: center;
        font-size: 14px;
        color: var(--wm-muted);
        padding: 32px 0;
        font-family: 'Space Mono', monospace;
      }

      /* ─── Responsive ──────────────────────────────────────────── */
      @media (max-width: 600px) {
        .wm-paths {
          grid-template-columns: 1fr;
        }

        .wm-quiz-options {
          flex-direction: column;
        }

        .wm-quiz-or {
          display: none;
        }

        .wm-quiz-card {
          padding: 24px 16px;
          width: 100%;
        }

        .wm-primary-top {
          flex-wrap: wrap;
        }

        .wm-fit-badge {
          margin-left: 0;
        }

        .wm-primary-lists {
          grid-template-columns: 1fr;
        }

        .wm-alt-grid {
          grid-template-columns: 1fr;
        }

        .wm-care-item {
          flex-wrap: wrap;
          gap: 4px;
        }

        .wm-care-trait {
          min-width: auto;
        }

        .wm-title {
          font-size: 48px;
        }

        .wm-quiz-prompt {
          font-size: 28px;
        }

        .wm-section-title {
          font-size: 28px;
        }

        .wm-directory { padding: 0 16px 40px; }
        .wm-directory-grid { grid-template-columns: 1fr; }
        .wm-trait-row { grid-template-columns: 70px 1fr 18px; gap: 6px; }
        .wm-dir-controls-label { min-width: auto; }
        .wm-dir-chip { font-size: 11.5px; padding: 5px 9px; }
        .wm-mod-sortbadge-num { font-size: 20px; }
      }

    </style>
  </Fragment>

  <WhichModelApp client:idle />

  <BrowseDirectory client:visible />
