---
import BaseLayout from "../layouts/BaseLayout.astro";
import { MODELS } from "../lib/whichModel/models";
import { TRAIT_LABELS, type ModelProfile, type Trait } from "../lib/whichModel/types";
const title = "Which Model? — stanwood.dev";

const CARD_TRAITS: Trait[] = [
  "reasoning",
  "coding",
  "writing",
  "speed",
  "cost",
  "long_context",
];

const IMAGE_CARD_TRAITS: Trait[] = [
  "image_gen",
  "image_understanding",
  "speed",
  "cost",
  "open_source",
  "ecosystem",
];

function isImageModel(model: ModelProfile): boolean {
  return model.traits.image_gen >= 7 && model.traits.writing === 0;
}

function scoreLabel(score: number): string {
  if (score >= 9) return "elite";
  if (score >= 7) return "strong";
  if (score >= 5) return "solid";
  if (score >= 3) return "okay";
  if (score >= 1) return "weak";
  return "n/a";
}

function scorePct(score: number): number {
  return Math.min(100, score * 10);
}

function highlightTrait(model: ModelProfile): Trait {
  return isImageModel(model) ? "image_gen" : "reasoning";
}

const directoryModels = [...MODELS].sort((a, b) => {
  const diff = b.traits[highlightTrait(b)] - a.traits[highlightTrait(a)];
  if (diff !== 0) return diff;
  return a.name.localeCompare(b.name);
});
---

<BaseLayout
  title={title}
  description="Stop overthinking which AI model to use. Describe your task and get a straight answer across the major model families. Updated regularly, zero jargon."
  slug="which-model"
  favicon="/favicon-which-model.svg"
  themeColor="#fffdf5"
  fontsUrl="https://fonts.googleapis.com/css2?family=Bangers&family=Space+Grotesk:wght@400;500;600;700&display=swap"
  schemaCategory="UtilitiesApplication"
  schemaName="Which Model?"
>
  <Fragment slot="head">
    <style is:global>
      /* ─── Page Theme ─────────────────────────────────────────────── */
      :root {
        --wm-bg: #fffdf5;
        --wm-card: #ffffff;
        --wm-ink: #111;
        --wm-muted: #666;
        --wm-light: #999;
        --wm-gold: #f5c542;
        --wm-purple: #7c5cff;
        --wm-coral: #ff6b4a;
        --wm-border: #e5e2d9;
        --wm-shadow: 3px 3px 0 #111;
        --wm-shadow-sm: 2px 2px 0 #111;
      }

      body {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        background: var(--wm-bg);
        color: var(--wm-ink);
        margin: 0;
        -webkit-font-smoothing: antialiased;
      }

      astro-island {
        display: contents;
      }

      /* ─── Layout ───────────────────────────────────────────────── */
      .wm-page {
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
      }

      .wm-header {
        padding: 16px 24px;
      }

      .wm-back-home {
        font-family: 'Space Mono', monospace;
        font-size: 13px;
        color: var(--wm-muted);
        text-decoration: none;
      }
      .wm-back-home:hover {
        color: var(--wm-ink);
      }

      .wm-main {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding: 0 24px 48px;
      }

      .wm-footer {
        text-align: center;
        padding: 24px;
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        color: var(--wm-light);
        border-top: 1px solid var(--wm-border);
      }

      /* ─── Start Screen ────────────────────────────────────────── */
      .wm-start {
        max-width: 560px;
        width: 100%;
        padding-top: 48px;
        animation: wmFadeIn 0.3s ease;
      }

      .wm-hero {
        text-align: center;
        margin-bottom: 40px;
      }

      .wm-title {
        font-family: 'Bangers', cursive;
        font-size: clamp(48px, 10vw, 72px);
        letter-spacing: 2px;
        margin: 0;
        line-height: 1;
        color: var(--wm-ink);
      }

      .wm-subtitle {
        font-size: 17px;
        color: var(--wm-muted);
        margin: 12px 0 0;
        line-height: 1.5;
      }

      .wm-paths {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 40px;
      }

      .wm-path-card {
        background: var(--wm-card);
        border: 2px solid var(--wm-ink);
        box-shadow: var(--wm-shadow);
        border-radius: 8px;
        padding: 28px 20px;
        cursor: pointer;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        text-align: center;
        transition: transform 0.15s, box-shadow 0.15s;
        font-family: inherit;
        text-decoration: none;
        color: inherit;
      }
      .wm-path-card:hover {
        transform: translate(-2px, -2px);
        box-shadow: 5px 5px 0 #111;
      }
      .wm-path-card:active {
        transform: translate(1px, 1px);
        box-shadow: 1px 1px 0 #111;
      }

      .wm-path-emoji {
        font-size: 36px;
      }

      .wm-path-label {
        font-family: 'Bangers', cursive;
        font-size: 24px;
        letter-spacing: 1px;
      }

      .wm-path-desc {
        font-size: 14px;
        color: var(--wm-muted);
        line-height: 1.4;
      }

      .wm-examples {
        text-align: center;
      }

      .wm-examples-label {
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        color: var(--wm-light);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin: 0 0 12px;
      }

      .wm-example-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: center;
      }

      .wm-chip {
        font-size: 13px;
        padding: 6px 12px;
        border-radius: 20px;
        background: var(--wm-card);
        border: 1px solid var(--wm-border);
        color: var(--wm-muted);
      }

      /* ─── Animations ──────────────────────────────────────────── */
      @keyframes wmFadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: none; }
      }

      @media (prefers-reduced-motion: reduce) {
        .wm-start {
          animation: none !important;
        }
      }

      /* ─── Model Directory ─────────────────────────────────────── */
      .wm-directory {
        max-width: 880px;
        margin: 0 auto;
        padding: 0 24px 64px;
      }

      .wm-directory-head {
        text-align: center;
        margin-bottom: 28px;
        padding: 40px 0 24px;
        border-top: 2px dashed var(--wm-border);
      }

      .wm-directory-title {
        font-family: 'Bangers', cursive;
        font-size: clamp(30px, 6vw, 42px);
        letter-spacing: 1.5px;
        margin: 0 0 8px;
        color: var(--wm-ink);
        line-height: 1;
      }

      .wm-directory-sub {
        font-size: 14px;
        color: var(--wm-muted);
        max-width: 520px;
        margin: 0 auto;
        line-height: 1.55;
      }

      .wm-directory-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 14px;
      }

      .wm-mod-card {
        background: var(--wm-card);
        border: 2px solid var(--wm-ink);
        box-shadow: var(--wm-shadow-sm);
        border-radius: 8px;
        padding: 14px 16px 16px;
        border-top: 5px solid var(--mod-color, var(--wm-purple));
        display: flex;
        flex-direction: column;
        gap: 10px;
        position: relative;
      }

      .wm-mod-rank {
        position: absolute;
        top: -1px;
        right: 10px;
        font-family: 'Space Mono', monospace;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.08em;
        color: var(--wm-light);
        background: var(--wm-card);
        padding: 0 6px;
        line-height: 1;
        transform: translateY(-50%);
      }

      .wm-mod-head {
        display: flex;
        align-items: flex-start;
        gap: 10px;
      }

      .wm-mod-sortbadge {
        margin-left: auto;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 1px;
        flex-shrink: 0;
      }

      .wm-mod-sortbadge-num {
        font-family: 'Bangers', cursive;
        font-size: 22px;
        line-height: 1;
        color: var(--mod-color, var(--wm-ink));
        letter-spacing: 1px;
      }

      .wm-mod-sortbadge-label {
        font-family: 'Space Mono', monospace;
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--wm-light);
      }

      /* Trait bars */
      .wm-mod-traits {
        display: flex;
        flex-direction: column;
        gap: 4px;
        margin-top: 2px;
      }

      .wm-trait-row {
        display: grid;
        grid-template-columns: 80px 1fr 18px;
        align-items: center;
        gap: 8px;
      }

      .wm-trait-label {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        color: var(--wm-muted);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .wm-trait-track {
        height: 8px;
        background: var(--wm-bg);
        border: 1.5px solid var(--wm-ink);
        border-radius: 2px;
        overflow: hidden;
        position: relative;
      }

      .wm-trait-fill {
        height: 100%;
      }

      .wm-trait-score {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        font-weight: 700;
        color: var(--wm-ink);
        text-align: right;
      }

      .wm-trait-row--hot .wm-trait-label {
        color: var(--wm-ink);
        font-weight: 700;
      }
      .wm-trait-row--hot .wm-trait-track {
        border-color: var(--mod-color, var(--wm-ink));
      }
      .wm-trait-row--hot .wm-trait-score {
        color: var(--mod-color, var(--wm-ink));
      }

      .wm-mod-emoji {
        font-size: 22px;
        flex-shrink: 0;
        line-height: 1;
        margin-top: 2px;
      }

      .wm-mod-name {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: 15px;
        font-weight: 700;
        margin: 0;
        color: var(--wm-ink);
        line-height: 1.2;
      }

      .wm-mod-org {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        color: var(--wm-light);
        margin: 3px 0 0;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }

      .wm-mod-tag {
        font-size: 13px;
        color: var(--wm-ink);
        line-height: 1.45;
        margin: 0;
        font-style: italic;
      }

      .wm-mod-best {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
      }

      .wm-mod-best li {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        color: var(--wm-muted);
        background: var(--wm-bg);
        border: 1px solid var(--wm-border);
        padding: 2px 7px;
        border-radius: 999px;
      }

      .wm-directory-foot {
        text-align: center;
        font-size: 13px;
        color: var(--wm-muted);
        margin-top: 32px;
        padding-top: 18px;
        border-top: 1px solid var(--wm-border);
      }

      .wm-directory-foot a {
        color: var(--wm-coral);
        font-weight: 600;
      }

      .wm-dir-count {
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        color: var(--wm-muted);
        margin: 0 0 14px;
        padding-left: 4px;
      }
      .wm-dir-count strong {
        color: var(--wm-ink);
        font-weight: 700;
      }
      .wm-shift {
        border: 2px solid var(--wm-ink, #111);
        background: #fff;
        padding: 16px 18px;
        margin: 0 0 22px;
      }
      .wm-shift-title {
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin: 0 0 10px;
        color: var(--wm-ink, #111);
      }
      .wm-shift-foot {
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        margin: 0;
        color: var(--wm-muted, #6b6b6b);
      }
      .wm-shift-foot a {
        color: inherit;
        font-weight: 700;
      }

      /* ─── Quick Picks cheat sheet ─────────────────────────────── */
      .wm-quick {
        max-width: 1100px;
        width: 100%;
        margin: 0 auto;
        padding: 56px 24px 8px;
      }

      .wm-quick-head {
        text-align: center;
        margin-bottom: 28px;
      }

      .wm-quick-head h2 {
        font-family: 'Bangers', cursive;
        font-size: 38px;
        letter-spacing: 1.5px;
        color: var(--wm-ink);
        margin: 0 0 6px;
        line-height: 1;
      }

      .wm-quick-head p {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: 15px;
        color: var(--wm-muted);
        margin: 0;
        line-height: 1.5;
      }

      .wm-quick-head p strong {
        color: var(--wm-ink);
      }

      .wm-quick-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 14px;
      }

      @media (min-width: 800px) {
        .wm-quick-grid {
          grid-template-columns: repeat(4, 1fr);
        }
      }

      .wm-quick-card {
        background: var(--wm-card);
        border: 2px solid var(--wm-ink);
        border-left: 5px solid var(--card-color, var(--wm-gold));
        box-shadow: var(--wm-shadow-sm);
        border-radius: 8px;
        padding: 16px 16px 14px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        position: relative;
        transition: transform 0.12s ease, box-shadow 0.12s ease;
        min-width: 0;
        overflow: hidden;
      }
      .wm-quick-card:hover {
        transform: translate(-1px, -1px);
        box-shadow: 3px 3px 0 var(--wm-ink);
      }

      .wm-quick-task {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: 13px;
        font-weight: 600;
        color: var(--wm-ink);
        line-height: 1.35;
      }

      .wm-quick-task-icon {
        font-size: 18px;
        flex-shrink: 0;
        line-height: 1;
        margin-top: 1px;
      }

      .wm-quick-pick {
        background: var(--wm-bg);
        border: 1.5px solid var(--wm-border);
        border-radius: 6px;
        padding: 10px 12px;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .wm-quick-pick-emoji {
        font-size: 22px;
        line-height: 1;
        flex-shrink: 0;
      }

      .wm-quick-pick-body {
        display: flex;
        flex-direction: column;
        gap: 1px;
        min-width: 0;
        flex: 1;
      }

      .wm-quick-pick-name {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: 13px;
        font-weight: 700;
        color: var(--wm-ink);
        line-height: 1.15;
      }

      .wm-quick-pick-org {
        font-family: 'Space Mono', monospace;
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--wm-light);
      }

      .wm-quick-why {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: 12px;
        color: var(--wm-muted);
        line-height: 1.5;
        margin: 0;
        flex: 1;
      }

      .wm-quick-alt {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        color: var(--wm-light);
        margin: 0;
        padding-top: 8px;
        border-top: 1px dashed var(--wm-border);
        line-height: 1.4;
      }

      .wm-quick-alt span {
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-weight: 700;
        color: var(--wm-muted);
        margin-right: 4px;
      }

      .wm-quick-foot {
        text-align: center;
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        color: var(--wm-light);
        margin: 22px 0 0;
        line-height: 1.6;
      }

      .wm-quick-foot a {
        color: var(--wm-purple);
        text-decoration: underline;
        text-underline-offset: 2px;
        font-weight: 600;
      }

      .wm-quick-foot a:hover {
        color: var(--wm-coral);
      }

      /* ─── Decode the lingo ───────────────────────────────────── */
      .wm-decode {
        max-width: 1100px;
        width: 100%;
        margin: 0 auto;
        padding: 56px 24px 8px;
      }

      .wm-decode-head {
        text-align: center;
        margin-bottom: 26px;
      }

      .wm-decode-head h2 {
        font-family: 'Bangers', cursive;
        font-size: 38px;
        letter-spacing: 1.5px;
        color: var(--wm-ink);
        margin: 0 0 6px;
        line-height: 1;
      }

      .wm-decode-head p {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: 15px;
        color: var(--wm-muted);
        margin: 0;
        line-height: 1.5;
      }

      .wm-decode-head p strong {
        color: var(--wm-ink);
      }

      .wm-decode-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
      }

      @media (min-width: 600px) {
        .wm-decode-grid { grid-template-columns: repeat(2, 1fr); }
      }

      @media (min-width: 920px) {
        .wm-decode-grid { grid-template-columns: repeat(4, 1fr); }
      }

      .wm-decode-card {
        background: var(--wm-card);
        border: 2px solid var(--wm-ink);
        border-left: 5px solid var(--card-accent, var(--wm-purple));
        box-shadow: var(--wm-shadow-sm);
        border-radius: 8px;
        padding: 14px 14px 15px;
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-width: 0;
        transition: transform 0.12s ease, box-shadow 0.12s ease;
      }

      .wm-decode-card:hover {
        transform: translate(-1px, -1px);
        box-shadow: 3px 3px 0 var(--wm-ink);
      }

      .wm-decode-icon {
        font-size: 18px;
        line-height: 1;
        margin-bottom: 2px;
      }

      .wm-decode-term {
        font-family: 'Space Mono', monospace;
        font-size: 14px;
        font-weight: 700;
        color: var(--wm-ink);
        margin: 0;
        line-height: 1.15;
        letter-spacing: -0.01em;
      }

      .wm-decode-en {
        font-family: 'Space Mono', monospace;
        font-size: 9px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--wm-light);
        margin: 0 0 2px;
      }

      .wm-decode-meaning {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: 12.5px;
        color: var(--wm-muted);
        line-height: 1.55;
        margin: 0;
      }

      .wm-decode-example {
        font-family: 'Space Mono', monospace;
        font-size: 10.5px;
        color: var(--wm-ink);
        opacity: 0.78;
        line-height: 1.5;
        margin: 4px 0 0;
        padding-top: 8px;
        border-top: 1px dashed var(--wm-border);
      }

      .wm-decode-example::before {
        content: "in practice ";
        font-family: 'Space Mono', monospace;
        font-size: 8.5px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--wm-purple);
        margin-right: 4px;
      }

      .wm-decode-foot {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        color: var(--wm-light);
        text-align: center;
        margin: 22px auto 0;
        max-width: 540px;
        line-height: 1.6;
      }

      /* ─── Responsive ──────────────────────────────────────────── */
      @media (max-width: 600px) {
        .wm-paths {
          grid-template-columns: 1fr;
        }

        .wm-title {
          font-size: 48px;
        }

        .wm-directory { padding: 0 16px 40px; }
        .wm-directory-grid { grid-template-columns: 1fr; }
        .wm-trait-row { grid-template-columns: 70px 1fr 18px; gap: 6px; }
        .wm-mod-sortbadge-num { font-size: 20px; }

        .wm-quick { padding: 40px 16px 0; }
        .wm-quick-head h2 { font-size: 30px; }
        .wm-quick-head p { font-size: 13px; }

        .wm-decode { padding: 40px 16px 0; }
        .wm-decode-head h2 { font-size: 30px; }
        .wm-decode-head p { font-size: 13px; }

      }

    </style>
  </Fragment>

  <div class="wm-page">
    <header class="wm-header">
      <a href="/" class="wm-back-home">← stanwood.dev</a>
    </header>

    <main class="wm-main">
      <div class="wm-start">
        <div class="wm-hero">
          <h1 class="wm-title">Which Model?</h1>
          <p class="wm-subtitle">
            Stop overthinking it. Match the shape of the job to the shape of the model.
          </p>
        </div>

        <div class="wm-paths">
          <a class="wm-path-card" href="#quick-picks-heading">
            <span class="wm-path-emoji" aria-hidden="true">🎯</span>
            <span class="wm-path-label">Quick picks</span>
            <span class="wm-path-desc">
              Start with the common task shapes and the model traits that matter.
            </span>
          </a>

          <a class="wm-path-card" href="#directory-heading">
            <span class="wm-path-emoji" aria-hidden="true">📊</span>
            <span class="wm-path-label">Compare</span>
            <span class="wm-path-desc">
              Scan the current model families side-by-side without chasing release names.
            </span>
          </a>
        </div>

        <div class="wm-examples">
          <p class="wm-examples-label">Good questions to ask first:</p>
          <div class="wm-example-chips">
            <span class="wm-chip">is quality or speed the bottleneck?</span>
            <span class="wm-chip">does it need tools?</span>
            <span class="wm-chip">how much context must fit?</span>
            <span class="wm-chip">what mistake is expensive?</span>
          </div>
        </div>
      </div>
    </main>

    <footer class="wm-footer">
      <p>Opinionated recommendations, not gospel. Model landscape changes fast — the directory below notes what's shifted since the snapshot. Last reviewed June 2026.</p>
    </footer>
  </div>

  <section class="wm-quick" aria-labelledby="quick-picks-heading">
    <div class="wm-quick-head">
      <h2 id="quick-picks-heading">Quick picks</h2>
      <p>Skip the quiz. <strong>Six common asks, six ways to narrow the field.</strong></p>
    </div>

    <div class="wm-quick-grid">
      <article class="wm-quick-card" style="--card-color: #d97706;">
        <div class="wm-quick-task">
          <span class="wm-quick-task-icon" aria-hidden="true">✍️</span>
          <span>Write polished prose</span>
        </div>
        <div class="wm-quick-pick">
          <span class="wm-quick-pick-emoji" aria-hidden="true">🧠</span>
          <div class="wm-quick-pick-body">
            <span class="wm-quick-pick-name">Pick for voice</span>
            <span class="wm-quick-pick-org">writing quality over benchmark rank</span>
          </div>
        </div>
        <p class="wm-quick-why">Use a model whose drafts need the fewest style edits. The best writing pick is the one you rewrite least.</p>
        <p class="wm-quick-alt"><span>Check</span>Ask for three versions and choose the one with the strongest default taste.</p>
      </article>

      <article class="wm-quick-card" style="--card-color: #d97706;">
        <div class="wm-quick-task">
          <span class="wm-quick-task-icon" aria-hidden="true">💻</span>
          <span>Code a feature in your app</span>
        </div>
        <div class="wm-quick-pick">
          <span class="wm-quick-pick-emoji" aria-hidden="true">🛠️</span>
          <div class="wm-quick-pick-body">
            <span class="wm-quick-pick-name">Pick for tool use</span>
            <span class="wm-quick-pick-org">repo access, tests, edit loop</span>
          </div>
        </div>
        <p class="wm-quick-why">Coding work needs context and verification more than a clever single answer. Favor models and apps that can inspect files, edit, and run tests.</p>
        <p class="wm-quick-alt"><span>Check</span>Give it a small real bug and see whether it changes the right file.</p>
      </article>

      <article class="wm-quick-card" style="--card-color: #10a37f;">
        <div class="wm-quick-task">
          <span class="wm-quick-task-icon" aria-hidden="true">🧮</span>
          <span>Crack hard math, logic, or research</span>
        </div>
        <div class="wm-quick-pick">
          <span class="wm-quick-pick-emoji" aria-hidden="true">🔬</span>
          <div class="wm-quick-pick-body">
            <span class="wm-quick-pick-name">Pick reasoning</span>
            <span class="wm-quick-pick-org">slower, pricier, more deliberate</span>
          </div>
        </div>
        <p class="wm-quick-why">Reasoning models are worth the extra latency when each mistake is expensive and the answer has multiple dependent steps.</p>
        <p class="wm-quick-alt"><span>Check</span>Ask for assumptions, not just the final answer.</p>
      </article>

      <article class="wm-quick-card" style="--card-color: #4285f4;">
        <div class="wm-quick-task">
          <span class="wm-quick-task-icon" aria-hidden="true">📚</span>
          <span>Summarize a huge document or codebase</span>
        </div>
        <div class="wm-quick-pick">
          <span class="wm-quick-pick-emoji" aria-hidden="true">📄</span>
          <div class="wm-quick-pick-body">
            <span class="wm-quick-pick-name">Pick long context</span>
            <span class="wm-quick-pick-org">fits the source without chopping</span>
          </div>
        </div>
        <p class="wm-quick-why">The model cannot reason over pages it never saw. Context window matters most when the source is long and cross-referenced.</p>
        <p class="wm-quick-alt"><span>Check</span>Ask it to cite where in the source each claim came from.</p>
      </article>

      <article class="wm-quick-card" style="--card-color: #4285f4;">
        <div class="wm-quick-task">
          <span class="wm-quick-task-icon" aria-hidden="true">⚡</span>
          <span>Run high-volume production tasks</span>
        </div>
        <div class="wm-quick-pick">
          <span class="wm-quick-pick-emoji" aria-hidden="true">✨</span>
          <div class="wm-quick-pick-body">
            <span class="wm-quick-pick-name">Pick cheap and fast</span>
            <span class="wm-quick-pick-org">latency and unit cost first</span>
          </div>
        </div>
        <p class="wm-quick-why">For tagging, extraction, routing, and simple Q&amp;A, the right answer is usually the cheapest model that clears your eval.</p>
        <p class="wm-quick-alt"><span>Check</span>Run a 50-item sample before paying flagship prices.</p>
      </article>

      <article class="wm-quick-card" style="--card-color: #4f88c6;">
        <div class="wm-quick-task">
          <span class="wm-quick-task-icon" aria-hidden="true">🔓</span>
          <span>Self-host or keep data local</span>
        </div>
        <div class="wm-quick-pick">
          <span class="wm-quick-pick-emoji" aria-hidden="true">🏠</span>
          <div class="wm-quick-pick-body">
            <span class="wm-quick-pick-name">Pick open weights</span>
            <span class="wm-quick-pick-org">control beats convenience</span>
          </div>
        </div>
        <p class="wm-quick-why">Open-weight models trade managed polish for privacy, offline use, customization, and predictable infrastructure costs.</p>
        <p class="wm-quick-alt"><span>Check</span>Read the license before building a business on it.</p>
      </article>
    </div>

    <p class="wm-quick-foot">
      Don't see your ask? Scroll to the full directory and compare the traits underneath the recommendation.
    </p>
  </section>

  <section class="wm-decode" aria-labelledby="decode-heading">
    <div class="wm-decode-head">
      <h2 id="decode-heading">Decode the AI lingo</h2>
      <p>Why these picks are these picks. <strong>Eight terms that quietly decide every choice.</strong></p>
    </div>

    <div class="wm-decode-grid">
      <article class="wm-decode-card" style="--card-accent: #7c5cff;">
        <span class="wm-decode-icon" aria-hidden="true">📄</span>
        <p class="wm-decode-en">working memory</p>
        <p class="wm-decode-term">Context window</p>
        <p class="wm-decode-meaning">Everything you paste — prompt, attachments, prior chat — has to fit. Bigger window means more code or more pages of a contract before you start chunking.</p>
        <p class="wm-decode-example">Use bigger windows for whole repos, long contracts, or many attached PDFs. Use smaller ones when the prompt is short and latency matters.</p>
      </article>

      <article class="wm-decode-card" style="--card-accent: #ff6b4a;">
        <span class="wm-decode-icon" aria-hidden="true">🧠</span>
        <p class="wm-decode-en">thinks before it answers</p>
        <p class="wm-decode-term">Reasoning model</p>
        <p class="wm-decode-meaning">A second class of model that runs an internal "scratchpad" before responding. Slower and pricier per query, but lands harder problems — math, multi-step logic, code refactors.</p>
        <p class="wm-decode-example">Best for hard math, planning, and codebase refactors. Overkill for rewriting a paragraph or classifying a support ticket.</p>
      </article>

      <article class="wm-decode-card" style="--card-accent: #f5c542;">
        <span class="wm-decode-icon" aria-hidden="true">🎨</span>
        <p class="wm-decode-en">handles more than text</p>
        <p class="wm-decode-term">Multimodal</p>
        <p class="wm-decode-meaning">Reads images, audio, video, or PDFs as input — not just text. Native multimodal models trained on all four feel sharper than ones bolted onto text-only bases.</p>
        <p class="wm-decode-example">Choose this when the task includes screenshots, charts, PDFs, audio, or video. Text-only work does not need the extra surface area.</p>
      </article>

      <article class="wm-decode-card" style="--card-accent: #10a37f;">
        <span class="wm-decode-icon" aria-hidden="true">🪙</span>
        <p class="wm-decode-en">the unit you pay by</p>
        <p class="wm-decode-term">Tokens</p>
        <p class="wm-decode-meaning">Sub-words the model reads and writes — roughly 0.75 word per token. Pricing is "$X per million input tokens / $Y per million output." Output is usually 3–5× more expensive than input.</p>
        <p class="wm-decode-example">Long inputs and long outputs both cost money. Summaries are cheap; repeated analysis loops over giant files are where bills grow.</p>
      </article>

      <article class="wm-decode-card" style="--card-accent: #4285f4;">
        <span class="wm-decode-icon" aria-hidden="true">⚡</span>
        <p class="wm-decode-en">fast vs. flagship</p>
        <p class="wm-decode-term">Tier (Fast · Mid · Flagship)</p>
        <p class="wm-decode-meaning">Each lab ships a tiered family. Fast tiers are 5–20× cheaper and answer in &lt;1s — built for production pipelines. Flagship tiers cost more, think harder, and only make sense when quality matters more than latency.</p>
        <p class="wm-decode-example">Start with the cheapest tier that can do the job, then move up only when you see quality failures you can name.</p>
      </article>

      <article class="wm-decode-card" style="--card-accent: #4f88c6;">
        <span class="wm-decode-icon" aria-hidden="true">🔓</span>
        <p class="wm-decode-en">can you run it yourself</p>
        <p class="wm-decode-term">Open vs. closed weights</p>
        <p class="wm-decode-meaning">Open-weight models publish the trained parameters — you can self-host, fine-tune, or run offline. Closed-weight models live behind an API only. Open trades some quality for full control and zero per-call cost.</p>
        <p class="wm-decode-example">Use open weights for privacy, offline use, fine-tuning, or predictable unit economics. Use hosted APIs when managed quality matters more.</p>
      </article>

      <article class="wm-decode-card" style="--card-accent: #d97706;">
        <span class="wm-decode-icon" aria-hidden="true">🛠️</span>
        <p class="wm-decode-en">can it call other things</p>
        <p class="wm-decode-term">Tool use / agents</p>
        <p class="wm-decode-meaning">Whether the model can call APIs, run code, search the web, or read files mid-conversation — instead of just generating text. The foundation under every "agent" headline.</p>
        <p class="wm-decode-example">Tool access is what turns a chat answer into a workflow: search, fetch, calculate, write, verify, repeat.</p>
      </article>

      <article class="wm-decode-card" style="--card-accent: #b76dff;">
        <span class="wm-decode-icon" aria-hidden="true">📅</span>
        <p class="wm-decode-en">how recent its world is</p>
        <p class="wm-decode-term">Knowledge cutoff</p>
        <p class="wm-decode-meaning">The date training data ends. Anything after — a release, a news event, a library version — the model has to be told or look up. Models with web search smooth this over; pure-LLM answers don't.</p>
        <p class="wm-decode-example">For current events, prices, docs, or laws, use a model with retrieval or bring the sources yourself. Guessing from memory is the trap.</p>
      </article>
    </div>

    <p class="wm-decode-foot">
      Match the term to the task. The Quick Picks above are shorthand — these are the dials underneath them.
    </p>
  </section>

  <section class="wm-directory" aria-labelledby="directory-heading">
    <div class="wm-directory-head">
      <h2 class="wm-directory-title" id="directory-heading">
        All {MODELS.length} model families, side-by-side
      </h2>
      <p class="wm-directory-sub">
        A deliberately stable snapshot as of April 2026. The labels are family-level on purpose:
        exact release names move faster than this page should.
      </p>
    </div>

    <p class="wm-dir-count">
      Showing <strong>{directoryModels.length}</strong> models, sorted by their strongest practical signal.
    </p>

    <aside class="wm-shift" aria-label="Keeping this current">
      <p class="wm-shift-title">This snapshot moves slowly on purpose</p>
      <p class="wm-shift-foot">New models and price cuts land almost daily — see <a href="/radar">AI Radar →</a> for what's fresh.</p>
    </aside>

    <div class="wm-directory-grid">
      {directoryModels.map((model, idx) => {
        const isImage = isImageModel(model);
        const traits = isImage ? IMAGE_CARD_TRAITS : CARD_TRAITS;
        const hotTrait = highlightTrait(model);
        const hotScore = model.traits[hotTrait] ?? 0;

        return (
          <article
            class="wm-mod-card"
            style={`--mod-color: ${model.color};`}
          >
            <div class="wm-mod-rank">#{idx + 1}</div>
            <header class="wm-mod-head">
              <span class="wm-mod-emoji" aria-hidden="true">{model.emoji}</span>
              <div>
                <h3 class="wm-mod-name">{model.name}</h3>
                <p class="wm-mod-org">{model.org}</p>
              </div>
              <div class="wm-mod-sortbadge" title={`${TRAIT_LABELS[hotTrait]} score`}>
                <span class="wm-mod-sortbadge-num">{hotScore}</span>
                <span class="wm-mod-sortbadge-label">{scoreLabel(hotScore)}</span>
              </div>
            </header>

            <p class="wm-mod-tag">{model.tagline}</p>

            <div class="wm-mod-traits">
              {traits.map((trait) => {
                const score = model.traits[trait] ?? 0;
                const isHot = trait === hotTrait;

                return (
                  <div class:list={["wm-trait-row", isHot && "wm-trait-row--hot"]}>
                    <span class="wm-trait-label">{TRAIT_LABELS[trait]}</span>
                    <div class="wm-trait-track">
                      <div
                        class="wm-trait-fill"
                        style={`width:${scorePct(score)}%;background:${isHot ? model.color : "var(--wm-ink)"};opacity:${score === 0 ? 0.15 : 1};`}
                      />
                    </div>
                    <span class="wm-trait-score">{score === 0 ? "—" : score}</span>
                  </div>
                );
              })}
            </div>

            <ul class="wm-mod-best">
              {model.bestFor.slice(0, 3).map((item) => <li>{item}</li>)}
            </ul>
          </article>
        );
      })}
    </div>

    <p class="wm-directory-foot">
      Models retire and new ones land. Spot something missing? <a href="mailto:stephen@stanwood.dev">let me know</a>.
    </p>
  </section>
</BaseLayout>
