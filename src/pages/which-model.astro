      .wm-dir-chip-emoji {
        font-size: 13px;
        line-height: 1;
      }

      .wm-dir-chip-count {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        font-weight: 700;
        background: var(--wm-border);
        color: var(--wm-muted);
        padding: 1px 6px;
        border-radius: 6px;
        line-height: 1.4;
      }
      .wm-dir-chip--active .wm-dir-chip-count {
        background: rgba(255,255,255,0.2);
        color: var(--wm-bg);
      }

      .wm-dir-sort-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
