---
import BaseLayout from "../layouts/BaseLayout.astro";

type Pixel = readonly [number, number];
type Breed = {
  key: string;
  name: string;
  tagline: string;
  desc: string;
  body: { fill: string; stripe: string };
  tail: string;
  fin: string;
  bodyR: readonly Pixel[];
  tailR: readonly Pixel[];
  finR: readonly Pixel[];
  eyeR: Pixel;
  stripeY: readonly number[];
  viewBox: string;
};

const PX = 8;

// Breed shapes match FISH_SHAPES in the canvas script — same pixel art, statically rendered
const breeds: Breed[] = [
  {
    key: "classic",
    name: "Classic",
    tagline: "compact diamond",
    desc: "Short, stocky body with a clean fork tail. The everyman of the tank — quick to dart, easy to spot.",
    body: { fill: "#FF6B9D", stripe: "#FFA0C2" },
    tail: "#DC4682",
    fin: "#FF8CB4",
    bodyR: [[2,0],[3,0],[4,0],[1,1],[2,1],[3,1],[4,1],[5,1],[0,2],[1,2],[2,2],[3,2],[4,2],[5,2],[6,2],[1,3],[2,3],[3,3],[4,3],[5,3],[2,4],[3,4],[4,4]],
    tailR: [[-1,1],[-2,0],[-2,1],[-1,2],[-2,2],[-1,3],[-2,3],[-2,4]],
    finR: [[3,5],[4,5]],
    eyeR: [5,1],
    stripeY: [2],
    viewBox: `-20 -4 80 64`,
  },
  {
    key: "angelfish",
    name: "Angelfish",
    tagline: "tall leaf",
    desc: "Towering vertical body, twin trailing tail fins. Glides slowly — claims the upper third of the tank.",
    body: { fill: "#00BEDC", stripe: "#5CD2EB" },
    tail: "#0096BE",
    fin: "#50D2EB",
    bodyR: [[3,0],[2,1],[3,1],[4,1],[1,2],[2,2],[3,2],[4,2],[5,2],[0,3],[1,3],[2,3],[3,3],[4,3],[5,3],[6,3],[1,4],[2,4],[3,4],[4,4],[5,4],[2,5],[3,5],[4,5],[3,6]],
    tailR: [[-1,2],[-1,3],[-1,4],[-2,1],[-2,3],[-2,5]],
    finR: [[2,7],[3,7]],
    eyeR: [5,2],
    stripeY: [3],
    viewBox: `-20 -4 80 80`,
  },
  {
    key: "pufferfish",
    name: "Pufferfish",
    tagline: "round and chunky",
    desc: "Wider than tall, stubby tail, drifting belly. Doesn't chase — pellets come to it eventually.",
    body: { fill: "#FFB432", stripe: "#FFD27B" },
    tail: "#E68C14",
    fin: "#FFD264",
    bodyR: [[2,0],[3,0],[4,0],[5,0],[1,1],[2,1],[3,1],[4,1],[5,1],[6,1],[0,2],[1,2],[2,2],[3,2],[4,2],[5,2],[6,2],[7,2],[0,3],[1,3],[2,3],[3,3],[4,3],[5,3],[6,3],[7,3],[1,4],[2,4],[3,4],[4,4],[5,4],[6,4],[2,5],[3,5],[4,5],[5,5]],
    tailR: [[-1,2],[-1,3]],
    finR: [[3,6],[4,6]],
    eyeR: [6,1],
    stripeY: [2, 3],
    viewBox: `-12 -4 88 72`,
  },
];
---

<BaseLayout
  title="Pixel Aquarium — stanwood.dev"
  description="Little pixel fish swim around your screen. Drop food pellets, switch between day, sunset, and night scenes, and watch the colors evolve. A chill zero-stakes aquarium in your browser."
  slug="pixel-aquarium"
  favicon="/favicon-aquarium.svg"
  themeColor="#041230"
  fontsUrl="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Inter:wght@400;500;600&display=swap"
  schemaCategory="GameApplication"
>
  <Fragment slot="head">
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        background: #041230;
        color: #e0e8f0;
        font-family: 'Inter', sans-serif;
        min-height: 100vh;
        overflow-x: hidden;
      }
      .pixel-font { font-family: 'Press Start 2P', monospace; }

      /* --- Hero banner --- */
      .hero-banner {
        position: relative;
        width: 100%;
        max-height: 340px;
        overflow: hidden;
        margin-top: 48px;
      }
      .hero-banner img {
        width: 100%;
        height: 340px;
        object-fit: cover;
        object-position: center 40%;
        display: block;
        image-rendering: pixelated;
      }
      .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to bottom,
          rgba(4, 18, 48, 0.15) 0%,
          rgba(4, 18, 48, 0.0) 30%,
          rgba(4, 18, 48, 0.3) 70%,
          rgba(4, 18, 48, 1) 100%
        );
        pointer-events: none;
      }
      /* Side fade vignette */
      .hero-overlay::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to right,
          rgba(4, 18, 48, 0.6) 0%,
          transparent 15%,
          transparent 85%,
          rgba(4, 18, 48, 0.6) 100%
        );
      }

      .container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 12px 16px 24px;
        max-width: 720px;
        margin: 0 auto;
      }
      h1 {
        font-size: 1.2rem;
        letter-spacing: 2px;
        margin-bottom: 8px;
        background: linear-gradient(90deg, #ff6b9d, #ff9a30, #ffd93d, #00d2ff, #ff6b9d);
        background-size: 200% 100%;
        animation: shimmer 6s ease-in-out infinite;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-shadow: none;
      }
      @keyframes shimmer {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
      }
      .subtitle {
        font-size: 0.65rem;
        color: rgba(0, 210, 255, 0.45);
        margin-bottom: 16px;
        letter-spacing: 1px;
      }
      #aquarium-canvas {
        border: 3px solid rgba(0, 180, 255, 0.25);
        border-radius: 8px;
        cursor: crosshair;
        image-rendering: pixelated;
        box-shadow:
          0 0 40px rgba(0, 140, 255, 0.2),
          0 0 80px rgba(255, 107, 157, 0.08),
          inset 0 0 60px rgba(0, 50, 120, 0.15);
        max-width: 100%;
        touch-action: none;
      }
      .info-bar {
        display: flex;
        gap: 24px;
        margin-top: 12px;
        font-size: 0.55rem;
        letter-spacing: 1px;
      }
      .info-bar span { color: rgba(0, 210, 255, 0.35); }
      .info-bar .val { color: #ffd93d; }

      /* ── Food palette ── */
      .palette {
        display: flex;
        gap: 7px;
        margin-top: 12px;
        align-items: center;
        flex-wrap: wrap;
        justify-content: center;
      }
      .palette-label {
        font-family: 'Press Start 2P', monospace;
        font-size: 0.45rem;
        color: rgba(0, 210, 255, 0.35);
        letter-spacing: 1px;
        margin-right: 2px;
      }
      .palette-swatch {
        width: 22px;
        height: 22px;
        border-radius: 3px;
        cursor: pointer;
        border: 2px solid rgba(255,255,255,0.12);
        transition: border-color 0.15s, transform 0.12s;
        image-rendering: pixelated;
        padding: 0;
        background-size: cover;
      }
      .palette-swatch:hover { transform: scale(1.25); border-color: rgba(255,255,255,0.4); }
      .palette-swatch.active { border-color: #fff; transform: scale(1.2); box-shadow: 0 0 6px rgba(255,255,255,0.35); }
      .palette-swatch.swatch-random {
        background: conic-gradient(#ff4060, #ff9a30, #ffd93d, #43e97b, #00d2ff, #c850c0, #ff6b9d, #ff4060);
      }

      /* ── Scene selector ── */
      .scene-row {
        display: flex;
        gap: 6px;
        margin-top: 10px;
        align-items: center;
        flex-wrap: wrap;
        justify-content: center;
      }
      .scene-btn {
        font-family: 'Press Start 2P', monospace;
        font-size: 0.45rem;
        letter-spacing: 1px;
        background: transparent;
        color: rgba(0, 210, 255, 0.4);
        border: 2px solid rgba(0, 180, 255, 0.18);
        padding: 6px 10px;
        cursor: pointer;
        transition: color 0.15s, border-color 0.15s, background 0.15s;
        text-transform: uppercase;
      }
      .scene-btn:hover {
        color: rgba(0, 210, 255, 0.85);
        border-color: rgba(0, 210, 255, 0.45);
      }
      .scene-btn.active {
        background: rgba(0, 210, 255, 0.12);
        border-color: rgba(0, 210, 255, 0.7);
        color: #fff;
      }
      .back-link {
        position: fixed;
        top: 16px;
        left: 16px;
        color: rgba(0, 210, 255, 0.4);
        text-decoration: none;
        font-size: 0.8rem;
        transition: color 0.2s;
        z-index: 10;
      }
      .back-link:hover { color: rgba(0, 210, 255, 0.8); }

      .desc {
        font-size: 0.75rem;
        color: rgba(0, 210, 255, 0.45);
        line-height: 1.7;
        max-width: 540px;
        text-align: center;
        margin: 0 auto 16px;
        letter-spacing: 0.02em;
      }

      /* ── Tips grid ── */
      .tips {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        max-width: 640px;
        margin: 16px auto 0;
      }
      @media (min-width: 540px) {
        .tips { grid-template-columns: repeat(4, 1fr); }
      }
      .tip {
        border: 1px solid rgba(0, 180, 255, 0.12);
        border-radius: 6px;
        padding: 10px 10px 12px;
        background: rgba(0, 100, 180, 0.06);
        text-align: center;
      }
      .tip-icon {
        font-size: 1.2rem;
        margin-bottom: 6px;
        display: block;
      }
      .tip-title {
        font-family: 'Press Start 2P', monospace;
        font-size: 0.45rem;
        color: rgba(0, 210, 255, 0.7);
        letter-spacing: 0.04em;
        margin-bottom: 5px;
        display: block;
      }
      .tip-body {
        font-size: 0.65rem;
        color: rgba(0, 210, 255, 0.35);
        line-height: 1.5;
      }

      /* ── Meet the breeds ── */
      .breeds {
        max-width: 640px;
        margin: 28px auto 0;
        border-top: 1px solid rgba(0, 180, 255, 0.1);
        padding-top: 24px;
      }
      .breeds-label {
        font-family: 'Press Start 2P', monospace;
        font-size: 0.45rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(0, 210, 255, 0.3);
        margin-bottom: 16px;
        text-align: left;
      }
      .breed-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
      }
      @media (max-width: 540px) {
        .breed-grid { grid-template-columns: 1fr; }
      }
      .breed-card {
        border: 1px solid rgba(0, 180, 255, 0.12);
        border-radius: 8px;
        padding: 14px 14px 16px;
        background: rgba(0, 60, 120, 0.18);
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
      }
      .breed-svg-wrap {
        width: 100%;
        aspect-ratio: 5 / 4;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(180deg, rgba(0, 30, 70, 0.55) 0%, rgba(0, 50, 90, 0.4) 100%);
        border-radius: 4px;
        padding: 10px;
        margin-bottom: 12px;
        image-rendering: pixelated;
        position: relative;
        overflow: hidden;
      }
      .breed-svg-wrap::after {
        /* subtle scanlines for the retro feel */
        content: '';
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(
          0deg,
          rgba(0, 0, 0, 0) 0,
          rgba(0, 0, 0, 0) 3px,
          rgba(0, 0, 0, 0.06) 3px,
          rgba(0, 0, 0, 0.06) 4px
        );
        pointer-events: none;
      }
      .breed-svg {
        width: 100%;
        height: 100%;
        max-height: 110px;
        shape-rendering: crispEdges;
      }
      .breed-name {
        font-family: 'Press Start 2P', monospace;
        font-size: 0.55rem;
        letter-spacing: 0.04em;
        color: rgba(0, 210, 255, 0.9);
        margin-bottom: 4px;
      }
      .breed-tagline {
        font-size: 0.6rem;
        color: rgba(0, 210, 255, 0.5);
        font-style: italic;
        margin-bottom: 8px;
      }
      .breed-desc {
        font-size: 0.65rem;
        color: rgba(0, 210, 255, 0.4);
        line-height: 1.5;
      }

      /* ── Famous Tank Fish section ── */
      .fame {
        max-width: 640px;
        margin: 28px auto 0;
        border-top: 1px solid rgba(0, 180, 255, 0.1);
        padding-top: 24px;
      }
      .fame-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 10px;
      }
      .fame-label {
        font-family: 'Press Start 2P', monospace;
        font-size: 0.45rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(0, 210, 255, 0.3);
      }
      .fame-tag {
        font-family: 'Press Start 2P', monospace;
        font-size: 0.4rem;
        letter-spacing: 0.08em;
        color: rgba(255, 217, 61, 0.5);
      }
      .fame-intro {
        font-size: 0.7rem;
        color: rgba(0, 210, 255, 0.4);
        line-height: 1.6;
        margin-bottom: 16px;
        max-width: 540px;
      }
      .fame-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }
      @media (max-width: 540px) {
        .fame-grid { grid-template-columns: 1fr; }
      }
      .fame-card {
        border: 1px solid rgba(0, 180, 255, 0.12);
        border-radius: 8px;
        padding: 12px 12px 14px;
        background: rgba(0, 60, 120, 0.18);
        display: flex;
        flex-direction: column;
      }
      .fame-svg-wrap {
        width: 100%;
        aspect-ratio: 16 / 9;
        background: linear-gradient(180deg, rgba(0, 30, 70, 0.55) 0%, rgba(0, 50, 90, 0.4) 100%);
        border-radius: 4px;
        margin-bottom: 10px;
        position: relative;
        overflow: hidden;
      }
      .fame-svg-wrap::after {
        content: '';
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(
          0deg,
          rgba(0, 0, 0, 0) 0,
          rgba(0, 0, 0, 0) 3px,
          rgba(0, 0, 0, 0.06) 3px,
          rgba(0, 0, 0, 0.06) 4px
        );
        pointer-events: none;
      }
      .fame-svg {
        width: 100%;
        height: 100%;
        display: block;
        shape-rendering: crispEdges;
      }
      .fame-row {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 6px;
        margin-bottom: 2px;
      }
      .fame-name {
        font-family: 'Press Start 2P', monospace;
        font-size: 0.5rem;
        letter-spacing: 0.04em;
        color: rgba(0, 210, 255, 0.9);
      }
      .fame-range {
        font-family: 'Press Start 2P', monospace;
        font-size: 0.42rem;
        color: rgba(255, 217, 61, 0.7);
        white-space: nowrap;
      }
      .fame-sci {
        font-size: 0.6rem;
        color: rgba(0, 210, 255, 0.45);
        font-style: italic;
        margin-bottom: 6px;
      }
      .fame-fact {
        font-size: 0.65rem;
        color: rgba(0, 210, 255, 0.4);
        line-height: 1.55;
      }
      .fame-foot {
        font-size: 0.62rem;
        color: rgba(255, 217, 61, 0.4);
        line-height: 1.6;
        margin-top: 14px;
        padding: 10px 12px;
        border: 1px dashed rgba(255, 217, 61, 0.2);
        border-radius: 6px;
      }

      /* ── Behind the Glass section ── */
      .behind-glass {
        max-width: 640px;
        margin: 28px auto 0;
        border-top: 1px solid rgba(0, 180, 255, 0.1);
        padding-top: 24px;
      }
      .behind-glass-label {
        font-family: 'Press Start 2P', monospace;
        font-size: 0.45rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(0, 210, 255, 0.3);
        margin-bottom: 16px;
        text-align: left;
      }
      .behind-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
      }
      @media (max-width: 540px) {
        .behind-grid { grid-template-columns: 1fr; }
      }
      .behind-card {
        border: 1px solid rgba(0, 180, 255, 0.1);
        border-radius: 8px;
        padding: 14px 14px 16px;
        background: rgba(0, 60, 120, 0.12);
      }
      .behind-card-title {
        font-size: 0.7rem;
        font-weight: 600;
        color: rgba(0, 210, 255, 0.65);
        margin-bottom: 6px;
        letter-spacing: 0.02em;
      }
      .behind-card-body {
        font-size: 0.65rem;
        color: rgba(0, 210, 255, 0.35);
        line-height: 1.65;
      }

      @media (max-width: 640px) {
        .hero-banner { max-height: 200px; margin-top: 40px; }
        .hero-banner img { height: 200px; }
        h1 { font-size: 0.9rem; }
      }
    </style>
  </Fragment>

    <a href="#aquarium-canvas" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-cyan-400 focus:text-black focus:rounded-lg focus:font-semibold">Skip to aquarium</a>
    <a href="/" class="back-link retro-back" aria-label="Back to stanwood.dev">&larr; stanwood.dev</a>

    <div class="hero-banner">
      <img
        src="/images/pixel-aquarium.webp"
        alt="Vibrant pixel art aquarium with colorful tropical fish swimming through coral and sea plants"
        loading="lazy"
        width="1280"
        height="340"
        decoding="async"
      />
      <div class="hero-overlay"></div>
    </div>

    <div class="container">
      <h1 class="pixel-font">PIXEL AQUARIUM</h1>
      <p class="subtitle pixel-font">click anywhere to drop food</p>
      <p class="desc">A little browser aquarium that runs on its own. Drop colorful food pellets, switch the scene, and watch the fish evolve, multiply, and make it theirs.</p>
      <canvas id="aquarium-canvas" role="img" aria-label="Pixel art aquarium with fish swimming around. Click to drop food."></canvas>
      <div class="info-bar pixel-font">
        <span>fish: <span class="val" id="fish-count">0</span></span>
        <span>fed: <span class="val" id="fed-count">0</span></span>
      </div>
      <div class="palette" role="group" aria-label="Food color selector">
        <span class="palette-label">food:</span>
        <button class="palette-swatch swatch-random active" data-color="random" title="Random color" aria-label="Random food color" aria-pressed="true"></button>
        <button class="palette-swatch" style="background:#ff4060" data-color="0" title="Red" aria-label="Red food" aria-pressed="false"></button>
        <button class="palette-swatch" style="background:#ff9a30" data-color="1" title="Orange" aria-label="Orange food" aria-pressed="false"></button>
        <button class="palette-swatch" style="background:#ffd93d" data-color="2" title="Yellow" aria-label="Yellow food" aria-pressed="false"></button>
        <button class="palette-swatch" style="background:#43e97b" data-color="3" title="Green" aria-label="Green food" aria-pressed="false"></button>
        <button class="palette-swatch" style="background:#00d2ff" data-color="4" title="Cyan" aria-label="Cyan food" aria-pressed="false"></button>
        <button class="palette-swatch" style="background:#c850c0" data-color="5" title="Purple" aria-label="Purple food" aria-pressed="false"></button>
        <button class="palette-swatch" style="background:#ff6b9d" data-color="6" title="Pink" aria-label="Pink food" aria-pressed="false"></button>
      </div>
      <div class="scene-row" role="group" aria-label="Aquarium scene selector">
        <span class="palette-label">scene:</span>
        <button class="scene-btn active" data-scene="day" aria-pressed="true">Day</button>
        <button class="scene-btn" data-scene="sunset" aria-pressed="false">Sunset</button>
        <button class="scene-btn" data-scene="night" aria-pressed="false">Night</button>
      </div>
      <div class="tips">
        <div class="tip">
          <span class="tip-icon">🎯</span>
          <span class="tip-title">Feed them</span>
          <span class="tip-body">Click the water to drop pellets. Fish swim toward food and eat whatever's closest.</span>
        </div>
        <div class="tip">
          <span class="tip-icon">🎨</span>
          <span class="tip-title">Color evolves</span>
          <span class="tip-body">Pick a food color above and feed consistently. Each meal nudges the fish's hue toward it — keep feeding to breed a whole red tank.</span>
        </div>
        <div class="tip">
          <span class="tip-icon">🐣</span>
          <span class="tip-title">New arrivals</span>
          <span class="tip-body">Well-fed fish spawn babies that inherit their parent's colors. Up to 20 fish total.</span>
        </div>
        <div class="tip">
          <span class="tip-icon">🐡</span>
          <span class="tip-title">Three breeds</span>
          <span class="tip-body">Classic, angelfish, and pufferfish swim together. Each has a distinct pixel shape.</span>
        </div>
      </div>

      <!-- Meet the breeds -->
      <div class="breeds">
        <p class="breeds-label">Meet the breeds</p>
        <div class="breed-grid">
          {breeds.map((breed) => (
            <div class="breed-card">
              <div class="breed-svg-wrap">
                <svg class="breed-svg" viewBox={breed.viewBox} xmlns="http://www.w3.org/2000/svg" role="img" aria-label={`${breed.name} fish`}>
                  {breed.tailR.map(([x, y]) => (
                    <rect x={x * PX} y={y * PX} width={PX} height={PX} fill={breed.tail} />
                  ))}
                  {breed.bodyR.map(([x, y]) => (
                    <rect x={x * PX} y={y * PX} width={PX} height={PX} fill={breed.stripeY.includes(y) ? breed.body.stripe : breed.body.fill} />
                  ))}
                  {breed.finR.map(([x, y]) => (
                    <rect x={x * PX} y={y * PX} width={PX} height={PX} fill={breed.fin} />
                  ))}
                  <rect x={breed.eyeR[0] * PX} y={breed.eyeR[1] * PX} width={PX} height={PX} fill="#fff" />
                </svg>
              </div>
              <p class="breed-name">{breed.name}</p>
