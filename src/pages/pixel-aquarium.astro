      <!-- Behind the Glass -->
      <div class="behind-glass">
        <p class="behind-glass-label">Behind the Glass</p>
        <div class="behind-grid">
          <div class="behind-card">
            <p class="behind-card-title">Fish personality</p>
            <p class="behind-card-body">Every fish spawns with four hidden traits: hunger (how motivated it is to seek food), laziness (idle drift frequency), swim speed, and wiggle rate. These are randomized at birth, so each fish moves a little differently — some are lazy drifters, some dart straight for every pellet.</p>
          </div>
          <div class="behind-card">
            <p class="behind-card-title">Color evolution</p>
            <p class="behind-card-body">Eating a food pellet lerps the fish's body, tail, and fin colors toward the pellet's RGB value — 25%, 15%, and 10% respectively per meal. A fish needs many consistent feedings to fully shift hue. Drop only red pellets and watch a cyan fish slowly turn coral over dozens of meals.</p>
          </div>
          <div class="behind-card">
            <p class="behind-card-title">Three breeds</p>
            <p class="behind-card-body">Classic, angelfish, and pufferfish each have a distinct pixel layout defined as arrays of (x, y) offsets for body, tail, fin, and eye. Left-facing versions are computed by mirroring the right-facing pixels across the fish's width — no separate sprite needed. Tail pixels wiggle via a sine function offset by each fish's timer.</p>
          </div>
          <div class="behind-card">
            <p class="behind-card-title">Breeding &amp; spawning</p>
            <p class="behind-card-body">Every 300 frames the tank checks if a new fish should spawn: the population must be under 20 and the fed count must exceed twice the current headcount. Babies inherit their parent's colors lerped 70% toward a random palette — so lineages gradually drift, but family resemblance persists for a few generations.</p>
          </div>
        </div>
      </div>
    </div>

    <script is:inline>
      const canvas = document.getElementById('aquarium-canvas');
      const ctx = canvas.getContext('2d');

      // --- Sizing ---
      const PIXEL = 4; // each "pixel" is 4x4 real pixels
      const COLS = 160;
      const ROWS = 100;
      canvas.width = COLS * PIXEL;
      canvas.height = ROWS * PIXEL;

      // --- Scenes (water gradient, sand tones, light rays) ---
      const SCENES = {
        day: {
          waterTop: [10, 20, 60],
          waterBot: [5, 10, 35],
          sand: ['#c2a64e', '#b89840', '#d4b85a', '#a08030'],
          rayColor: 'rgba(150,200,255,1)',
          rayAlpha: 0.03,
          plantSat: 60,
          bubbleColor: [100, 180, 255],
        },
        sunset: {
          waterTop: [80, 35, 90],
          waterBot: [25, 10, 50],
          sand: ['#a06535', '#8d4f2a', '#b4793f', '#7a4220'],
          rayColor: 'rgba(255,180,120,1)',
          rayAlpha: 0.07,
          plantSat: 45,
          bubbleColor: [255, 180, 200],
        },
        night: {
          waterTop: [4, 8, 28],
          waterBot: [2, 3, 12],
          sand: ['#3a3322', '#2e2818', '#43391d', '#231d12'],
          rayColor: 'rgba(120,180,255,1)',
          rayAlpha: 0.015,
          plantSat: 35,
          bubbleColor: [140, 200, 255],
        },
      };
      let currentScene = 'day';
      function scene() { return SCENES[currentScene]; }

      const FOOD_COLORS = [
        { name: 'red',    hex: '#ff4060', rgb: [255, 64, 96] },
        { name: 'orange', hex: '#ff9a30', rgb: [255, 154, 48] },
        { name: 'yellow', hex: '#ffd93d', rgb: [255, 217, 61] },
        { name: 'green',  hex: '#43e97b', rgb: [67, 233, 123] },
        { name: 'cyan',   hex: '#00d2ff', rgb: [0, 210, 255] },
        { name: 'purple', hex: '#c850c0', rgb: [200, 80, 192] },
        { name: 'pink',   hex: '#ff6b9d', rgb: [255, 107, 157] },
      ];

      // --- State ---
      let fishes = [];
      let foods = [];
      let bubbles = [];
      let plants = [];
      let fedCount = 0;
      const SAND_HEIGHT = 8;
      const SAND_LINE = ROWS - SAND_HEIGHT;

      // --- Pixel helpers ---
      function px(x, y, color) {
        ctx.fillStyle = color;
        ctx.fillRect(x * PIXEL, y * PIXEL, PIXEL, PIXEL);
      }

      function rgbStr(r, g, b, a = 1) {
        return a < 1 ? `rgba(${r},${g},${b},${a})` : `rgb(${r},${g},${b})`;
      }

      function lerpColor(c1, c2, t) {
        return [
          Math.round(c1[0] + (c2[0] - c1[0]) * t),
          Math.round(c1[1] + (c2[1] - c1[1]) * t),
          Math.round(c1[2] + (c2[2] - c1[2]) * t),
        ];
      }

      // --- Fish shapes (multiple body types) ---
      function mirrorX(pixels, w) {
        return pixels.map(([x, y]) => [w - 1 - x, y]);
      }

      /**
       * @typedef {{ bodyR: number[][]; tailR: number[][]; eyeR: number[]; finR: number[][]; w: number; stripeY: number[]; bodyL?: number[][]; tailL?: number[][]; eyeL?: number[]; finL?: number[][] }} FishShape
       * @type {FishShape[]}
       */
      const FISH_SHAPES = [
        { // Classic — compact diamond
          bodyR: [[2,0],[3,0],[4,0],[1,1],[2,1],[3,1],[4,1],[5,1],[0,2],[1,2],[2,2],[3,2],[4,2],[5,2],[6,2],[1,3],[2,3],[3,3],[4,3],[5,3],[2,4],[3,4],[4,4]],
          tailR: [[-1,1],[-2,0],[-2,1],[-1,2],[-2,2],[-1,3],[-2,3],[-2,4]],
          eyeR: [5,1], finR: [[3,5],[4,5]], w: 7, stripeY: [2],
        },
        { // Angelfish — tall leaf shape
          bodyR: [[3,0],[2,1],[3,1],[4,1],[1,2],[2,2],[3,2],[4,2],[5,2],[0,3],[1,3],[2,3],[3,3],[4,3],[5,3],[6,3],[1,4],[2,4],[3,4],[4,4],[5,4],[2,5],[3,5],[4,5],[3,6]],
          tailR: [[-1,2],[-1,3],[-1,4],[-2,1],[-2,3],[-2,5]],
          eyeR: [5,2], finR: [[2,7],[3,7]], w: 7, stripeY: [3],
        },
        { // Pufferfish — round and chunky
          bodyR: [[2,0],[3,0],[4,0],[5,0],[1,1],[2,1],[3,1],[4,1],[5,1],[6,1],[0,2],[1,2],[2,2],[3,2],[4,2],[5,2],[6,2],[7,2],[0,3],[1,3],[2,3],[3,3],[4,3],[5,3],[6,3],[7,3],[1,4],[2,4],[3,4],[4,4],[5,4],[6,4],[2,5],[3,5],[4,5],[5,5]],
          tailR: [[-1,2],[-1,3]],
          eyeR: [6,1], finR: [[3,6],[4,6]], w: 8, stripeY: [2, 3],
        },
      ];

      // Precompute left-facing versions for each shape
      for (const s of FISH_SHAPES) {
        s.bodyL = mirrorX(s.bodyR, s.w);
        s.tailL = mirrorX(s.tailR.map(([x,y]) => [x + s.w, y]), s.w + 3).map(([x,y]) => [x - s.w, y]);
        s.eyeL = [s.w - 1 - s.eyeR[0], s.eyeR[1]];
        s.finL = mirrorX(s.finR, s.w);
      }

      // --- Curated fish palettes (body, tail, fin) ---
      const FISH_PALETTES = [
        { body: [255, 107, 157], tail: [220, 70, 130], fin: [255, 140, 180] }, // coral pink
        { body: [0, 190, 220],   tail: [0, 150, 190],  fin: [80, 210, 235] }, // tropical cyan
        { body: [255, 180, 50],  tail: [230, 140, 20],  fin: [255, 210, 100] }, // golden
        { body: [130, 100, 220], tail: [100, 70, 190],  fin: [165, 140, 240] }, // soft purple
        { body: [80, 210, 140],  tail: [50, 180, 110],  fin: [120, 230, 170] }, // seafoam
        { body: [255, 120, 80],  tail: [220, 90, 55],   fin: [255, 155, 120] }, // tangerine
        { body: [100, 180, 255], tail: [65, 145, 225],  fin: [140, 200, 255] }, // sky blue
        { body: [240, 130, 200], tail: [210, 95, 170],  fin: [250, 170, 220] }, // orchid
        { body: [255, 200, 100], tail: [240, 170, 60],  fin: [255, 220, 150] }, // buttercup
        { body: [90, 200, 200],  tail: [60, 170, 175],  fin: [130, 220, 220] }, // teal
      ];

      // --- Size presets ---
      const FISH_SIZES = [0.6, 0.7, 0.8, 1.0, 1.0, 1.0, 1.2, 1.4];

      // --- Create fish ---
      function createFish(x, y) {
        const palette = FISH_PALETTES[Math.floor(Math.random() * FISH_PALETTES.length)];
        const size = FISH_SIZES[Math.floor(Math.random() * FISH_SIZES.length)];
        const shapeIdx = Math.floor(Math.random() * FISH_SHAPES.length);
        return {
          x, y,
          vx: (Math.random() - 0.5) * 0.3,
          vy: (Math.random() - 0.5) * 0.15,
          color: [...palette.body],
          tailColor: [...palette.tail],
          finColor: [...palette.fin],
          facing: Math.random() > 0.5 ? 1 : -1,
          swimTimer: Math.random() * 1000,
          targetFood: null,
          size,
          shapeIdx,
          hasStripe: Math.random() > 0.5,
          // personality
          hunger: 0.3 + Math.random() * 0.7,    // 0-1: how motivated by food
          laziness: 0.3 + Math.random() * 0.5,   // affects idle drift frequency
          swimSpeed: 0.5 + Math.random() * 0.8,  // faster + more variable
          wiggleRate: 0.001 + Math.random() * 0.0015, // slower, calmer animation
        };
      }

      function hslToRgb(h, s, l) {
        s /= 100; l /= 100;
        const k = n => (n + h / 30) % 12;
        const a = s * Math.min(l, 1 - l);
        const f = n => l - a * Math.max(-1, Math.min(k(n) - 3, 9 - k(n), 1));
        return [Math.round(f(0)*255), Math.round(f(8)*255), Math.round(f(4)*255)];
      }

      // --- Spawn initial fish ---
      function spawnInitialFish() {
        const count = 6 + Math.floor(Math.random() * 4);
        for (let i = 0; i < count; i++) {
          const x = 15 + Math.random() * (COLS - 30);
          const y = 10 + Math.random() * (SAND_LINE - 20);
          fishes.push(createFish(x, y));
        }
      }

      // --- Plants ---
      function spawnPlants() {
        const count = 4 + Math.floor(Math.random() * 5);
        for (let i = 0; i < count; i++) {
          const x = 5 + Math.random() * (COLS - 10);
          const height = 6 + Math.floor(Math.random() * 12);
          const hue = 100 + Math.random() * 60; // greens
          plants.push({ x: Math.floor(x), height, hue, sway: Math.random() * Math.PI * 2 });
        }
      }

      function plantLightness(base) {
        // Night dims plants; sunset warms slightly via lightness drop too
        if (currentScene === 'night') return Math.max(12, base - 14);
        if (currentScene === 'sunset') return Math.max(20, base - 6);
        return base;
      }

      // --- Draw background ---
      function drawBackground() {
        const sc = scene();

        // Water gradient
        for (let y = 0; y < SAND_LINE; y++) {
          const t = y / SAND_LINE;
          const c = lerpColor(sc.waterTop, sc.waterBot, t);
          ctx.fillStyle = rgbStr(c[0], c[1], c[2]);
          ctx.fillRect(0, y * PIXEL, COLS * PIXEL, PIXEL);
        }

        // Sand
        for (let y = SAND_LINE; y < ROWS; y++) {
          for (let x = 0; x < COLS; x++) {
            const ci = (x * 7 + y * 13) % sc.sand.length;
            px(x, y, sc.sand[ci]);
          }
        }

        // Light rays (or moonlight)
        const time = Date.now() * 0.0003;
        ctx.globalAlpha = sc.rayAlpha;
        const rayBase = sc.rayColor.replace(/,1\)$/, '');
        for (let i = 0; i < 5; i++) {
          const rx = (Math.sin(time + i * 1.8) * 0.3 + 0.5) * COLS * PIXEL;
          const grad = ctx.createLinearGradient(rx, 0, rx + 80, ROWS * PIXEL * 0.6);
          grad.addColorStop(0, sc.rayColor);
          grad.addColorStop(1, `${rayBase},0)`);
          ctx.fillStyle = grad;
          ctx.fillRect(rx - 20, 0, 60, ROWS * PIXEL * 0.6);
        }
        ctx.globalAlpha = 1;

        // Stars at night
        if (currentScene === 'night') {
          ctx.globalAlpha = 0.55;
          for (let i = 0; i < 24; i++) {
            const sx = (i * 37 + 11) % COLS;
            const sy = (i * 13 + 5) % Math.floor(SAND_LINE * 0.55);
            const tw = 0.55 + Math.sin(time * 4 + i) * 0.45;
            px(sx, sy, rgbStr(220, 230, 255, tw));
          }
          ctx.globalAlpha = 1;
        }
      }

      // --- Draw plants ---
      function drawPlants(time) {
        const sat = scene().plantSat;
        for (const p of plants) {
          for (let i = 0; i < p.height; i++) {
            const sway = Math.sin(time * 0.001 + p.sway + i * 0.3) * (i * 0.15);
            const x = Math.round(p.x + sway);
            const y = SAND_LINE - i;
            const lightness = plantLightness(30 + (i / p.height) * 25);
            const [r, g, b] = hslToRgb(p.hue, sat, lightness);
            px(x, y, rgbStr(r, g, b));
            if (i > 2 && i % 3 === 0) {
              px(x + (i % 2 === 0 ? 1 : -1), y, rgbStr(r, g + 20, b, 0.7));
            }
          }
        }
      }

      // --- Draw fish ---
      function drawFish(fish, time) {
        const dir = fish.facing;
        const shape = FISH_SHAPES[fish.shapeIdx];
        const body = dir > 0 ? shape.bodyR : shape.bodyL;
        const tail = dir > 0 ? shape.tailR : shape.tailL;
        const eye = dir > 0 ? shape.eyeR : shape.eyeL;
        const fin = dir > 0 ? shape.finR : shape.finL;

        const s = fish.size;
        const ps = Math.round(PIXEL * s);
        const ox = Math.round(fish.x * PIXEL);
        const oy = Math.round(fish.y * PIXEL);
        const [r, g, b] = fish.color;
        const [tr, tg, tb] = fish.tailColor;
        const [fr, fg, fb] = fish.finColor;

        // Gentle tail wiggle — calm amplitude
        const wiggle = Math.round(Math.sin(time * fish.wiggleRate + fish.swimTimer) * 0.5);

        // Body
        ctx.fillStyle = rgbStr(r, g, b);
        for (const [bx, by] of body) {
          ctx.fillRect(ox + bx * ps, oy + by * ps, ps, ps);
        }

        // Stripe overlay for detail
        if (fish.hasStripe) {
          const sr = Math.min(255, r + 45);
          const sg = Math.min(255, g + 45);
          const sb = Math.min(255, b + 45);
          ctx.fillStyle = rgbStr(sr, sg, sb, 0.6);
          for (const [bx, by] of body) {
            if (shape.stripeY.includes(by)) {
              ctx.fillRect(ox + bx * ps, oy + by * ps, ps, ps);
            }
          }
        }

        // Tail with wiggle
        ctx.fillStyle = rgbStr(tr, tg, tb);
        for (const [tx, ty] of tail) {
          ctx.fillRect(ox + (tx + wiggle * -dir) * ps, oy + ty * ps, ps, ps);
        }

        // Eye
        ctx.fillStyle = '#fff';
        ctx.fillRect(ox + eye[0] * ps, oy + eye[1] * ps, ps, ps);

        // Fin — gentle, shows about 60% of the time with smooth sine
        const finAlpha = Math.sin(time * fish.wiggleRate * 0.5 + fish.swimTimer) * 0.3 + 0.5;
        if (finAlpha > 0.4) {
          ctx.fillStyle = rgbStr(fr, fg, fb, Math.min(finAlpha, 0.7));
          for (const [fx, fy] of fin) {
            ctx.fillRect(ox + fx * ps, oy + fy * ps, ps, ps);
          }
        }
      }

      // --- Draw food ---
      function drawFood(food) {
        px(Math.round(food.x), Math.round(food.y), food.color.hex);
        // tiny sparkle
        if (Math.random() > 0.7) {
          px(Math.round(food.x) + 1, Math.round(food.y), food.color.hex);
        }
      }

      // --- Draw bubbles ---
      function drawBubbles() {
        const [br, bg, bb] = scene().bubbleColor;
        for (const b of bubbles) {
          const alpha = Math.max(0, 0.5 - b.y / 20);
          px(Math.round(b.x), Math.round(b.y), rgbStr(br, bg, bb, alpha));
        }
      }

      // --- Update fish ---
      function updateFish(fish, dt) {
        fish.swimTimer += dt;

        // --- Food interest (governed by personality) ---
        // Only look for food sometimes, based on hunger trait
        if (!fish.targetFood || foods.indexOf(fish.targetFood) === -1) {
          fish.targetFood = null;

          // Less hungry fish only check occasionally
          if (foods.length > 0 && Math.random() < fish.hunger * 0.05) {
            let minDist = Infinity;
            const detectRange = 30 + fish.hunger * 50; // hungry fish notice from farther
            for (const f of foods) {
              const dx = f.x - fish.x;
              const dy = f.y - fish.y;
              const dist = Math.sqrt(dx * dx + dy * dy);
              if (dist < detectRange && dist < minDist) {
                minDist = dist;
                fish.targetFood = f;
              }
            }
          }
        }

        if (fish.targetFood) {
          // Swim toward food — gently, not a mad dash
          const dx = fish.targetFood.x - fish.x;
          const dy = fish.targetFood.y - fish.y;
          const dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < 5) {
            // Eat!
            const foodColor = fish.targetFood.color.rgb;
            fish.color = lerpColor(fish.color, foodColor, 0.25);
            fish.tailColor = lerpColor(fish.tailColor, foodColor, 0.15);
            fish.finColor = lerpColor(fish.finColor, foodColor, 0.1);
            foods.splice(foods.indexOf(fish.targetFood), 1);
            fish.targetFood = null;
            fedCount++;

            // Tiny bubble
            bubbles.push({
              x: fish.x + 3,
              y: fish.y,
              vx: (Math.random() - 0.5) * 0.15,
              vy: -0.2 - Math.random() * 0.15,
            });
          } else {
            // Gentle pursuit — scales with hunger
            const accel = 0.02 + fish.hunger * 0.03;
            fish.vx += (dx / dist) * accel;
            fish.vy += (dy / dist) * accel * 0.7;
          }
        } else {
          // --- Idle swimming (the main state) ---
          // Each fish drifts on its own rhythm
          const drift = fish.laziness;

          // Occasional gentle course change
          if (Math.random() < 0.008 * (1 - drift)) {
            fish.vx += (Math.random() - 0.5) * 0.2;
            fish.vy += (Math.random() - 0.5) * 0.12;
          }

          // Smooth sine wave — unique per fish
          fish.vy += Math.sin(fish.swimTimer * 0.0015 + fish.laziness * 100) * 0.001;
          fish.vx += Math.cos(fish.swimTimer * 0.001 + fish.hunger * 100) * 0.0005;
        }

        // Damping — heavier for a floaty feel
        fish.vx *= 0.97;
        fish.vy *= 0.96;

        // Speed limit — personal max speed
        const speed = Math.sqrt(fish.vx * fish.vx + fish.vy * fish.vy);
        const maxSpeed = 0.7 * fish.swimSpeed;
        if (speed > maxSpeed) {
          fish.vx = (fish.vx / speed) * maxSpeed;
          fish.vy = (fish.vy / speed) * maxSpeed;
        }

        // Update position
        fish.x += fish.vx;
        fish.y += fish.vy;

        // Facing direction — only flip when clearly moving
        if (Math.abs(fish.vx) > 0.03) {
          fish.facing = fish.vx > 0 ? 1 : -1;
        }

        // Soft boundary — gentle nudge back instead of hard bounce
        const margin = 4;
        const nudge = 0.01;
        if (fish.x < margin) fish.vx += nudge;
        if (fish.x > COLS - 12) fish.vx -= nudge;
        if (fish.y < margin) fish.vy += nudge;
        if (fish.y > SAND_LINE - 10) fish.vy -= nudge;

        // Hard clamp just in case
        fish.x = Math.max(2, Math.min(COLS - 10, fish.x));
        fish.y = Math.max(2, Math.min(SAND_LINE - 8, fish.y));
      }

      // --- Update food ---
      function updateFood() {
        for (let i = foods.length - 1; i >= 0; i--) {
          const f = foods[i];
          f.vy = Math.min(f.vy + 0.003, 0.15); // gentle gravity
          f.y += f.vy;
          f.x += Math.sin(f.y * 0.1) * 0.05; // gentle drift

          // Settle on sand
          if (f.y >= SAND_LINE - 1) {
            f.y = SAND_LINE - 1;
            f.vy = 0;
            f.life -= 1;
            if (f.life <= 0) {
              foods.splice(i, 1);
            }
          }
        }
      }

      // --- Update bubbles ---
      function updateBubbles() {
        for (let i = bubbles.length - 1; i >= 0; i--) {
          const b = bubbles[i];
          b.x += b.vx + Math.sin(b.y * 0.2) * 0.05;
          b.y += b.vy;
          if (b.y < 0) bubbles.splice(i, 1);
        }
      }

      // --- Random idle bubbles ---
      function spawnIdleBubble() {
        if (Math.random() < 0.005) {
          bubbles.push({
            x: 5 + Math.random() * (COLS - 10),
            y: SAND_LINE - 2,
            vx: (Math.random() - 0.5) * 0.1,
            vy: -0.2 - Math.random() * 0.2,
          });
        }
      }

      // --- Click to drop food ---
      function getCanvasPos(e) {
        const rect = canvas.getBoundingClientRect();
        const scaleX = canvas.width / rect.width;
        const scaleY = canvas.height / rect.height;
        const clientX = e.touches ? e.touches[0].clientX : e.clientX;
        const clientY = e.touches ? e.touches[0].clientY : e.clientY;
        return {
          x: (clientX - rect.left) * scaleX / PIXEL,
          y: (clientY - rect.top) * scaleY / PIXEL,
        };
      }

      // --- Food color selection ---
      let selectedColorIdx = null; // null = random
      const swatches = document.querySelectorAll('.palette-swatch');
      swatches.forEach(swatch => {
        swatch.addEventListener('click', () => {
          swatches.forEach(s => { s.classList.remove('active'); s.setAttribute('aria-pressed', 'false'); });
          swatch.classList.add('active');
          swatch.setAttribute('aria-pressed', 'true');
          const c = swatch.dataset.color;
          selectedColorIdx = c === 'random' ? null : parseInt(c);
        });
      });

      // --- Scene selection (persisted to URL) ---
      const sceneBtns = document.querySelectorAll('.scene-btn');
      function applyScene(name, push) {
        if (!SCENES[name]) name = 'day';
        currentScene = name;
        sceneBtns.forEach(b => {
          const active = b.dataset.scene === name;
          b.classList.toggle('active', active);
          b.setAttribute('aria-pressed', active ? 'true' : 'false');
        });
        if (push) {
          const url = new URL(window.location.href);
          if (name === 'day') url.searchParams.delete('scene');
          else url.searchParams.set('scene', name);
          history.replaceState(null, '', url.toString());
        }
      }
      sceneBtns.forEach(btn => {
        btn.addEventListener('click', () => applyScene(btn.dataset.scene, true));
      });
      const initialScene = new URLSearchParams(window.location.search).get('scene');
      if (initialScene && SCENES[initialScene]) applyScene(initialScene, false);

      function dropFood(e) {
        e.preventDefault();
        const pos = getCanvasPos(e);
        if (pos.y >= SAND_LINE) return; // don't drop food in sand

        const color = selectedColorIdx !== null
          ? FOOD_COLORS[selectedColorIdx]
          : FOOD_COLORS[Math.floor(Math.random() * FOOD_COLORS.length)];
        // Drop 2-4 food pellets near click
        const count = 2 + Math.floor(Math.random() * 3);
        for (let i = 0; i < count; i++) {
          foods.push({
            x: pos.x + (Math.random() - 0.5) * 4,
            y: pos.y + (Math.random() - 0.5) * 2,
            vy: 0.05,
            color,
            life: 600, // frames before disappearing
          });
        }
      }

      canvas.addEventListener('click', dropFood);
      canvas.addEventListener('touchstart', dropFood, { passive: false });

      // --- Maybe spawn a new fish if well-fed ---
      let spawnCheck = 0;
      function maybeSpawnFish() {
        spawnCheck++;
        if (spawnCheck % 300 === 0 && fishes.length < 20 && fedCount > fishes.length * 2) {
          const parent = fishes[Math.floor(Math.random() * fishes.length)];
          const baby = createFish(parent.x + (Math.random() - 0.5) * 8, parent.y);
          // Inherit parent colors with slight variation
          baby.color = lerpColor(parent.color, baby.color, 0.3);
          baby.tailColor = lerpColor(parent.tailColor, baby.tailColor, 0.3);
          baby.finColor = lerpColor(parent.finColor, baby.finColor, 0.3);
          baby.size = 0.5 + Math.random() * 0.2; // babies are small
          fishes.push(baby);
        }
      }

      // --- Main loop ---
      let lastTime = 0;
      const fishCountEl = document.getElementById('fish-count');
      const fedCountEl = document.getElementById('fed-count');
      function gameLoop(timestamp) {
        if (document.hidden) { return; }
        const dt = Math.min(timestamp - lastTime, 50);
        lastTime = timestamp;

        drawBackground();
        drawPlants(timestamp);

        // Update and draw food
        updateFood();
        for (const f of foods) drawFood(f);

        // Update and draw fish
        for (const fish of fishes) {
          updateFish(fish, dt);
          drawFish(fish, timestamp);
        }

        // Bubbles
        spawnIdleBubble();
        updateBubbles();
        drawBubbles();

        maybeSpawnFish();

        // HUD
        fishCountEl.textContent = fishes.length;
        fedCountEl.textContent = fedCount;

        requestAnimationFrame(gameLoop);
      }

      // --- Init ---
      spawnPlants();
      spawnInitialFish();
      requestAnimationFrame(gameLoop);
      document.addEventListener("visibilitychange", () => {
        if (!document.hidden) requestAnimationFrame(gameLoop);
      });
    </script>
</BaseLayout>
