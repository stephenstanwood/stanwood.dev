---
import BaseLayout from "../layouts/BaseLayout.astro";
import RedesignRolodex from "../components/redesign-rolodex/RedesignRolodex.tsx";
const title = "Redesign Rolodex — stanwood.dev";
---

<BaseLayout
  title={title}
  description="Paste a URL and spin through alternate-universe redesigns. AI-generated design directions with concept cards, palettes, and ready-to-use prompts."
  slug="redesign-rolodex"
  favicon="/favicon-rr.svg"
  themeColor="#FAF6F0"
  fontsUrl="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Cabin:wght@400;500;600;700&family=Permanent+Marker&family=Playfair+Display:wght@400;600&display=swap"
  schemaCategory="WebApplication"
  schemaName="Redesign Rolodex"
>
  <Fragment slot="head">
    <style is:global>
      /* ─── Redesign Rolodex Theme ─────────────────────────────── */
      :root {
        --rr-bg: #FAF6F0;
        --rr-card-bg: #FFFDF8;
        --rr-ink: #1C1917;
        --rr-gray: #57534E;
        --rr-light-gray: #A8A29E;
        --rr-border: #E7E0D8;
        --rr-border-dark: #D4CBC0;
        --rr-accent: #6D28D9;
        --rr-accent-light: #EDE9FE;
        --rr-accent-hover: #5B21B6;
        --rr-warm: #EA580C;
        --rr-warm-light: #FFF7ED;
      }

      body {
        font-family: 'Cabin', system-ui, sans-serif;
        background: var(--rr-bg);
        color: var(--rr-ink);
        margin: 0;
      }

      /* ─── Animations ─────────────────────────────────────────── */
      @keyframes rrFadeIn {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes rrFadeMsg {
        0%   { opacity: 0; transform: translateY(8px); }
        15%  { opacity: 1; transform: translateY(0); }
        85%  { opacity: 1; transform: translateY(0); }
        100% { opacity: 0; transform: translateY(-8px); }
      }
      @keyframes rrFloat {
        0%, 100% { transform: translateY(0) rotate(-2deg); }
        50% { transform: translateY(-8px) rotate(2deg); }
      }
      @keyframes rrFloat2 {
        0%, 100% { transform: translateY(0) rotate(3deg); }
        50% { transform: translateY(-6px) rotate(-1deg); }
      }
      @keyframes rrFloat3 {
        0%, 100% { transform: translateY(0) rotate(-1deg); }
        50% { transform: translateY(-10px) rotate(3deg); }
      }

      .rr-fade-in { animation: rrFadeIn 0.4s ease-out; }

      /* ─── Page Layout ────────────────────────────────────────── */
      .rr-page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .rr-header {
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .rr-back {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        color: var(--rr-light-gray);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: color 0.15s;
      }
      .rr-back:hover { color: var(--rr-ink); }
      .rr-back svg { width: 16px; height: 16px; }

      .rr-brand {
        font-family: 'Space Mono', monospace;
        font-weight: 700;
        font-size: 1rem;
        color: var(--rr-accent);
        letter-spacing: -0.02em;
      }

      .rr-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 1rem 1.5rem 4rem;
      }

      .rr-app {
        width: 100%;
        max-width: 800px;
      }

      /* ─── Form / Idle ────────────────────────────────────────── */
      .rr-form-container {
        text-align: center;
        padding-top: 2rem;
      }

      .rr-title {
        font-family: 'Permanent Marker', cursive;
        font-size: 2.5rem;
        color: var(--rr-ink);
        margin: 0 0 0.25rem;
        letter-spacing: -0.02em;
        line-height: 1.1;
      }
      @media (min-width: 480px) {
        .rr-title { font-size: 3.5rem; }
      }

      .rr-subtitle {
        font-family: 'Space Mono', monospace;
        font-size: 0.85rem;
        color: var(--rr-light-gray);
        margin: 0 0 2.5rem;
      }

      .rr-form {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        max-width: 520px;
        margin: 0 auto;
      }
      @media (min-width: 480px) {
        .rr-form {
          flex-direction: row;
          gap: 0.5rem;
        }
      }

      .rr-input {
        flex: 1;
        padding: 0.85rem 1rem;
        border: 2px solid var(--rr-border);
        border-radius: 10px;
        font-family: 'Space Mono', monospace;
        font-size: 1rem;
        color: var(--rr-ink);
        background: var(--rr-card-bg);
        transition: border-color 0.15s;
        box-sizing: border-box;
      }
      .rr-input:focus {
        outline: none;
        border-color: var(--rr-accent);
        box-shadow: 0 0 0 3px rgba(109, 40, 217, 0.1);
      }
      .rr-input::placeholder { color: var(--rr-border-dark); }

      .rr-btn-primary {
        padding: 0.85rem 1.75rem;
        border: 2px solid var(--rr-accent);
        border-radius: 10px;
        background: var(--rr-accent);
        color: #fff;
        font-family: 'Space Mono', monospace;
        font-size: 0.85rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.15s;
        white-space: nowrap;
      }
      .rr-btn-primary:hover {
        background: var(--rr-accent-hover);
        border-color: var(--rr-accent-hover);
      }
      .rr-btn-primary:active { transform: scale(0.98); }
      .rr-btn-primary:disabled { opacity: 0.3; cursor: not-allowed; }

      .rr-helper {
        font-size: 0.75rem;
        color: var(--rr-light-gray);
        margin: 1.5rem 0 0;
        font-style: italic;
      }

      /* ─── Mode Toggle ────────────────────────────────────────── */
      .rr-mode-toggle {
        display: flex;
        gap: 0;
        justify-content: center;
        margin: 1.5rem auto 0;
        max-width: 400px;
        border: 2px solid var(--rr-border);
        border-radius: 10px;
        overflow: hidden;
        background: var(--rr-card-bg);
      }

      .rr-mode-btn {
        flex: 1;
        padding: 0.6rem 0.75rem;
        border: none;
        background: transparent;
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--rr-gray);
        cursor: pointer;
        transition: all 0.15s;
        text-transform: uppercase;
        letter-spacing: 0.02em;
      }
      .rr-mode-btn:not(:last-child) {
        border-right: 1.5px solid var(--rr-border);
      }
      .rr-mode-btn:hover { color: var(--rr-accent); }
      .rr-mode-active {
        background: var(--rr-accent);
        color: #fff !important;
      }

      /* ─── Examples ───────────────────────────────────────────── */
      .rr-examples {
        margin-top: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        flex-wrap: wrap;
      }

      .rr-examples-label {
        font-family: 'Space Mono', monospace;
        font-size: 0.75rem;
        color: var(--rr-light-gray);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .rr-example-btn {
        padding: 0.3rem 0.7rem;
        border: 1.5px solid var(--rr-border);
        border-radius: 999px;
        background: transparent;
        color: var(--rr-gray);
        font-family: 'Space Mono', monospace;
        font-size: 0.75rem;
        cursor: pointer;
        transition: all 0.15s;
      }
      .rr-example-btn:hover {
        border-color: var(--rr-accent);
        color: var(--rr-accent);
        background: var(--rr-accent-light);
      }

      /* ─── Error ──────────────────────────────────────────────── */
      .rr-error {
        margin-top: 1.5rem;
        padding: 1rem 1.25rem;
        background: #fef2f2;
        border: 1.5px solid #fecaca;
        border-radius: 10px;
        text-align: center;
      }
      .rr-error p {
        color: #b91c1c;
        font-size: 0.85rem;
        margin: 0 0 0.75rem;
      }

      .rr-btn-secondary {
        padding: 0.5rem 1.25rem;
        border: 1.5px solid var(--rr-border);
        border-radius: 8px;
        background: var(--rr-card-bg);
        color: var(--rr-gray);
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        cursor: pointer;
        transition: all 0.15s;
      }
      .rr-btn-secondary:hover {
        border-color: var(--rr-accent);
        color: var(--rr-accent);
      }

      /* ─── Loading ────────────────────────────────────────────── */
      .rr-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        padding: 6rem 0;
        animation: rrFadeIn 0.3s ease-out;
      }

      .rr-loading-spinner {
        position: relative;
        width: 80px;
        height: 60px;
      }

      .rr-spinner-card {
        position: absolute;
        width: 52px;
        height: 36px;
        border-radius: 6px;
        border: 2px solid var(--rr-border-dark);
        background: var(--rr-card-bg);
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
      }
      .rr-sc-1 {
        top: 0; left: 6px;
        animation: rrFloat 2.4s ease-in-out infinite;
      }
      .rr-sc-2 {
        top: 6px; left: 16px;
        animation: rrFloat2 2.8s ease-in-out infinite;
        background: var(--rr-accent-light);
        border-color: var(--rr-accent);
      }
      .rr-sc-3 {
        top: 12px; left: 26px;
        animation: rrFloat3 2.2s ease-in-out infinite;
      }

      .rr-loading-text {
        font-family: 'Space Mono', monospace;
        font-size: 0.85rem;
        color: var(--rr-gray);
        text-align: center;
        min-height: 1.5em;
        animation: rrFadeMsg 2.2s ease-in-out;
      }

      /* ─── Result Layout ──────────────────────────────────────── */
      .rr-result-container {
        width: 100%;
      }

      .rr-result-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
      }

      .rr-btn-reset {
        padding: 0.4rem 0.85rem;
        border: 1.5px solid var(--rr-border);
        border-radius: 8px;
        background: var(--rr-card-bg);
        color: var(--rr-gray);
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.15s;
        text-transform: uppercase;
      }
      .rr-btn-reset:hover {
        border-color: var(--rr-accent);
        color: var(--rr-accent);
      }

      .rr-result-url {
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        color: var(--rr-gray);
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .rr-result-count {
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        color: var(--rr-light-gray);
        background: var(--rr-accent-light);
        padding: 0.2rem 0.6rem;
        border-radius: 999px;
      }

      /* ─── Rolodex Viewer ─────────────────────────────────────── */
      .rr-rolodex-container {
        width: 100%;
      }

      .rr-rolodex-counter {
        text-align: center;
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        color: var(--rr-light-gray);
        margin-bottom: 0.75rem;
        letter-spacing: 0.05em;
      }

      .rr-rolodex-stage {
        position: relative;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .rr-nav-btn {
        flex-shrink: 0;
        width: 40px;
        height: 40px;
        border: 2px solid var(--rr-border);
        border-radius: 50%;
        background: var(--rr-card-bg);
        color: var(--rr-gray);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.15s;
        z-index: 20;
      }
      .rr-nav-btn:hover:not(:disabled) {
        border-color: var(--rr-accent);
        color: var(--rr-accent);
        background: var(--rr-accent-light);
      }
      .rr-nav-btn:disabled {
        opacity: 0.25;
        cursor: not-allowed;
      }

      .rr-rolodex-track {
        flex: 1;
        position: relative;
        height: 500px;
        perspective: 1200px;
        overflow: hidden;
        touch-action: pan-y;
      }
      @media (max-width: 600px) {
        .rr-rolodex-track { height: 440px; }
      }

      .rr-rolodex-slot {
        position: absolute;
        top: 0;
        left: 50%;
        width: 380px;
        max-width: 90%;
        margin-left: -190px;
        height: 100%;
        transition: all 0.45s cubic-bezier(0.22, 1, 0.36, 1);
        transform-style: preserve-3d;
      }
      @media (max-width: 480px) {
        .rr-rolodex-slot {
          width: 300px;
          margin-left: -150px;
        }
      }

      .rr-rolodex-dots {
        display: flex;
        justify-content: center;
        gap: 6px;
        margin-top: 1rem;
        flex-wrap: wrap;
        max-width: 100%;
      }

      .rr-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        border: 1.5px solid var(--rr-border-dark);
        background: transparent;
        cursor: pointer;
        padding: 0;
        transition: all 0.2s;
      }
      .rr-dot:hover { border-color: var(--rr-accent); }
      .rr-dot-active {
        background: var(--rr-accent);
        border-color: var(--rr-accent);
        transform: scale(1.3);
      }

      /* ─── Cards (shared) ─────────────────────────────────────── */
      .rr-card {
        background: var(--rr-card-bg);
        border: 2px solid var(--rr-border);
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 4px 24px rgba(28, 25, 23, 0.08), 0 1px 4px rgba(28, 25, 23, 0.04);
        height: 100%;
        display: flex;
        flex-direction: column;
      }

      .rr-card-number {
        font-family: 'Space Mono', monospace;
        font-size: 0.6rem;
        font-weight: 700;
        color: var(--rr-light-gray);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: 0.75rem 1rem 0;
      }

      .rr-card-label-tag {
        font-family: 'Space Mono', monospace;
        font-size: 0.65rem;
        font-weight: 700;
        color: var(--rr-accent);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 0.25rem 1rem 0;
      }

      /* ─── Current Site Card ──────────────────────────────────── */
      .rr-card-screenshot {
        margin: 0.75rem;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid var(--rr-border);
        flex-shrink: 0;
      }
      .rr-card-screenshot img {
        width: 100%;
        height: auto;
        display: block;
        max-height: 220px;
        object-fit: cover;
        object-position: top;
      }

      .rr-card-info {
        padding: 0 1rem 1rem;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        overflow-y: auto;
      }

      .rr-card-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.1rem;
        font-weight: 600;
        margin: 0;
        color: var(--rr-ink);
        line-height: 1.2;
      }

      .rr-card-desc {
        font-size: 0.8rem;
        color: var(--rr-gray);
        margin: 0;
        line-height: 1.45;
      }

      .rr-card-style-notes {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
        margin-top: 0.25rem;
      }

      .rr-style-tag {
        font-family: 'Space Mono', monospace;
        font-size: 0.6rem;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        background: var(--rr-bg);
        border: 1px solid var(--rr-border);
        color: var(--rr-gray);
      }
      .rr-style-tag-accent {
        background: var(--rr-accent-light);
        border-color: var(--rr-accent);
        color: var(--rr-accent);
        font-weight: 700;
      }

      /* ─── Direction Card ─────────────────────────────────────── */
      .rr-card-concept {
        margin: 0.75rem;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid var(--rr-border);
        flex-shrink: 0;
        height: 200px;
        background: #f5f5f5;
      }

      .rr-concept-iframe {
        width: 400px;
        height: 280px;
        border: none;
        transform: scale(0.714);
        transform-origin: top left;
        pointer-events: none;
      }

      .rr-card-tagline {
        font-size: 0.8rem;
        color: var(--rr-gray);
        margin: 0;
        line-height: 1.4;
        font-style: italic;
      }

      .rr-card-palette {
        display: flex;
        gap: 4px;
        margin: 0.2rem 0;
      }

      .rr-swatch {
        width: 20px;
        height: 20px;
        border-radius: 4px;
        border: 1px solid rgba(0,0,0,0.1);
        flex-shrink: 0;
      }

      .rr-card-font-dir {
        font-family: 'Space Mono', monospace;
        font-size: 0.65rem;
        color: var(--rr-light-gray);
        margin: 0;
        line-height: 1.4;
      }

      /* ─── Copy Button ────────────────────────────────────────── */
      .rr-copy-btn {
        padding: 0.5rem 1rem;
        border: 1.5px solid var(--rr-accent);
        border-radius: 8px;
        background: transparent;
        color: var(--rr-accent);
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.15s;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-top: auto;
      }
      .rr-copy-btn:hover {
        background: var(--rr-accent);
        color: #fff;
      }
      .rr-copy-copied {
        background: #16a34a;
        border-color: #16a34a;
        color: #fff;
      }

      /* ─── More Controls ──────────────────────────────────────── */
      .rr-more-controls {
        display: flex;
        justify-content: center;
        gap: 0.5rem;
        margin-top: 1.5rem;
        flex-wrap: wrap;
      }

      .rr-more-btn {
        padding: 0.55rem 1.1rem;
        border: 2px solid var(--rr-border);
        border-radius: 10px;
        background: var(--rr-card-bg);
        color: var(--rr-gray);
        font-family: 'Space Mono', monospace;
        font-size: 0.75rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.15s;
      }
      .rr-more-btn:hover:not(:disabled) {
        border-color: var(--rr-accent);
        color: var(--rr-accent);
      }
      .rr-more-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
      }
      .rr-more-weirder:hover:not(:disabled) {
        border-color: var(--rr-warm);
        color: var(--rr-warm);
      }
      .rr-more-calmer:hover:not(:disabled) {
        border-color: #059669;
        color: #059669;
      }
    </style>
  </Fragment>

  <div class="rr-page">
    <a href="#main-content" class="skip-nav">Skip to content</a>

    <header class="rr-header">
      <a href="/" class="rr-back" aria-label="Back to stanwood.dev">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
        stanwood.dev
      </a>
      <span class="rr-brand">// redesign-rolodex</span>
    </header>

    <main id="main-content" class="rr-main">
      <div class="rr-app">
        <RedesignRolodex client:load />
      </div>
    </main>
  </div>
</BaseLayout>
