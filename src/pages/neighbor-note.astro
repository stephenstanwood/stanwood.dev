---
import BaseLayout from "../layouts/BaseLayout.astro";
import NeighborNote from "../components/neighbor-note/NeighborNote.tsx";
const title = "Neighbor Note — stanwood.dev";
---

<BaseLayout
  title={title}
  description="Write polite, non-awkward neighbor notes for real-life situations. Dog got out, package mix-up, noise complaint — we'll help you sound human."
  slug="neighbor-note"
  favicon="/favicon-nn.svg"
  themeColor="#F7F5F0"
  fontsUrl="https://fonts.googleapis.com/css2?family=Caveat:wght@500;700&family=Inter:wght@400;500;600&family=Space+Mono:wght@400;700&display=swap"
  schemaCategory="UtilitiesApplication"
>
  <Fragment slot="head">
    <style is:global>
      /* ─── Neighbor Note Theme ─────────────────────────────────── */
      :root {
        --nn-bg: #F7F5F0;
        --nn-card-bg: #FFFFFF;
        --nn-ink: #2D2A26;
        --nn-gray: #6B6560;
        --nn-light-gray: #A39E97;
        --nn-border: #E5E0D8;
        --nn-border-dark: #D1CBC2;
        --nn-accent: #3D8B6E;
        --nn-accent-light: #E8F5EE;
        --nn-accent-dark: #2E6B54;
        --nn-warm: #D4956A;
        --nn-warm-light: #FFF3EB;
        --nn-warning-bg: #FFF8E1;
        --nn-warning-border: #FFE082;
        --nn-error-bg: #fef2f2;
        --nn-error-border: #fecaca;
      }

      body {
        font-family: 'Inter', system-ui, sans-serif;
        background: var(--nn-bg);
        color: var(--nn-ink);
        margin: 0;
      }

      /* ─── Animations ────────────────────────────────────────── */
      @keyframes nnFadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      @keyframes nnBob {
        0%, 100% { transform: translateY(0) rotate(-5deg); }
        50%      { transform: translateY(-6px) rotate(5deg); }
      }

      .nn-fade-in { animation: nnFadeIn 0.3s ease-out; }

      /* ─── Layout ────────────────────────────────────────────── */
      .nn-page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .nn-header {
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .nn-back {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        color: var(--nn-light-gray);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: color 0.15s;
      }
      .nn-back:hover { color: var(--nn-ink); }
      .nn-back svg { width: 16px; height: 16px; }

      .nn-brand {
        font-family: 'Space Mono', monospace;
        font-weight: 700;
        font-size: 1rem;
        color: var(--nn-accent);
        letter-spacing: -0.02em;
      }

      .nn-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 1.5rem 1.25rem 4rem;
      }

      .nn-app {
        width: 100%;
        max-width: 580px;
      }

      /* ─── Title ─────────────────────────────────────────────── */
      .nn-title {
        font-family: 'Caveat', cursive;
        font-size: 2.8rem;
        font-weight: 700;
        color: var(--nn-ink);
        margin: 0 0 0.15rem;
        line-height: 1.1;
        text-align: center;
      }
      @media (min-width: 480px) {
        .nn-title { font-size: 3.4rem; }
      }

      .nn-subtitle {
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        color: var(--nn-light-gray);
        margin: 0 0 2rem;
        text-align: center;
      }

      /* ─── Scenario cards ────────────────────────────────────── */
      .nn-scenarios {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.65rem;
        margin-bottom: 1.75rem;
      }
      @media (min-width: 480px) {
        .nn-scenarios {
          grid-template-columns: repeat(3, 1fr);
          gap: 0.75rem;
        }
      }

      .nn-scenario-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.35rem;
        padding: 0.85rem 0.5rem;
        border: 2px solid var(--nn-border);
        border-radius: 12px;
        background: var(--nn-card-bg);
        cursor: pointer;
        transition: all 0.15s;
        -webkit-tap-highlight-color: transparent;
      }
      .nn-scenario-card:hover {
        border-color: var(--nn-accent);
        background: var(--nn-accent-light);
      }
      .nn-scenario-card.nn-selected {
        border-color: var(--nn-accent);
        background: var(--nn-accent-light);
        box-shadow: 0 0 0 3px rgba(61, 139, 110, 0.15);
      }

      .nn-scenario-emoji {
        font-size: 1.5rem;
        line-height: 1;
      }

      .nn-scenario-label {
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--nn-gray);
        text-align: center;
        line-height: 1.2;
      }

      /* ─── Form ──────────────────────────────────────────────── */
      .nn-form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }

      .nn-field {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
      }

      .nn-field-row {
        display: flex;
        gap: 0.75rem;
      }

      .nn-field-half {
        flex: 1;
        min-width: 0;
      }

      .nn-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--nn-gray);
      }

      .nn-optional {
        font-weight: 400;
        color: var(--nn-light-gray);
        font-size: 0.7rem;
      }

      .nn-input {
        padding: 0.7rem 0.85rem;
        border: 2px solid var(--nn-border);
        border-radius: 10px;
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 0.9rem;
        color: var(--nn-ink);
        background: var(--nn-card-bg);
        transition: border-color 0.15s;
        box-sizing: border-box;
        width: 100%;
      }
      .nn-input:focus {
        outline: none;
        border-color: var(--nn-accent);
        box-shadow: 0 0 0 3px rgba(61, 139, 110, 0.1);
      }
      .nn-input::placeholder {
        color: var(--nn-border-dark);
      }

      .nn-textarea {
        resize: vertical;
        min-height: 56px;
      }

      /* ─── Tone picker ───────────────────────────────────────── */
      .nn-tone-section {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }

      .nn-tone-row {
        display: flex;
        gap: 0.5rem;
      }

      .nn-tone-btn {
        flex: 1;
        padding: 0.55rem 0.5rem;
        border: 2px solid var(--nn-border);
        border-radius: 10px;
        background: var(--nn-card-bg);
        color: var(--nn-gray);
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 0.8rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.15s;
        text-align: center;
      }
      .nn-tone-btn:hover {
        border-color: var(--nn-accent);
        color: var(--nn-accent);
      }
      .nn-tone-btn.nn-tone-active {
        border-color: var(--nn-accent);
        background: var(--nn-accent-light);
        color: var(--nn-accent-dark);
        font-weight: 600;
      }

      /* ─── Primary button ────────────────────────────────────── */
      .nn-btn-primary {
        padding: 0.85rem 1.75rem;
        border: 2px solid var(--nn-accent);
        border-radius: 12px;
        background: var(--nn-accent);
        color: #fff;
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.15s;
        margin-top: 0.5rem;
      }
      .nn-btn-primary:hover {
        background: var(--nn-accent-dark);
        border-color: var(--nn-accent-dark);
      }
      .nn-btn-primary:active { transform: scale(0.98); }
      .nn-btn-primary:disabled {
        opacity: 0.35;
        cursor: not-allowed;
      }

      /* ─── Error ─────────────────────────────────────────────── */
      .nn-error {
        padding: 0.75rem 1rem;
        background: var(--nn-error-bg);
        border: 1.5px solid var(--nn-error-border);
        border-radius: 10px;
        text-align: center;
      }
      .nn-error p {
        color: #b91c1c;
        font-size: 0.85rem;
        margin: 0;
      }

      /* ─── Loading ───────────────────────────────────────────── */
      .nn-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        padding: 5rem 0;
      }

      .nn-pencil-animation {
        font-size: 2.5rem;
        animation: nnBob 1.2s ease-in-out infinite;
      }

      .nn-loading-text {
        font-family: 'Space Mono', monospace;
        font-size: 0.85rem;
        color: var(--nn-gray);
      }

      /* ─── Results ───────────────────────────────────────────── */
      .nn-results {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
      }

      .nn-warning {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.75rem 1rem;
        background: var(--nn-warning-bg);
        border: 1.5px solid var(--nn-warning-border);
        border-radius: 10px;
        font-size: 0.85rem;
        color: #92400e;
      }
      .nn-warning-icon {
        font-size: 1rem;
        flex-shrink: 0;
      }

      .nn-cards {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }

      .nn-result-card {
        background: var(--nn-card-bg);
        border: 2px solid var(--nn-border);
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(45, 42, 38, 0.06);
      }

      .nn-printable-card {
        border-color: var(--nn-warm);
        border-style: dashed;
      }

      .nn-card-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.65rem 1rem;
        border-bottom: 1px solid var(--nn-border);
        background: rgba(0, 0, 0, 0.015);
      }

      .nn-card-label {
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--nn-light-gray);
      }

      .nn-copy-btn {
        padding: 0.25rem 0.65rem;
        border: 1.5px solid var(--nn-border);
        border-radius: 6px;
        background: transparent;
        color: var(--nn-gray);
        font-family: 'Space Mono', monospace;
        font-size: 0.65rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.15s;
        text-transform: lowercase;
      }
      .nn-copy-btn:hover {
        border-color: var(--nn-accent);
        color: var(--nn-accent);
      }

      .nn-card-text {
        padding: 1rem;
        font-size: 0.9rem;
        line-height: 1.6;
        color: var(--nn-ink);
        margin: 0;
        white-space: pre-line;
      }

      .nn-door-badge {
        display: inline-block;
        margin: 0 1rem 0.85rem;
        padding: 0.25rem 0.6rem;
        background: var(--nn-warm-light);
        border: 1.5px solid var(--nn-warm);
        border-radius: 6px;
        font-family: 'Space Mono', monospace;
        font-size: 0.6rem;
        font-weight: 700;
        color: #92400e;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }

      /* ─── Tone adjuster ─────────────────────────────────────── */
      .nn-adjust-section {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .nn-adjust-label {
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        color: var(--nn-light-gray);
        text-transform: lowercase;
        white-space: nowrap;
      }

      .nn-adjust-row {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
      }

      .nn-adjust-btn {
        padding: 0.35rem 0.75rem;
        border: 1.5px solid var(--nn-border);
        border-radius: 999px;
        background: transparent;
        color: var(--nn-gray);
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 0.75rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.15s;
      }
      .nn-adjust-btn:hover {
        border-color: var(--nn-accent);
        color: var(--nn-accent);
      }
      .nn-adjust-btn.nn-adjust-active {
        border-color: var(--nn-accent);
        background: var(--nn-accent-light);
        color: var(--nn-accent-dark);
      }

      /* ─── Start over ────────────────────────────────────────── */
      .nn-btn-start-over {
        display: block;
        width: 100%;
        padding: 0.85rem;
        border: 2px solid var(--nn-border);
        border-radius: 12px;
        background: transparent;
        color: var(--nn-gray);
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.15s;
        text-transform: lowercase;
      }
      .nn-btn-start-over:hover {
        border-color: var(--nn-accent);
        color: var(--nn-accent);
      }
    </style>
  </Fragment>

  <div class="nn-page">
    <a href="#main-content" class="skip-nav">Skip to content</a>

    <header class="nn-header">
      <a href="/" class="nn-back" aria-label="Back to stanwood.dev">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
        stanwood.dev
      </a>
      <span class="nn-brand">// neighbor-note</span>
    </header>

    <main id="main-content" class="nn-main">
      <div class="nn-app">
        <NeighborNote client:idle />
      </div>
    </main>
  </div>
</BaseLayout>
