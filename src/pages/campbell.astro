      .cb-source-note span {
        font-size: 0.76rem;
        color: var(--cb-light-gray);
      }
      .cb-source-note a {
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--cb-blue);
        text-decoration: none;
      }
      .cb-source-note a:hover { text-decoration: underline; }

      /* ── Homes and roadmap ── */
      .cb-property-metrics {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.65rem;
        margin: 0 0 1rem;
      }
      @media (min-width: 640px) {
        .cb-property-metrics { grid-template-columns: repeat(2, 1fr); }
      }
      .cb-property-metric {
        min-height: 7.25rem;
        padding: 0.85rem 0.95rem;
        color: var(--cb-ink);
        text-decoration: none;
        background: var(--cb-card-bg);
        border: 1px solid var(--cb-border);
        border-radius: 8px;
        transition: border-color 0.16s, box-shadow 0.16s, transform 0.16s;
      }
      .cb-property-metric:hover {
        border-color: var(--cb-blue);
        box-shadow: 0 4px 12px rgba(27, 79, 138, 0.1);
        transform: translateY(-1px);
      }
      .cb-property-metric span,
      .cb-property-metric strong,
      .cb-property-metric em {
