      }
      .cb-anchor-card p,
      .cb-ledger-card p {
        font-size: 0.8rem;
        line-height: 1.5;
        color: var(--cb-gray);
        margin: 0;
      }
      .cb-live-events-head {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
