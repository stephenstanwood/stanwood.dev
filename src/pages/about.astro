---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About Stephen Stanwood — stanwood.dev"
  description="Builder and designer in Campbell, California. Makes apps, games, and tools that solve small everyday problems or just look cool. Shipping fast and keeping it fun."
  slug="about"
  themeColor="#fffef5"
  fontsUrl="https://fonts.googleapis.com/css2?family=Permanent+Marker&display=swap"
  schemaType="WebSite"
  schemaName="Stephen Stanwood"
>
  <style is:global>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #fffef5;
      --ink: #111;
      --yellow: #f5e642;
      --orange: #ff5c1a;
      --blue: #1a4fff;
      --pixel: 3px;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: 'Cabin', sans-serif;
      font-size: 16px;
      line-height: 1.7;
      overflow-x: hidden;
    }

    .about-wrap {
      max-width: 640px;
      margin: 0 auto;
      padding: 48px 24px 80px;
    }

    .about-header {
      background: var(--yellow);
      border: var(--pixel) solid var(--ink);
      box-shadow: 6px 6px 0 var(--ink);
      padding: 32px;
      margin-bottom: 40px;
    }

    .about-header h1 {
      font-family: 'Permanent Marker', cursive;
      font-size: 36px;
      line-height: 1.2;
      margin-bottom: 8px;
    }

    .about-header .subtitle {
      font-family: 'Space Mono', monospace;
      font-size: 13px;
      letter-spacing: 0.05em;
      opacity: 0.7;
    }

    .about-section {
      margin-bottom: 36px;
    }

    .about-section h2 {
      font-family: 'Permanent Marker', cursive;
      font-size: 22px;
      margin-bottom: 12px;
      border-bottom: var(--pixel) solid var(--ink);
      padding-bottom: 6px;
      display: inline-block;
    }

    .about-section p {
      margin-bottom: 14px;
    }

    .about-section a {
      color: var(--blue);
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .about-section a:hover {
      color: var(--orange);
    }

    /* ── Project grid ── */
    .project-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-top: 16px;
    }

    .project-card {
      display: flex;
      align-items: flex-start;
      gap: 11px;
      border: 2px solid var(--ink);
      padding: 12px 13px;
      background: #fff;
      box-shadow: 3px 3px 0 var(--ink);
      text-decoration: none;
      color: var(--ink);
      transition: background 0.1s, transform 0.1s, box-shadow 0.1s;
    }

    .project-card:hover {
      background: var(--yellow);
      transform: translate(-1px, -1px);
      box-shadow: 4px 4px 0 var(--ink);
    }

    .project-card-emoji {
      font-size: 20px;
      flex-shrink: 0;
      line-height: 1;
      margin-top: 2px;
    }

    .project-card-body {
      min-width: 0;
    }

    .project-card-name {
      font-family: 'Space Mono', monospace;
      font-weight: 700;
      font-size: 11px;
      line-height: 1.3;
      margin-bottom: 3px;
    }

    .project-card-tag {
      font-size: 11px;
      opacity: 0.5;
      line-height: 1.4;
    }

    @media (max-width: 600px) {
      .project-grid { grid-template-columns: 1fr; }
    }

    .back-link {
      display: inline-block;
      font-family: 'Space Mono', monospace;
      font-size: 13px;
      color: var(--ink);
      text-decoration: none;
      margin-bottom: 24px;
      opacity: 0.6;
    }

    .back-link:hover {
      opacity: 1;
    }

    .connect-list {
      list-style: none;
      padding: 0;
      font-family: 'Space Mono', monospace;
      font-size: 14px;
    }

    .connect-list li {
      margin-bottom: 6px;
    }

    .connect-list a {
      color: var(--ink);
      text-decoration: none;
    }

    .connect-list a:hover {
      color: var(--orange);
      text-decoration: underline;
    }

    /* ── Now section ── */
    .now-section {
      margin-bottom: 36px;
    }

    .now-heading {
      font-family: 'Permanent Marker', cursive;
      font-size: 22px;
      margin-bottom: 12px;
      border-bottom: 3px solid var(--ink);
      padding-bottom: 6px;
      display: inline-block;
    }

    .now-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    .now-card {
      border: 2px solid var(--ink);
      padding: 12px 14px;
      background: #fff;
      box-shadow: 3px 3px 0 var(--ink);
    }

    .now-card-label {
      font-family: 'Space Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      opacity: 0.45;
      margin-bottom: 4px;
    }

    .now-card-value {
      font-size: 14px;
      font-weight: 700;
      line-height: 1.4;
    }

    /* ── Stack badges ── */
    .stack-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 12px;
    }

    .stack-badge {
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      font-weight: 700;
      padding: 4px 10px;
      border: 2px solid var(--ink);
      background: var(--bg);
      box-shadow: 2px 2px 0 var(--ink);
      white-space: nowrap;
    }

    .stack-badge.highlight {
      background: var(--yellow);
    }

    /* ── Connect cards ── */
    .connect-cards {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .connect-card {
      display: flex;
      align-items: center;
      gap: 12px;
      border: 2px solid var(--ink);
      padding: 12px 16px;
      background: #fff;
      box-shadow: 3px 3px 0 var(--ink);
      text-decoration: none;
      color: var(--ink);
      font-family: 'Space Mono', monospace;
      font-size: 13px;
      font-weight: 700;
      transition: background 0.1s, transform 0.1s, box-shadow 0.1s;
    }

    .connect-card:hover {
      background: var(--yellow);
      transform: translate(-1px, -1px);
      box-shadow: 4px 4px 0 var(--ink);
    }

    .connect-card-icon {
      font-size: 18px;
      flex-shrink: 0;
    }

    .connect-card-sub {
      font-weight: 400;
      opacity: 0.55;
      font-size: 11px;
      margin-top: 1px;
    }

    /* ── Start here ── */
    .start-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
      margin-top: 16px;
    }

    .start-card {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      border: 2px solid var(--ink);
      padding: 16px;
      background: var(--yellow);
      box-shadow: 3px 3px 0 var(--ink);
      text-decoration: none;
      color: var(--ink);
      transition: background 0.1s, transform 0.1s, box-shadow 0.1s;
    }

    .start-card:hover {
      background: #f0d800;
      transform: translate(-1px, -1px);
      box-shadow: 4px 4px 0 var(--ink);
    }

    .start-card-emoji {
      font-size: 24px;
      flex-shrink: 0;
      line-height: 1;
      margin-top: 2px;
    }

    .start-card-body { min-width: 0; }

    .start-card-name {
      font-family: 'Space Mono', monospace;
      font-weight: 700;
      font-size: 13px;
      margin-bottom: 5px;
    }

    .start-card-desc {
      font-size: 13px;
      line-height: 1.6;
      opacity: 0.75;
    }

    @media (max-width: 600px) {
      .about-header h1 { font-size: 28px; }
      .about-wrap { padding: 32px 16px 60px; }
      .now-grid { grid-template-columns: 1fr; }
    }
  </style>

  <div class="about-wrap">
    <a href="/" class="back-link">&larr; stanwood.dev</a>

    <div class="about-header">
      <h1>Stephen Stanwood</h1>
      <div class="subtitle">builder &middot; designer &middot; developer &middot; campbell, ca</div>
    </div>

    <div class="about-section">
      <h2>Who I Am</h2>
      <p>
        I'm Stephen Stanwood, a builder and designer based in Campbell, California (just south of San Jose).
        I make apps, games, and tools that make life a little simpler or a little more fun.
        Everything on <a href="/">stanwood.dev</a> is something I built because I wanted it to exist.
      </p>
      <p>
        I studied public policy at the University of Chicago and law and business at Georgetown and Santa Clara.
        I've worked at a small law firm, ran my own practice for a while, and also spent time with organizations like City Year and the Electronic Frontier Foundation.
        These days you'll mostly find me swimming pre-dawn laps with a wonderful team, building here, doing yoga, and chasing my two-year-old daughter around the house.
      </p>
    </div>

    <div class="now-section">
      <h2 class="now-heading">Now</h2>
      <div class="now-grid">
        <div class="now-card">
          <div class="now-card-label">Location</div>
          <div class="now-card-value">Campbell, CA</div>
        </div>
        <div class="now-card">
          <div class="now-card-label">Day job</div>
          <div class="now-card-value">US Government</div>
        </div>
        <div class="now-card">
          <div class="now-card-label">Studying</div>
          <div class="now-card-value">CS @ Oregon State</div>
        </div>
        <div class="now-card">
          <div class="now-card-label">Side project</div>
          <div class="now-card-value">stanwood.dev</div>
        </div>
      </div>
    </div>

    <div class="about-section">
      <h2>Start here</h2>
      <p>A few favorites — each does one specific thing and does it well.</p>
      <div class="start-grid">
        <a href="/radar" class="start-card">
          <span class="start-card-emoji">📡</span>
          <div class="start-card-body">
            <div class="start-card-name">AI Radar</div>
            <div class="start-card-desc">A curated daily signal feed of AI launches worth knowing about. No hype, just what matters for builders.</div>
          </div>
        </a>
        <a href="/mlb-gamerank" class="start-card">
          <span class="start-card-emoji">⚾</span>
          <div class="start-card-body">
            <div class="start-card-name">MLB GameRank</div>
            <div class="start-card-desc">Live MLB scores ranked by watchability — closeness, inning, runners on base, and team quality. Updates every 30 seconds.</div>
          </div>
        </a>
        <a href="/green-light" class="start-card">
          <span class="start-card-emoji">🟢</span>
          <div class="start-card-body">
            <div class="start-card-name">Green Light</div>
            <div class="start-card-desc">A 60-second taste quiz that tells you exactly what to order — matches the menu to what you actually enjoy.</div>
          </div>
        </a>
      </div>
    </div>

    <div class="about-section">
      <h2>What I Build</h2>
      <p>
        Tools for curious people — useful, fun, or both, and small enough to actually finish.
        Everything here is free to use. Here's the full list:
      </p>
      <div class="project-grid">
        <a href="https://nbanow.app" class="project-card">
          <span class="project-card-emoji">🏀</span>
          <div class="project-card-body">
            <div class="project-card-name">NBA Now</div>
            <div class="project-card-tag">best NBA game to watch right now</div>
          </div>
        </a>
        <a href="/wtwtw" class="project-card">
          <span class="project-card-emoji">📺</span>
          <div class="project-card-body">
            <div class="project-card-name">What to Watch This Week</div>
            <div class="project-card-tag">best game each night across MLB, NBA &amp; NHL</div>
          </div>
        </a>
        <a href="/mlb-gamerank" class="project-card">
          <span class="project-card-emoji">⚾</span>
          <div class="project-card-body">
            <div class="project-card-name">MLB GameRank</div>
            <div class="project-card-tag">best MLB game to watch right now</div>
          </div>
        </a>
        <a href="/show-swipe" class="project-card">
          <span class="project-card-emoji">🍿</span>
          <div class="project-card-body">
            <div class="project-card-name">Show Swipe</div>
            <div class="project-card-tag">swipe through movie &amp; TV trailers</div>
          </div>
        </a>
        <a href="/swim" class="project-card">
          <span class="project-card-emoji">🏊</span>
          <div class="project-card-body">
            <div class="project-card-name">Lap Lab</div>
            <div class="project-card-tag">custom swim workouts</div>
          </div>
        </a>
        <a href="/nearest-coffee" class="project-card">
          <span class="project-card-emoji">☕</span>
          <div class="project-card-body">
            <div class="project-card-name">Nearest Coffee</div>
            <div class="project-card-tag">nearest open coffee shop</div>
          </div>
        </a>
        <a href="/radar" class="project-card">
          <span class="project-card-emoji">📡</span>
          <div class="project-card-body">
            <div class="project-card-name">AI Radar</div>
            <div class="project-card-tag">curated AI launches for builders</div>
          </div>
        </a>
        <a href="/which-model" class="project-card">
          <span class="project-card-emoji">🧠</span>
          <div class="project-card-body">
            <div class="project-card-name">Which Model?</div>
            <div class="project-card-tag">pick the right AI model for your task</div>
          </div>
        </a>
        <a href="/tldr" class="project-card">
          <span class="project-card-emoji">📄</span>
          <div class="project-card-body">
            <div class="project-card-name">TL;DR</div>
            <div class="project-card-tag">drop a PDF, get the short version</div>
          </div>
        </a>
        <a href="/redesign-rolodex" class="project-card">
          <span class="project-card-emoji">🎰</span>
          <div class="project-card-body">
            <div class="project-card-name">Redesign Rolodex</div>
            <div class="project-card-tag">alternate-universe redesigns for any website</div>
          </div>
        </a>
        <a href="/green-light" class="project-card">
          <span class="project-card-emoji">🟢</span>
          <div class="project-card-body">
            <div class="project-card-name">Green Light</div>
            <div class="project-card-tag">taste quiz → know what to order</div>
          </div>
        </a>
        <a href="/ship-clock" class="project-card">
          <span class="project-card-emoji">🕒</span>
          <div class="project-card-body">
            <div class="project-card-name">Ship Clock</div>
            <div class="project-card-tag">days since your last deploy</div>
          </div>
        </a>
        <a href="/campbell" class="project-card">
          <span class="project-card-emoji">🏛️</span>
          <div class="project-card-body">
            <div class="project-card-name">Campbell, CA</div>
            <div class="project-card-tag">city services, events &amp; permits</div>
          </div>
        </a>
        <a href="/driverless" class="project-card">
          <span class="project-card-emoji">🚗</span>
          <div class="project-card-body">
            <div class="project-card-name">Driverless Cars</div>
            <div class="project-card-tag">self-driving, by the numbers</div>
          </div>
        </a>
        <a href="/museum-label" class="project-card">
          <span class="project-card-emoji">🔖</span>
          <div class="project-card-body">
            <div class="project-card-name">Museum Label</div>
            <div class="project-card-tag">deadpan museum placard for any object</div>
          </div>
        </a>
        <a href="/pixel-aquarium" class="project-card">
          <span class="project-card-emoji">🐠</span>
          <div class="project-card-body">
            <div class="project-card-name">Pixel Aquarium</div>
            <div class="project-card-tag">feed the fish, day to night</div>
          </div>
        </a>
        <a href="/pixel-tide" class="project-card">
          <span class="project-card-emoji">🌊</span>
          <div class="project-card-body">
            <div class="project-card-name">Pixel Tide</div>
            <div class="project-card-tag">no winning, just vibes</div>
          </div>
        </a>
      </div>
    </div>

    <div class="about-section">
      <h2>How I Build</h2>
      <p>
        I build fast and iterate — ship something that works, then refine. Most projects go from idea to live in a day or two.
        I use <a href="https://claude.ai/claude-code">Claude Code</a> as a design partner — riffing back and forth until the vision clicks.
      </p>
      <div class="stack-row">
        <span class="stack-badge highlight">Astro 5</span>
        <span class="stack-badge highlight">React 19</span>
        <span class="stack-badge highlight">Tailwind v4</span>
        <span class="stack-badge">Vercel</span>
        <span class="stack-badge">TypeScript</span>
        <span class="stack-badge">Claude API</span>
        <span class="stack-badge">ESPN API</span>
        <span class="stack-badge">Google Places</span>
      </div>
    </div>

    <div class="about-section">
      <h2>Connect</h2>
      <div class="connect-cards">
        <a href="mailto:stephen@stanwood.dev" class="connect-card">
          <span class="connect-card-icon">✉</span>
          <div>
            <div>stephen@stanwood.dev</div>
            <div class="connect-card-sub">email — best way to reach me</div>
          </div>
        </a>
        <a href="https://www.linkedin.com/in/stephenstanwood" class="connect-card" target="_blank" rel="noopener noreferrer">
          <span class="connect-card-icon">in</span>
          <div>
            <div>LinkedIn</div>
            <div class="connect-card-sub">stephenstanwood</div>
          </div>
        </a>
        <a href="https://github.com/stephenstanwood" class="connect-card" target="_blank" rel="noopener noreferrer">
          <span class="connect-card-icon">⌥</span>
          <div>
            <div>GitHub</div>
            <div class="connect-card-sub">stephenstanwood</div>
          </div>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
