---
import BaseLayout from "../layouts/BaseLayout.astro";

const featuredWork = [
  {
    href: "https://southbaysignal.org",
    label: "Local",
    title: "South Bay Signal",
    description: "Local news, events, and useful civic information for the South Bay.",
  },
  {
    href: "https://nbanow.app",
    label: "Sports",
    title: "NBA Now",
    description: "The best NBA game to watch right now, ranked live so you do not have to channel surf.",
  },
  {
    href: "/radar",
    label: "AI",
    title: "AI Radar",
    description: "A short daily read on what changed in AI and whether it is worth your time.",
  },
  {
    href: "/green-light",
    label: "Food",
    title: "Green Light",
    description: "A taste quiz that helps you pick what to order at a nearby restaurant.",
  },
];

const elsewhere = [
  { href: "mailto:stephen@stanwood.dev", label: "Email", value: "stephen@stanwood.dev" },
  { href: "https://github.com/stephenstanwood", label: "GitHub", value: "stephenstanwood" },
  { href: "https://www.linkedin.com/in/stephenstanwood", label: "LinkedIn", value: "stephenstanwood" },
];
---

<BaseLayout
  title="Stephen Stanwood — About"
  description="Stephen Stanwood is a builder in Campbell, California. He makes small, useful web tools for local information, sports, food, and everyday decisions."
  slug="about"
  themeColor="#faf7ed"
  fontsUrl="https://fonts.googleapis.com/css2?family=Fraunces:wght@500;650;700&display=swap"
  schemaType="WebSite"
  schemaName="Stephen Stanwood"
>
  <style is:global>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --about-paper: #faf7ed;
      --about-ink: #171511;
      --about-muted: #6f6a5f;
      --about-line: #d8d0bf;
      --about-panel: #fffdf6;
      --about-gold: #e9c46a;
      --about-green: #55745d;
      --about-blue: #244f8f;
    }

    body {
      background: var(--about-paper);
      color: var(--about-ink);
      font-family: "Cabin", system-ui, sans-serif;
      font-size: 17px;
      line-height: 1.65;
      overflow-x: hidden;
    }

    a {
      color: inherit;
    }

    .about-page {
      min-height: 100vh;
      background:
        linear-gradient(90deg, rgba(216, 208, 191, 0.32) 1px, transparent 1px),
        linear-gradient(180deg, rgba(216, 208, 191, 0.26) 1px, transparent 1px);
      background-size: 40px 40px;
    }

    .about-shell {
      width: min(1120px, calc(100% - 40px));
      margin: 0 auto;
      padding: 28px 0 72px;
    }

    .about-nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      color: var(--about-muted);
      font-family: "Space Mono", ui-monospace, monospace;
      font-size: 12px;
      line-height: 1.3;
    }

    .about-home {
      text-decoration: none;
    }

    .about-home:hover,
    .about-nav-link:hover {
      color: var(--about-ink);
    }

    .about-nav-links {
      display: flex;
      align-items: center;
      gap: 18px;
    }

    .about-nav-link {
      text-decoration: none;
    }

    .about-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(260px, 360px);
      align-items: center;
      gap: 64px;
      min-height: calc(100svh - 104px);
      padding: 48px 0 64px;
      border-bottom: 1px solid var(--about-line);
    }

    .about-kicker {
      color: var(--about-green);
      font-family: "Space Mono", ui-monospace, monospace;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0;
      margin-bottom: 18px;
    }

    .about-title {
      max-width: 780px;
      font-family: "Fraunces", Georgia, serif;
      font-size: 74px;
      font-weight: 700;
      line-height: 0.98;
      letter-spacing: 0;
    }

    .about-lede {
      max-width: 690px;
      margin-top: 28px;
      color: #312d25;
      font-size: 25px;
      line-height: 1.38;
    }

    .about-intro {
      max-width: 650px;
      margin-top: 22px;
      color: var(--about-muted);
      font-size: 18px;
    }

    .about-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 34px;
    }

    .about-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      border: 1px solid var(--about-ink);
      border-radius: 999px;
      padding: 10px 18px;
      background: var(--about-ink);
      color: var(--about-panel);
      font-family: "Space Mono", ui-monospace, monospace;
      font-size: 12px;
      font-weight: 700;
      line-height: 1;
      text-decoration: none;
      transition: background 0.16s ease, color 0.16s ease, transform 0.16s ease;
    }

    .about-button:hover {
      transform: translateY(-1px);
    }

    .about-button.secondary {
      background: transparent;
      color: var(--about-ink);
    }

    .about-button.secondary:hover {
      background: var(--about-panel);
    }

    .about-portrait {
      position: relative;
      justify-self: end;
      width: 100%;
      max-width: 360px;
      border: 1px solid var(--about-ink);
      border-radius: 8px;
      background: var(--about-panel);
      padding: 12px;
      box-shadow: 18px 18px 0 rgba(23, 21, 17, 0.08);
    }

    .about-portrait::before {
      content: "";
      position: absolute;
      inset: 18px -18px -18px 18px;
      z-index: -1;
      border-radius: 8px;
      background: var(--about-gold);
    }

    .about-portrait img {
      display: block;
      width: 100%;
      aspect-ratio: 1;
      border-radius: 6px;
      object-fit: cover;
      object-position: center top;
    }

    .about-caption {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      padding: 12px 2px 0;
      color: var(--about-muted);
      font-family: "Space Mono", ui-monospace, monospace;
      font-size: 11px;
      line-height: 1.35;
    }

    .about-section {
      padding: 70px 0;
      border-bottom: 1px solid var(--about-line);
    }

    .about-section:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }

    .about-split {
      display: grid;
      grid-template-columns: 280px minmax(0, 1fr);
      gap: 56px;
      align-items: start;
    }

    .section-label {
      color: var(--about-green);
      font-family: "Space Mono", ui-monospace, monospace;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0;
      line-height: 1.4;
      text-transform: uppercase;
    }

    .about-copy {
      max-width: 760px;
    }

    .about-copy p + p {
      margin-top: 20px;
    }

    .about-copy a {
      color: var(--about-blue);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 4px;
    }

    .about-copy a:hover {
      color: var(--about-green);
    }

    .about-facts {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-top: 34px;
    }

    .about-fact {
      border: 1px solid var(--about-line);
      border-radius: 8px;
      background: rgba(255, 253, 246, 0.78);
      padding: 16px;
    }

    .about-fact dt {
      color: var(--about-muted);
      font-family: "Space Mono", ui-monospace, monospace;
      font-size: 11px;
      line-height: 1.3;
      margin-bottom: 6px;
    }

    .about-fact dd {
      color: var(--about-ink);
      font-size: 15px;
      font-weight: 700;
      line-height: 1.35;
    }

    .work-list {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .work-card {
      min-height: 188px;
      border: 1px solid var(--about-line);
      border-radius: 8px;
      background: rgba(255, 253, 246, 0.9);
      padding: 22px;
      color: var(--about-ink);
      text-decoration: none;
      transition: border-color 0.16s ease, box-shadow 0.16s ease, transform 0.16s ease;
    }

    .work-card:hover {
      border-color: var(--about-ink);
      box-shadow: 0 16px 32px rgba(23, 21, 17, 0.08);
      transform: translateY(-2px);
    }

    .work-label {
      color: var(--about-green);
      font-family: "Space Mono", ui-monospace, monospace;
      font-size: 11px;
      font-weight: 700;
      line-height: 1.3;
    }

    .work-title {
      margin-top: 22px;
      font-family: "Fraunces", Georgia, serif;
      font-size: 28px;
      font-weight: 650;
      line-height: 1.05;
      letter-spacing: 0;
    }

    .work-description {
      margin-top: 12px;
      color: var(--about-muted);
      font-size: 15px;
      line-height: 1.55;
    }

    .elsewhere-list {
      display: grid;
      gap: 10px;
      max-width: 620px;
    }

    .elsewhere-link {
      display: grid;
      grid-template-columns: 110px minmax(0, 1fr);
      gap: 18px;
      align-items: center;
      border-bottom: 1px solid var(--about-line);
      padding: 14px 0;
      color: var(--about-ink);
      text-decoration: none;
    }

    .elsewhere-link:hover .elsewhere-value {
      color: var(--about-blue);
    }

    .elsewhere-label {
      color: var(--about-green);
      font-family: "Space Mono", ui-monospace, monospace;
      font-size: 11px;
      font-weight: 700;
      line-height: 1.3;
    }

    .elsewhere-value {
      font-size: 19px;
      font-weight: 700;
      line-height: 1.25;
      word-break: break-word;
      transition: color 0.16s ease;
    }

    @media (max-width: 860px) {
      .about-shell {
        width: min(100% - 32px, 680px);
        padding-top: 22px;
      }

      .about-nav {
        align-items: flex-start;
      }

      .about-nav-links {
        gap: 12px;
      }

      .about-hero {
        grid-template-columns: 1fr;
        gap: 34px;
        min-height: auto;
        padding: 42px 0 54px;
      }

      .about-title {
        font-size: 48px;
      }

      .about-lede {
        font-size: 21px;
      }

      .about-intro {
        font-size: 17px;
      }

      .about-portrait {
        justify-self: start;
        max-width: 300px;
      }

      .about-section {
        padding: 52px 0;
      }

      .about-split {
        grid-template-columns: 1fr;
        gap: 22px;
      }

      .about-facts,
      .work-list {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 520px) {
      body {
        font-size: 16px;
      }

      .about-shell {
        width: min(100% - 28px, 680px);
      }

      .about-title {
        font-size: 40px;
      }

      .about-lede {
        font-size: 20px;
      }

      .about-actions {
        flex-direction: column;
      }

      .about-button {
        width: 100%;
      }

      .about-portrait {
        max-width: none;
        box-shadow: 10px 10px 0 rgba(23, 21, 17, 0.08);
      }

      .about-portrait::before {
        inset: 12px -10px -10px 12px;
      }

      .about-caption,
      .elsewhere-link {
        grid-template-columns: 1fr;
      }

      .about-caption {
        display: grid;
        gap: 4px;
      }

      .work-card {
        min-height: 0;
      }
    }
  </style>

  <div class="about-page">
    <div class="about-shell">
      <nav class="about-nav" aria-label="About page navigation">
        <a class="about-home" href="/">stanwood.dev</a>
        <div class="about-nav-links">
          <a class="about-nav-link" href="#work">Work</a>
          <a class="about-nav-link" href="#connect">Contact</a>
        </div>
      </nav>

      <header class="about-hero">
        <div>
          <p class="about-kicker">Campbell, California</p>
          <h1 class="about-title">Stephen Stanwood</h1>
          <p class="about-lede">
            I build small, useful things for the internet: tools for watching sports,
            finding dinner, following local news, and making sense of what just changed.
          </p>
          <p class="about-intro">
            My favorite projects have a narrow promise and a little personality. You should
            know what they do in five seconds, use them without an account, and leave with a
            real answer.
          </p>
          <div class="about-actions" aria-label="Primary links">
            <a class="about-button" href="#work">See selected work</a>
            <a class="about-button secondary" href="mailto:stephen@stanwood.dev">Email me</a>
          </div>
        </div>

        <figure class="about-portrait">
          <img src="/images/headshot.png" alt="Stephen Stanwood" width="400" height="400" />
          <figcaption class="about-caption">
            <span>Builder, designer, developer</span>
            <span>Bay Area</span>
          </figcaption>
        </figure>
      </header>

      <section class="about-section" aria-labelledby="about-story-title">
        <div class="about-split">
          <h2 id="about-story-title" class="section-label">About</h2>
          <div class="about-copy">
            <p>
              I am a builder based in Campbell, just south of San Jose. I studied public
              policy at the University of Chicago, then law and business at Georgetown and
              Santa Clara. Before I got this deep into building software, I worked around
              law, public policy, education, civil liberties, and local institutions.
            </p>
            <p>
              That background still shows up in the work. I like making complicated
              information feel easier to act on, whether that is a city agenda, a game
              schedule, a restaurant menu, or a flood of new AI tools.
            </p>
            <p>
              Outside the laptop, I am usually swimming early, doing yoga, or hanging out
              with my family.
            </p>

            <dl class="about-facts" aria-label="Quick facts">
              <div class="about-fact">
                <dt>Based in</dt>
                <dd>Campbell, CA</dd>
              </div>
              <div class="about-fact">
                <dt>Drawn to</dt>
                <dd>Useful public information</dd>
              </div>
              <div class="about-fact">
                <dt>Style</dt>
                <dd>Small tools, finished enough</dd>
              </div>
            </dl>
          </div>
        </div>
      </section>

      <section id="work" class="about-section" aria-labelledby="about-work-title">
        <div class="about-split">
          <h2 id="about-work-title" class="section-label">Selected Work</h2>
          <div class="work-list">
            {featuredWork.map((item) => (
              <a class="work-card" href={item.href}>
                <span class="work-label">{item.label}</span>
                <h3 class="work-title">{item.title}</h3>
                <p class="work-description">{item.description}</p>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section id="connect" class="about-section" aria-labelledby="about-connect-title">
        <div class="about-split">
          <h2 id="about-connect-title" class="section-label">Connect</h2>
          <div class="about-copy">
            <p>
              The best place to start is email. I am also easy to find on GitHub and LinkedIn.
            </p>
            <div class="elsewhere-list" aria-label="Contact links">
              {elsewhere.map((item) => (
                <a class="elsewhere-link" href={item.href}>
                  <span class="elsewhere-label">{item.label}</span>
                  <span class="elsewhere-value">{item.value}</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
