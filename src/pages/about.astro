---
import BaseLayout from "../layouts/BaseLayout.astro";
import { execSync } from "node:child_process";

// ── Recently shipped: pulled from git log at build time ────────────
type Ship = {
  hash: string;
  project: string;
  message: string;
  date: string;       // ISO
  iso: string;        // YYYY-MM-DD
  href: string | null;
  emoji: string;
  display: string;
};

// Project key → public link, emoji, and display name
const PROJECT_META: Record<string, { href: string | null; emoji: string; display: string }> = {
  "pixel-tide":      { href: "/pixel-tide",       emoji: "🌊", display: "Pixel Tide" },
  "pixel-aquarium":  { href: "/pixel-aquarium",   emoji: "🐠", display: "Pixel Aquarium" },
  "mlb-gamerank":    { href: "/mlb-gamerank",     emoji: "⚾", display: "MLB GameRank" },
  "swim":            { href: "/swim",             emoji: "🏊", display: "Lap Lab" },
  "ship-clock":      { href: "/ship-clock",       emoji: "🕒", display: "Ship Clock" },
  "which-model":     { href: "/which-model",      emoji: "🧠", display: "Which Model?" },
  "driverless":      { href: "/driverless",       emoji: "🚗", display: "Driverless" },
  "campbell":        { href: "/campbell",         emoji: "🏛️", display: "Campbell, CA" },
  "wtwtw":           { href: "/wtwtw",            emoji: "📺", display: "WTWTW" },
  "nearest-coffee":  { href: "/nearest-coffee",   emoji: "☕", display: "Nearest Coffee" },
  "green-light":     { href: "/green-light",      emoji: "🟢", display: "Green Light" },
  "museum-label":    { href: "/museum-label",     emoji: "🔖", display: "Museum Label" },
  "tldr":            { href: "/tldr",             emoji: "📄", display: "TL;DR" },
  "redesign-rolodex":{ href: "/redesign-rolodex", emoji: "🎰", display: "Redesign Rolodex" },
  "show-swipe":      { href: "/show-swipe",       emoji: "🍿", display: "Show Swipe" },
  "nba-now":         { href: "https://nbanow.app", emoji: "🏀", display: "NBA Now" },
  "radar":           { href: "/radar",            emoji: "📡", display: "AI Radar" },
  "about":           { href: "/about",            emoji: "👤", display: "About" },
  "shop":            { href: "/shop",             emoji: "🛍️", display: "Shop" },
  "youtube":         { href: null,                emoji: "📺", display: "YouTube Queue" },
  "money":           { href: null,                emoji: "💰", display: "Money" },
  "index":           { href: "/",                 emoji: "🏠", display: "Homepage" },
  "home":            { href: "/",                 emoji: "🏠", display: "Homepage" },
  "homepage":        { href: "/",                 emoji: "🏠", display: "Homepage" },
};

// Skip non-project commits
const SKIP_PREFIXES = /^(chore|daily cleanup|data|fix|refactor|docs|test|build|ci|style|deps|deps-dev):/i;

let recentShips: Ship[] = [];
try {
  const raw = execSync("git log --pretty=format:%h%x09%s%x09%cI -n 200", {
    cwd: process.cwd(),
    encoding: "utf-8",
    timeout: 5000,
  });

  const seenProjects = new Set<string>();
  for (const line of raw.split("\n")) {
    const [hash, subject, iso] = line.split("\t");
    if (!hash || !subject || !iso) continue;
    if (SKIP_PREFIXES.test(subject)) continue;
    // Strip trailing "(#123)" PR refs
    const cleanSubject = subject.replace(/\s*\(#\d+\)\s*$/, "");
    const m = cleanSubject.match(/^([a-z0-9-]+):\s*(.+)$/i);
    if (!m) continue;
    const project = m[1].toLowerCase();
    const message = m[2].trim();
    const meta = PROJECT_META[project];
    if (!meta) continue;
    // Limit to one entry per project so the feed shows breadth, not just the last project touched
    if (seenProjects.has(project)) continue;
    seenProjects.add(project);
    recentShips.push({
      hash,
      project,
      message,
      date: iso,
      iso: iso.slice(0, 10),
      href: meta.href,
      emoji: meta.emoji,
      display: meta.display,
    });
    if (recentShips.length >= 8) break;
  }
} catch {
  // Build environment without git history → render section empty (gracefully hidden)
  recentShips = [];
}

function relTime(iso: string): string {
  const then = new Date(iso).getTime();
  const days = Math.floor((Date.now() - then) / 86400000);
  if (days <= 0) return "today";
  if (days === 1) return "yesterday";
  if (days < 7) return `${days}d ago`;
  if (days < 30) return `${Math.floor(days / 7)}w ago`;
  if (days < 365) return `${Math.floor(days / 30)}mo ago`;
  return `${Math.floor(days / 365)}y ago`;
}

// Stats: project count and ship count over last 30 days (from same log scan)
let shipsLast30 = 0;
let activeProjects = 0;
try {
  const raw = execSync("git log --pretty=format:%s%x09%cI -n 500 --since='30 days ago'", {
    cwd: process.cwd(),
    encoding: "utf-8",
    timeout: 5000,
  });
  const projects = new Set<string>();
  for (const line of raw.split("\n")) {
    const [subject] = line.split("\t");
    if (!subject) continue;
    if (SKIP_PREFIXES.test(subject)) continue;
    const cleanSubject = subject.replace(/\s*\(#\d+\)\s*$/, "");
    const m = cleanSubject.match(/^([a-z0-9-]+):\s*/i);
    if (!m) continue;
    const project = m[1].toLowerCase();
    if (!PROJECT_META[project]) continue;
    projects.add(project);
    shipsLast30++;
  }
  activeProjects = projects.size;
} catch {
  shipsLast30 = 0;
  activeProjects = 0;
}
---

<BaseLayout
  title="About Stephen Stanwood — stanwood.dev"
  description="Builder and designer in Campbell, California. Makes apps, games, and tools that solve small everyday problems or just look cool. Shipping fast and keeping it fun."
  slug="about"
  themeColor="#fffef5"
  fontsUrl="https://fonts.googleapis.com/css2?family=Permanent+Marker&display=swap"
  schemaType="WebSite"
  schemaName="Stephen Stanwood"
>
  <style is:global>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #fffef5;
      --ink: #111;
      --yellow: #f5e642;
      --orange: #ff5c1a;
      --blue: #1a4fff;
      --pixel: 3px;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: 'Cabin', sans-serif;
      font-size: 16px;
      line-height: 1.7;
      overflow-x: hidden;
    }

    .about-wrap {
      max-width: 640px;
      margin: 0 auto;
      padding: 48px 24px 80px;
    }

    .about-header {
      background: var(--yellow);
      border: var(--pixel) solid var(--ink);
      box-shadow: 6px 6px 0 var(--ink);
      padding: 32px;
      margin-bottom: 40px;
    }

    .about-header h1 {
      font-family: 'Permanent Marker', cursive;
      font-size: 36px;
      line-height: 1.2;
      margin-bottom: 8px;
    }

    .about-header .subtitle {
      font-family: 'Space Mono', monospace;
      font-size: 13px;
      letter-spacing: 0.05em;
      opacity: 0.7;
    }

    .about-section {
      margin-bottom: 36px;
    }

    .about-section h2 {
      font-family: 'Permanent Marker', cursive;
      font-size: 22px;
      margin-bottom: 12px;
      border-bottom: var(--pixel) solid var(--ink);
      padding-bottom: 6px;
      display: inline-block;
    }

    .about-section p {
      margin-bottom: 14px;
    }

    .about-section a {
      color: var(--blue);
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .about-section a:hover {
      color: var(--orange);
    }

    /* ── Project grid ── */
    .project-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-top: 16px;
    }

    .project-card {
      display: flex;
      align-items: flex-start;
      gap: 11px;
      border: 2px solid var(--ink);
      padding: 12px 13px;
      background: #fff;
      box-shadow: 3px 3px 0 var(--ink);
      text-decoration: none;
      color: var(--ink);
      transition: background 0.1s, transform 0.1s, box-shadow 0.1s;
    }

    .project-card:hover {
      background: var(--yellow);
      transform: translate(-1px, -1px);
      box-shadow: 4px 4px 0 var(--ink);
    }

    .project-card-emoji {
      font-size: 20px;
      flex-shrink: 0;
      line-height: 1;
      margin-top: 2px;
    }

    .project-card-body {
      min-width: 0;
    }

    .project-card-name {
      font-family: 'Space Mono', monospace;
      font-weight: 700;
      font-size: 11px;
      line-height: 1.3;
      margin-bottom: 3px;
    }

    .project-card-tag {
      font-size: 11px;
      opacity: 0.5;
      line-height: 1.4;
    }

    @media (max-width: 600px) {
      .project-grid { grid-template-columns: 1fr; }
    }

    .back-link {
      display: inline-block;
      font-family: 'Space Mono', monospace;
      font-size: 13px;
      color: var(--ink);
      text-decoration: none;
      margin-bottom: 24px;
      opacity: 0.6;
    }

    .back-link:hover {
      opacity: 1;
    }

    .connect-list {
      list-style: none;
      padding: 0;
      font-family: 'Space Mono', monospace;
      font-size: 14px;
    }

    .connect-list li {
      margin-bottom: 6px;
    }

    .connect-list a {
      color: var(--ink);
      text-decoration: none;
    }

    .connect-list a:hover {
      color: var(--orange);
      text-decoration: underline;
    }

    /* ── Recently shipped ── */
    .ships-section {
      margin-bottom: 36px;
    }

    .ships-heading-row {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
      flex-wrap: wrap;
    }

    .ships-heading {
      font-family: 'Permanent Marker', cursive;
      font-size: 22px;
      border-bottom: 3px solid var(--ink);
      padding-bottom: 6px;
      display: inline-block;
    }

    .ships-stats {
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--ink);
      opacity: 0.55;
    }

    .ships-stats strong {
      color: var(--orange);
      font-weight: 700;
    }

    .ships-list {
      display: flex;
      flex-direction: column;
      gap: 0;
      border: 2px solid var(--ink);
      box-shadow: 4px 4px 0 var(--ink);
      background: #fff;
    }

    .ship-row {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 12px 14px;
      border-bottom: 1px dashed rgba(0,0,0,0.12);
      text-decoration: none;
      color: var(--ink);
      transition: background 0.1s;
    }
    .ship-row:last-child { border-bottom: none; }
    .ship-row:hover {
      background: var(--yellow);
    }
    .ship-row.no-link {
      cursor: default;
    }
    .ship-row.no-link:hover {
      background: transparent;
    }

    .ship-tag {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.02em;
      padding: 3px 8px;
      border: 1.5px solid var(--ink);
      background: var(--bg);
      flex-shrink: 0;
      white-space: nowrap;
      align-self: flex-start;
      margin-top: 1px;
    }

    .ship-tag-emoji {
      font-size: 12px;
      line-height: 1;
    }

    .ship-body {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .ship-msg {
      font-size: 13px;
      line-height: 1.45;
      color: var(--ink);
    }

    .ship-time {
      font-family: 'Space Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.05em;
      color: var(--ink);
      opacity: 0.45;
    }

    .ships-foot {
      font-family: 'Space Mono', monospace;
      font-size: 10px;
      color: var(--ink);
      opacity: 0.45;
      margin-top: 10px;
      letter-spacing: 0.05em;
    }

    @media (max-width: 600px) {
      .ship-row { flex-direction: column; gap: 6px; padding: 11px 12px; }
      .ship-tag { font-size: 10px; padding: 2px 6px; }
    }

    /* ── Now section ── */
    .now-section {
      margin-bottom: 36px;
    }

    .now-heading {
      font-family: 'Permanent Marker', cursive;
      font-size: 22px;
      margin-bottom: 12px;
      border-bottom: 3px solid var(--ink);
      padding-bottom: 6px;
      display: inline-block;
    }

    .now-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    .now-card {
      border: 2px solid var(--ink);
      padding: 12px 14px;
      background: #fff;
      box-shadow: 3px 3px 0 var(--ink);
    }

    .now-card-label {
      font-family: 'Space Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      opacity: 0.45;
      margin-bottom: 4px;
    }

    .now-card-value {
      font-size: 14px;
      font-weight: 700;
      line-height: 1.4;
    }

    /* ── Stack badges ── */
    .stack-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 12px;
    }

    .stack-badge {
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      font-weight: 700;
      padding: 4px 10px;
      border: 2px solid var(--ink);
      background: var(--bg);
      box-shadow: 2px 2px 0 var(--ink);
      white-space: nowrap;
    }

    .stack-badge.highlight {
      background: var(--yellow);
    }

    /* ── Connect cards ── */
    .connect-cards {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .connect-card {
      display: flex;
      align-items: center;
      gap: 12px;
      border: 2px solid var(--ink);
      padding: 12px 16px;
      background: #fff;
      box-shadow: 3px 3px 0 var(--ink);
      text-decoration: none;
      color: var(--ink);
      font-family: 'Space Mono', monospace;
      font-size: 13px;
      font-weight: 700;
      transition: background 0.1s, transform 0.1s, box-shadow 0.1s;
    }

    .connect-card:hover {
      background: var(--yellow);
      transform: translate(-1px, -1px);
      box-shadow: 4px 4px 0 var(--ink);
    }

    .connect-card-icon {
      font-size: 18px;
      flex-shrink: 0;
    }

    .connect-card-sub {
      font-weight: 400;
      opacity: 0.55;
      font-size: 11px;
      margin-top: 1px;
    }

    /* ── Start here ── */
    .start-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
      margin-top: 16px;
    }

    .start-card {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      border: 2px solid var(--ink);
      padding: 16px;
      background: var(--yellow);
      box-shadow: 3px 3px 0 var(--ink);
      text-decoration: none;
      color: var(--ink);
      transition: background 0.1s, transform 0.1s, box-shadow 0.1s;
    }

    .start-card:hover {
      background: #f0d800;
      transform: translate(-1px, -1px);
      box-shadow: 4px 4px 0 var(--ink);
    }

    .start-card-emoji {
      font-size: 24px;
      flex-shrink: 0;
      line-height: 1;
      margin-top: 2px;
    }

    .start-card-body { min-width: 0; }

    .start-card-name {
      font-family: 'Space Mono', monospace;
      font-weight: 700;
      font-size: 13px;
      margin-bottom: 5px;
    }

    .start-card-desc {
      font-size: 13px;
      line-height: 1.6;
      opacity: 0.75;
    }

    @media (max-width: 600px) {
      .about-header h1 { font-size: 28px; }
      .about-wrap { padding: 32px 16px 60px; }
      .now-grid { grid-template-columns: 1fr; }
    }
  </style>

  <div class="about-wrap">
    <a href="/" class="back-link">&larr; stanwood.dev</a>

    <div class="about-header">
      <h1>Stephen Stanwood</h1>
      <div class="subtitle">builder &middot; designer &middot; developer &middot; campbell, ca</div>
    </div>

    <div class="about-section">
      <h2>Who I Am</h2>
      <p>
        I'm Stephen Stanwood, a builder and designer based in Campbell, California (just south of San Jose).
        I make apps, games, and tools that make life a little simpler or a little more fun.
        Everything on <a href="/">stanwood.dev</a> is something I built because I wanted it to exist.
      </p>
      <p>
        I studied public policy at the University of Chicago and law and business at Georgetown and Santa Clara.
        I've worked at a small law firm, ran my own practice for a while, and also spent time with organizations like City Year and the Electronic Frontier Foundation.
        These days you'll mostly find me swimming pre-dawn laps with a wonderful team, building here, doing yoga, and chasing my two-year-old daughter around the house.
      </p>
    </div>

    <div class="now-section">
      <h2 class="now-heading">Now</h2>
      <div class="now-grid">
        <div class="now-card">
          <div class="now-card-label">Location</div>
          <div class="now-card-value">Campbell, CA</div>
        </div>
        <div class="now-card">
          <div class="now-card-label">Day job</div>
          <div class="now-card-value">US Government</div>
        </div>
        <div class="now-card">
          <div class="now-card-label">Studying</div>
          <div class="now-card-value">CS @ Oregon State</div>
        </div>
        <div class="now-card">
          <div class="now-card-label">Side project</div>
          <div class="now-card-value">stanwood.dev</div>
        </div>
      </div>
    </div>

    {recentShips.length > 0 && (
      <div class="ships-section">
        <div class="ships-heading-row">
          <h2 class="ships-heading">Recently Shipped</h2>
          {(shipsLast30 > 0 || activeProjects > 0) && (
            <span class="ships-stats">
              <strong>{shipsLast30}</strong> ships across <strong>{activeProjects}</strong> projects · last 30 days
            </span>
          )}
        </div>
        <div class="ships-list">
          {recentShips.map((s) => (
            s.href ? (
              <a href={s.href} class="ship-row" aria-label={`${s.display}: ${s.message}`}>
                <span class="ship-tag">
                  <span class="ship-tag-emoji">{s.emoji}</span>
                  {s.display}
                </span>
                <span class="ship-body">
                  <span class="ship-msg">{s.message}</span>
                  <span class="ship-time">{relTime(s.date)}</span>
                </span>
              </a>
            ) : (
              <div class="ship-row no-link">
                <span class="ship-tag">
                  <span class="ship-tag-emoji">{s.emoji}</span>
                  {s.display}
                </span>
                <span class="ship-body">
                  <span class="ship-msg">{s.message}</span>
                  <span class="ship-time">{relTime(s.date)}</span>
                </span>
              </div>
            )
          ))}
        </div>
        <p class="ships-foot">live from git · one row per project, most recent first</p>
      </div>
    )}

    <div class="about-section">
      <h2>Start here</h2>
      <p>A few favorites — each does one specific thing and does it well.</p>
      <div class="start-grid">
        <a href="/radar" class="start-card">
          <span class="start-card-emoji">📡</span>
          <div class="start-card-body">
            <div class="start-card-name">AI Radar</div>
            <div class="start-card-desc">A curated daily signal feed of AI launches worth knowing about. No hype, just what matters for builders.</div>
          </div>
        </a>
        <a href="/mlb-gamerank" class="start-card">
          <span class="start-card-emoji">⚾</span>
          <div class="start-card-body">
            <div class="start-card-name">MLB GameRank</div>
            <div class="start-card-desc">Live MLB scores ranked by watchability — closeness, inning, runners on base, and team quality. Updates every 30 seconds.</div>
          </div>
        </a>
        <a href="/green-light" class="start-card">
          <span class="start-card-emoji">🟢</span>
          <div class="start-card-body">
            <div class="start-card-name">Green Light</div>
            <div class="start-card-desc">A 60-second taste quiz that tells you exactly what to order — matches the menu to what you actually enjoy.</div>
          </div>
        </a>
      </div>
    </div>

    <div class="about-section">
      <h2>What I Build</h2>
      <p>
        Tools for curious people — useful, fun, or both, and small enough to actually finish.
        Everything here is free to use. Here's the full list:
      </p>
      <div class="project-grid">
        <a href="https://nbanow.app" class="project-card">
          <span class="project-card-emoji">🏀</span>
          <div class="project-card-body">
            <div class="project-card-name">NBA Now</div>
            <div class="project-card-tag">best NBA game to watch right now</div>
          </div>
        </a>
        <a href="/wtwtw" class="project-card">
          <span class="project-card-emoji">📺</span>
          <div class="project-card-body">
            <div class="project-card-name">What to Watch This Week</div>
            <div class="project-card-tag">best game each night across MLB, NBA &amp; NHL</div>
          </div>
        </a>
        <a href="/mlb-gamerank" class="project-card">
          <span class="project-card-emoji">⚾</span>
          <div class="project-card-body">
            <div class="project-card-name">MLB GameRank</div>
            <div class="project-card-tag">best MLB game to watch right now</div>
          </div>
        </a>
        <a href="/show-swipe" class="project-card">
          <span class="project-card-emoji">🍿</span>
          <div class="project-card-body">
            <div class="project-card-name">Show Swipe</div>
            <div class="project-card-tag">swipe through movie &amp; TV trailers</div>
          </div>
        </a>
        <a href="/swim" class="project-card">
          <span class="project-card-emoji">🏊</span>
          <div class="project-card-body">
            <div class="project-card-name">Lap Lab</div>
            <div class="project-card-tag">custom swim workouts</div>
          </div>
        </a>
        <a href="/nearest-coffee" class="project-card">
          <span class="project-card-emoji">☕</span>
          <div class="project-card-body">
            <div class="project-card-name">Nearest Coffee</div>
            <div class="project-card-tag">nearest open coffee shop</div>
          </div>
        </a>
