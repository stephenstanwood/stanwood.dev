---
import BaseLayout from "../layouts/BaseLayout.astro";
import ShipClock from "../components/ShipClock.tsx";
const title = "Ship Clock — stanwood.dev";
---

<BaseLayout
  title={title}
  description="A single number on the wall: days since your last deploy. Connect your GitHub repo and keep yourself honest. One number, zero excuses, maximum accountability."
  slug="ship-clock"
  favicon="/favicon-ship-clock.svg"
  themeColor="#fffef5"
  fontsUrl="https://fonts.googleapis.com/css2?family=Permanent+Marker&family=Space+Mono:wght@400;700&family=Cabin:wght@400;700&display=swap"
  schemaCategory="DeveloperApplication"
>
  <Fragment slot="head">
    <style is:global>
      :root {
        --sc-bg: #fffef5;
        --sc-ink: #111;
        --sc-pixel: 3px;
        --sc-accent: #ff5c1a;
      }

      body {
        font-family: 'Cabin', sans-serif;
        background: var(--sc-bg);
        color: var(--sc-ink);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .sc-page {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 24px;
        min-height: 100vh;
      }

      .sc-back {
        position: fixed;
        top: 20px;
        left: 20px;
        font-family: 'Space Mono', monospace;
        font-size: 13px;
        color: var(--sc-ink);
        text-decoration: none;
        opacity: 0.6;
        transition: opacity 0.2s;
      }
      .sc-back:hover { opacity: 1; }

      .sc-card {
        border: var(--sc-pixel) solid var(--sc-ink);
        box-shadow: 4px 4px 0 var(--sc-ink);
        background: #fff;
        padding: 48px 64px;
        text-align: center;
        max-width: 480px;
        width: 100%;
      }

      .sc-number {
        font-family: 'Permanent Marker', cursive;
        font-size: clamp(72px, 20vw, 160px);
        line-height: 1;
        color: var(--sc-ink);
        margin-bottom: 8px;
      }

      .sc-today {
        font-size: clamp(32px, 8vw, 56px);
        color: var(--sc-accent);
      }

      .sc-label {
        font-family: 'Space Mono', monospace;
        font-size: clamp(14px, 3vw, 18px);
        letter-spacing: 0.05em;
        text-transform: lowercase;
        opacity: 0.7;
      }

      .sc-meta {
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        margin-top: 24px;
        opacity: 0.4;
      }

      .sc-error {
        font-family: 'Space Mono', monospace;
        font-size: clamp(16px, 4vw, 22px);
        color: var(--sc-accent);
        margin-bottom: 8px;
      }

      .sc-wrap {
        display: flex;
        flex-direction: column;
        gap: 16px;
        max-width: 480px;
        width: 100%;
      }

      .sc-what-shipped {
        border: var(--sc-pixel) solid var(--sc-ink);
        box-shadow: 4px 4px 0 var(--sc-ink);
        background: #fff;
        padding: 20px 24px;
      }

      .sc-section-label {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--sc-ink);
        opacity: 0.35;
        margin-bottom: 10px;
      }

      .sc-shipped-row {
        display: flex;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 8px;
      }

      .sc-project-badge {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.05em;
        background: var(--sc-accent);
        color: #fff;
        padding: 2px 8px;
        white-space: nowrap;
      }

      .sc-shipped-summary {
        font-family: 'Cabin', sans-serif;
        font-size: 15px;
        font-weight: 600;
        color: var(--sc-ink);
      }

      .sc-shipped-meta {
        display: flex;
        gap: 12px;
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        opacity: 0.4;
      }

      .sc-history {
        border: var(--sc-pixel) solid var(--sc-ink);
        box-shadow: 4px 4px 0 var(--sc-ink);
        background: #fff;
        padding: 20px 24px;
      }

      .sc-history-list {
        display: flex;
        flex-direction: column;
        gap: 0;
      }

      .sc-history-row {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 8px 0;
        border-bottom: 1px solid rgba(0,0,0,0.06);
      }
      .sc-history-row:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }
      .sc-history-row:first-child {
        padding-top: 0;
      }

      .sc-history-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--sc-ink);
        opacity: 0.25;
        flex-shrink: 0;
        margin-top: 6px;
      }

      .sc-history-body {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
      }

      .sc-history-msg {
        font-family: 'Cabin', sans-serif;
        font-size: 13px;
        color: var(--sc-ink);
        opacity: 0.8;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .sc-history-time {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        color: var(--sc-ink);
        opacity: 0.35;
      }

      .sc-history-sha {
        opacity: 0.6;
      }

      .sc-meta-link {
        color: inherit;
        text-decoration: none;
        border-bottom: 1px dotted currentColor;
        transition: opacity 0.15s;
      }
      .sc-meta-link:hover { opacity: 1 !important; }

      /* ── Status label ── */
      .sc-status {
        font-family: 'Space Mono', monospace;
        font-size: clamp(11px, 2.5vw, 13px);
        letter-spacing: 0.08em;
        text-transform: lowercase;
        margin-top: 6px;
        opacity: 0.75;
      }
      .sc-status--hot  { color: var(--sc-accent); }
      .sc-status--good { color: #22c55e; }
      .sc-status--warn { color: #f59e0b; }
      .sc-status--bad  { color: #ef4444; }

      /* ── Activity heatmap ── */
      .sc-activity {
        border: var(--sc-pixel) solid var(--sc-ink);
        box-shadow: 4px 4px 0 var(--sc-ink);
        background: #fff;
        padding: 16px 20px;
      }

      .sc-dots {
        display: grid;
        grid-template-columns: repeat(28, 1fr);
        gap: 3px;
        margin-top: 8px;
      }

      .sc-dot {
        aspect-ratio: 1;
        border-radius: 2px;
        background: #e5e5e5;
        cursor: default;
      }
      .sc-dot--active {
        background: var(--sc-ink);
      }

      /* ── Share button ── */
      .sc-share-btn {
        margin-top: 20px;
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        letter-spacing: 0.1em;
        text-transform: lowercase;
        color: var(--sc-ink);
        background: transparent;
        border: 1.5px solid var(--sc-ink);
        padding: 6px 16px;
        cursor: pointer;
        opacity: 0.45;
        transition: opacity 0.15s;
      }
      .sc-share-btn:hover { opacity: 1; }

      /* ── Stats strip ── */
      .sc-stats {
        border: var(--sc-pixel) solid var(--sc-ink);
        box-shadow: 4px 4px 0 var(--sc-ink);
        background: #fff;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 16px;
        flex-wrap: wrap;
      }

      .sc-stat {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
      }

      .sc-stat-num {
        font-family: 'Permanent Marker', cursive;
        font-size: clamp(22px, 5vw, 32px);
        line-height: 1;
        color: var(--sc-ink);
      }

      .sc-stat-label {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: lowercase;
        opacity: 0.5;
        white-space: nowrap;
      }

      .sc-stat-divider {
        width: 1px;
        height: 36px;
        background: var(--sc-ink);
        opacity: 0.12;
      }

      @media (max-width: 480px) {
        .sc-card {
          padding: 32px 24px;
        }
        .sc-what-shipped,
        .sc-history,
        .sc-activity,
        .sc-stats {
          padding: 14px 16px;
        }
        .sc-dots {
          gap: 2px;
        }
      }

      /* ── How it works / build your own ── */
      .sc-explainer {
        max-width: 480px;
        width: 100%;
        margin-top: 40px;
        padding-top: 32px;
        border-top: 1.5px solid rgba(0,0,0,0.08);
      }

      .sc-explainer-heading {
        font-family: 'Permanent Marker', cursive;
        font-size: clamp(20px, 5vw, 28px);
        color: var(--sc-ink);
        margin: 0 0 6px;
      }

      .sc-explainer-sub {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: lowercase;
        color: var(--sc-ink);
        opacity: 0.4;
        margin: 0 0 20px;
      }

      .sc-steps {
        display: flex;
        flex-direction: column;
        gap: 16px;
        margin-bottom: 24px;
      }

      .sc-step {
        display: flex;
        gap: 14px;
        align-items: flex-start;
      }

      .sc-step-num {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        font-weight: 700;
        color: var(--sc-accent);
        opacity: 0.7;
        padding-top: 2px;
        flex-shrink: 0;
        width: 22px;
      }

      .sc-step-title {
        font-family: 'Cabin', sans-serif;
        font-size: 14px;
        font-weight: 700;
        color: var(--sc-ink);
        margin-bottom: 2px;
      }

      .sc-step-body {
        font-family: 'Cabin', sans-serif;
        font-size: 13px;
        color: var(--sc-ink);
        opacity: 0.55;
        line-height: 1.5;
      }

      .sc-code-block {
        border: var(--sc-pixel) solid var(--sc-ink);
        box-shadow: 3px 3px 0 var(--sc-ink);
        background: #111;
        color: #fffef5;
        padding: 16px 18px;
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        line-height: 1.7;
        overflow-x: auto;
        white-space: pre;
        margin-bottom: 12px;
        position: relative;
      }

      .sc-code-comment { color: rgba(255,254,245,0.3); }
      .sc-code-key     { color: #ff5c1a; }
      .sc-code-str     { color: #7dde8a; }
      .sc-code-var     { color: #ffd06e; }

      .sc-copy-btn {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: lowercase;
        color: var(--sc-ink);
        background: transparent;
        border: 1.5px solid var(--sc-ink);
        padding: 5px 14px;
        cursor: pointer;
        opacity: 0.4;
        transition: opacity 0.15s;
        margin-bottom: 8px;
      }
      .sc-copy-btn:hover { opacity: 1; }

      .sc-explainer-note {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        color: var(--sc-ink);
        opacity: 0.35;
        line-height: 1.6;
        margin-top: 8px;
      }

      /* ── Hero image ── */
      .sc-hero {
        width: 100%;
        max-width: 480px;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 24px;
        position: relative;
        border: var(--sc-pixel) solid var(--sc-ink);
        box-shadow: 4px 4px 0 var(--sc-ink);
      }
      .sc-hero img {
        width: 100%;
        height: 160px;
        object-fit: cover;
        display: block;
      }
      .sc-hero::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, transparent 30%, rgba(255, 254, 245, 0.85) 100%);
        pointer-events: none;
      }

      /* ── Intro header ── */
      .sc-intro {
        text-align: center;
        margin-bottom: 20px;
        max-width: 480px;
        width: 100%;
      }
      .sc-intro-title {
        font-family: 'Permanent Marker', cursive;
        font-size: clamp(32px, 9vw, 52px);
        color: var(--sc-accent);
        margin: 0 0 4px;
        line-height: 1.05;
      }
      .sc-intro-sub {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        color: var(--sc-ink);
        opacity: 0.4;
        margin: 0 0 10px;
        letter-spacing: 0.08em;
        text-transform: lowercase;
      }
      .sc-intro-desc {
        font-family: 'Cabin', sans-serif;
        font-size: 13px;
        color: var(--sc-ink);
        opacity: 0.5;
        margin: 0;
        line-height: 1.55;
        max-width: 360px;
        margin-inline: auto;
      }
    </style>
  </Fragment>

  <div class="sc-page">
    <a href="/" class="sc-back">← stanwood.dev</a>

    <div class="sc-hero">
      <img
        src="/images/ship-clock.webp"
        alt="A wall clock above a developer's desk with code on screen"
        loading="eager"
        decoding="async"
        width="960"
        height="540"
      />
    </div>

    <div class="sc-intro">
      <h1 class="sc-intro-title">Ship Clock</h1>
      <p class="sc-intro-sub">stanwood.dev · production deploy tracker</p>
      <p class="sc-intro-desc">One number on the wall. Days since this site last shipped — no spin, no excuses. Updates every five minutes from Vercel.</p>
    </div>

    <ShipClock client:idle />

    <!-- How it works / build your own -->
    <div class="sc-explainer">
      <h2 class="sc-explainer-heading">Build Your Own</h2>
      <p class="sc-explainer-sub">three steps · ~30 minutes</p>

      <div class="sc-steps">
        <div class="sc-step">
          <span class="sc-step-num">01</span>
          <div>
            <p class="sc-step-title">Create a Vercel read token</p>
            <p class="sc-step-body">In Vercel → Account Settings → Tokens, create a scoped read token. Grab your Project ID from the project settings URL.</p>
          </div>
        </div>
        <div class="sc-step">
          <span class="sc-step-num">02</span>
          <div>
            <p class="sc-step-title">Call the deployments API</p>
            <p class="sc-step-body">One fetch pulls the last 25 production deploys with commit metadata attached. The rest is arithmetic.</p>
          </div>
        </div>
        <div class="sc-step">
          <span class="sc-step-num">03</span>
          <div>
            <p class="sc-step-title">Mount a counter component</p>
            <p class="sc-step-body">Compute <code>daysSince</code> from <code>deployments[0].created</code> and display it. Poll every 5 minutes with a <code>setInterval</code> or use stale-while-revalidate caching.</p>
          </div>
        </div>
      </div>

      <div class="sc-code-block" id="sc-snippet"><span class="sc-code-comment">// GET /api/ship-clock</span>
<span class="sc-code-key">const</span> <span class="sc-code-var">url</span> = &#96;<span class="sc-code-str">https://api.vercel.com/v6/deployments</span>
<span class="sc-code-str">  ?projectId=&#36;&#123;</span><span class="sc-code-var">VERCEL_PROJECT_ID</span><span class="sc-code-str">&#125;</span>
<span class="sc-code-str">  &amp;target=production&amp;limit=25&amp;state=READY</span>&#96;;

<span class="sc-code-key">const</span> <span class="sc-code-var">res</span> = <span class="sc-code-key">await</span> fetch(<span class="sc-code-var">url</span>, &#123;
  headers: &#123; Authorization: &#96;<span class="sc-code-str">Bearer &#36;&#123;</span><span class="sc-code-var">VERCEL_TOKEN</span><span class="sc-code-str">&#125;</span>&#96; &#125;
&#125;);

<span class="sc-code-key">const</span> &#123; deployments &#125; = <span class="sc-code-key">await</span> <span class="sc-code-var">res</span>.json();
<span class="sc-code-key">const</span> <span class="sc-code-var">lastDeploy</span> = <span class="sc-code-key">new</span> Date(deployments[0].created);
<span class="sc-code-key">const</span> <span class="sc-code-var">daysSince</span> = Math.floor(
  (Date.now() - <span class="sc-code-var">lastDeploy</span>.getTime()) / 86400000
);</div>

      <button class="sc-copy-btn" id="sc-copy-btn">copy snippet</button>

      <p class="sc-explainer-note">
        Works with any Vercel project. Swap in GitHub Actions or Fly.io by adapting the deployment source.<br>
        Commit metadata (message, SHA, PR number) lives in <code>deployments[0].meta</code>.
      </p>
    </div>
  </div>

  <script>
    const btn = document.getElementById('sc-copy-btn');
    const snippet = document.getElementById('sc-snippet');
    if (btn && snippet) {
      btn.addEventListener('click', () => {
        const code = `// GET /api/ship-clock
const url = \`https://api.vercel.com/v6/deployments?projectId=\${VERCEL_PROJECT_ID}&target=production&limit=25&state=READY\`;

const res = await fetch(url, {
  headers: { Authorization: \`Bearer \${VERCEL_TOKEN}\` }
});

const { deployments } = await res.json();
const lastDeploy = new Date(deployments[0].created);
const daysSince = Math.floor(
  (Date.now() - lastDeploy.getTime()) / 86400000
);`;
        navigator.clipboard.writeText(code).then(() => {
          btn.textContent = 'copied!';
          setTimeout(() => { btn.textContent = 'copy snippet'; }, 2000);
        });
      });
    }
  </script>
</BaseLayout>
