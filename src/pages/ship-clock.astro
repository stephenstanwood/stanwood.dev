---
import BaseLayout from "../layouts/BaseLayout.astro";
import ShipClock from "../components/ShipClock.tsx";
const title = "Ship Clock — stanwood.dev";
---

<BaseLayout
  title={title}
  description="A single number on the wall: days since your last deploy. Connect your GitHub repo and keep yourself honest. One number, zero excuses, maximum accountability."
  slug="ship-clock"
  themeColor="#fffef5"
  fontsUrl="https://fonts.googleapis.com/css2?family=Permanent+Marker&family=Space+Mono:wght@400;700&family=Cabin:wght@400;700&display=swap"
  schemaCategory="DeveloperApplication"
>
  <Fragment slot="head">
    <style is:global>
      :root {
        --sc-bg: #fffef5;
        --sc-ink: #111;
        --sc-pixel: 3px;
        --sc-accent: #ff5c1a;
      }

      body {
        font-family: 'Cabin', sans-serif;
        background: var(--sc-bg);
        color: var(--sc-ink);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .sc-page {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 24px;
        min-height: 100vh;
      }

      .sc-back {
        position: fixed;
        top: 20px;
        left: 20px;
        font-family: 'Space Mono', monospace;
        font-size: 13px;
        color: var(--sc-ink);
        text-decoration: none;
        opacity: 0.6;
        transition: opacity 0.2s;
      }
      .sc-back:hover { opacity: 1; }

      .sc-card {
        border: var(--sc-pixel) solid var(--sc-ink);
        box-shadow: 4px 4px 0 var(--sc-ink);
        background: #fff;
        padding: 48px 64px;
        text-align: center;
        max-width: 480px;
        width: 100%;
      }

      .sc-number {
        font-family: 'Permanent Marker', cursive;
        font-size: clamp(72px, 20vw, 160px);
        line-height: 1;
        color: var(--sc-ink);
        margin-bottom: 8px;
      }

      .sc-today {
        font-size: clamp(32px, 8vw, 56px);
        color: var(--sc-accent);
      }

      .sc-label {
        font-family: 'Space Mono', monospace;
        font-size: clamp(14px, 3vw, 18px);
        letter-spacing: 0.05em;
        text-transform: lowercase;
        opacity: 0.7;
      }

      .sc-meta {
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        margin-top: 24px;
        opacity: 0.4;
      }

      .sc-error {
        font-family: 'Space Mono', monospace;
        font-size: clamp(16px, 4vw, 22px);
        color: var(--sc-accent);
        margin-bottom: 8px;
      }

      @media (max-width: 480px) {
        .sc-card {
          padding: 32px 24px;
        }
      }
    </style>
  </Fragment>

  <div class="sc-page">
    <a href="/" class="sc-back">← stanwood.dev</a>
    <ShipClock client:idle />
  </div>
</BaseLayout>
