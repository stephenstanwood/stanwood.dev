---
import BaseLayout from "../layouts/BaseLayout.astro";
import ShipClockApp from "../components/ShipClock.tsx";
import RepoTracker from "../components/RepoTracker.tsx";
const title = "Ship Clock — stanwood.dev";
---

<BaseLayout
  title={title}
  description="A single number on the wall: days since your last deploy. Connect your GitHub repo and keep yourself honest. One number, zero excuses, maximum accountability."
  slug="ship-clock"
  favicon="/favicon-ship-clock.svg"
  themeColor="#fffef5"
  fontsUrl="https://fonts.googleapis.com/css2?family=Permanent+Marker&display=swap"
  schemaCategory="DeveloperApplication"
>
  <Fragment slot="head">
    <style is:global>
      :root {
        --sc-bg: #fffef5;
        --sc-ink: #111;
        --sc-pixel: 3px;
        --sc-accent: #ff5c1a;
      }

      body {
        font-family: 'Cabin', sans-serif;
        background: var(--sc-bg);
        color: var(--sc-ink);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .sc-page {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 24px;
        min-height: 100vh;
      }

      .sc-back {
        position: fixed;
        top: 20px;
        left: 20px;
        font-family: 'Space Mono', monospace;
        font-size: 13px;
        color: var(--sc-ink);
        text-decoration: none;
        opacity: 0.6;
        transition: opacity 0.2s;
      }
      .sc-back:hover { opacity: 1; }

      .sc-card {
        border: var(--sc-pixel) solid var(--sc-ink);
        box-shadow: 4px 4px 0 var(--sc-ink);
        background: #fff;
        padding: 48px 64px;
        text-align: center;
        max-width: 480px;
        width: 100%;
      }

      .sc-number {
        font-family: 'Permanent Marker', cursive;
        font-size: clamp(72px, 20vw, 160px);
        line-height: 1;
        color: var(--sc-ink);
        margin-bottom: 8px;
      }

      .sc-today {
        font-size: clamp(32px, 8vw, 56px);
        color: var(--sc-accent);
      }

      .sc-label {
        font-family: 'Space Mono', monospace;
        font-size: clamp(14px, 3vw, 18px);
        letter-spacing: 0.05em;
        text-transform: lowercase;
        opacity: 0.7;
      }

      .sc-meta {
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        margin-top: 24px;
        opacity: 0.4;
      }

      .sc-error {
        font-family: 'Space Mono', monospace;
        font-size: clamp(16px, 4vw, 22px);
        color: var(--sc-accent);
        margin-bottom: 8px;
      }

      .sc-wrap {
        display: flex;
        flex-direction: column;
        gap: 16px;
        max-width: 480px;
        width: 100%;
      }

      .sc-what-shipped {
        border: var(--sc-pixel) solid var(--sc-ink);
        box-shadow: 4px 4px 0 var(--sc-ink);
        background: #fff;
        padding: 20px 24px;
      }

      .sc-section-label {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--sc-ink);
        opacity: 0.35;
        margin-bottom: 10px;
      }

      .sc-shipped-row {
        display: flex;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 8px;
      }

      .sc-project-badge {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.05em;
        background: var(--sc-accent);
        color: #fff;
        padding: 2px 8px;
        white-space: nowrap;
      }

      .sc-shipped-summary {
        font-family: 'Cabin', sans-serif;
        font-size: 15px;
        font-weight: 600;
        color: var(--sc-ink);
      }

      .sc-shipped-meta {
        display: flex;
        gap: 12px;
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        opacity: 0.4;
      }

      .sc-history {
        border: var(--sc-pixel) solid var(--sc-ink);
        box-shadow: 4px 4px 0 var(--sc-ink);
        background: #fff;
        padding: 20px 24px;
      }

      .sc-history-list {
        display: flex;
        flex-direction: column;
        gap: 0;
      }

      .sc-history-row {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 8px 0;
        border-bottom: 1px solid rgba(0,0,0,0.06);
      }
      .sc-history-row:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }
      .sc-history-row:first-child {
        padding-top: 0;
      }

      .sc-history-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--sc-ink);
        opacity: 0.25;
        flex-shrink: 0;
        margin-top: 6px;
      }

      .sc-history-body {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
      }

      .sc-history-msg {
        font-family: 'Cabin', sans-serif;
        font-size: 13px;
        color: var(--sc-ink);
        opacity: 0.8;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .sc-history-time {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        color: var(--sc-ink);
        opacity: 0.35;
      }

      .sc-history-sha {
        opacity: 0.6;
      }

      .sc-meta-link {
        color: inherit;
        text-decoration: none;
        border-bottom: 1px dotted currentColor;
        transition: opacity 0.15s;
      }
      .sc-meta-link:hover { opacity: 1 !important; }

      /* ── Status label ── */
      .sc-status {
        font-family: 'Space Mono', monospace;
        font-size: clamp(11px, 2.5vw, 13px);
        letter-spacing: 0.08em;
        text-transform: lowercase;
        margin-top: 6px;
        opacity: 0.75;
      }
      .sc-status--hot  { color: var(--sc-accent); }
      .sc-status--good { color: #22c55e; }
      .sc-status--warn { color: #f59e0b; }
      .sc-status--bad  { color: #ef4444; }

      /* ── Activity heatmap ── */
      .sc-activity {
        border: var(--sc-pixel) solid var(--sc-ink);
        box-shadow: 4px 4px 0 var(--sc-ink);
        background: #fff;
        padding: 16px 20px;
      }

      .sc-dots {
        display: grid;
        grid-template-columns: repeat(28, 1fr);
        gap: 3px;
        margin-top: 8px;
      }

      .sc-dot {
        aspect-ratio: 1;
        border-radius: 2px;
        background: #e5e5e5;
        cursor: default;
      }
      .sc-dot--active {
        background: var(--sc-ink);
      }

      /* ── Share button ── */
      .sc-share-btn {
        margin-top: 20px;
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        letter-spacing: 0.1em;
        text-transform: lowercase;
        color: var(--sc-ink);
        background: transparent;
        border: 1.5px solid var(--sc-ink);
        padding: 6px 16px;
        cursor: pointer;
        opacity: 0.45;
        transition: opacity 0.15s;
      }
      .sc-share-btn:hover { opacity: 1; }

      /* ── Stats strip ── */
      .sc-stats {
        border: var(--sc-pixel) solid var(--sc-ink);
        box-shadow: 4px 4px 0 var(--sc-ink);
        background: #fff;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 16px;
        flex-wrap: wrap;
      }

      .sc-stat {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
      }

      .sc-stat-num {
        font-family: 'Permanent Marker', cursive;
        font-size: clamp(22px, 5vw, 32px);
        line-height: 1;
        color: var(--sc-ink);
      }

      .sc-stat-label {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: lowercase;
        opacity: 0.5;
        white-space: nowrap;
      }

      .sc-stat-divider {
        width: 1px;
        height: 36px;
        background: var(--sc-ink);
        opacity: 0.12;
      }

      @media (max-width: 480px) {
        .sc-card {
          padding: 32px 24px;
        }
        .sc-what-shipped,
        .sc-history,
        .sc-activity,
        .sc-stats {
          padding: 14px 16px;
        }
        .sc-dots {
          gap: 2px;
        }
      }

      /* ── How it works / build your own ── */
      .sc-explainer {
        max-width: 480px;
        width: 100%;
        margin-top: 40px;
        padding-top: 32px;
        border-top: 1.5px solid rgba(0,0,0,0.08);
      }

      .sc-explainer-heading {
        font-family: 'Permanent Marker', cursive;
        font-size: clamp(20px, 5vw, 28px);
        color: var(--sc-ink);
        margin: 0 0 6px;
      }

      .sc-explainer-sub {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: lowercase;
        color: var(--sc-ink);
        opacity: 0.4;
        margin: 0 0 20px;
      }

      .sc-steps {
        display: flex;
        flex-direction: column;
        gap: 16px;
        margin-bottom: 24px;
      }

      .sc-step {
        display: flex;
        gap: 14px;
        align-items: flex-start;
      }

      .sc-step-num {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        font-weight: 700;
        color: var(--sc-accent);
        opacity: 0.7;
        padding-top: 2px;
        flex-shrink: 0;
        width: 22px;
      }

      .sc-step-title {
        font-family: 'Cabin', sans-serif;
        font-size: 14px;
        font-weight: 700;
        color: var(--sc-ink);
        margin-bottom: 2px;
      }

      .sc-step-body {
        font-family: 'Cabin', sans-serif;
        font-size: 13px;
        color: var(--sc-ink);
        opacity: 0.55;
        line-height: 1.5;
      }

      .sc-code-block {
        border: var(--sc-pixel) solid var(--sc-ink);
        box-shadow: 3px 3px 0 var(--sc-ink);
        background: #111;
        color: #fffef5;
        padding: 16px 18px;
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        line-height: 1.7;
        overflow-x: auto;
        white-space: pre;
        margin-bottom: 12px;
        position: relative;
      }

      .sc-code-comment { color: rgba(255,254,245,0.3); }
      .sc-code-key     { color: #ff5c1a; }
      .sc-code-str     { color: #7dde8a; }
      .sc-code-var     { color: #ffd06e; }

      .sc-copy-btn {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: lowercase;
        color: var(--sc-ink);
        background: transparent;
        border: 1.5px solid var(--sc-ink);
        padding: 5px 14px;
        cursor: pointer;
        opacity: 0.4;
        transition: opacity 0.15s;
        margin-bottom: 8px;
      }
      .sc-copy-btn:hover { opacity: 1; }

      .sc-explainer-note {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        color: var(--sc-ink);
        opacity: 0.35;
        line-height: 1.6;
        margin-top: 8px;
      }

      /* ── Cadence ladder ── */
      .sc-cadence {
        max-width: 480px;
        width: 100%;
        margin-top: 40px;
        padding-top: 32px;
        border-top: 1.5px solid rgba(0,0,0,0.08);
      }

      .sc-cadence-heading {
        font-family: 'Permanent Marker', cursive;
        font-size: clamp(20px, 5vw, 28px);
        color: var(--sc-ink);
        margin: 0 0 6px;
      }

      .sc-cadence-sub {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: lowercase;
        color: var(--sc-ink);
        opacity: 0.4;
        margin: 0 0 18px;
      }

      .sc-tier-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .sc-tier {
        display: grid;
        grid-template-columns: 78px 1fr;
        gap: 14px;
        align-items: center;
        border: var(--sc-pixel) solid var(--sc-ink);
        box-shadow: 3px 3px 0 var(--sc-ink);
        background: #fff;
        padding: 14px 16px;
      }

      .sc-tier-days {
        font-family: 'Permanent Marker', cursive;
        font-size: 26px;
        line-height: 1;
        text-align: center;
        padding: 6px 8px;
        border: 2px solid currentColor;
      }

      .sc-tier-body {
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-width: 0;
      }

      .sc-tier-label {
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: lowercase;
      }

      .sc-tier-text {
        font-family: 'Cabin', sans-serif;
        font-size: 13px;
        color: var(--sc-ink);
        opacity: 0.6;
        line-height: 1.5;
        margin: 0;
      }

      .sc-tier--hot  .sc-tier-days,
      .sc-tier--hot  .sc-tier-label { color: var(--sc-accent); }
      .sc-tier--good .sc-tier-days,
      .sc-tier--good .sc-tier-label { color: #1a9d3f; }
      .sc-tier--warn .sc-tier-days,
      .sc-tier--warn .sc-tier-label { color: #c97718; }
      .sc-tier--cool .sc-tier-days,
      .sc-tier--cool .sc-tier-label { color: #8a6cb5; }
      .sc-tier--bad  .sc-tier-days,
      .sc-tier--bad  .sc-tier-label { color: #c52727; }

      .sc-cadence-note {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        color: var(--sc-ink);
        opacity: 0.4;
        line-height: 1.6;
        margin-top: 14px;
      }

      @media (max-width: 480px) {
        .sc-tier {
          grid-template-columns: 64px 1fr;
          padding: 12px 14px;
          gap: 12px;
        }
        .sc-tier-days { font-size: 20px; padding: 5px 6px; }
        .sc-tier-text { font-size: 12px; }
      }

      /* ── Unstick the clock ── */
      .sc-unstick {
        max-width: 480px;
        width: 100%;
        margin-top: 40px;
        padding-top: 32px;
        border-top: 1.5px solid rgba(0,0,0,0.08);
      }

      .sc-unstick-heading {
        font-family: 'Permanent Marker', cursive;
        font-size: clamp(20px, 5vw, 28px);
        color: var(--sc-ink);
        margin: 0 0 6px;
      }

      .sc-unstick-sub {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: lowercase;
        color: var(--sc-ink);
        opacity: 0.4;
        margin: 0 0 18px;
      }

      .sc-unstick-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      .sc-unstick-row {
        border: var(--sc-pixel) solid var(--sc-ink);
        box-shadow: 3px 3px 0 var(--sc-ink);
        background: #fff;
        padding: 14px 16px 16px;
        position: relative;
      }

      .sc-unstick-row::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 5px;
        background: currentColor;
      }

      .sc-unstick-row--scope { color: #c97718; }
      .sc-unstick-row--review { color: #8a6cb5; }
      .sc-unstick-row--spread { color: #c52727; }
      .sc-unstick-row--perfect { color: #1a9d3f; }
      .sc-unstick-row--debt { color: var(--sc-accent); }

      .sc-unstick-head {
        display: flex;
        align-items: baseline;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 6px;
      }

      .sc-unstick-num {
        font-family: 'Permanent Marker', cursive;
        font-size: 18px;
        line-height: 1;
        color: currentColor;
        flex-shrink: 0;
      }

      .sc-unstick-label {
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: lowercase;
        color: currentColor;
      }

      .sc-unstick-symptom {
        font-family: 'Cabin', sans-serif;
        font-size: 13px;
        line-height: 1.5;
        color: var(--sc-ink);
        opacity: 0.65;
        margin: 0 0 8px;
      }

      .sc-unstick-fix {
        font-family: 'Cabin', sans-serif;
        font-size: 13px;
        line-height: 1.55;
        color: var(--sc-ink);
        margin: 0;
        padding: 8px 10px;
        background: rgba(0,0,0,0.03);
        border-left: 2px solid currentColor;
      }

      .sc-unstick-fix-label {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: currentColor;
        margin-right: 6px;
      }

      .sc-unstick-foot {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        color: var(--sc-ink);
        opacity: 0.4;
        line-height: 1.6;
        margin-top: 14px;
      }

      @media (max-width: 480px) {
        .sc-unstick-row { padding: 12px 14px 14px; }
        .sc-unstick-row::before { width: 4px; }
        .sc-unstick-symptom { font-size: 12.5px; }
        .sc-unstick-fix { font-size: 12.5px; padding: 7px 9px; }
      }

      /* ── Cadences in the wild ── */
      .sc-wild {
        max-width: 480px;
        width: 100%;
        margin-top: 40px;
        padding-top: 32px;
        border-top: 1.5px solid rgba(0,0,0,0.08);
      }

      .sc-wild-heading {
        font-family: 'Permanent Marker', cursive;
        font-size: clamp(20px, 5vw, 28px);
        color: var(--sc-ink);
        margin: 0 0 6px;
      }

      .sc-wild-sub {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: lowercase;
        color: var(--sc-ink);
        opacity: 0.4;
        margin: 0 0 18px;
      }

      .sc-wild-intro {
        font-family: 'Cabin', sans-serif;
        font-size: 13px;
        color: var(--sc-ink);
        opacity: 0.65;
        line-height: 1.55;
        margin: 0 0 18px;
      }

      .sc-wild-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .sc-wild-card {
        border: var(--sc-pixel) solid var(--sc-ink);
        box-shadow: 3px 3px 0 var(--sc-ink);
        background: #fff;
        padding: 12px 14px 14px;
        display: grid;
        grid-template-columns: 88px 1fr;
        gap: 12px;
        align-items: stretch;
      }

      .sc-wild-stat {
        background: rgba(0,0,0,0.04);
        border: 2px solid currentColor;
        padding: 6px 4px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
      }

      .sc-wild-stat-num {
        font-family: 'Permanent Marker', cursive;
        font-size: 18px;
        line-height: 1;
        color: currentColor;
      }

      .sc-wild-stat-unit {
        font-family: 'Space Mono', monospace;
        font-size: 9px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: currentColor;
        opacity: 0.85;
        margin-top: 4px;
      }

      .sc-wild-body {
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-width: 0;
      }

      .sc-wild-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 8px;
        flex-wrap: wrap;
      }

      .sc-wild-name {
        font-family: 'Space Mono', monospace;
        font-size: 13px;
        font-weight: 700;
        color: var(--sc-ink);
        letter-spacing: 0.02em;
      }

      .sc-wild-tag {
        font-family: 'Space Mono', monospace;
        font-size: 9px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: currentColor;
        opacity: 0.7;
        white-space: nowrap;
      }

      .sc-wild-text {
        font-family: 'Cabin', sans-serif;
        font-size: 12.5px;
        line-height: 1.5;
        color: var(--sc-ink);
        opacity: 0.7;
        margin: 0;
      }

      .sc-wild-text strong {
        color: var(--sc-ink);
        opacity: 1;
        font-weight: 700;
      }

      .sc-wild-card--blazing { color: var(--sc-accent); }
      .sc-wild-card--fast    { color: #1a9d3f; }
      .sc-wild-card--steady  { color: #c97718; }
      .sc-wild-card--cycle   { color: #2563a0; }
      .sc-wild-card--annual  { color: #8a6cb5; }
      .sc-wild-card--glacial { color: #c52727; }

      .sc-wild-foot {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        color: var(--sc-ink);
        opacity: 0.4;
        line-height: 1.6;
        margin-top: 14px;
      }

      @media (max-width: 480px) {
        .sc-wild-card { grid-template-columns: 72px 1fr; padding: 10px 12px 12px; gap: 10px; }
        .sc-wild-stat-num { font-size: 15px; }
        .sc-wild-text { font-size: 12px; }
      }

      /* ── Repo tracker ── */
      .sc-rt-wrap {
        max-width: 480px;
        width: 100%;
        margin-top: 24px;
        padding-top: 24px;
        border-top: 1.5px solid rgba(0,0,0,0.08);
      }
      .sc-rt-row {
        display: flex;
        gap: 0;
      }
      .sc-rt-input {
        flex: 1;
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        padding: 10px 14px;
        border: var(--sc-pixel) solid var(--sc-ink);
        background: #fff;
        color: var(--sc-ink);
        outline: none;
        min-width: 0;
      }
      .sc-rt-input::placeholder { opacity: 0.3; }
      .sc-rt-input:focus { background: #fffef5; }
      .sc-rt-btn {
        font-family: 'Space Mono', monospace;
