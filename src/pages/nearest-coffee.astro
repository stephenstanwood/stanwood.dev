---
import "../styles/global.css";
const title = "Nearest Coffee — stanwood.dev";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="Find the nearest open coffee shop. Tap and go." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        background: #1a1210;
        overflow-x: hidden;
      }

      /* warm ambient glow */
      .bg-glow {
        position: fixed;
        inset: 0;
        z-index: -1;
        background:
          radial-gradient(ellipse 60% 50% at 50% 0%, rgba(255,179,0,0.08) 0%, transparent 70%),
          radial-gradient(ellipse 50% 40% at 80% 100%, rgba(78,52,46,0.15) 0%, transparent 70%),
          #1a1210;
      }

      /* card carousel */
      .cards-track {
        display: flex;
        gap: 16px;
        scroll-snap-type: x mandatory;
        overflow-x: auto;
        padding: 0 max(24px, calc((100vw - 400px) / 2));
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
      }
      .cards-track::-webkit-scrollbar { display: none; }

      .coffee-card {
        flex: 0 0 min(85vw, 380px);
        scroll-snap-align: center;
        border-radius: 24px;
        background: rgba(44,34,32,0.85);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255,179,0,0.12);
        transition: transform 0.3s, box-shadow 0.3s;
      }
      .coffee-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 40px rgba(255,179,0,0.08);
      }

      /* nav button */
      .nav-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        height: 52px;
        border-radius: 14px;
        background: #FFB300;
        color: #3E2723;
        font-weight: 700;
        font-size: 15px;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
      }
      .nav-btn:hover {
        background: #FFC107;
        transform: scale(1.02);
      }
      .nav-btn:active {
        transform: scale(0.98);
      }

      /* open badge */
      .open-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 10px;
        border-radius: 8px;
        background: rgba(102,187,106,0.12);
        color: #66BB6A;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
      }
      .open-badge::before {
        content: '';
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #66BB6A;
        animation: pulse-dot 2s ease-in-out infinite;
      }

      @keyframes pulse-dot {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
      }

      /* dot indicators */
      .dot-track {
        display: flex;
        gap: 8px;
        justify-content: center;
        padding: 16px 0 32px;
      }
      .dot {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: rgba(255,248,225,0.15);
        transition: all 0.3s;
      }
      .dot.active {
        width: 24px;
        background: #FFB300;
      }

      /* star */
      .star { color: #FFD600; }

      /* states */
      .state-screen {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 70vh;
        text-align: center;
        padding: 32px;
      }

      /* spinner */
      .spinner {
        width: 40px;
        height: 40px;
        border: 3px solid rgba(255,179,0,0.2);
        border-top-color: #FFB300;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
      }
      @keyframes spin {
        to { transform: rotate(360deg); }
      }

      /* fade in */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .fade-up {
        animation: fadeUp 0.5s ease both;
      }
    </style>
  </head>

  <body class="text-[#FFF8E1] antialiased">
    <div class="bg-glow"></div>

    <main class="mx-auto max-w-2xl px-6 pt-12 pb-8">
      <!-- Top bar -->
      <div class="flex items-center">
        <a
          href="/"
          class="text-sm font-semibold text-[#FFF8E1]/30 hover:text-[#FFF8E1] transition-colors"
        >
          &larr; Home
        </a>
      </div>

      <!-- Header -->
      <header class="mt-8 mb-6">
        <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-[#FFF8E1]">
          Nearest Coffee
        </h1>
        <p class="mt-2 text-[#D7CCC8] text-base">
          Open. Close. Go.
        </p>
      </header>

      <!-- Loading state -->
      <div id="loading-state" class="state-screen">
        <div class="spinner"></div>
        <p class="mt-4 text-[#D7CCC8] text-sm">Finding coffee nearby&hellip;</p>
      </div>

      <!-- Permission state -->
      <div id="permission-state" class="state-screen hidden">
        <div class="text-6xl mb-6">📍</div>
        <h2 class="text-2xl font-bold text-[#FFF8E1] mb-3">Find Your Coffee</h2>
        <p class="text-[#D7CCC8] mb-8 max-w-xs leading-relaxed">
          Allow location access to find the nearest open coffee shop.
        </p>
        <button
          id="enable-location-btn"
          class="nav-btn"
          style="width: auto; padding: 0 32px;"
        >
          Enable Location
        </button>
      </div>

      <!-- Error state -->
      <div id="error-state" class="state-screen hidden">
        <h2 id="error-title" class="text-2xl font-bold text-[#FFF8E1] mb-3">Oops</h2>
        <p id="error-message" class="text-[#D7CCC8] mb-8 max-w-xs leading-relaxed"></p>
        <button
          id="retry-btn"
          class="nav-btn"
          style="width: auto; padding: 0 32px;"
        >
          Try Again
        </button>
      </div>

      <!-- Results -->
      <div id="results-state" class="hidden fade-up">
        <div id="cards-track" class="cards-track"></div>
        <div id="dot-track" class="dot-track"></div>
      </div>
    </main>

    <!-- Card template (hidden) -->
    <template id="card-template">
      <div class="coffee-card p-6 flex flex-col justify-between" style="min-height: 380px;">
        <div>
          <!-- Top row -->
          <div class="flex items-center justify-between mb-6">
            <span class="ordinal text-xs font-bold text-[#FFB300] tracking-wide"></span>
            <span class="open-badge">Open</span>
          </div>

          <!-- Name -->
          <h2 class="shop-name text-[26px] sm:text-3xl font-bold text-[#FFF8E1] leading-tight mb-2"></h2>

          <!-- Distance -->
          <p class="shop-distance text-xl font-semibold text-[#FFB300] mb-4"></p>

          <!-- Address -->
          <div class="flex items-start gap-1.5 mb-3">
            <svg class="w-4 h-4 mt-0.5 text-[#D7CCC8] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="shop-address text-sm text-[#D7CCC8] leading-relaxed"></span>
          </div>

          <!-- Rating -->
          <div class="shop-rating flex items-center gap-1.5 text-sm hidden">
            <span class="star">★</span>
            <span class="rating-value text-[#FFF8E1]"></span>
            <span class="rating-count text-[#D7CCC8]"></span>
          </div>
        </div>

        <!-- Navigate button -->
        <button class="navigate-btn nav-btn mt-6">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2L4.5 20.29l.71.71L12 18l6.79 3 .71-.71z"/>
          </svg>
          Navigate
        </button>
      </div>
    </template>

    <script>
      // ── State ──
      type CoffeeShop = {
        id: string;
        name: string;
        address: string;
        lat: number;
        lng: number;
        distance: number;
        rating: number | null;
        ratingCount: number | null;
        isOpen: boolean | null;
      };

      const els = {
        loading: document.getElementById("loading-state")!,
        permission: document.getElementById("permission-state")!,
        error: document.getElementById("error-state")!,
        results: document.getElementById("results-state")!,
        errorTitle: document.getElementById("error-title")!,
        errorMessage: document.getElementById("error-message")!,
        cardsTrack: document.getElementById("cards-track")!,
        dotTrack: document.getElementById("dot-track")!,
        enableBtn: document.getElementById("enable-location-btn")!,
        retryBtn: document.getElementById("retry-btn")!,
        template: document.getElementById("card-template") as HTMLTemplateElement,
      };

      // ── Helpers ──

      function showState(state: "loading" | "permission" | "error" | "results") {
        els.loading.classList.toggle("hidden", state !== "loading");
        els.permission.classList.toggle("hidden", state !== "permission");
        els.error.classList.toggle("hidden", state !== "error");
        els.results.classList.toggle("hidden", state !== "results");
      }

      function showError(title: string, message: string) {
        els.errorTitle.textContent = title;
        els.errorMessage.textContent = message;
        showState("error");
      }

      function formatDistance(meters: number): string {
        if (meters < 1000) return `${meters}m away`;
        return `${(meters / 1000).toFixed(1)} km away`;
      }

      function ordinalSuffix(n: number): string {
        if (n % 100 >= 11 && n % 100 <= 13) return `${n}th`;
        switch (n % 10) {
          case 1: return `${n}st`;
          case 2: return `${n}nd`;
          case 3: return `${n}rd`;
          default: return `${n}th`;
        }
      }

      function openNavigation(lat: number, lng: number) {
        // Try Google Maps first, falls back to browser default map handler
        const url = `https://www.google.com/maps/dir/?api=1&destination=${lat},${lng}&travelmode=walking`;
        window.open(url, "_blank");
      }

      // ── Dot indicators ──

      let currentPage = 0;

      function updateDots(total: number, active: number) {
        els.dotTrack.innerHTML = "";
        if (total <= 1) return;
        for (let i = 0; i < total; i++) {
          const dot = document.createElement("div");
          dot.className = `dot${i === active ? " active" : ""}`;
          els.dotTrack.appendChild(dot);
        }
      }

      // ── Scroll snap observer ──

      function observeSnap(total: number) {
        const track = els.cardsTrack;
        const cards = track.querySelectorAll(".coffee-card");
        if (!cards.length) return;

        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting && entry.intersectionRatio > 0.6) {
                const idx = Array.from(cards).indexOf(entry.target as HTMLElement);
                if (idx >= 0 && idx !== currentPage) {
                  currentPage = idx;
                  updateDots(total, currentPage);
                }
              }
            }
          },
          { root: track, threshold: 0.6 },
        );

        cards.forEach((card) => observer.observe(card));
      }

      // ── Render results ──

      function renderResults(shops: CoffeeShop[]) {
        els.cardsTrack.innerHTML = "";

        shops.forEach((shop, i) => {
          const fragment = els.template.content.cloneNode(true) as DocumentFragment;
          const card = fragment.querySelector(".coffee-card") as HTMLElement;

          card.querySelector(".ordinal")!.textContent = `${ordinalSuffix(i + 1)} nearest`;
          card.querySelector(".shop-name")!.textContent = shop.name;
          card.querySelector(".shop-distance")!.textContent = formatDistance(shop.distance);
          card.querySelector(".shop-address")!.textContent = shop.address;

          if (shop.rating) {
            const ratingEl = card.querySelector(".shop-rating") as HTMLElement;
            ratingEl.classList.remove("hidden");
            ratingEl.querySelector(".rating-value")!.textContent = shop.rating.toFixed(1);
            if (shop.ratingCount) {
              ratingEl.querySelector(".rating-count")!.textContent = `(${shop.ratingCount})`;
            }
          }

          const navBtn = card.querySelector(".navigate-btn") as HTMLButtonElement;
          navBtn.addEventListener("click", () => openNavigation(shop.lat, shop.lng));

          // stagger animation
          card.style.animation = `fadeUp 0.4s ease ${i * 0.08}s both`;

          els.cardsTrack.appendChild(card);
        });

        currentPage = 0;
        updateDots(shops.length, 0);
        observeSnap(shops.length);
        showState("results");
      }

      // ── Fetch coffee shops ──

      async function fetchCoffeeShops(lat: number, lng: number) {
        showState("loading");

        try {
          const res = await fetch("/api/nearby-coffee", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ latitude: lat, longitude: lng }),
          });

          if (!res.ok) throw new Error("API request failed");

          const data = await res.json();
          const shops: CoffeeShop[] = data.results || [];

          if (shops.length === 0) {
            showError(
              "No Coffee Nearby",
              "No open coffee shops found within 2km. Try again later or wander somewhere new.",
            );
            return;
          }

          renderResults(shops);
        } catch (err) {
          showError("Oops", "Something went wrong finding coffee. Please try again.");
        }
      }

      // ── Geolocation ──

      function requestLocation() {
        showState("loading");

        if (!("geolocation" in navigator)) {
          showError("No GPS", "Your browser doesn't support geolocation.");
          return;
        }

        navigator.geolocation.getCurrentPosition(
          (pos) => {
            fetchCoffeeShops(pos.coords.latitude, pos.coords.longitude);
          },
          (err) => {
            if (err.code === err.PERMISSION_DENIED) {
              showState("permission");
            } else {
              showError(
                "Location Unavailable",
                "Unable to determine your location. Please ensure GPS is enabled.",
              );
            }
          },
          { enableHighAccuracy: true, timeout: 10000 },
        );
      }

      // ── Events ──

      els.enableBtn.addEventListener("click", requestLocation);
      els.retryBtn.addEventListener("click", requestLocation);

      // ── Init ──

      // Check if we can access location right away
      if ("permissions" in navigator) {
        navigator.permissions.query({ name: "geolocation" }).then((result) => {
          if (result.state === "granted") {
            requestLocation();
          } else if (result.state === "prompt") {
            requestLocation();
          } else {
            showState("permission");
          }
        });
      } else {
        requestLocation();
      }
    </script>
  </body>
</html>
