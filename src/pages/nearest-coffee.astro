---
import BaseLayout from "../layouts/BaseLayout.astro";
const hasMapsKey = Boolean(import.meta.env.GOOGLE_PLACES_API_KEY);
---

<BaseLayout
  title="Nearest Coffee — stanwood.dev"
  description="Find the nearest coffee shop that's open right now. Uses your location to sort by distance and shows hours, ratings, and directions."
  slug="nearest-coffee"
  favicon="/favicon-coffee.svg"
  themeColor="#FAFAF8"
  fontsUrl="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap"
  schemaCategory="LifestyleApplication"
>
  <Fragment slot="head">
    <style is:global>
      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background: #FAFAF8;
        color: #1A1A1A;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* ── Page layout ── */
      .nc-page {
        max-width: 860px;
        margin: 0 auto;
        padding: 40px 24px 80px;
      }
      @media (min-width: 768px) {
        .nc-page { padding: 56px 48px 120px; }
      }

      /* ── Navigation ── */
      .nc-back {
        font-size: 13px;
        font-weight: 500;
        color: #9A9A9A;
        text-decoration: none;
        letter-spacing: 0.02em;
        transition: color 0.2s;
      }
      .nc-back:hover { color: #1A1A1A; }

      /* ── Header ── */
      .nc-header {
        margin-top: 56px;
        margin-bottom: 40px;
      }
      @media (min-width: 768px) {
        .nc-header { margin-top: 72px; margin-bottom: 48px; }
      }
      .nc-label {
        display: block;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #9A9A9A;
        margin-bottom: 16px;
      }
      .nc-title {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: clamp(2rem, 4.5vw + 0.5rem, 3.25rem);
        font-weight: 500;
        line-height: 1.12;
        color: #1A1A1A;
        letter-spacing: -0.02em;
        max-width: 480px;
      }

      /* ── Divider ── */
      .nc-rule {
        border: none;
        height: 1px;
        background: #E5E3DF;
        margin: 0;
      }

      /* ── Loading ── */
      .nc-loading {
        padding: 56px 0;
      }
      .nc-loading-bar {
        height: 1px;
        background: #E5E3DF;
        overflow: hidden;
        max-width: 180px;
      }
      .nc-loading-fill {
        height: 100%;
        background: #5C4033;
        transition: width 0.3s ease-out;
        width: 0%;
      }
      .nc-loading-text {
        margin-top: 14px;
        font-size: 13px;
        color: #9A9A9A;
        font-weight: 400;
        letter-spacing: 0.02em;
      }

      /* ── Permission ── */
      .nc-permission {
        padding: 72px 0 56px;
        max-width: 380px;
      }
      .nc-permission p {
        font-size: 15px;
        line-height: 1.7;
        color: #6B6B6B;
        margin-bottom: 28px;
      }

      /* ── Buttons ── */
      .nc-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 28px;
        background: #1A1A1A;
        color: #FAFAF8;
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.03em;
        border: none;
        border-radius: 2px;
        cursor: pointer;
        transition: background 0.2s;
      }
      .nc-btn:hover { background: #5C4033; }

      /* ── Error ── */
      .nc-error {
        padding: 72px 0 56px;
        max-width: 400px;
      }
      .nc-error h2 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 24px;
        font-weight: 500;
        margin-bottom: 12px;
        color: #1A1A1A;
      }
      .nc-error p {
        font-size: 15px;
        line-height: 1.7;
        color: #6B6B6B;
        margin-bottom: 28px;
      }

      /* ── Primary result ── */
      .nc-result {
        padding: 44px 0 0;
      }
      @media (min-width: 768px) {
        .nc-result { padding: 52px 0 0; }
      }
      .nc-result-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 32px;
      }
      @media (min-width: 768px) {
        .nc-result-grid {
          grid-template-columns: 1fr 240px;
          gap: 56px;
        }
      }

      /* Status */
      .nc-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #3D6B4F;
        margin-bottom: 8px;
      }
      .nc-status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #3D6B4F;
        animation: nc-pulse 2s ease-in-out infinite;
      }

      /* Inline distance (mobile) */
      .nc-meta-line {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: #6B6B6B;
        margin-bottom: 20px;
      }
      .nc-meta-sep {
        color: #D0CDC6;
      }
      @media (min-width: 768px) {
        .nc-meta-line { display: none; }
      }

      /* Shop name */
      .nc-shop-name {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: clamp(1.75rem, 3vw + 0.5rem, 2.5rem);
        font-weight: 500;
        line-height: 1.15;
        color: #1A1A1A;
        letter-spacing: -0.01em;
        margin-bottom: 10px;
      }

      /* Address */
      .nc-address {
        font-size: 14px;
        line-height: 1.6;
        color: #6B6B6B;
        margin-bottom: 8px;
      }

      /* Rating inline */
      .nc-rating-inline {
        font-size: 13px;
        color: #9A9A9A;
        margin-bottom: 24px;
      }
      .nc-rating-star { color: #5C4033; }

      /* CTA */
      .nc-cta {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        font-weight: 600;
        color: #5C4033;
        text-decoration: none;
        letter-spacing: 0.02em;
        transition: color 0.2s;
      }
      .nc-cta:hover { color: #1A1A1A; }
      .nc-cta svg { transition: transform 0.2s; }
      .nc-cta:hover svg { transform: translateX(3px); }

      /* ── Aside: distance + map (desktop) ── */
      .nc-aside {
        display: none;
      }
      @media (min-width: 768px) {
        .nc-aside { display: block; }
      }

      .nc-distance-lg {
        margin-bottom: 4px;
      }
      .nc-distance-number {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 56px;
        font-weight: 400;
        line-height: 1;
        color: #1A1A1A;
        letter-spacing: -0.03em;
      }
      .nc-distance-unit {
        display: block;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #9A9A9A;
        margin-top: 4px;
      }
      .nc-aside-meta {
        font-size: 13px;
        color: #9A9A9A;
        margin-top: 6px;
      }
      .nc-aside-rating {
        font-size: 13px;
        color: #9A9A9A;
        margin-top: 2px;
      }

      /* Map */
      .nc-map-wrap {
        margin-top: 20px;
        overflow: hidden;
        border-radius: 2px;
        background: #F2F0EC;
        aspect-ratio: 4 / 3;
        position: relative;
      }
      /* Mobile map: full width below CTA */
      .nc-map-mobile {
        display: block;
        margin-top: 28px;
        aspect-ratio: 2 / 1;
      }
      @media (min-width: 768px) {
        .nc-map-mobile { display: none; }
      }
      .nc-map-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0;
        transition: opacity 0.4s;
      }
      .nc-map-skeleton {
        animation: nc-skeleton 1.5s ease-in-out infinite;
      }

      /* ── Nearby list ── */
      .nc-nearby {
        margin-top: 48px;
      }
      @media (min-width: 768px) {
        .nc-nearby { margin-top: 56px; }
      }
      .nc-nearby-label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #9A9A9A;
        margin-bottom: 16px;
      }
      .nc-nearby-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 14px 0;
        border-top: 1px solid #E5E3DF;
        text-decoration: none;
        color: inherit;
        transition: opacity 0.2s;
      }
      .nc-nearby-item:last-child {
        border-bottom: 1px solid #E5E3DF;
      }
      .nc-nearby-item:hover { opacity: 0.6; }
      .nc-nearby-name {
        font-size: 15px;
        font-weight: 500;
        color: #1A1A1A;
        margin-bottom: 2px;
      }
      .nc-nearby-addr {
        font-size: 12px;
        color: #9A9A9A;
        line-height: 1.4;
      }
      .nc-nearby-right {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-shrink: 0;
      }
      .nc-nearby-dist {
        font-size: 13px;
        font-weight: 500;
        color: #6B6B6B;
        white-space: nowrap;
      }
      .nc-nearby-arrow {
        color: #C0BDB8;
        font-size: 14px;
        transition: color 0.2s;
      }
      .nc-nearby-item:hover .nc-nearby-arrow {
        color: #5C4033;
      }
      .nc-nearby-dist-wrap {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 2px;
      }
      .nc-nearby-walk {
        font-size: 11px;
        color: #C0BDB8;
        white-space: nowrap;
      }
      .nc-nearby-rating {
        font-size: 12px;
        color: #9A9A9A;
        margin-top: 3px;
      }
      .nc-nearby-rating-star {
        color: #5C4033;
      }

      /* ── Footer ── */
      .nc-footer {
        margin-top: 48px;
        padding-top: 24px;
      }
      .nc-refresh {
        background: none;
        border: none;
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 13px;
        font-weight: 500;
        color: #9A9A9A;
        cursor: pointer;
        padding: 0;
        transition: color 0.2s;
        letter-spacing: 0.02em;
      }
      .nc-refresh:hover { color: #5C4033; }
      .nc-location-note {
        font-size: 12px;
        color: #C0BDB8;
        margin-top: 6px;
      }

      /* ── Animations ── */
      @keyframes nc-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
      }
      @keyframes nc-skeleton {
        0%, 100% { opacity: 0.6; }
        50% { opacity: 0.3; }
      }
      @keyframes nc-fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .nc-fade-in {
        animation: nc-fadeIn 0.45s ease both;
      }
      .nc-fade-in-delay {
        animation: nc-fadeIn 0.45s ease 0.1s both;
      }

      /* ── How it works ── */
      .nc-how {
        margin-top: 40px;
        margin-bottom: 40px;
      }
      @media (min-width: 768px) {
        .nc-how { margin-top: 48px; margin-bottom: 48px; }
      }
      .nc-how-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 28px;
      }
      @media (min-width: 640px) {
        .nc-how-grid { grid-template-columns: repeat(3, 1fr); gap: 40px; }
      }
      .nc-how-label {
        display: block;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #5C4033;
        margin-bottom: 10px;
      }
      .nc-how-body {
        font-size: 13px;
        line-height: 1.7;
        color: #6B6B6B;
      }

      /* ── Reduced motion ── */
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
        }
      }
    </style>
  </Fragment>

    <a href="#app" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-[#5C4033] focus:text-[#FAFAF8] focus:rounded focus:font-semibold">Skip to content</a>

    <main class="nc-page">
      <nav>
        <a href="/" class="nc-back">&larr; Back</a>
      </nav>

      <header class="nc-header">
        <span class="nc-label">Nearest Coffee</span>
        <h1 class="nc-title">Your nearest open coffee.</h1>
      </header>

      <hr class="nc-rule">

      <!-- How it works -->
      <section class="nc-how">
        <div class="nc-how-grid">
          <div>
            <span class="nc-how-label">How it works</span>
            <p class="nc-how-body">Share your location and it queries Google Places for coffee shops open right now — sorted by walking distance, closest first.</p>
          </div>
          <div>
            <span class="nc-how-label">What you get</span>
            <p class="nc-how-body">The nearest open shop with its name, address, walking estimate, and a map. Plus up to four alternatives nearby with ratings and walk times — each linking straight to directions.</p>
          </div>
          <div>
            <span class="nc-how-label">Privacy</span>
            <p class="nc-how-body">Your coordinates go to the server only to run the Places query. They're never stored, logged, or tied to you in any way.</p>
          </div>
        </div>
      </section>

      <div id="app" data-has-maps={hasMapsKey ? "1" : ""}></div>
    </main>

    <script>
      import {
        formatDistance,
        estimateWalk,
        computeZoom,
        createProgress,
        initGeolocation,
        requestGeolocation,
      } from "../lib/nearbyUtils";

      type CoffeeShop = {
        id: string;
        name: string;
        address: string;
        lat: number;
        lng: number;
        distance: number;
        rating: number | null;
        ratingCount: number | null;
        isOpen: boolean | null;
      };

      const app = document.getElementById("app")!;
      const hasMaps = app.dataset.hasMaps === "1";

      const progress = createProgress([
        { at: 0, text: "Locating\u2026" },
        { at: 25, text: "Searching nearby\u2026" },
        { at: 55, text: "Checking hours\u2026" },
        { at: 80, text: "Almost ready\u2026" },
      ]);

      let userLat: number;
      let userLng: number;

      // ── Light map styles ──

      const LIGHT_MAP_STYLES = [
        "feature:all|element:geometry|color:0xf2f0ec",
        "feature:all|element:labels.text.fill|color:0xb0ada6",
        "feature:all|element:labels.text.stroke|color:0xfafaf8",
        "feature:water|element:geometry.fill|color:0xe5e3df",
        "feature:road|element:geometry.fill|color:0xffffff",
        "feature:road|element:geometry.stroke|color:0xeae8e4",
        "feature:road.highway|element:geometry.fill|color:0xf5f3ef",
        "feature:poi|visibility:off",
        "feature:transit|visibility:off",
        "feature:administrative|element:geometry.stroke|color:0xe5e3df",
      ];

      // ── Helpers ──

      function render(html: string) {
        app.innerHTML = html;
      }

      function esc(s: string) {
        return s
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;");
      }

      function parseDistance(meters: number): { value: string; unit: string } {
        const miles = meters / 1609.34;
        if (miles < 0.1) {
          return { value: String(Math.round(meters * 3.28084)), unit: "ft" };
        }
        return { value: miles.toFixed(1), unit: "mi" };
      }

      // ── Map URL ──

      function buildMapUrl(
        shop: CoffeeShop,
        size = "480x360",
      ): string {
        const midLat = (userLat + shop.lat) / 2;
        const midLng = (userLng + shop.lng) / 2;
        const zoom = computeZoom(shop.distance);

        const params = new URLSearchParams();
        params.set("center", `${midLat},${midLng}`);
        params.set("zoom", String(zoom));
        params.set("size", size);
        params.set("scale", "2");
        params.set("maptype", "roadmap");

        for (const s of LIGHT_MAP_STYLES) params.append("style", s);

        params.append(
          "markers",
          `color:0x9A9A9A|size:small|${userLat},${userLng}`,
        );
        params.append(
          "markers",
          `color:0x5C4033|size:mid|${shop.lat},${shop.lng}`,
        );

        return `/api/static-map?${params.toString()}`;
      }

      // ── States ──

      function renderLoading() {
        render(`
          <div class="nc-loading">
            <div class="nc-loading-bar">
              <div id="progressFill" class="nc-loading-fill"></div>
            </div>
            <p id="progressLabel" class="nc-loading-text">Locating\u2026</p>
          </div>
        `);
        progress.start();
      }

      function renderPermission() {
        render(`
          <div class="nc-permission">
            <p>Location access is needed to find coffee shops near you.</p>
            <button id="enable-btn" class="nc-btn">Enable Location</button>
          </div>
        `);
        document
          .getElementById("enable-btn")!
          .addEventListener("click", doRequestLocation);
      }

      function renderError(title: string, message: string) {
        render(`
          <div class="nc-error">
            <h2>${esc(title)}</h2>
            <p>${esc(message)}</p>
            <button id="retry-btn" class="nc-btn">Try Again</button>
          </div>
        `);
        document
          .getElementById("retry-btn")!
          .addEventListener("click", doRequestLocation);
      }

      // ── Results ──

      function renderResults(shops: CoffeeShop[]) {
        progress.finish();

        setTimeout(() => {
          const primary = shops[0];
          const secondary = shops.slice(1, 5);
          const dist = parseDistance(primary.distance);
          const navUrl = `https://www.google.com/maps/dir/?api=1&destination=${primary.lat},${primary.lng}&travelmode=walking`;

          // Rating
          let ratingDesktop = "";
          let ratingMobile = "";
          if (primary.rating) {
            const rText = `<span class="nc-rating-star">\u2605</span> ${primary.rating.toFixed(1)}${primary.ratingCount ? ` \u00b7 ${primary.ratingCount}` : ""}`;
            ratingDesktop = `<p class="nc-aside-rating">${rText}</p>`;
            ratingMobile = `<p class="nc-rating-inline">${rText}</p>`;
          }

          // Maps
          let mapDesktop = "";
          let mapMobile = "";
          if (hasMaps) {
            const desktopUrl = buildMapUrl(primary, "480x360");
            const mobileUrl = buildMapUrl(primary, "600x300");
            mapDesktop = `
              <div class="nc-map-wrap nc-map-skeleton">
                <img
                  src="${desktopUrl}"
                  alt="Map to ${esc(primary.name)}"
                  class="nc-map-img"
                  loading="lazy"
                  onload="this.style.opacity='1';this.parentElement.classList.remove('nc-map-skeleton');"
                />
              </div>`;
            mapMobile = `
              <div class="nc-map-wrap nc-map-mobile nc-map-skeleton">
                <img
                  src="${mobileUrl}"
                  alt="Map to ${esc(primary.name)}"
                  class="nc-map-img"
                  loading="lazy"
                  onload="this.style.opacity='1';this.parentElement.classList.remove('nc-map-skeleton');"
                />
              </div>`;
          }

          // Secondary list
          let nearbyHtml = "";
          if (secondary.length > 0) {
            const items = secondary
              .map((shop) => {
                const url = `https://www.google.com/maps/dir/?api=1&destination=${shop.lat},${shop.lng}&travelmode=walking`;
                const walkTime = estimateWalk(shop.distance);
                const ratingHtml = shop.rating
                  ? `<div class="nc-nearby-rating"><span class="nc-nearby-rating-star">\u2605</span> ${shop.rating.toFixed(1)}</div>`
                  : "";
                return `
                <a href="${url}" target="_blank" rel="noopener" class="nc-nearby-item">
                  <div>
                    <div class="nc-nearby-name">${esc(shop.name)}</div>
                    <div class="nc-nearby-addr">${esc(shop.address)}</div>
                    ${ratingHtml}
                  </div>
                  <div class="nc-nearby-right">
                    <div class="nc-nearby-dist-wrap">
                      <span class="nc-nearby-dist">${formatDistance(shop.distance)}</span>
                      <span class="nc-nearby-walk">${walkTime}</span>
                    </div>
                    <span class="nc-nearby-arrow">\u2192</span>
                  </div>
                </a>`;
              })
              .join("");

            nearbyHtml = `
              <div class="nc-nearby nc-fade-in-delay">
                <div class="nc-nearby-label">Nearby</div>
                ${items}
              </div>`;
          }

          render(`
            <div class="nc-result nc-fade-in">
              <div class="nc-result-grid">
                <div>
                  <div class="nc-status">
                    <span class="nc-status-dot"></span>
                    Open Now
                  </div>
                  <div class="nc-meta-line">
                    <span>${formatDistance(primary.distance)}</span>
                    <span class="nc-meta-sep">\u00b7</span>
                    <span>${estimateWalk(primary.distance)}</span>
                  </div>
                  <h2 class="nc-shop-name">${esc(primary.name)}</h2>
                  <p class="nc-address">${esc(primary.address)}</p>
                  ${ratingMobile}
                  <a href="${navUrl}" target="_blank" rel="noopener" class="nc-cta">
                    Open in Maps
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </a>
                  ${mapMobile}
                </div>
                <div class="nc-aside">
                  <div class="nc-distance-lg">
                    <span class="nc-distance-number">${dist.value}</span>
                    <span class="nc-distance-unit">${dist.unit}</span>
                  </div>
                  <p class="nc-aside-meta">${estimateWalk(primary.distance)}</p>
                  ${ratingDesktop}
                  ${mapDesktop}
                </div>
              </div>

              ${nearbyHtml}

              <div class="nc-footer">
                <button id="refresh-btn" class="nc-refresh">\u21bb Refresh</button>
                <p class="nc-location-note">Based on your current location</p>
              </div>
            </div>
          `);

          document
            .getElementById("refresh-btn")!
            .addEventListener("click", doRequestLocation);
        }, 300);
      }

      // ── Fetch ──

      async function fetchCoffeeShops(lat: number, lng: number) {
        try {
          const res = await fetch("/api/nearby-coffee", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ latitude: lat, longitude: lng }),
          });

          if (!res.ok) throw new Error("API request failed");

          const data = await res.json();
          const shops: CoffeeShop[] = data.results || [];

          if (shops.length === 0) {
            progress.finish();
            setTimeout(() => {
              renderError(
                "No coffee nearby",
                "Couldn\u2019t find any open spots. Try again later or wander somewhere new.",
              );
            }, 300);
            return;
          }

          renderResults(shops);
        } catch {
          progress.finish();
          setTimeout(() => {
            renderError(
              "Something went wrong",
              "Couldn\u2019t find coffee right now. Please try again.",
            );
          }, 300);
        }
      }

      // ── Geolocation ──

      function doRequestLocation() {
        requestGeolocation({
          onLoading: renderLoading,
          onPosition: (lat, lng) => {
            userLat = lat;
            userLng = lng;
            fetchCoffeeShops(lat, lng);
          },
          onPermissionDenied: renderPermission,
          onError: renderError,
        });
      }

      // ── Init ──

      initGeolocation({
        onLoading: renderLoading,
        onPosition: (lat, lng) => {
          userLat = lat;
          userLng = lng;
          fetchCoffeeShops(lat, lng);
        },
        onPermissionDenied: renderPermission,
        onPermissionScreen: renderPermission,
        onError: renderError,
      });
    </script>
</BaseLayout>
