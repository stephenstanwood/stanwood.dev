---
import BaseLayout from "../layouts/BaseLayout.astro";
const hasMapsKey = Boolean(import.meta.env.GOOGLE_PLACES_API_KEY);
---

<BaseLayout
  title="Nearest Coffee — stanwood.dev"
  description="Find the nearest coffee shop that's open right now. Uses your location to sort by distance and shows hours, ratings, and directions."
  slug="nearest-coffee"
  favicon="/favicon-coffee.svg"
  themeColor="#FAFAF8"
  fontsUrl="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap"
  schemaCategory="LifestyleApplication"
>
  <Fragment slot="head">
    <style is:global>
      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background: #FAFAF8;
        color: #1A1A1A;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* ── Page layout ── */
      .nc-page {
        max-width: 860px;
        margin: 0 auto;
        padding: 40px 24px 80px;
      }
      @media (min-width: 768px) {
        .nc-page { padding: 56px 48px 120px; }
      }

      /* ── Navigation ── */
      .nc-back {
        font-size: 13px;
        font-weight: 500;
        color: #9A9A9A;
        text-decoration: none;
        letter-spacing: 0.02em;
        transition: color 0.2s;
      }
      .nc-back:hover { color: #1A1A1A; }

      /* ── Hero ── */
      .nc-hero {
        margin-top: 28px;
        margin-bottom: 8px;
        border-radius: 2px;
        overflow: hidden;
        background: #F2F0EC;
        aspect-ratio: 16 / 7;
        position: relative;
      }
      @media (min-width: 768px) {
        .nc-hero { aspect-ratio: 24 / 7; margin-top: 36px; }
      }
      .nc-hero img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        filter: contrast(0.97) saturate(0.92);
      }
      .nc-hero::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 60%, rgba(250,250,248,0.55));
        pointer-events: none;
      }

      /* ── Header ── */
      .nc-header {
        margin-top: 32px;
        margin-bottom: 40px;
      }
      @media (min-width: 768px) {
        .nc-header { margin-top: 40px; margin-bottom: 48px; }
      }
      .nc-label {
        display: block;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #9A9A9A;
        margin-bottom: 16px;
      }
      .nc-title {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: clamp(2rem, 4.5vw + 0.5rem, 3.25rem);
        font-weight: 500;
        line-height: 1.12;
        color: #1A1A1A;
        letter-spacing: -0.02em;
        max-width: 480px;
      }

      /* ── Divider ── */
      .nc-rule {
        border: none;
        height: 1px;
        background: #E5E3DF;
        margin: 0;
      }

      /* ── Loading ── */
      .nc-loading {
        padding: 56px 0;
      }
      .nc-loading-bar {
        height: 1px;
        background: #E5E3DF;
        overflow: hidden;
        max-width: 180px;
      }
      .nc-loading-fill {
        height: 100%;
        background: #5C4033;
        transition: width 0.3s ease-out;
        width: 0%;
      }
      .nc-loading-text {
        margin-top: 14px;
        font-size: 13px;
        color: #9A9A9A;
        font-weight: 400;
        letter-spacing: 0.02em;
      }

      /* ── Permission ── */
      .nc-permission {
        padding: 72px 0 56px;
        max-width: 380px;
      }
      .nc-permission p {
        font-size: 15px;
        line-height: 1.7;
        color: #6B6B6B;
        margin-bottom: 28px;
      }

      /* ── Buttons ── */
      .nc-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 28px;
        background: #1A1A1A;
        color: #FAFAF8;
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.03em;
        border: none;
        border-radius: 2px;
        cursor: pointer;
        transition: background 0.2s;
      }
      .nc-btn:hover { background: #5C4033; }

      /* ── Error ── */
      .nc-error {
        padding: 72px 0 56px;
        max-width: 400px;
      }
      .nc-error h2 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 24px;
        font-weight: 500;
        margin-bottom: 12px;
        color: #1A1A1A;
      }
      .nc-error p {
        font-size: 15px;
        line-height: 1.7;
        color: #6B6B6B;
        margin-bottom: 28px;
      }

      /* ── Primary result ── */
      .nc-result {
        padding: 44px 0 0;
      }
      @media (min-width: 768px) {
        .nc-result { padding: 52px 0 0; }
      }
      .nc-result-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 32px;
      }
      @media (min-width: 768px) {
        .nc-result-grid {
          grid-template-columns: 1fr 240px;
          gap: 56px;
        }
      }

      /* Status */
      .nc-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #3D6B4F;
        margin-bottom: 8px;
      }
      .nc-status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #3D6B4F;
        animation: nc-pulse 2s ease-in-out infinite;
      }

      /* Inline distance (mobile) */
      .nc-meta-line {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: #6B6B6B;
        margin-bottom: 20px;
      }
      .nc-meta-sep {
        color: #D0CDC6;
      }
      @media (min-width: 768px) {
        .nc-meta-line { display: none; }
      }

      /* Shop name */
      .nc-shop-name {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: clamp(1.75rem, 3vw + 0.5rem, 2.5rem);
        font-weight: 500;
        line-height: 1.15;
        color: #1A1A1A;
        letter-spacing: -0.01em;
        margin-bottom: 10px;
      }

      /* Address */
      .nc-address {
        font-size: 14px;
        line-height: 1.6;
        color: #6B6B6B;
        margin-bottom: 8px;
      }

      /* Rating inline */
      .nc-rating-inline {
        font-size: 13px;
        color: #9A9A9A;
        margin-bottom: 24px;
      }
      .nc-rating-star { color: #5C4033; }

      /* CTA */
      .nc-cta {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        font-weight: 600;
        color: #5C4033;
        text-decoration: none;
        letter-spacing: 0.02em;
        transition: color 0.2s;
      }
      .nc-cta:hover { color: #1A1A1A; }
      .nc-cta svg { transition: transform 0.2s; }
      .nc-cta:hover svg { transform: translateX(3px); }

      /* ── Aside: distance + map (desktop) ── */
      .nc-aside {
        display: none;
      }
      @media (min-width: 768px) {
        .nc-aside { display: block; }
      }

      .nc-distance-lg {
        margin-bottom: 4px;
      }
      .nc-distance-number {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 56px;
        font-weight: 400;
        line-height: 1;
        color: #1A1A1A;
        letter-spacing: -0.03em;
      }
      .nc-distance-unit {
        display: block;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #9A9A9A;
        margin-top: 4px;
      }
      .nc-aside-meta {
        font-size: 13px;
        color: #9A9A9A;
        margin-top: 6px;
      }
      .nc-aside-rating {
        font-size: 13px;
        color: #9A9A9A;
        margin-top: 2px;
      }

      /* Map */
      .nc-map-wrap {
        margin-top: 20px;
        overflow: hidden;
        border-radius: 2px;
        background: #F2F0EC;
        aspect-ratio: 4 / 3;
        position: relative;
      }
      /* Mobile map: full width below CTA */
      .nc-map-mobile {
        display: block;
        margin-top: 28px;
        aspect-ratio: 2 / 1;
      }
      @media (min-width: 768px) {
        .nc-map-mobile { display: none; }
      }
      .nc-map-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0;
        transition: opacity 0.4s;
      }
      .nc-map-skeleton {
        animation: nc-skeleton 1.5s ease-in-out infinite;
      }

      /* ── Nearby list ── */
      .nc-nearby {
        margin-top: 48px;
      }
      @media (min-width: 768px) {
        .nc-nearby { margin-top: 56px; }
      }
      .nc-nearby-label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #9A9A9A;
      }
      .nc-nearby-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
      }
      .nc-sort-toggle {
        display: flex;
        gap: 4px;
      }
      .nc-sort-btn {
        background: none;
        border: 1px solid #E5E3DF;
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: #9A9A9A;
        padding: 4px 10px;
        border-radius: 2px;
        cursor: pointer;
        transition: all 0.15s;
      }
      .nc-sort-btn:hover {
        border-color: #5C4033;
        color: #5C4033;
      }
      .nc-sort-btn--active {
        background: #1A1A1A;
        border-color: #1A1A1A;
        color: #FAFAF8;
      }
      .nc-nearby-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 14px 0;
        border-top: 1px solid #E5E3DF;
        text-decoration: none;
        color: inherit;
        transition: opacity 0.2s;
      }
      .nc-nearby-item:last-child {
        border-bottom: 1px solid #E5E3DF;
      }
      .nc-nearby-item:hover { opacity: 0.6; }
      .nc-nearby-name {
        font-size: 15px;
        font-weight: 500;
        color: #1A1A1A;
        margin-bottom: 2px;
      }
      .nc-nearby-addr {
        font-size: 12px;
        color: #9A9A9A;
        line-height: 1.4;
      }
      .nc-nearby-right {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-shrink: 0;
      }
      .nc-nearby-dist {
        font-size: 13px;
        font-weight: 500;
        color: #6B6B6B;
        white-space: nowrap;
      }
      .nc-nearby-arrow {
        color: #C0BDB8;
        font-size: 14px;
        transition: color 0.2s;
      }
      .nc-nearby-item:hover .nc-nearby-arrow {
        color: #5C4033;
      }
      .nc-nearby-dist-wrap {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 2px;
      }
      .nc-nearby-walk {
        font-size: 11px;
        color: #C0BDB8;
        white-space: nowrap;
      }
      .nc-nearby-rating {
        font-size: 12px;
        color: #9A9A9A;
        margin-top: 3px;
      }
      .nc-nearby-rating-star {
        color: #5C4033;
      }

      /* ── Footer ── */
      .nc-footer {
        margin-top: 48px;
        padding-top: 24px;
      }
      .nc-refresh {
        background: none;
        border: none;
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 13px;
        font-weight: 500;
        color: #9A9A9A;
        cursor: pointer;
        padding: 0;
        transition: color 0.2s;
        letter-spacing: 0.02em;
      }
      .nc-refresh:hover { color: #5C4033; }
      .nc-location-note {
        font-size: 12px;
        color: #C0BDB8;
        margin-top: 6px;
      }

      /* ── Animations ── */
      @keyframes nc-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
      }
      @keyframes nc-skeleton {
        0%, 100% { opacity: 0.6; }
        50% { opacity: 0.3; }
      }
      @keyframes nc-fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .nc-fade-in {
        animation: nc-fadeIn 0.45s ease both;
      }
      .nc-fade-in-delay {
        animation: nc-fadeIn 0.45s ease 0.1s both;
      }

      /* ── For moments like ── */
      .nc-forwhen {
        margin-top: 40px;
        margin-bottom: 8px;
      }
      @media (min-width: 768px) {
        .nc-forwhen { margin-top: 48px; }
      }
      .nc-forwhen-label {
        display: block;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #9A9A9A;
        margin-bottom: 22px;
      }
      .nc-forwhen-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 18px;
      }
      @media (min-width: 640px) {
        .nc-forwhen-grid { grid-template-columns: 1fr 1fr; gap: 22px 44px; }
      }
      .nc-forwhen-item {
        display: flex;
        gap: 14px;
        align-items: baseline;
      }
      .nc-forwhen-num {
        font-family: 'Playfair Display', Georgia, serif;
        font-style: italic;
        font-size: 18px;
        color: #C0BDB8;
        font-weight: 400;
        flex-shrink: 0;
        min-width: 22px;
      }
      .nc-forwhen-text {
        font-size: 14px;
        line-height: 1.65;
        color: #4A4A4A;
        margin: 0;
      }
      .nc-forwhen-text em {
        font-family: 'Playfair Display', Georgia, serif;
        font-style: italic;
        font-weight: 500;
        color: #1A1A1A;
      }

      /* ── How it works ── */
      .nc-how {
        margin-top: 40px;
        margin-bottom: 40px;
      }
      @media (min-width: 768px) {
        .nc-how { margin-top: 48px; margin-bottom: 48px; }
      }
      .nc-how-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 28px;
      }
      @media (min-width: 640px) {
        .nc-how-grid { grid-template-columns: repeat(3, 1fr); gap: 40px; }
      }
      .nc-how-label {
        display: block;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #5C4033;
        margin-bottom: 10px;
      }
      .nc-how-body {
        font-size: 13px;
        line-height: 1.7;
        color: #6B6B6B;
      }

      /* ── Glossary ── */
      .nc-glossary {
        margin-top: 40px;
      }
      @media (min-width: 768px) {
        .nc-glossary { margin-top: 48px; }
      }
      .nc-section-eyebrow {
        display: block;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #9A9A9A;
        margin-bottom: 8px;
      }
      .nc-section-intro {
        font-family: 'Playfair Display', Georgia, serif;
        font-style: italic;
        font-size: 16px;
        color: #4A4A4A;
        margin: 0 0 28px;
        line-height: 1.5;
        max-width: 560px;
      }
      .nc-glossary-block {
        margin-bottom: 28px;
      }
      .nc-glossary-block:last-child {
        margin-bottom: 0;
      }
      .nc-glossary-heading {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 18px;
        font-weight: 500;
        font-style: italic;
        color: #5C4033;
        margin: 0 0 14px;
        letter-spacing: -0.01em;
      }
      .nc-glossary-list {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px 32px;
        margin: 0;
      }
      @media (min-width: 640px) {
        .nc-glossary-list { grid-template-columns: 1fr 1fr; }
      }
      .nc-glossary-list > div {
        display: grid;
        grid-template-columns: 118px 1fr;
        gap: 12px;
        align-items: baseline;
      }
      .nc-glossary-list dt {
        font-size: 12.5px;
        font-weight: 600;
        color: #1A1A1A;
        letter-spacing: 0.01em;
      }
      .nc-glossary-list dd {
        font-size: 13px;
        line-height: 1.55;
        color: #6B6B6B;
        margin: 0;
      }
      @media (max-width: 460px) {
        .nc-glossary-list > div {
          grid-template-columns: 1fr;
          gap: 2px;
        }
      }

      /* ── Tips callout ── */
      .nc-tips {
        margin: 40px 0 0;
        background: #F5F2EC;
        border-radius: 4px;
        padding: 22px 24px 24px;
        border-left: 3px solid #5C4033;
      }
      @media (min-width: 768px) {
        .nc-tips { margin-top: 48px; }
      }
      .nc-tips-label {
        display: block;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #5C4033;
        margin-bottom: 14px;
      }
      .nc-tips ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 11px;
      }
      .nc-tips li {
        font-size: 13.5px;
        line-height: 1.65;
        color: #4A4A4A;
      }
      .nc-tips em {
        font-family: 'Playfair Display', Georgia, serif;
        font-style: italic;
        font-weight: 500;
        color: #1A1A1A;
      }

      /* ── Reduced motion ── */
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
        }
      }
    </style>
  </Fragment>

    <a href="#app" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-[#5C4033] focus:text-[#FAFAF8] focus:rounded focus:font-semibold">Skip to content</a>

    <main class="nc-page">
      <nav>
        <a href="/" class="nc-back">&larr; Back</a>
      </nav>

      <div class="nc-hero">
        <img
          src="/images/nearest-coffee.webp"
          alt="A quiet cafe morning with golden light through the window"
          width="800"
          height="449"
          loading="lazy"
          decoding="async"
        />
      </div>

      <header class="nc-header">
        <span class="nc-label">Nearest Coffee</span>
        <h1 class="nc-title">Your nearest open coffee.</h1>
      </header>

      <hr class="nc-rule">

      <!-- For moments like -->
      <section class="nc-forwhen" aria-label="Why this exists">
        <span class="nc-forwhen-label">Built for moments like</span>
        <div class="nc-forwhen-grid">
          <div class="nc-forwhen-item">
            <span class="nc-forwhen-num">i.</span>
            <p class="nc-forwhen-text"><em>You&rsquo;re early for a meeting</em> in a strange neighborhood and need somewhere to land for twenty minutes.</p>
          </div>
          <div class="nc-forwhen-item">
            <span class="nc-forwhen-num">ii.</span>
            <p class="nc-forwhen-text"><em>The cafe you wanted is closed</em> and you need a fast Plan B before the morning slips away.</p>
          </div>
          <div class="nc-forwhen-item">
            <span class="nc-forwhen-num">iii.</span>
            <p class="nc-forwhen-text"><em>You&rsquo;re visiting a friend</em> and want to suggest somewhere walkable instead of staring at Google Maps.</p>
          </div>
          <div class="nc-forwhen-item">
            <span class="nc-forwhen-num">iv.</span>
            <p class="nc-forwhen-text"><em>You just need a desk for an hour</em> and don&rsquo;t care which chain &mdash; closest open seat wins.</p>
          </div>
        </div>
      </section>

      <hr class="nc-rule" style="margin-top: 40px;">

      <!-- How it works -->
      <section class="nc-how">
        <div class="nc-how-grid">
          <div>
            <span class="nc-how-label">How it works</span>
            <p class="nc-how-body">Share your location and it queries Google Places for coffee shops open right now &mdash; sorted by walking distance, closest first.</p>
          </div>
          <div>
            <span class="nc-how-label">What you get</span>
            <p class="nc-how-body">The nearest open shop with its name, address, walking estimate, and a map. Plus up to four alternatives nearby with ratings and walk times &mdash; each linking straight to directions.</p>
          </div>
          <div>
            <span class="nc-how-label">Privacy</span>
            <p class="nc-how-body">Your coordinates go to the server only to run the Places query. They&rsquo;re never stored, logged, or tied to you in any way.</p>
          </div>
        </div>
      </section>

      <hr class="nc-rule" style="margin-top: 40px;">

      <!-- Decode the menu -->
      <section class="nc-glossary" aria-label="Coffee menu glossary">
        <span class="nc-section-eyebrow">Decode the menu</span>
        <p class="nc-section-intro">A pocket primer for whatever cafe shows up first.</p>

        <div class="nc-glossary-block">
          <p class="nc-glossary-heading">Espresso, neat</p>
          <dl class="nc-glossary-list">
            <div><dt>Espresso</dt><dd>A 1 oz shot &mdash; bitter, syrupy, the base for everything else.</dd></div>
            <div><dt>Doppio</dt><dd>Double shot. Same cup, twice the punch.</dd></div>
            <div><dt>Ristretto</dt><dd>Short pull. Sweeter, more concentrated than a regular shot.</dd></div>
            <div><dt>Lungo</dt><dd>Long pull. Mellower, but more bitter than an americano.</dd></div>
            <div><dt>Macchiato</dt><dd>Shot &ldquo;stained&rdquo; with foam &mdash; not the syrupy chain version.</dd></div>
            <div><dt>Affogato</dt><dd>Shot poured over a scoop of vanilla gelato. Dessert and caffeine in one cup.</dd></div>
          </dl>
        </div>

        <div class="nc-glossary-block">
          <p class="nc-glossary-heading">Espresso + milk</p>
          <dl class="nc-glossary-list">
            <div><dt>Cappuccino</dt><dd>Equal espresso, steamed milk, and foam. Drier and foamier than a latte.</dd></div>
            <div><dt>Latte</dt><dd>Shot with steamed milk and a thin foam cap. Smoothest of the milk drinks.</dd></div>
            <div><dt>Flat white</dt><dd>Stronger pull, microfoam, smaller cup. Less foam, more coffee.</dd></div>
            <div><dt>Cortado</dt><dd>Equal espresso and warm milk. Cuts the bite without watering down.</dd></div>
            <div><dt>Gibraltar</dt><dd>Bay Area cortado, named for the rocks glass it&rsquo;s served in.</dd></div>
            <div><dt>Mocha</dt><dd>Latte plus chocolate. Dessert in a cup.</dd></div>
            <div><dt>Breve</dt><dd>Latte with half-and-half. Richer, heavier, sneaky strong.</dd></div>
            <div><dt>Con panna</dt><dd>Espresso topped with whipped cream. Tiny indulgence, no froth required.</dd></div>
          </dl>
        </div>

        <div class="nc-glossary-block">
          <p class="nc-glossary-heading">Brewed coffee</p>
          <dl class="nc-glossary-list">
            <div><dt>Drip</dt><dd>Batch-brewed. The house default. Refills are usually free.</dd></div>
            <div><dt>Pour-over</dt><dd>Single cup made by hand. Cleaner and brighter &mdash; what indie cafes show off.</dd></div>
            <div><dt>French press</dt><dd>Steeped, then plunged. Full-bodied with a little sediment.</dd></div>
            <div><dt>Cold brew</dt><dd>Steeped 12+ hours in cold water. Low acid, smooth, naturally sweet.</dd></div>
            <div><dt>Nitro</dt><dd>Cold brew on tap with nitrogen. Creamy head, almost like a stout.</dd></div>
            <div><dt>Americano</dt><dd>Espresso topped with hot water. Drip&rsquo;s bolder cousin.</dd></div>
          </dl>
        </div>

        <div class="nc-glossary-block">
          <p class="nc-glossary-heading">Tweaks &amp; mods</p>
          <dl class="nc-glossary-list">
            <div><dt>Half-caf</dt><dd>Half regular, half decaf. Less jitter, same ritual.</dd></div>
            <div><dt>Decaf</dt><dd>Caffeine mostly removed. Doesn&rsquo;t taste worse &mdash; just calmer.</dd></div>
            <div><dt>Oat / oat M</dt><dd>Alt-milk swap. Oat steams best for lattes &mdash; creamy without the dairy.</dd></div>
            <div><dt>Extra shot</dt><dd>The cheapest upgrade on the menu.</dd></div>
            <div><dt>2-pump / 4-pump</dt><dd>Fewer or more pumps of syrup. Default is 3 small / 4 large.</dd></div>
            <div><dt>Kid temp</dt><dd>Steamed milk drink, served lukewarm. Works for adults too.</dd></div>
          </dl>
        </div>
      </section>

      <aside class="nc-tips" aria-label="Pro tips">
        <span class="nc-tips-label">Pro tips</span>
        <ul>
          <li><em>Indie spot?</em> Order the pour-over or whatever&rsquo;s on the espresso menu &mdash; that&rsquo;s where they show off.</li>
          <li><em>Chain drive-thru?</em> Stick to drip or a basic latte. Built for volume, not nuance.</li>
          <li><em>&ldquo;Open now&rdquo; lies sometimes.</em> Google&rsquo;s hours are usually right, but call ahead for tiny shops with weird hours.</li>
          <li><em>Switch to &ldquo;Rating&rdquo;</em> in unfamiliar neighborhoods &mdash; the closest one isn&rsquo;t always the right one.</li>
        </ul>
      </aside>

      <div id="app" data-has-maps={hasMapsKey ? "1" : ""}></div>
    </main>

    <script>
      import {
        formatDistance,
        estimateWalk,
        computeZoom,
        createProgress,
        initGeolocation,
        requestGeolocation,
      } from "../lib/nearbyUtils";

      type CoffeeShop = {
        id: string;
        name: string;
        address: string;
        lat: number;
        lng: number;
        distance: number;
        rating: number | null;
        ratingCount: number | null;
        isOpen: boolean | null;
      };

      const app = document.getElementById("app")!;
      const hasMaps = app.dataset.hasMaps === "1";

      const progress = createProgress([
        { at: 0, text: "Locating\u2026" },
        { at: 25, text: "Searching nearby\u2026" },
        { at: 55, text: "Checking hours\u2026" },
        { at: 80, text: "Almost ready\u2026" },
      ]);

      let userLat: number;
      let userLng: number;
      let secondaryShops: CoffeeShop[] = [];
      let currentSort: "distance" | "rating" = "distance";

      // ── Light map styles ──

      const LIGHT_MAP_STYLES = [
        "feature:all|element:geometry|color:0xf2f0ec",
        "feature:all|element:labels.text.fill|color:0xb0ada6",
        "feature:all|element:labels.text.stroke|color:0xfafaf8",
        "feature:water|element:geometry.fill|color:0xe5e3df",
        "feature:road|element:geometry.fill|color:0xffffff",
        "feature:road|element:geometry.stroke|color:0xeae8e4",
        "feature:road.highway|element:geometry.fill|color:0xf5f3ef",
        "feature:poi|visibility:off",
        "feature:transit|visibility:off",
        "feature:administrative|element:geometry.stroke|color:0xe5e3df",
      ];

      // ── Helpers ──

      function render(html: string) {
        app.innerHTML = html;
      }

      function esc(s: string) {
        return s
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;");
      }

      function parseDistance(meters: number): { value: string; unit: string } {
        const miles = meters / 1609.34;
        if (miles < 0.1) {
          return { value: String(Math.round(meters * 3.28084)), unit: "ft" };
        }
        return { value: miles.toFixed(1), unit: "mi" };
      }

      // ── Map URL ──

      function buildMapUrl(
        shop: CoffeeShop,
        size = "480x360",
      ): string {
        const midLat = (userLat + shop.lat) / 2;
        const midLng = (userLng + shop.lng) / 2;
        const zoom = computeZoom(shop.distance);

        const params = new URLSearchParams();
        params.set("center", `${midLat},${midLng}`);
        params.set("zoom", String(zoom));
        params.set("size", size);
        params.set("scale", "2");
        params.set("maptype", "roadmap");

        for (const s of LIGHT_MAP_STYLES) params.append("style", s);

        params.append(
          "markers",
          `color:0x9A9A9A|size:small|${userLat},${userLng}`,
        );
        params.append(
          "markers",
          `color:0x5C4033|size:mid|${shop.lat},${shop.lng}`,
        );

        return `/api/static-map?${params.toString()}`;
      }

      // ── States ──

      function renderLoading() {
        render(`
          <div class="nc-loading">
            <div class="nc-loading-bar">
              <div id="progressFill" class="nc-loading-fill"></div>
            </div>
            <p id="progressLabel" class="nc-loading-text">Locating\u2026</p>
          </div>
        `);
        progress.start();
      }

      function renderPermission() {
        render(`
          <div class="nc-permission">
            <p>Location access is needed to find coffee shops near you.</p>
            <button id="enable-btn" class="nc-btn">Enable Location</button>
          </div>
        `);
        document
          .getElementById("enable-btn")!
          .addEventListener("click", doRequestLocation);
      }

      function renderError(title: string, message: string) {
        render(`
          <div class="nc-error">
            <h2>${esc(title)}</h2>
            <p>${esc(message)}</p>
            <button id="retry-btn" class="nc-btn">Try Again</button>
          </div>
        `);
        document
          .getElementById("retry-btn")!
          .addEventListener("click", doRequestLocation);
      }

      // ── Results ──

      function buildNearbyItems(shops: CoffeeShop[]): string {
        const sorted = [...shops].sort((a, b) =>
          currentSort === "rating"
            ? (b.rating ?? -1) - (a.rating ?? -1)
            : a.distance - b.distance,
        );
        return sorted
          .map((shop) => {
            const url = `https://www.google.com/maps/dir/?api=1&destination=${shop.lat},${shop.lng}&travelmode=walking`;
            const walkTime = estimateWalk(shop.distance);
            const ratingHtml = shop.rating
              ? `<div class="nc-nearby-rating"><span class="nc-nearby-rating-star">\u2605</span> ${shop.rating.toFixed(1)}</div>`
              : "";
            return `
              <a href="${url}" target="_blank" rel="noopener" class="nc-nearby-item">
                <div>
                  <div class="nc-nearby-name">${esc(shop.name)}</div>
                  <div class="nc-nearby-addr">${esc(shop.address)}</div>
                  ${ratingHtml}
                </div>
                <div class="nc-nearby-right">
                  <div class="nc-nearby-dist-wrap">
                    <span class="nc-nearby-dist">${formatDistance(shop.distance)}</span>
                    <span class="nc-nearby-walk">${walkTime}</span>
                  </div>
                  <span class="nc-nearby-arrow">\u2192</span>
                </div>
              </a>`;
          })
          .join("");
      }

      function renderResults(shops: CoffeeShop[]) {
        progress.finish();

        setTimeout(() => {
          const primary = shops[0];
          const secondary = shops.slice(1, 5);
          const dist = parseDistance(primary.distance);
          const navUrl = `https://www.google.com/maps/dir/?api=1&destination=${primary.lat},${primary.lng}&travelmode=walking`;

          // Rating
          let ratingDesktop = "";
          let ratingMobile = "";
          if (primary.rating) {
            const rText = `<span class="nc-rating-star">\u2605</span> ${primary.rating.toFixed(1)}${primary.ratingCount ? ` \u00b7 ${primary.ratingCount}` : ""}`;
            ratingDesktop = `<p class="nc-aside-rating">${rText}</p>`;
            ratingMobile = `<p class="nc-rating-inline">${rText}</p>`;
          }

          // Maps
          let mapDesktop = "";
          let mapMobile = "";
          if (hasMaps) {
            const desktopUrl = buildMapUrl(primary, "480x360");
            const mobileUrl = buildMapUrl(primary, "600x300");
            mapDesktop = `
              <div class="nc-map-wrap nc-map-skeleton">
                <img
                  src="${desktopUrl}"
                  alt="Map to ${esc(primary.name)}"
                  class="nc-map-img"
                  loading="lazy"
                  onload="this.style.opacity='1';this.parentElement.classList.remove('nc-map-skeleton');"
                />
              </div>`;
            mapMobile = `
              <div class="nc-map-wrap nc-map-mobile nc-map-skeleton">
                <img
                  src="${mobileUrl}"
                  alt="Map to ${esc(primary.name)}"
                  class="nc-map-img"
                  loading="lazy"
                  onload="this.style.opacity='1';this.parentElement.classList.remove('nc-map-skeleton');"
                />
              </div>`;
          }

          // Secondary list
          secondaryShops = secondary;
          currentSort = "distance";
          let nearbyHtml = "";
          if (secondary.length > 0) {
            nearbyHtml = `
              <div class="nc-nearby nc-fade-in-delay">
                <div class="nc-nearby-header">
                  <div class="nc-nearby-label">Nearby</div>
                  <div class="nc-sort-toggle">
                    <button class="nc-sort-btn nc-sort-btn--active" data-sort="distance">Distance</button>
                    <button class="nc-sort-btn" data-sort="rating">Rating</button>
                  </div>
                </div>
                <div id="nearby-list">
                  ${buildNearbyItems(secondary)}
                </div>
              </div>`;
          }

          render(`
            <div class="nc-result nc-fade-in">
              <div class="nc-result-grid">
                <div>
                  <div class="nc-status">
                    <span class="nc-status-dot"></span>
                    Open Now
                  </div>
                  <div class="nc-meta-line">
                    <span>${formatDistance(primary.distance)}</span>
                    <span class="nc-meta-sep">\u00b7</span>
                    <span>${estimateWalk(primary.distance)}</span>
                  </div>
                  <h2 class="nc-shop-name">${esc(primary.name)}</h2>
                  <p class="nc-address">${esc(primary.address)}</p>
                  ${ratingMobile}
                  <a href="${navUrl}" target="_blank" rel="noopener" class="nc-cta">
                    Open in Maps
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </a>
                  ${mapMobile}
                </div>
                <div class="nc-aside">
                  <div class="nc-distance-lg">
                    <span class="nc-distance-number">${dist.value}</span>
                    <span class="nc-distance-unit">${dist.unit}</span>
                  </div>
                  <p class="nc-aside-meta">${estimateWalk(primary.distance)}</p>
                  ${ratingDesktop}
                  ${mapDesktop}
                </div>
              </div>

              ${nearbyHtml}

              <div class="nc-footer">
                <button id="refresh-btn" class="nc-refresh">\u21bb Refresh</button>
                <p class="nc-location-note">Found ${shops.length} open nearby \u00b7 Last checked: ${new Date().toLocaleTimeString("en-US", { hour: "numeric", minute: "2-digit" })}</p>
              </div>
            </div>
          `);

          document
            .getElementById("refresh-btn")!
            .addEventListener("click", doRequestLocation);

          document
            .querySelectorAll<HTMLButtonElement>(".nc-sort-btn")
            .forEach((btn) => {
              btn.addEventListener("click", () => {
                currentSort = btn.dataset.sort as "distance" | "rating";
                document
                  .querySelectorAll<HTMLButtonElement>(".nc-sort-btn")
                  .forEach((b) => {
                    b.classList.toggle(
                      "nc-sort-btn--active",
                      b.dataset.sort === currentSort,
                    );
                  });
                const list = document.getElementById("nearby-list");
                if (list) list.innerHTML = buildNearbyItems(secondaryShops);
              });
            });
        }, 300);
      }

      // ── Fetch ──

      async function fetchCoffeeShops(lat: number, lng: number) {
        try {
          const res = await fetch("/api/nearby-coffee", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ latitude: lat, longitude: lng }),
          });

          if (!res.ok) throw new Error("API request failed");

          const data = await res.json();
          const shops: CoffeeShop[] = data.results || [];

          if (shops.length === 0) {
            progress.finish();
            setTimeout(() => {
              renderError(
                "No coffee nearby",
                "Couldn\u2019t find any open spots. Try again later or wander somewhere new.",
              );
            }, 300);
            return;
          }

          renderResults(shops);
        } catch {
          progress.finish();
          setTimeout(() => {
            renderError(
              "Something went wrong",
              "Couldn\u2019t find coffee right now. Please try again.",
            );
          }, 300);
        }
      }

      // ── Geolocation ──

      function doRequestLocation() {
        requestGeolocation({
          onLoading: renderLoading,
          onPosition: (lat, lng) => {
            userLat = lat;
            userLng = lng;
            fetchCoffeeShops(lat, lng);
          },
          onPermissionDenied: renderPermission,
          onError: renderError,
        });
      }

      // ── Init ──

      initGeolocation({
        onLoading: renderLoading,
        onPosition: (lat, lng) => {
          userLat = lat;
          userLng = lng;
          fetchCoffeeShops(lat, lng);
        },
        onPermissionDenied: renderPermission,
        onPermissionScreen: renderPermission,
        onError: renderError,
      });
    </script>
</BaseLayout>
