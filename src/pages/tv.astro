      border: 1px solid #999;
      background: transparent;
      font-size: 0.7rem;
      padding: 2px 6px;
      cursor: pointer;
      font-family: inherit;
    }
    .mark-btn:hover { background: var(--hot); color: var(--paper); border-color: var(--hot); }
    /* Touch devices need bigger tap targets than the dense desktop list */
    @media (pointer: coarse) {
      .mark-btn { padding: 10px 14px; font-size: 0.85rem; }
    }

    .empty {
      padding: 2rem;
      text-align: center;
      background: var(--paper);
      border: var(--border);
    }
    /* Around the internet */
    .internet-section {
      margin-top: 0;
    }
    .section-head {
      display: block;
    }
    .section-kicker, .section-note { display: none; }
    .internet-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0;
      margin: -1.45rem 0 1rem;
      color: var(--muted);
      font-size: 0.7rem;
    }
    .meta-pill {
      white-space: nowrap;
    }
    .meta-pill + .meta-pill::before { content: ' · '; white-space: pre; }
    .broader-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1rem;
    }
    .bcard {
      background: var(--paper);
      border: var(--border);
      box-shadow: var(--shadow);
      display: flex;
      flex-direction: column;
      color: var(--ink);
      position: relative;
      min-width: 0;
      transition: transform 0.05s ease, box-shadow 0.05s ease;
    }
    .bcard:hover {
      transform: translate(-2px, -2px);
      box-shadow: 8px 8px 0 var(--ink);
    }
    .bcard.hidden { display: none; }
    .bcard-link {
      display: flex;
      flex: 1;
      flex-direction: column;
      min-width: 0;
      color: inherit;
      text-decoration: none;
    }
    .bcard-thumb {
      aspect-ratio: 16 / 9;
      background: #000 center/cover no-repeat;
      border-bottom: 2px solid var(--ink);
      position: relative;
    }
    .pick-badge { display: none; }
    .explore-badge,
    .series-badge,
    .classic-badge {
      position: absolute;
      left: 6px;
      z-index: 1;
      border: 2px solid var(--ink);
      font-size: 0.65rem;
      font-weight: 700;
      padding: 1px 5px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .bcard-dur {
      position: absolute;
      bottom: 6px;
      right: 6px;
      background: var(--ink);
      color: var(--paper);
      font-size: 0.7rem;
      padding: 1px 5px;
      font-weight: 700;
    }
    .bcard-body {
      padding: .65rem .75rem .75rem;
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .bcard-title {
      font-size: 0.9rem;
      font-weight: 700;
      line-height: 1.3;
      margin: 0 0 .35rem;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .bcard-meta {
      font-size: 0.72rem;
      color: #666;
      margin-top: auto;
      display: flex;
      justify-content: space-between;
      gap: .5rem;
    }
    .bcard-chan {
      color: #333;
      font-weight: 700;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .explore-badge {
      top: 6px;
      background: var(--lime);
    }
    .series-badge {
      bottom: 6px;
      background: var(--yellow);
    }
    .classic-badge {
      top: 6px;
      background: var(--hot);
      color: var(--paper);
    }
    .sdsn-card .bcard-thumb {
      background-color: #171717;
    }
    .sdsn-card-loading .bcard-thumb {
      background:
        linear-gradient(135deg, #171717 0 48%, #2a2a2a 48% 52%, #171717 52% 100%);
    }
