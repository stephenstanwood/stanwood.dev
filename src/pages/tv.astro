      font-size: 1.3rem;
    }
    .series-meta { font-size: 0.75rem; color: #666; }
    .score-chip {
      display: inline-block;
      background: var(--lime);
      border: 2px solid var(--ink);
      padding: 1px 6px;
      font-size: 0.7rem;
      font-weight: 700;
      margin-left: .5rem;
    }
    .score-chip.low { background: #fff; color: #999; }
