<html lang="en" class:list={{ 'yt-unlocked': AUTO_UNLOCK_IN_DEV }}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>TV Queue · stanwood.dev</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Permanent+Marker&family=Space+Mono:wght@400;700&display=swap"
    rel="stylesheet"
  />
  <script is:inline>
    (function () {
      try {
        if (localStorage.getItem('yt-gate-v1') === 'meow') {
          document.documentElement.classList.add('yt-unlocked');
        }
      } catch {}
    })();
    // Frame-friendly: full reload every 20 min so static content (videos, broader)
    // stays fresh and the live strip resyncs even if the tab has been backgrounded.
    setTimeout(function () { window.location.reload(); }, 20 * 60 * 1000);
  </script>
  <style is:global>
    :root {
      --bg: #f2f4f7;
      --ink: #1a1a1a;
      --paper: #ffffff;
      --hot: #ff3b30;
      --cool: #0a84ff;
      --cool-soft: #e5edf7;
      --lime: #b8e986;
      --yellow: #ffd86b;
      --muted: #666;
      --line: #c7ccd4;
      --border: 3px solid var(--ink);
      --shadow: 6px 6px 0 var(--ink);
    }
    * { box-sizing: border-box; }
    html { background: var(--bg); }
    body {
      margin: 0;
      padding: 2rem 1rem;
      min-height: 100vh;
      background: var(--bg);
      color: var(--ink);
      font-family: 'Space Mono', monospace;
      font-size: 15px;
      line-height: 1.5;
    }
    button, input { font: inherit; }
    button:focus-visible, a:focus-visible, input:focus-visible {
      outline: 3px solid var(--yellow);
      outline-offset: 3px;
    }
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
    .wrap { max-width: 1100px; margin: 0 auto; }

    /* Password gate */
    html:not(.yt-unlocked) .wrap { display: none; }
    html.yt-unlocked #yt-gate { display: none; }
    #yt-gate {
      max-width: 360px;
      margin: 4rem auto;
      padding: 2rem 1.5rem;
      background: var(--paper);
      border: var(--border);
      box-shadow: var(--shadow);
      text-align: center;
    }
    #yt-gate h2 {
      font-family: 'Permanent Marker', cursive;
      font-size: 1.6rem;
      margin: 0 0 1rem;
    }
    #yt-gate input {
      width: 100%;
      padding: .6rem .8rem;
      border: var(--border);
      font-family: 'Space Mono', monospace;
      font-size: 1rem;
      background: var(--bg);
      color: var(--ink);
    }
    #yt-gate input:focus { outline: none; background: var(--paper); }
    #yt-gate.shake { animation: gate-shake 0.3s; }
    @keyframes gate-shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-8px); }
      75% { transform: translateX(8px); }
    }
    h1 {
      font-family: 'Permanent Marker', cursive;
      font-size: clamp(2.4rem, 6vw, 3.6rem);
      margin: 0 0 .25rem;
      line-height: 1;
      letter-spacing: -0.02em;
    }
    .subtitle {
      font-size: 0.85rem;
      color: var(--muted);
      margin: 0 0 2rem;
    }
    .subtitle a { color: var(--cool); }

