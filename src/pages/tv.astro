      text-overflow: ellipsis;
    }
    .recap-team-abbr {
      font-size: 0.65rem;
      color: #888;
      letter-spacing: 0.06em;
    }
    @container (max-width: 430px) {
      .recap-team-name { display: none; }
      .recap-team-abbr {
        font-family: 'Space Mono', monospace;
        font-weight: 700;
        font-size: 0.85rem;
        line-height: 1.15;
        color: var(--ink);
        letter-spacing: 0;
      }
    }
    .recap-score {
      font-family: 'Permanent Marker', cursive;
      font-size: 1.7rem;
      line-height: 1;
      padding: 0 0.3rem;
      color: #aaa;
    }
    .recap-score.win { color: var(--ink); }
    .recap-vs {
      font-family: 'Permanent Marker', cursive;
      font-size: 0.85rem;
      color: #888;
      flex-shrink: 0;
    }
    .recap-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      border-top: 1px dashed #ccc;
      padding-top: 0.55rem;
    }
    .recap-final { font-weight: 700; color: #444; }
    .recap-watch { font-weight: 700; color: var(--cool); }

    /* Live tile variant — same big-tile chrome, with pulsing LIVE indicator
       and no winner/loser score emphasis (no winner yet). */
    .recap-tile.live .recap-score.live { color: var(--ink); }
    .recap-live-status {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-weight: 700;
      color: var(--hot);
    }
    .recap-live-dot {
      display: inline-block;
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--hot);
      animation: livePulse 1.5s ease-in-out infinite;
    }

    /* MLB Big Inning live indicator — small pill above the live tile grid
       when the broadcast window is active. */
    .big-inning-pill {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      padding: 0.45rem 0.8rem 0.45rem 0.7rem;
      background: var(--paper);
      border: 2px solid var(--ink);
      border-left-width: 5px;
      font-family: 'Space Mono', monospace;
      font-size: 0.8rem;
      text-decoration: none;
      color: var(--ink);
      transition: transform 0.05s ease, box-shadow 0.05s ease;
    }
    .sports-recap-shell .big-inning-pill {
      grid-column: 1 / -1;
    }
    .big-inning-pill:hover {
      transform: translate(-1px, -1px);
      box-shadow: 3px 3px 0 var(--ink);
    }
    .big-inning-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #bf0d3e;
      animation: livePulse 1.5s ease-in-out infinite;
      flex-shrink: 0;
    }
    .big-inning-label { font-weight: 700; }
    .big-inning-detail {
      color: #555;
      font-size: 0.72rem;
      letter-spacing: 0.03em;
    }
    .big-inning-platform {
      margin-left: auto;
      color: var(--cool);
      font-weight: 700;
      font-size: 0.72rem;
      letter-spacing: 0.04em;
    }

    /* Today schedule strip — small horizontal row under yesterday tiles */
    .schedule-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.45rem;
    }
    .schedule-leader {
      font-family: 'Permanent Marker', cursive;
      font-size: 0.95rem;
      color: #555;
      letter-spacing: 0.02em;
      margin-right: 0.15rem;
    }
    .schedule-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.25rem 0.55rem 0.25rem 0.45rem;
      background: var(--paper);
      border: 2px solid var(--ink);
      border-left-width: 4px;
      font-family: 'Space Mono', monospace;
      font-size: 0.75rem;
    }
    .schedule-teams {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      font-weight: 700;
    }
    .schedule-at { color: #999; font-weight: 400; }
    .schedule-time { color: #555; font-size: 0.7rem; letter-spacing: 0.03em; }
    .schedule-time.live {
      color: var(--hot);
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
    }
    @media (max-width: 1040px) {
      .broader-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    @media (pointer: coarse) {
      .bhide { min-width: 44px; height: 44px; font-size: 0.9rem; opacity: 1; }
    }
    @media (max-width: 620px) {
      body { padding: 1rem 0.75rem 1.5rem; }
      .page-head { margin-bottom: 1.25rem; }
      .corner-launchers { gap: 0.85rem; }
      .internet-meta { margin-top: -1.45rem; }
      .broader-grid { grid-template-columns: 1fr; }
      .bhide { min-width: 44px; height: 44px; font-size: 0.9rem; opacity: 1; }
      .schedule-row { align-items: stretch; flex-direction: column; }
      .schedule-chip { width: 100%; justify-content: space-between; }
    }
  </style>
</head>
<body>
  <div id="yt-gate">
