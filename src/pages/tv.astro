---
// stanwood.dev/tv — the family room TV homepage. Runs fullscreen on the Mac Mini
// wired to the Samsung Q80C. Big key-art tiles, sports rails (shared engine),
// SDSN Classic, and quick launchers. No Samsung UI, no ads, no junk.
// Show key art is baked from TMDB (static, doesn't change). Sports + SDSN are live.
import LiveSports from '../components/LiveSports.tsx';
import TodaySports from '../components/TodaySports.tsx';
import YesterdaySports from '../components/YesterdaySports.tsx';

const IMG = 'https://image.tmdb.org/t/p/w1280';

const shows = [
  {
    title: 'All Creatures Great & Small',
    sub: 'PBS Masterpiece · the cozy one',
    href: 'https://www.amazon.com/dp/B08QGM6VTY',
    art: `${IMG}/l61sjSZCsf99abjlnt2ToG442ol.jpg`,
    badge: { type: 'logo', file: 'primevideo', color: '#00A8E1', w: 76, h: 20 },
  },
  {
    title: 'Gilmore Girls',
    sub: '→ moving to Hulu Jun 30',
    subWarn: true,
    href: 'https://www.netflix.com/title/70155618',
    art: `${IMG}/8U2ndZrneigI2zkvGuTJtt1ZsxK.jpg`,
    badge: { type: 'logo', file: 'netflix', color: '#E50914', w: 62, h: 18 },
  },
  {
    title: 'Daniel Tiger',
    sub: 'ad-free · for the kids',
    href: 'https://pbskids.org/daniel-tiger',
    art: `${IMG}/yAIpWHcLmS1O2aCrx4oBhXtwoHt.jpg`,
    badge: { type: 'text', label: 'PBS KIDS', bg: '#2AA84F' },
  },
];

const launchers = [
  { label: 'Netflix', href: 'https://www.netflix.com', logo: { file: 'netflix', color: '#E50914', w: 56, h: 15 } },
  { label: 'Prime Video', href: 'https://www.amazon.com/gp/video/storefront', logo: { file: 'primevideo', color: '#00A8E1', w: 68, h: 18 } },
  { label: 'YouTube TV', href: 'https://tv.youtube.com/', logo: { file: 'youtubetv', color: '#FF0000', w: 78, h: 18 } },
  { label: 'WNBA League Pass', href: 'https://www.wnba.com/league-pass-stream/', text: true },
  { label: 'MLB.tv', href: 'https://www.mlb.com/tv', text: true },
];
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <meta name="theme-color" content="#fdf6e3" />
  <title>the stanwoods · tv</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://image.tmdb.org" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Permanent+Marker&family=Space+Mono:wght@400;700&display=swap"
    rel="stylesheet"
  />
  <style is:global>
    :root {
      --bg: #fdf6e3;
      --ink: #1a1a1a;
      --paper: #ffffff;
      --hot: #ff3b30;
      --cool: #0a84ff;
      --border: 3px solid var(--ink);
      --shadow: 6px 6px 0 var(--ink);
    }
    * { box-sizing: border-box; }
    html { font-size: 16px; }
    @media (min-width: 1300px) { html { font-size: 18px; } }
    @media (min-width: 2000px) { html { font-size: 21px; } }
    body {
      margin: 0;
      background: var(--bg);
      color: var(--ink);
      font-family: 'Space Mono', monospace;
      -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; }
    .wrap { max-width: 1560px; margin: 0 auto; padding: 2.4rem 3rem 4rem; }

    /* Masthead */
    .masthead {
      display: flex; align-items: flex-end; justify-content: space-between;
      gap: 1rem; border-bottom: var(--border); padding-bottom: 1rem; margin-bottom: 2.2rem;
    }
    .mast-title { font-family: 'Permanent Marker', cursive; font-size: 2.7rem; line-height: 1; }
    .mast-clock { text-align: right; line-height: 1.1; }
    .mast-time { font-size: 2rem; font-weight: 700; }
    .mast-date { font-size: 0.92rem; color: #555; text-transform: uppercase; letter-spacing: 0.12em; }

    .section-title {
      font-family: 'Permanent Marker', cursive; font-size: 1.55rem; margin: 0 0 1rem; font-weight: 400;
    }
    section { margin: 0 0 2.6rem; }

    /* Big key-art tiles (shows + classic) */
    .show-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr)); gap: 1.5rem; }
    .show-tile {
      position: relative; display: block; aspect-ratio: 16 / 9; overflow: hidden;
      border: var(--border); box-shadow: var(--shadow); background: #222; color: #fff;
      text-decoration: none; transition: transform 0.07s ease, box-shadow 0.07s ease;
    }
    .show-tile:hover { transform: translate(-3px, -3px); box-shadow: 10px 10px 0 var(--ink); }
    /* Remote / d-pad focus ring — applies to any focusable tile (Samsung CEC, Flirc, BT remote, phone, keyboard) */
    .show-tile:focus, .recap-tile:focus, .jump-chip:focus, .big-inning-pill:focus {
      outline: 5px solid var(--hot); outline-offset: 3px;
    }
    .show-tile:focus { transform: translate(-3px, -3px); box-shadow: 10px 10px 0 var(--ink); }
    .recap-tile:focus, .jump-chip:focus { transform: translate(-2px, -2px); }
    .show-art { position: absolute; inset: 0; background-size: cover; background-position: center 18%; }
    .show-scrim {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.28) 46%, rgba(0,0,0,0) 72%);
    }
    .show-cap { position: absolute; left: 0; right: 0; bottom: 0; padding: 1.1rem 1.15rem; }
    .show-title { font-weight: 700; font-size: 1.5rem; line-height: 1.08; text-shadow: 0 2px 10px rgba(0,0,0,0.65); }
    .show-sub { font-size: 0.82rem; margin-top: 0.35rem; opacity: 0.92; }
    .show-sub.warn { color: #ffd23f; opacity: 1; }
    .show-badge {
      position: absolute; top: 0.8rem; left: 0.8rem; display: inline-flex; align-items: center;
      background: #fff; border: 2px solid var(--ink); box-shadow: 3px 3px 0 var(--ink); padding: 0.32rem 0.5rem;
    }
    .show-badge.text-badge { color: #fff; font-weight: 700; font-size: 0.72rem; letter-spacing: 0.06em; }
    .brandmark {
      display: inline-block; background-color: var(--bm, #000);
      -webkit-mask: var(--bms) center / contain no-repeat; mask: var(--bms) center / contain no-repeat;
    }

    /* SDSN Classic — wide cinematic tile, hydrated client-side */
    .classic-tile { aspect-ratio: 24 / 9; }
    .classic-tile .show-art { background-color: #1a1a1a; background-position: center; }
    .classic-badge { background: var(--hot); color: #fff; font-weight: 700; font-size: 0.74rem; letter-spacing: 0.08em; padding: 0.34rem 0.6rem; }
    .classic-tile.is-loading .show-title { opacity: 0.6; }

    /* Sports section — shared engine classes (LiveSports / YesterdaySports / TodaySports) */
    .sports-recap-shell, .recap-grid {
      display: grid; grid-template-columns: 1fr; gap: 1rem; margin-bottom: 0.85rem;
    }
    .sports-recap-shell > astro-island, .sports-recap-shell .recap-grid { display: contents; }
    @media (min-width: 720px) { .sports-recap-shell, .recap-grid { grid-template-columns: 1fr 1fr; } }
    @media (min-width: 1300px) { .sports-recap-shell, .recap-grid { grid-template-columns: 1fr 1fr 1fr; } }
    .recap-tile {
      background: var(--paper); border: var(--border); box-shadow: var(--shadow); border-left-width: 8px;
      padding: 1rem 1.1rem; text-decoration: none; color: var(--ink); display: flex; flex-direction: column;
      gap: 0.75rem; container-type: inline-size; transition: transform 0.05s ease, box-shadow 0.05s ease;
    }
    .recap-tile:hover { transform: translate(-2px, -2px); box-shadow: 8px 8px 0 var(--ink); }
    .recap-matchup { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; }
    .recap-team { display: flex; align-items: center; gap: 0.55rem; flex: 1; min-width: 0; }
    .recap-team.home { flex-direction: row-reverse; text-align: right; }
    .recap-logo { width: 40px; height: 40px; object-fit: contain; flex-shrink: 0; }
    .recap-team-text { display: flex; flex-direction: column; min-width: 0; line-height: 1.15; }
    .recap-team-name { font-weight: 700; font-size: 0.85rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .recap-team-abbr { font-size: 0.65rem; color: #888; letter-spacing: 0.06em; }
    @container (max-width: 430px) {
      .recap-team-name { display: none; }
      .recap-team-abbr { font-weight: 700; font-size: 0.85rem; line-height: 1.15; color: var(--ink); letter-spacing: 0; }
    }
    .recap-score { font-family: 'Permanent Marker', cursive; font-size: 1.7rem; line-height: 1; padding: 0 0.3rem; color: #aaa; }
    .recap-score.win { color: var(--ink); }
    .recap-vs { font-family: 'Permanent Marker', cursive; font-size: 0.85rem; color: #888; flex-shrink: 0; }
    .recap-meta {
      display: flex; justify-content: space-between; align-items: center; font-size: 0.7rem;
      text-transform: uppercase; letter-spacing: 0.08em; border-top: 1px dashed #ccc; padding-top: 0.55rem;
    }
    .recap-final { font-weight: 700; color: #444; }
    .recap-watch { font-weight: 700; color: var(--cool); }
    .recap-tile.live .recap-score.live { color: var(--ink); }
    .recap-live-status { display: inline-flex; align-items: center; gap: 0.4rem; font-weight: 700; color: var(--hot); }
    .recap-live-dot { display: inline-block; width: 7px; height: 7px; border-radius: 50%; background: var(--hot); animation: livePulse 1.5s ease-in-out infinite; }
    @keyframes livePulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }
    .big-inning-pill {
      display: flex; align-items: center; gap: 0.55rem; padding: 0.45rem 0.8rem 0.45rem 0.7rem; background: var(--paper);
      border: 2px solid var(--ink); border-left-width: 5px; font-size: 0.8rem; text-decoration: none; color: var(--ink);
      transition: transform 0.05s ease, box-shadow 0.05s ease;
    }
    .sports-recap-shell .big-inning-pill { grid-column: 1 / -1; }
    .big-inning-pill:hover { transform: translate(-1px, -1px); box-shadow: 3px 3px 0 var(--ink); }
    .big-inning-dot { width: 8px; height: 8px; border-radius: 50%; background: #bf0d3e; animation: livePulse 1.5s ease-in-out infinite; flex-shrink: 0; }
    .big-inning-label { font-weight: 700; }
    .big-inning-detail { color: #555; font-size: 0.72rem; letter-spacing: 0.03em; }
    .big-inning-platform { margin-left: auto; color: var(--cool); font-weight: 700; font-size: 0.72rem; letter-spacing: 0.04em; }
    .schedule-row { display: flex; flex-wrap: wrap; align-items: center; gap: 0.45rem; }
    .schedule-leader { font-family: 'Permanent Marker', cursive; font-size: 0.95rem; color: #555; letter-spacing: 0.02em; margin-right: 0.15rem; }
    .schedule-chip { display: inline-flex; align-items: center; gap: 0.45rem; padding: 0.25rem 0.55rem 0.25rem 0.45rem; background: var(--paper); border: 2px solid var(--ink); border-left-width: 4px; font-size: 0.75rem; }
    .schedule-teams { display: inline-flex; align-items: center; gap: 0.3rem; font-weight: 700; }
    .schedule-at { color: #999; font-weight: 400; }
    .schedule-time { color: #555; font-size: 0.7rem; letter-spacing: 0.03em; }
    .schedule-time.live { color: var(--hot); font-weight: 700; display: inline-flex; align-items: center; gap: 0.3rem; }

    /* Jump-to launchers */
    .jump-row { display: flex; flex-wrap: wrap; gap: 0.8rem; align-items: center; }
    .jump-chip {
      display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.55rem 0.95rem; background: var(--paper);
      border: var(--border); box-shadow: 4px 4px 0 var(--ink); text-decoration: none; color: var(--ink);
      font-weight: 700; font-size: 0.85rem; transition: transform 0.06s ease, box-shadow 0.06s ease;
    }
    .jump-chip:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--ink); }
  </style>
</head>
<body>
  <div class="wrap">
    <header class="masthead">
      <div class="mast-title">the stanwoods</div>
      <div class="mast-clock">
        <div class="mast-time" id="clock-time">—</div>
        <div class="mast-date" id="clock-date">&nbsp;</div>
      </div>
    </header>

    <section aria-label="Watch">
      <h2 class="section-title">tonight</h2>
      <div class="show-grid">
        {shows.map((s) => (
          <a class="show-tile" href={s.href}>
            <div class="show-art" style={`background-image:url('${s.art}')`}></div>
            <div class="show-scrim"></div>
            {s.badge.type === 'logo' ? (
              <span class="show-badge">
                <span class="brandmark" style={`--bms:url('/images/family/logos/${s.badge.file}.svg');--bm:${s.badge.color};width:${s.badge.w}px;height:${s.badge.h}px`}></span>
              </span>
            ) : (
              <span class="show-badge text-badge" style={`background:${s.badge.bg}`}>{s.badge.label}</span>
            )}
            <div class="show-cap">
              <div class="show-title">{s.title}</div>
              <div class={`show-sub${s.subWarn ? ' warn' : ''}`}>{s.sub}</div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section aria-label="SDSN Classic">
      <h2 class="section-title">sdsn classic</h2>
      <a class="show-tile classic-tile is-loading" id="sdsn-classic-card"
         href="https://www.youtube.com/playlist?list=PLk7eG7txNmA0aOww_rvQJy49xGEZe_U5d">
        <div class="show-art" data-sdsn-thumb></div>
        <div class="show-scrim"></div>
        <span class="show-badge classic-badge">CLASSIC</span>
        <div class="show-cap">
          <div class="show-title" data-sdsn-title>loading a classic…</div>
          <div class="show-sub"><span data-sdsn-channel>SDSN Classic</span> · <span data-sdsn-duration>full game</span> · random</div>
        </div>
      </a>
    </section>

    <section class="sports-section" aria-label="Sports">
      <h2 class="section-title">sports</h2>
      <div class="sports-recap-shell">
        <LiveSports client:only="react" />
        <YesterdaySports client:only="react" />
      </div>
      <TodaySports client:only="react" />
    </section>

    <section aria-label="Jump to">
      <h2 class="section-title">jump to</h2>
      <div class="jump-row">
        {launchers.map((l) => (
          <a class="jump-chip" href={l.href} rel="noopener">
            {l.text ? null : (
              <span class="brandmark" style={`--bms:url('/images/family/logos/${l.logo.file}.svg');--bm:${l.logo.color};width:${l.logo.w}px;height:${l.logo.h}px`}></span>
            )}
            <span>{l.label}</span>
          </a>
        ))}
      </div>
    </section>
  </div>

  <script is:inline>
    (function () {
      const timeEl = document.getElementById('clock-time');
      const dateEl = document.getElementById('clock-date');
      function tick() {
        const d = new Date();
        timeEl.textContent = d.toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' });
        dateEl.textContent = d.toLocaleDateString([], { weekday: 'long', month: 'long', day: 'numeric' });
      }
      tick();
      setInterval(tick, 15000);

      async function loadClassic() {
        const card = document.getElementById('sdsn-classic-card');
        if (!card) return;
        try {
          const res = await fetch('/api/tv/random-sdsn', { cache: 'no-store' });
          if (!res.ok) throw new Error('sdsn ' + res.status);
          const v = await res.json();
          if (v.url) card.href = v.url;
          const thumb = card.querySelector('[data-sdsn-thumb]');
          const title = card.querySelector('[data-sdsn-title]');
          const channel = card.querySelector('[data-sdsn-channel]');
          const duration = card.querySelector('[data-sdsn-duration]');
          if (thumb && v.thumb) thumb.style.backgroundImage = "url('" + v.thumb + "')";
          if (title && v.title) title.textContent = v.title;
          if (channel) channel.textContent = v.playlistTitle || 'SDSN Classic';
          if (duration) duration.textContent = v.duration || 'full game';
          card.classList.remove('is-loading');
        } catch (err) {
          const title = card.querySelector('[data-sdsn-title]');
          if (title) title.textContent = 'SDSN Classic — open the playlist';
          card.classList.remove('is-loading');
        }
      }
      loadClassic();
    })();
  </script>

  <script is:inline>
    // D-pad / remote navigation. Hardware-agnostic: works with arrow keys from a
    // Samsung remote (via CEC→libcec→keystrokes), a Flirc'd remote, a BT remote,
    // the phone remote, or a keyboard. Re-queries each press so late-hydrated
    // sports tiles join the grid. Enter is native (tiles are <a>).
    (function () {
      function items() {
        return Array.from(document.querySelectorAll('.wrap a')).filter(function (el) {
          var r = el.getBoundingClientRect();
          return r.width > 0 && r.height > 0;
        });
      }
      function center(el) {
        var r = el.getBoundingClientRect();
        return { x: r.left + r.width / 2, y: r.top + r.height / 2 };
      }
      function move(dir) {
        var all = items();
        if (!all.length) return;
        var cur = (document.activeElement && all.indexOf(document.activeElement) !== -1) ? document.activeElement : null;
        if (!cur) { all[0].focus(); all[0].scrollIntoView({ block: 'center', behavior: 'smooth' }); return; }
        var c = center(cur), best = null, bestScore = Infinity;
        for (var i = 0; i < all.length; i++) {
          if (all[i] === cur) continue;
          var t = center(all[i]), dx = t.x - c.x, dy = t.y - c.y, valid, primary, secondary;
          if (dir === 'left') { valid = dx < -4; primary = -dx; secondary = Math.abs(dy); }
          else if (dir === 'right') { valid = dx > 4; primary = dx; secondary = Math.abs(dy); }
          else if (dir === 'up') { valid = dy < -4; primary = -dy; secondary = Math.abs(dx); }
          else { valid = dy > 4; primary = dy; secondary = Math.abs(dx); }
          if (!valid) continue;
          var score = primary + secondary * 2;
          if (score < bestScore) { bestScore = score; best = all[i]; }
        }
        if (best) { best.focus(); best.scrollIntoView({ block: 'nearest', behavior: 'smooth' }); }
      }
      document.addEventListener('keydown', function (e) {
        switch (e.key) {
          case 'ArrowLeft': move('left'); e.preventDefault(); break;
          case 'ArrowRight': move('right'); e.preventDefault(); break;
          case 'ArrowUp': move('up'); e.preventDefault(); break;
          case 'ArrowDown': move('down'); e.preventDefault(); break;
          case 'Home': case 'Backspace': case 'Escape': {
            var all = items();
            if (all.length) { all[0].focus(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
            e.preventDefault(); break;
          }
        }
      });
      // Remote-first: land focus on the first tile so a d-pad works immediately.
      window.addEventListener('load', function () {
        setTimeout(function () {
          var all = items();
          if (all.length && !(document.activeElement && all.indexOf(document.activeElement) !== -1)) all[0].focus();
        }, 600);
      });
    })();
  </script>
</body>
</html>
