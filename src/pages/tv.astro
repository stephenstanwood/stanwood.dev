          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 13c3.5 4 6.5 5.5 9.5 5.5s6-1.5 8.5-4"/>
            <path d="M17 14.5l4-1 1 4"/>
          </svg>
        </a>
      </div>
    </div>

    <section class="sports-section" aria-label="Sports">
      <h2 class="section-title">sports</h2>
      <div class="sports-recap-shell">
        <LiveSports client:only="react" />
        <YesterdaySports client:only="react" />
      </div>
      <TodaySports client:only="react" />
    </section>

    {SHOW_STANFORD_TALKS && data.queue.length === 0 && (
      <div class="empty">
        <p>queue is empty — the pipeline hasn't run yet, or yt-dlp is having a bad day.</p>
      </div>
    )}

    {broader.queue.length > 0 && (
      <section class="internet-section" aria-labelledby="internet-title">
        <h2 class="section-title" id="internet-title">around the internet</h2>
        <div class="internet-meta" aria-label="queue details">
          <span class="meta-pill">{fmtRefresh(broader.built_at)}</span>
          <span class="meta-pill">{broader.channel_count} trusted sources</span>
          {Boolean(broader.discovery_query_count) && <span class="meta-pill">open discovery</span>}
          <span class="meta-pill" id="classic-count">{broader.queue.length} picks + a classic</span>
        </div>
        <div
          class="broader-grid"
          id="broader-grid"
          data-tile-target={INTERNET_TILE_COUNT}
          data-source-limit={INTERNET_MAX_PER_SOURCE}
        >
          <article
            class="bcard sdsn-card sdsn-card-loading"
            id="sdsn-classic-card"
            data-published-at="9999-12-31T00:00:00.000Z"
          >
            <a
              class="bcard-link"
              href="https://www.youtube.com/playlist?list=PLk7eG7txNmA0aOww_rvQJy49xGEZe_U5d"
              target="_blank"
              rel="noopener"
              aria-label="Random SDSN Classic"
            >
              <div class="bcard-thumb" data-sdsn-thumb>
                <span class="classic-badge">classic</span>
                <span class="bcard-dur" data-sdsn-duration>...</span>
              </div>
              <div class="bcard-body">
                <p class="bcard-title" data-sdsn-title>loading sdsn classic...</p>
                <div class="bcard-meta">
                  <span class="bcard-chan" data-sdsn-channel>SDSN Classic</span>
                  <span>random</span>
                </div>
              </div>
            </a>
            <div class="bcard-actions">
              <span class="topic-chip">rewatch shelf</span>
            </div>
          </article>
          {broader.queue.map((v, index) => (
            <article
              class={`bcard ${index === 0 ? 'is-featured' : ''}`}
              data-broader-id={v.id}
              data-published-at={v.published_at}
              data-source-key={v.channel_id || v.channel_handle || v.channel_title || v.id}
              data-series-key={v.series_key || ''}
              data-episode-number={v.episode_number != null ? String(v.episode_number) : ''}
            >
              <a class="bcard-link" href={v.url} target="_blank" rel="noopener" aria-label={`${v.title} on YouTube`}>
                <div class="bcard-thumb" style={v.thumb ? `background-image:url(${v.thumb})` : ''}>
                  {index === 0 && <span class="pick-badge">start here</span>}
                  {(v.source === 'discovery' || v.exploration) && (
                    <span class="explore-badge">{v.source === 'discovery' ? 'discovery' : 'wildcard'}</span>
                  )}
                  {v.series_key && <span class="series-badge">series · ep {v.episode_number}</span>}
                  <span class="bcard-dur">{fmtDuration(v.duration)}</span>
                </div>
                <div class="bcard-body">
                  <p class="bcard-title">{v.title}</p>
                  <div class="bcard-meta">
                    <span class="bcard-chan">{v.channel_title}</span>
                    <span>{fmtAgo(v.published_at)}</span>
                  </div>
                </div>
              </a>
              <div class="bcard-actions">
                <span class="topic-chip">{topicLabel(v)}</span>
                <div class="mark-actions">
                  <button class="bhide" data-mark-broader={v.id} data-action="pass" title={v.series_key ? 'hide this series' : 'not for me'} aria-label={v.series_key ? 'Hide this series' : 'Not for me'}>×</button>
                  <button class="bhide like" data-mark-broader={v.id} data-action="like" title={v.series_key ? 'follow this series' : 'more like this'} aria-label={v.series_key ? 'Follow this series' : 'More like this'}>✓</button>
                </div>
              </div>
            </article>
          ))}
        </div>
        <p class="queue-status" id="queue-status" aria-live="polite"></p>
        <div id="followed-series-container"></div>
      </section>
    )}

    {SHOW_STANFORD_TALKS && (topSeries || restSeries.length > 0) && (
      <h2 class="section-title">stanford talks</h2>
    )}

    {SHOW_STANFORD_TALKS && topSeries && (() => {
      const videos = seriesVideos(topSeries);
      return (
        <div class="series" data-series={topSeries.key}>
          <div class="series-head">
            <div>
              <span class="series-name">{topSeries.display_name}</span>
              <span class={`score-chip ${topSeries.best_score >= 3 ? '' : 'low'}`}>
                score {topSeries.best_score}
              </span>
            </div>
            <span class="series-meta">
              {topSeries.video_count} {topSeries.video_count === 1 ? 'video' : 'videos'}
            </span>
          </div>
          <ul class="videos">
            {videos.map((v) => (
              <li data-video-id={v.id} data-duration={v.duration} data-video-url={v.url || `https://www.youtube.com/watch?v=${v.id}&autoplay=1`}>
                <span class="vtitle">
                  {v.lecture_num != null ? `#${v.lecture_num} · ` : ''}
                  {v.title.replace(/^Stanford\s+[A-Z]+\d+[A-Z]?\s*\|?\s*/i, '').replace(/^[^:|]+[:|]\s*/, '')}
                </span>
                <span class="vmeta">
                  {fmtDuration(v.duration)} · {fmtAgo(v.published_at)}
                </span>
                <span class="row-btns">
                  <button class="mark-btn" data-toggle-watched={v.id} title="toggle watched">✓</button>
                  <button class="mark-btn" data-hide-stanford={v.id} title="hide everywhere">×</button>
                </span>
              </li>
            ))}
          </ul>
        </div>
      );
    })()}

    {SHOW_STANFORD_TALKS && restSeries.length > 0 && (
      <>
        <h2>more from the queue</h2>
        {restSeries.map((s) => {
          const videos = seriesVideos(s);
          if (videos.length === 0) return null;
          const showScore = s.best_score >= 3;
          return (
            <div class="series" data-series={s.key}>
              <div class="series-head">
                <div>
                  <span class="series-name">{s.display_name}</span>
                  <span class={`score-chip ${showScore ? '' : 'low'}`}>
                    score {s.best_score}
                  </span>
                </div>
                <span class="series-meta">
                  {s.video_count} {s.video_count === 1 ? 'video' : 'videos'}
                </span>
              </div>
              <ul class="videos">
                {videos.map((v) => (
                  <li data-video-id={v.id} data-duration={v.duration} data-video-url={v.url || `https://www.youtube.com/watch?v=${v.id}&autoplay=1`}>
                    <span class="vtitle">
                      {v.lecture_num != null ? `#${v.lecture_num} · ` : ''}
                      {v.title.replace(/^Stanford\s+[A-Z]+\d+[A-Z]?\s*\|?\s*/i, '').replace(/^[^:|]+[:|]\s*/, '')}
                    </span>
                    <span class="vmeta">
                      {fmtDuration(v.duration)} · {fmtAgo(v.published_at)}
                    </span>
                    <span class="row-btns">
                      <button class="mark-btn" data-toggle-watched={v.id} title="toggle watched">✓</button>
                      <button class="mark-btn" data-hide-stanford={v.id} title="hide everywhere">×</button>
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          );
        })}
      </>
    )}

    <div class="footer">
      ✓ means more like this · × means not for me · both clear the card and shape future edits
    </div>
  </div>

  <!-- Ranked reserve pool, consumed client-side as the visible edit is marked -->
  <script is:inline type="application/json" id="broader-pool" set:html={JSON.stringify(broader.pool || [])}></script>
  <script is:inline type="application/json" id="broader-series-episodes" set:html={JSON.stringify(broader.series_episodes || {})}></script>

  <script is:inline>
    // ---- Password gate ----
    (function () {
      const form = document.getElementById('yt-gate-form');
      const input = document.getElementById('yt-gate-input');
      const gate = document.getElementById('yt-gate');
      if (!form || !input || !gate) return;
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        if (input.value.trim().toLowerCase() === 'meow') {
          try { localStorage.setItem('yt-gate-v1', 'meow'); } catch {}
          document.documentElement.classList.add('yt-unlocked');
        } else {
          gate.classList.remove('shake');
          void gate.offsetWidth;
          gate.classList.add('shake');
          input.value = '';
        }
      });
    })();

    // ---- Mark-sync: tell the Mini about likes + passes (drops from feed +
    // future builds, feeds back into scoring). ----
    // Port 8443 is the Tailscale Funnel listener (public), so marks land from
    // any device — the :443 route is tailnet-only and silently ate clicks
    // whenever the browsing device wasn't on Tailscale DNS. The key is a
    // spam gate, not a secret (this page is already client-gated).
    const MARK_API_URL = 'https://stephens-mac-mini.tailcac25b.ts.net:8443/api/mark';
    const MARK_API_KEY = 'b682274e4f6c8e1c7e5579fa';
    const MARK_PENDING_KEY = 'tv-mark-pending-v1';
    function getPendingMarks() {
      try { return JSON.parse(localStorage.getItem(MARK_PENDING_KEY) || '{}'); }
      catch { return {}; }
    }
    function savePendingMarks(pending) {
      try { localStorage.setItem(MARK_PENDING_KEY, JSON.stringify(pending)); } catch {}
    }
    async function sendMark(id, kind, action) {
      const key = `${kind}:${id}`;
      const pending = getPendingMarks();
      pending[key] = { id, kind, action };
      savePendingMarks(pending);
      try {
        const response = await fetch(MARK_API_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Mark-Key': MARK_API_KEY },
          body: JSON.stringify({ id, kind, action }),
          keepalive: true,
        });
        if (!response.ok) return false;
        const latest = getPendingMarks();
        if (latest[key]?.action === action) {
          delete latest[key];
          savePendingMarks(latest);
        }
        return true;
      } catch {}
      return false;
    }
    function flushPendingMarks() {
      Object.values(getPendingMarks()).forEach((mark) => {
        if (mark?.id && mark?.kind && mark?.action) {
          sendMark(mark.id, mark.kind, mark.action);
        }
      });
    }
    flushPendingMarks();

    // One-shot: flush existing localStorage state to the Mini so feed.xml
    // drops items already marked before /api/mark existed. Runs once per browser.
    // v2 (2026-06-09): marks silently failed to reach the Mini from
    // non-tailnet-DNS devices between Apr 20 and Jun 9 — bumping the flag
    // makes every browser re-flush its full localStorage mark state through
    // the fixed endpoint. Server appends are idempotent, so this is safe.
    const SYNC_FLAG = 'mark-sync-v2';
    function bootstrapSync() {
      if (localStorage.getItem(SYNC_FLAG)) return;
      try {
        const watched = JSON.parse(localStorage.getItem('stanford-queue-watched-v1') || '[]');
        const sHidden = JSON.parse(localStorage.getItem('stanford-hidden-v1') || '[]');
        // Legacy broader-hidden-v1 mixes likes and passes, so never replay it
        // to the server. Only the action-specific stores below are safe.
        const bLiked = new Set(JSON.parse(localStorage.getItem('broader-liked-v1') || '[]'));
        const bPassed = new Set(JSON.parse(localStorage.getItem('broader-passed-v1') || '[]'));
        watched.forEach(id => sendMark(id, 'stanford', 'like'));
        sHidden.forEach(id => sendMark(id, 'stanford', 'pass'));
        bPassed.forEach(id => sendMark(id, 'broader', 'pass'));
        bLiked.forEach(id => sendMark(id, 'broader', 'like'));
        localStorage.setItem(SYNC_FLAG, String(Date.now()));
      } catch {}
    }
    bootstrapSync();

    // ---- Stanford: watched state + auto-hide watched-out series ----
    const WATCHED_KEY = 'stanford-queue-watched-v1';
    const STANFORD_HIDDEN_KEY = 'stanford-hidden-v1';

    function getWatched() {
      try { return new Set(JSON.parse(localStorage.getItem(WATCHED_KEY) || '[]')); }
      catch { return new Set(); }
    }
    function saveWatched(set) {
      localStorage.setItem(WATCHED_KEY, JSON.stringify([...set]));
    }
    function toggleWatched(id) {
      const w = getWatched();
      const adding = !w.has(id);
      if (adding) w.add(id); else w.delete(id);
      saveWatched(w);
      if (adding) sendMark(id, 'stanford', 'like');
      renderWatched();
    }
    function getStanfordHidden() {
      try { return new Set(JSON.parse(localStorage.getItem(STANFORD_HIDDEN_KEY) || '[]')); }
      catch { return new Set(); }
    }
    function saveStanfordHidden(set) {
      localStorage.setItem(STANFORD_HIDDEN_KEY, JSON.stringify([...set]));
    }
    function hideStanford(id) {
      const h = getStanfordHidden();
      h.add(id);
      saveStanfordHidden(h);
      sendMark(id, 'stanford', 'pass');
      renderWatched();
    }
    function renderWatched() {
      const w = getWatched();
      const hidden = getStanfordHidden();
      document.querySelectorAll('li[data-video-id]').forEach(li => {
        li.classList.toggle('watched', w.has(li.dataset.videoId));
        li.classList.toggle('hidden-row', hidden.has(li.dataset.videoId));
      });
      // Hide any series whose videos are all watched or hidden
      document.querySelectorAll('.series').forEach(s => {
        const lis = s.querySelectorAll('li[data-video-id]');
        const allGone = lis.length > 0 && [...lis].every(li =>
          li.classList.contains('watched') || li.classList.contains('hidden-row')
        );
        s.hidden = allGone;
      });
    }

    // Row click → open on YouTube (autoplay). Ignore clicks on the row buttons.
    document.querySelectorAll('li[data-video-id]').forEach(li => {
      li.addEventListener('click', (e) => {
        if (e.target.closest('[data-toggle-watched]') || e.target.closest('[data-hide-stanford]')) return;
        const url = li.dataset.videoUrl;
        if (url) window.open(url, '_blank', 'noopener');
      });
    });
    document.querySelectorAll('[data-toggle-watched]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleWatched(btn.dataset.toggleWatched);
      });
    });
    document.querySelectorAll('[data-hide-stanford]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        hideStanford(btn.dataset.hideStanford);
      });
    });

    renderWatched();

    // ---- Around the internet: hide + refill from reserve pool ----
    const BROADER_HIDDEN_KEY = 'broader-hidden-v1';
    const BROADER_LIKED_KEY = 'broader-liked-v1';
    const BROADER_PASSED_KEY = 'broader-passed-v1';
    const BROADER_FOLLOWED_SERIES_KEY = 'broader-followed-series-v1';
    const BROADER_BANNED_SERIES_KEY = 'broader-banned-series-v1';
    const POOL = JSON.parse(document.getElementById('broader-pool').textContent) || [];
    const SERIES_EPISODES = JSON.parse(document.getElementById('broader-series-episodes').textContent) || {};

    function getSet(key) {
      try { return new Set(JSON.parse(localStorage.getItem(key) || '[]')); }
      catch { return new Set(); }
    }
    function saveSet(key, set) {
      localStorage.setItem(key, JSON.stringify([...set]));
    }
    const getBroaderHidden = () => getSet(BROADER_HIDDEN_KEY);
    const saveBroaderHidden = (s) => saveSet(BROADER_HIDDEN_KEY, s);
    const getBroaderLiked = () => getSet(BROADER_LIKED_KEY);
    const saveBroaderLiked = (s) => saveSet(BROADER_LIKED_KEY, s);
    const getBroaderPassed = () => getSet(BROADER_PASSED_KEY);
    const saveBroaderPassed = (s) => saveSet(BROADER_PASSED_KEY, s);
    const getFollowedSeries = () => getSet(BROADER_FOLLOWED_SERIES_KEY);
    const saveFollowedSeries = (s) => saveSet(BROADER_FOLLOWED_SERIES_KEY, s);
    const getBannedSeries = () => getSet(BROADER_BANNED_SERIES_KEY);
    const saveBannedSeries = (s) => saveSet(BROADER_BANNED_SERIES_KEY, s);

    function renderBroaderHidden() {
      const h = getBroaderHidden();
      const banned = getBannedSeries();
      document.querySelectorAll('[data-broader-id]').forEach(card => {
        const byId = h.has(card.dataset.broaderId);
        const bySeries = card.dataset.seriesKey && banned.has(card.dataset.seriesKey);
        card.classList.toggle('hidden', byId || bySeries);
      });
      updateFeaturedCard();
    }

    function fmtDurationJS(seconds) {
      const h = Math.floor(seconds / 3600);
      const m = Math.floor((seconds % 3600) / 60);
      return h > 0 ? `${h}h${String(m).padStart(2, '0')}` : `${m}m`;
    }
    function fmtAgoJS(iso) {
      const days = Math.floor((Date.now() - new Date(iso).getTime()) / 86400000);
      if (days === 0) return 'today';
      if (days < 7) return `${days}d ago`;
      if (days < 30) return `${Math.floor(days / 7)}w ago`;
      return `${Math.floor(days / 30)}mo ago`;
    }
    function escapeHTML(s) {
      return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    }
    function topicLabelJS(v) {
      const categories = Array.isArray(v.categories) ? v.categories : [];
      if (categories.includes('hci')) return 'design';
      if (categories.includes('working_method')) return 'working method';
      if (categories.includes('product_craft')) return 'product craft';
      if (categories.includes('solo_builder')) return 'solo builder';
      if (categories.includes('war_stories')) return 'how it went';
      if (categories.includes('swe_craft')) return 'software craft';
      if (categories.includes('systems_db')) return 'systems';
      if (categories.includes('algorithms')) return 'computer science';
      if (categories.includes('applied_ai')) return 'AI in practice';
      if (categories.includes('civic_open')) return 'public tech';
      if (categories.includes('math_viz')) return 'visual math';
      return 'worth a look';
    }
    function sourceKeyJS(v) {
      return v.channel_id || v.channel_handle || v.channel_title || v.id;
    }
    function updateFeaturedCard() {
      const cards = Array.from(document.querySelectorAll('[data-broader-id]'));
      cards.forEach(card => {
        card.classList.remove('is-featured');
        card.querySelector('.pick-badge')?.remove();
      });
      const firstVisible = cards.find(card => !card.classList.contains('hidden'));
      if (firstVisible) {
        firstVisible.classList.add('is-featured');
        const thumb = firstVisible.querySelector('.bcard-thumb');
        if (thumb) {
          const badge = document.createElement('span');
          badge.className = 'pick-badge';
          badge.textContent = 'start here';
          thumb.prepend(badge);
        }
      }
    }
    function announceMark(action) {
      const status = document.getElementById('queue-status');
      if (!status) return;
      status.textContent = action === 'like'
        ? 'Got it — more like that in future edits.'
        : 'Got it — that one is out.';
    }
    function buildCard(v) {
      const card = document.createElement('article');
      card.className = 'bcard';
      card.dataset.broaderId = v.id;
      card.dataset.publishedAt = v.published_at;
      card.dataset.sourceKey = sourceKeyJS(v);
      if (v.series_key) card.dataset.seriesKey = v.series_key;
      if (v.episode_number != null) card.dataset.episodeNumber = String(v.episode_number);
      const thumbStyle = v.thumb ? `background-image:url(${v.thumb})` : '';
      const safeId = escapeHTML(v.id);
      const seriesBadge = v.series_key
        ? `<span class="series-badge">series · ep ${v.episode_number}</span>` : '';
      const likeTitle = v.series_key ? 'follow this series' : 'more like this';
      const passTitle = v.series_key ? 'hide this series' : 'not for me';
      card.innerHTML = `
        <a class="bcard-link" href="${escapeHTML(v.url)}" target="_blank" rel="noopener" aria-label="${escapeHTML(v.title)} on YouTube">
          <div class="bcard-thumb" style="${thumbStyle}">
          ${v.source === 'discovery'
            ? '<span class="explore-badge">discovery</span>'
            : v.exploration ? '<span class="explore-badge">wildcard</span>' : ''}
            ${seriesBadge}
            <span class="bcard-dur">${fmtDurationJS(v.duration)}</span>
          </div>
          <div class="bcard-body">
            <p class="bcard-title">${escapeHTML(v.title)}</p>
            <div class="bcard-meta">
              <span class="bcard-chan">${escapeHTML(v.channel_title)}</span>
              <span>${fmtAgoJS(v.published_at)}</span>
            </div>
          </div>
        </a>
        <div class="bcard-actions">
          <span class="topic-chip">${escapeHTML(topicLabelJS(v))}</span>
          <div class="mark-actions">
            <button class="bhide" data-mark-broader="${safeId}" data-action="pass" title="${passTitle}" aria-label="${passTitle}">×</button>
            <button class="bhide like" data-mark-broader="${safeId}" data-action="like" title="${likeTitle}" aria-label="${likeTitle}">✓</button>
          </div>
        </div>
      `;
      card.querySelectorAll('[data-mark-broader]').forEach(wireMarkButton);
      return card;
    }

    function wireMarkButton(btn) {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const id = btn.dataset.markBroader;
        const action = btn.dataset.action || 'pass';
        const card = btn.closest('[data-broader-id]');
        const seriesKey = card && card.dataset.seriesKey;
        const hidden = getBroaderHidden();
        hidden.add(id);
        saveBroaderHidden(hidden);
        const liked = getBroaderLiked();
        const passed = getBroaderPassed();
        if (action === 'like') {
          liked.add(id);
          passed.delete(id);
        } else {
          liked.delete(id);
          passed.add(id);
        }
        saveBroaderLiked(liked);
        saveBroaderPassed(passed);

        if (seriesKey) {
          if (action === 'like') {
            const f = getFollowedSeries();
            f.add(seriesKey);
            saveFollowedSeries(f);
          } else {
            const b = getBannedSeries();
            b.add(seriesKey);
            saveBannedSeries(b);
          }
          sendMark(id, 'broader', action);
          announceMark(action);
          renderFollowedSeries();
          renderBroaderHidden();
          refillIfNeeded();
          return;
        }

        sendMark(id, 'broader', action);
        announceMark(action);
        renderBroaderHidden();
        refillIfNeeded();
      });
    }

    async function loadSdsnClassicCard() {
      const card = document.getElementById('sdsn-classic-card');
      if (!card) return;

      try {
        const response = await fetch('/api/tv/random-sdsn', { cache: 'no-store' });
        if (!response.ok) throw new Error('SDSN Classic unavailable');

        const video = await response.json();
        if (!video || typeof video.url !== 'string' || typeof video.title !== 'string') {
          throw new Error('SDSN Classic payload malformed');
        }

        const thumb = card.querySelector('[data-sdsn-thumb]');
        const title = card.querySelector('[data-sdsn-title]');
        const channel = card.querySelector('[data-sdsn-channel]');
        const duration = card.querySelector('[data-sdsn-duration]');

        const link = card.querySelector('.bcard-link');
        if (link) link.href = video.url;
        if (thumb && typeof video.thumb === 'string') {
          thumb.style.backgroundImage = `url(${video.thumb})`;
        }
        if (title) title.textContent = video.title;
        if (channel) channel.textContent = video.channelTitle || 'SDSN Classic';
        if (duration) {
          if (video.duration) duration.textContent = video.duration;
          else duration.hidden = true;
        }

        card.classList.remove('sdsn-card-loading');
      } catch {
        card.classList.add('hidden');
        refillIfNeeded();
        const classicCount = document.getElementById('classic-count');
        const visiblePicks = document.querySelectorAll('[data-broader-id]:not(.hidden)').length;
        if (classicCount) classicCount.textContent = `${visiblePicks} current picks`;
      }
    }

    function renderFollowedSeries() {
      const container = document.getElementById('followed-series-container');
      if (!container) return;
      const followed = getFollowedSeries();
      const watched = getWatched();
      const stanfordHidden = getStanfordHidden();
      container.innerHTML = '';
      followed.forEach(key => {
        const eps = SERIES_EPISODES[key];
        if (!eps || eps.length === 0) return;
        const section = document.createElement('div');
        section.className = 'series';
        section.dataset.series = key;
        const channelTitle = eps[0].channel_title || 'series';
        const head = document.createElement('div');
        head.className = 'series-head';
        head.innerHTML = `
          <div>
            <span class="series-name">${escapeHTML(channelTitle)}</span>
            <span class="score-chip">followed</span>
          </div>
          <span class="series-meta">${eps.length} ${eps.length === 1 ? 'video' : 'videos'} · <button class="mark-btn" data-unfollow-series="${escapeHTML(key)}" title="unfollow">×</button></span>
        `;
        const ul = document.createElement('ul');
        ul.className = 'videos';
        eps.forEach(v => {
          const li = document.createElement('li');
          li.dataset.videoId = v.id;
          li.dataset.videoUrl = v.url;
          if (watched.has(v.id)) li.classList.add('watched');
          if (stanfordHidden.has(v.id)) li.classList.add('hidden-row');
          const ep = v.episode_number != null ? `#${v.episode_number} · ` : '';
          li.innerHTML = `
            <span class="vtitle">${ep}${escapeHTML(v.title)}</span>
            <span class="vmeta">${fmtDurationJS(v.duration)} · ${fmtAgoJS(v.published_at)}</span>
            <span class="row-btns">
              <button class="mark-btn" data-toggle-watched="${escapeHTML(v.id)}" title="toggle watched">✓</button>
              <button class="mark-btn" data-hide-stanford="${escapeHTML(v.id)}" title="hide everywhere">×</button>
            </span>
          `;
          li.addEventListener('click', (e) => {
            if (e.target.closest('[data-toggle-watched]') || e.target.closest('[data-hide-stanford]')) return;
            window.open(v.url, '_blank', 'noopener');
          });
          ul.appendChild(li);
        });
        section.appendChild(head);
        section.appendChild(ul);
        container.appendChild(section);
      });
      container.querySelectorAll('[data-toggle-watched]').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          toggleWatched(btn.dataset.toggleWatched);
        });
      });
      container.querySelectorAll('[data-hide-stanford]').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          hideStanford(btn.dataset.hideStanford);
        });
      });
      container.querySelectorAll('[data-unfollow-series]').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const key = btn.dataset.unfollowSeries;
          const f = getFollowedSeries();
          f.delete(key);
          saveFollowedSeries(f);
          renderFollowedSeries();
        });
      });
    }

    function refillIfNeeded() {
      const grid = document.getElementById('broader-grid');
      if (!grid) return;
      const visible = grid.querySelectorAll('.bcard:not(.hidden)').length;
      // Keep the grid at a full 20 tiles. If the classic endpoint is down,
      // a current pick fills its spot instead of leaving an orphan card.
      const target = Number(grid.dataset.tileTarget) || 20;
      if (target <= visible || POOL.length === 0) return;
      const needed = target - visible;
      const hidden = getBroaderHidden();
      const banned = getBannedSeries();
      const followed = getFollowedSeries();
      const sourceLimit = Number(grid.dataset.sourceLimit) || 2;
      const sourceCounts = new Map();
      grid.querySelectorAll('.bcard:not(.hidden)[data-source-key]').forEach(card => {
        const key = card.dataset.sourceKey;
        sourceCounts.set(key, (sourceCounts.get(key) || 0) + 1);
      });
      const seenSeriesOnGrid = new Set(
        Array.from(grid.querySelectorAll('[data-series-key]'))
          .map(el => el.dataset.seriesKey)
          .filter(Boolean)
      );
      let added = 0;
      let checked = 0;
      const available = POOL.length;
      const deferred = [];
      while (added < needed && checked < available && POOL.length > 0) {
        const v = POOL.shift();
        checked++;
        if (hidden.has(v.id)) continue;
        if (v.series_key && (banned.has(v.series_key) || followed.has(v.series_key) || seenSeriesOnGrid.has(v.series_key))) continue;
        const sourceKey = sourceKeyJS(v);
        if ((sourceCounts.get(sourceKey) || 0) >= sourceLimit) {
          deferred.push(v);
          continue;
        }
        if (v.series_key) seenSeriesOnGrid.add(v.series_key);
        const card = buildCard(v);
        grid.appendChild(card);
        sourceCounts.set(sourceKey, (sourceCounts.get(sourceKey) || 0) + 1);
        added++;
      }
      POOL.push(...deferred);
      updateFeaturedCard();
    }

    // Wire up any pre-rendered mark buttons
    document.querySelectorAll('[data-mark-broader]').forEach(wireMarkButton);
    renderFollowedSeries();
    renderBroaderHidden();
    refillIfNeeded();
    loadSdsnClassicCard();
  </script>
  <script is:inline>
    // WNBA's watch pages can render as logged-out even when the browser has a
    // valid WNBA ID session. Prime their same-site auth bridge in the new tab
    // first, then send that tab to the specific game/replay URL.
    (function () {
      const WNBA_AUTH_BRIDGE = 'https://www.wnba.com/api/auth/authenticate';
      const WNBA_AUTH_DELAY_MS = 1200;

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const link = target.closest('a[data-wnba-auth-launch]');
        if (!(link instanceof HTMLAnchorElement)) return;
        if (
          event.defaultPrevented ||
          event.button !== 0 ||
          event.metaKey ||
          event.ctrlKey ||
          event.shiftKey ||
          event.altKey
        ) {
          return;
        }

        const href = link.href;
        if (!href.startsWith('https://www.wnba.com/')) return;
        event.preventDefault();

        const tab = window.open('about:blank', '_blank');
        if (!tab) {
          window.location.href = href;
          return;
        }

        try {
          tab.opener = null;
        } catch {}
        tab.location.href = WNBA_AUTH_BRIDGE;
        window.setTimeout(() => {
          try {
            tab.location.href = href;
          } catch {
            window.open(href, '_blank', 'noopener');
          }
        }, WNBA_AUTH_DELAY_MS);
      });
    })();
  </script>
  <script>
    // Point the basketball launcher at the previous day's best WNBA game page.
    // WNBA.com exposes full-game replay choices from the game page once the
    // replay is ready, while synthesized /watch/video URLs can load a shell
    // with no playable video. Falls back to the WNBA Watch page (the
    // static href) on off-days or if the game can't be resolved.
    import { fetchEspnScoreboard } from '../lib/sportsCore';
    import {
      competitorsOf,
      fetchWnbaGameIds,
      finishedGameWatchScore,
      isFinalEvent,
      isoDateInPT,
      watchRecordingUrl,
      yyyymmddInPT,
      type ESPNEvent,
    } from '../lib/wtwtwSports';
    import { MS_PER_DAY } from '../lib/time';

    const launcher = document.getElementById('best-wnba-launcher');
    if (launcher instanceof HTMLAnchorElement) {
      (async () => {
        try {
          const yesterday = new Date(Date.now() - MS_PER_DAY);
          const ymd = yyyymmddInPT(yesterday);
          const iso = isoDateInPT(yesterday);
          const [board, wnbaGameIds] = await Promise.all([
            fetchEspnScoreboard<ESPNEvent>('basketball/wnba', ymd),
            fetchWnbaGameIds(),
          ]);
          const finals = (board.events || []).filter(isFinalEvent);
          if (finals.length === 0) return;

          let best: ESPNEvent | null = null;
          let bestScore = -Infinity;
          for (const ev of finals) {
            const score = finishedGameWatchScore(ev);
            if (score > bestScore) {
              bestScore = score;
              best = ev;
            }
          }
          if (!best) return;

          const cs = competitorsOf(best);
          const away = cs.find((c) => c.homeAway === 'away');
          const home = cs.find((c) => c.homeAway === 'home');
          const watch = watchRecordingUrl({
            league: 'basketball/wnba',
            awayAbbr: away?.team?.abbreviation,
            homeAbbr: home?.team?.abbreviation,
            isoDate: iso,
            wnbaGameIds,
          });
          // Only override the static fallback when a real WNBA target resolved.
          if (!watch.href.includes('/game/')) {
            return;
          }

          launcher.href = watch.href;
          const awayName =
            away?.team?.shortDisplayName || away?.team?.abbreviation || 'Away';
          const homeName =
            home?.team?.shortDisplayName || home?.team?.abbreviation || 'Home';
          const label = `Yesterday's best WNBA game: ${awayName} @ ${homeName}`;
          launcher.title = label;
          launcher.setAttribute('aria-label', label);
        } catch {
          /* keep the WNBA League Pass fallback href */
        }
      })();
    }
  </script>
</body>
</html>
