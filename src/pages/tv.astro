      line-height: 1;
      letter-spacing: -0.02em;
      margin: 2.5rem 0 2rem;
    }

    .series {
      border: var(--border);
      background: var(--paper);
      box-shadow: var(--shadow);
      margin-bottom: 1.5rem;
      padding: 1rem 1.25rem;
    }
    .series[hidden] { display: none; }
    .series-head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1rem;
      margin-bottom: .5rem;
      flex-wrap: wrap;
    }
