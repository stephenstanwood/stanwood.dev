---
// Stanford queue + Around the internet. Both are launchpads — click to open
// on YouTube (Stanford disabled embedding, so no in-page player).

import fs from 'node:fs';
import path from 'node:path';
import LiveSports from '../components/LiveSports.tsx';
import TodaySports from '../components/TodaySports.tsx';
import YesterdaySports from '../components/YesterdaySports.tsx';
import { daysSince } from '../lib/time';

interface QueueVideo {
  id: string;
  title: string;
  url?: string;
  duration: number;
  published_at: string;
  lecture_num: number | null;
}

interface Series {
  key: string;
  display_name: string;
  best_score: number;
  video_count: number;
  video_ids: string[];
}

interface BroaderVideo {
  id: string;
  title: string;
  url: string;
  duration: number;
  published_at: string;
  channel_title: string;
  channel_id?: string;
  channel_handle?: string;
  thumb?: string;
  series_key?: string;
  episode_number?: number;
  exploration?: boolean;
  categories?: string[];
  score?: number;
  rank_score?: number;
  feedback_mult?: number;
  source?: 'trusted' | 'discovery';
  editorial_score?: number;
  editorial_reason?: string;
}

interface YouTubeData {
  queue: QueueVideo[];
  series: Series[];
  built_at: string | null;
}

interface BroaderData {
  queue: BroaderVideo[];
  pool: BroaderVideo[];
  built_at: string | null;
  channel_count: number;
  discovery_query_count?: number;
  discovery_candidate_count?: number;
  editorial_applied?: boolean;
  series_episodes?: Record<string, BroaderVideo[]>;
}

const dataPath = path.join(process.cwd(), 'public', 'yt', 'videos.json');
let data: YouTubeData = { queue: [], series: [], built_at: null };
if (fs.existsSync(dataPath)) {
  data = JSON.parse(fs.readFileSync(dataPath, 'utf-8'));
}

const broaderPath = path.join(process.cwd(), 'public', 'yt', 'broader.json');
let broader: BroaderData = { queue: [], pool: [], built_at: null, channel_count: 0 };
if (fs.existsSync(broaderPath)) {
  broader = JSON.parse(fs.readFileSync(broaderPath, 'utf-8'));
}

// Channels permanently screened out of "around the internet" — never render
// these, even if the nightly pipeline surfaces them. Matched on channel_id
// (stable) or @handle (case-insensitive). The Mini's build_broader.py drops
// them at the source too; this is the repo-side guarantee that survives any
// pipeline regression.
const BLOCKED_CHANNEL_IDS = new Set<string>([
  'UCbRP3c757lWg9M-U7TyEkXA', // Theo - t3.gg
  'UCrqM0Ym_NbK1fqeQG2VIohg', // Tsoding Daily
]);
const BLOCKED_CHANNEL_HANDLES = new Set<string>([
  '@t3dotgg', // Theo - t3.gg
  '@tsodingdaily', // Tsoding Daily
]);
function isBlockedBroader(v: BroaderVideo): boolean {
  if (v.channel_id && BLOCKED_CHANNEL_IDS.has(v.channel_id)) return true;
  const handle = v.channel_handle?.toLowerCase();
  return handle ? BLOCKED_CHANNEL_HANDLES.has(handle) : false;
}

const byRecency = (a: { published_at: string }, b: { published_at: string }) =>
  new Date(b.published_at).getTime() - new Date(a.published_at).getTime();

const SHOW_STANFORD_TALKS = false;
const AUTO_UNLOCK_IN_DEV = import.meta.env.DEV;
const INTERNET_TILE_COUNT = 20;
const INTERNET_PICK_COUNT = INTERNET_TILE_COUNT - 1;
const INTERNET_MAX_AGE_DAYS = 7;
const INTERNET_MAX_PER_SOURCE = 2;

const TOPIC_LABELS: Record<string, string> = {
  hci: 'design',
  product_craft: 'product craft',
  solo_builder: 'solo builder',
  working_method: 'working method',
  war_stories: 'how it went',
  swe_craft: 'software craft',
  systems_db: 'systems',
  algorithms: 'computer science',
  applied_ai: 'AI in practice',
  civic_open: 'public tech',
  math_viz: 'visual math',
};

function topicLabel(v: BroaderVideo): string {
  const priority = ['hci', 'working_method', 'product_craft', 'solo_builder', 'war_stories', 'swe_craft', 'systems_db', 'algorithms', 'applied_ai', 'civic_open', 'math_viz'];
  const category = priority.find((key) => v.categories?.includes(key));
  return category ? TOPIC_LABELS[category] : 'worth a look';
}

function ageInDays(v: BroaderVideo): number {
  return Math.max(0, (Date.now() - new Date(v.published_at).getTime()) / 86_400_000);
}

function editorialScore(v: BroaderVideo): number {
  const pipelineRank = v.rank_score;
  const quality = pipelineRank ?? (v.score ?? 0) - ageInDays(v) * 1.25;
  const explorationCost = v.exploration ? 2 : 0;
  const utilityBonus = v.categories?.includes('solo_builder')
    ? 4
    : v.categories?.includes('working_method')
      ? 3
      : v.categories?.includes('product_craft')
        ? 2
        : 0;
  return quality + utilityBonus - explorationCost;
}

function chooseInternetPicks(items: BroaderVideo[], count: number): BroaderVideo[] {
  const ranked = [...items].sort((a, b) => {
    const scoreDiff = editorialScore(b) - editorialScore(a);
    return scoreDiff || byRecency(a, b);
  });
  const selected: BroaderVideo[] = [];
  const channelCounts = new Map<string, number>();
  const topicCounts = new Map<string, number>();

  for (const video of ranked) {
    if (ageInDays(video) > INTERNET_MAX_AGE_DAYS || editorialScore(video) < 2) continue;
    const channelKey = video.channel_id || video.channel_handle || video.channel_title;
    const topic = topicLabel(video);
    const topicLimit = topic === 'AI in practice' ? 2 : 3;
    if ((channelCounts.get(channelKey) ?? 0) > 0 || (topicCounts.get(topic) ?? 0) >= topicLimit) continue;
    selected.push(video);
    channelCounts.set(channelKey, 1);
    topicCounts.set(topic, (topicCounts.get(topic) ?? 0) + 1);
    if (selected.length === count) return selected;
  }

  for (const video of ranked) {
    if (selected.some((pick) => pick.id === video.id)) continue;
    if (ageInDays(video) > INTERNET_MAX_AGE_DAYS || editorialScore(video) < 2) continue;
    const channelKey = video.channel_id || video.channel_handle || video.channel_title;
    if ((channelCounts.get(channelKey) ?? 0) >= INTERNET_MAX_PER_SOURCE) continue;
    selected.push(video);
    channelCounts.set(channelKey, (channelCounts.get(channelKey) ?? 0) + 1);
    if (selected.length === count) return selected;
  }

  return selected;
}

const seenBroaderIds = new Set<string>();
const allBroader = [...(broader.queue ?? []), ...(broader.pool ?? [])]
  .filter((video) => {
    if (isBlockedBroader(video) || seenBroaderIds.has(video.id)) return false;
    seenBroaderIds.add(video.id);
    return true;
  });
const internetPicks = chooseInternetPicks(allBroader, INTERNET_PICK_COUNT);
const internetPickIds = new Set(internetPicks.map((video) => video.id));
broader.queue = internetPicks;
broader.pool = allBroader
  .filter((video) => !internetPickIds.has(video.id))
  .sort((a, b) => editorialScore(b) - editorialScore(a) || byRecency(a, b));

function fmtDuration(seconds: number) {
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  return h > 0 ? `${h}h${String(m).padStart(2, '0')}` : `${m}m`;
}

function fmtAgo(iso: string) {
  const days = daysSince(iso);
  if (days === 0) return 'today';
  if (days < 7) return `${days}d ago`;
  if (days < 30) return `${Math.floor(days / 7)}w ago`;
  return `${Math.floor(days / 30)}mo ago`;
}

function fmtRefresh(iso: string | null) {
  if (!iso) return 'refresh pending';
  const time = new Intl.DateTimeFormat('en-US', {
    timeZone: 'America/Los_Angeles',
    hour: 'numeric',
    minute: '2-digit',
  }).format(new Date(iso));
  return `updated ${fmtAgo(iso)} · ${time} PT`;
}

const topSeries = data.series?.[0] ?? null;
const restSeries = (data.series ?? []).slice(1);

// Series where videos are independent (seminars, talk series) — show newest first.
// Sequential courses (lectures 1, 2, 3...) stay in original order.
const REVERSE_ORDER_KEYS = new Set(['CS547', 'Robotics Seminar']);

function seriesVideos(series: Series): QueueVideo[] {
  const vids = series.video_ids
    .map((id) => data.queue.find((v) => v.id === id))
    .filter((v): v is QueueVideo => v !== undefined);
  if (REVERSE_ORDER_KEYS.has(series.key)) {
    return [...vids].sort(byRecency);
  }
  return vids;
}
