---
export const prerender = false;

let error = false;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const password = form.get('password') as string | null;
  const expected = import.meta.env.MONEY_PASSWORD || process.env.MONEY_PASSWORD;

  if (password && expected && password === expected) {
    return new Response(null, {
      status: 302,
      headers: {
        'Location': '/money',
        'Set-Cookie': `money_session=${expected}; Path=/; HttpOnly; Secure; SameSite=Strict`,
      },
    });
  }
  error = true;
}
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>$$$ — stanwood.dev</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Permanent+Marker&family=Rubik+Mono+One&family=Space+Mono:wght@400;700&display=swap" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Space Mono', monospace;
      background: #fffef5;
      color: #111;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }
    .box {
      border: 3px solid #111;
      box-shadow: 6px 6px 0 #111;
      background: #fff;
      padding: 40px 36px;
      width: 100%;
      max-width: 360px;
      text-align: center;
    }
    h1 {
      font-family: 'Rubik Mono One', sans-serif;
      font-size: 48px;
      line-height: 1;
      background: #ffb938;
      border: 3px solid #111;
      box-shadow: 4px 4px 0 #111;
      display: inline-block;
      padding: 6px 20px;
      transform: rotate(-1.5deg);
      margin-bottom: 28px;
    }
    label {
      display: block;
      font-size: 10px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      opacity: 0.6;
      margin-bottom: 8px;
      text-align: left;
    }
    input[type="password"] {
      width: 100%;
      border: 2px solid #111;
      padding: 10px 14px;
      font-family: 'Space Mono', monospace;
      font-size: 16px;
      background: #fffef5;
      margin-bottom: 16px;
      outline: none;
    }
    input[type="password"]:focus { border-color: #ff5c1a; }
    button {
      width: 100%;
      background: #111;
      color: #fffef5;
      border: 2px solid #111;
      padding: 12px;
      font-family: 'Space Mono', monospace;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.1s, color 0.1s;
    }
    button:hover { background: #ff5c1a; border-color: #ff5c1a; }
    .error {
      font-family: 'Permanent Marker', cursive;
      color: #e11;
      font-size: 16px;
      margin-bottom: 16px;
    }
  </style>
</head>
<body>
  <div class="box">
    <h1>$$$</h1>
    {error && <div class="error">wrong password</div>}
    <form method="POST">
      <label for="pw">password</label>
      <input id="pw" type="password" name="password" autofocus autocomplete="current-password" />
      <button type="submit">unlock</button>
    </form>
  </div>
</body>
</html>
