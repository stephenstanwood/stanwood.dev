---
import BaseLayout from "../layouts/BaseLayout.astro";
import ShowSwipe from "../components/ShowSwipe.tsx";
const title = "Show Swipe — stanwood.dev";
---

<BaseLayout
  title={title}
  description="Swipe through movie and TV trailers. Like a dating app, but for what to watch next."
  slug="show-swipe"
  favicon="/favicon-ss.svg"
  themeColor="#0a0e17"
  fontsUrl="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Space+Grotesk:wght@500;700&display=swap"
  schemaCategory="EntertainmentApplication"
  schemaName="Show Swipe"
>
  <Fragment slot="head">
    <style is:global>
      /* ─── Page Theme ─────────────────────────────────────────────── */
      :root {
        --ss-bg: #0a0e17;
        --ss-surface: #141a26;
        --ss-surface-raised: #1c2435;
        --ss-text: #e8e6e3;
        --ss-text-muted: #7a8599;
        --ss-text-dim: #3d4a5c;
        --ss-warm: #d4a24e;
        --ss-warm-light: #e8bb6a;
        --ss-warm-glow: rgba(212, 162, 78, 0.15);
        --ss-cool: #5a7aa8;
        --ss-nope: #4a3d50;
        --ss-nope-light: #7a6585;
        --ss-star: #d4a24e;
        --ss-border: #1e2a3a;
        --ss-card-radius: 14px;
        --ss-grain: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      }

      body {
        font-family: 'Inter', system-ui, sans-serif;
        background: var(--ss-bg);
        color: var(--ss-text);
        margin: 0;
        overflow-x: hidden;
      }

      /* Film grain overlay */
      body::after {
        content: '';
        position: fixed;
        inset: 0;
        background: var(--ss-grain);
        pointer-events: none;
        z-index: 9999;
        opacity: 0.5;
      }

      /* ─── Animations ─────────────────────────────────────────────── */
      @keyframes ssFadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes ssFadeUp {
        from { opacity: 0; transform: translateY(16px) scale(0.98); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
      }
      @keyframes ssSpin {
        to { transform: rotate(360deg); }
      }
      @keyframes ssPulse {
        0%, 100% { opacity: 0.3; }
        50% { opacity: 0.8; }
      }
      @keyframes ssSlideIn {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes ssToast {
        0% { opacity: 0; transform: translateY(10px); }
        15% { opacity: 1; transform: translateY(0); }
        85% { opacity: 1; transform: translateY(0); }
        100% { opacity: 0; transform: translateY(-10px); }
      }

      /* ─── Layout ─────────────────────────────────────────────────── */
      .ss-page {
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        max-width: 480px;
        margin: 0 auto;
        position: relative;
      }

      .ss-header {
        padding: 0.75rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
      }

      .ss-back {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        color: var(--ss-text-dim);
        text-decoration: none;
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        transition: color 0.15s;
      }
      .ss-back:hover { color: var(--ss-text-muted); }
      .ss-back svg { width: 14px; height: 14px; }

      .ss-brand {
        font-family: 'Space Grotesk', sans-serif;
        font-weight: 700;
        font-size: 0.95rem;
        color: var(--ss-warm);
        letter-spacing: -0.01em;
      }

      .ss-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        padding: 0 0.75rem 1rem;
        min-height: 0;
      }

      /* ─── App Container ──────────────────────────────────────────── */
      .ss-app {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        animation: ssFadeIn 0.3s ease-out;
      }

      /* ─── Toggles Container ──────────────────────────────────────── */
      .ss-toggles {
        display: flex;
        flex-direction: column;
        gap: 4px;
        flex-shrink: 0;
      }

      /* ─── Media Toggle ───────────────────────────────────────────── */
      .ss-toggle {
        display: flex;
        gap: 2px;
        background: var(--ss-surface);
        border: 1px solid var(--ss-border);
        border-radius: 10px;
        padding: 3px;
        flex-shrink: 0;
      }
      .ss-toggle-sm .ss-toggle-btn {
        padding: 0.3rem 0.75rem;
        font-size: 0.7rem;
        letter-spacing: 0.04em;
      }
      .ss-toggle-btn {
        flex: 1;
        padding: 0.45rem 0.75rem;
        border: none;
        border-radius: 8px;
        background: transparent;
        color: var(--ss-text-dim);
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
      }
      .ss-toggle-icon {
        font-size: 0.85rem;
      }
      .ss-toggle-btn.ss-toggle-active {
        background: var(--ss-surface-raised);
        color: var(--ss-warm);
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.3);
      }
      .ss-toggle-btn:not(.ss-toggle-active):hover {
        color: var(--ss-text-muted);
      }

      /* ─── Card Area ──────────────────────────────────────────────── */
      .ss-card-area {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 0;
        position: relative;
      }

      /* ─── Swipe Card ─────────────────────────────────────────────── */
      .ss-card {
        width: 100%;
        border-radius: var(--ss-card-radius);
        overflow: hidden;
        cursor: grab;
        background: var(--ss-surface);
        border: 1px solid var(--ss-border);
        box-shadow:
          0 2px 8px rgba(0, 0, 0, 0.3),
          0 12px 40px rgba(0, 0, 0, 0.2);
        touch-action: pan-y;
        user-select: none;
        will-change: transform;
        position: relative;
        animation: ssFadeUp 0.3s ease-out;
      }
      .ss-card:active {
        cursor: grabbing;
      }

      /* ─── Trailer ────────────────────────────────────────────────── */
      .ss-trailer {
        width: 100%;
        aspect-ratio: 16/9;
        background: #000;
        position: relative;
        overflow: hidden;
      }
      .ss-trailer-iframe {
        width: 100%;
        height: 100%;
        border: none;
        display: block;
      }

      /* ─── Card Info ──────────────────────────────────────────────── */
      .ss-card-info {
        padding: 0.75rem 0.875rem 0.25rem;
      }
      .ss-card-title-row {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 0.5rem;
      }
      .ss-card-title {
        font-family: 'Space Grotesk', sans-serif;
        font-weight: 700;
        font-size: 1.1rem;
        line-height: 1.2;
        margin: 0;
        flex: 1;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: var(--ss-text);
      }

      /* Share link */
      .ss-share-link {
        background: none;
        border: none;
        color: var(--ss-text-dim);
        font-family: 'Inter', sans-serif;
        font-size: 0.65rem;
        font-weight: 500;
        letter-spacing: 0.03em;
        cursor: pointer;
        white-space: nowrap;
        flex-shrink: 0;
        padding: 0.2rem 0;
        transition: color 0.15s;
        text-decoration: none;
        border-bottom: 1px solid transparent;
      }
      .ss-share-link:hover {
        color: var(--ss-warm);
        border-bottom-color: var(--ss-warm);
      }

      .ss-card-meta {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        margin-top: 0.2rem;
        font-size: 0.75rem;
        color: var(--ss-text-muted);
      }
      .ss-card-year {
        color: var(--ss-text-muted);
        font-variant-numeric: tabular-nums;
      }
      .ss-card-rating {
        color: var(--ss-star);
      }
      .ss-card-dot {
        opacity: 0.3;
      }
      .ss-card-genres {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: var(--ss-text-dim);
      }
      .ss-card-overview {
        font-size: 0.78rem;
        color: var(--ss-text-muted);
        line-height: 1.5;
        margin-top: 0.35rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      /* ─── Card Action Buttons ────────────────────────────────────── */
      .ss-card-actions {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 0.875rem 0.75rem;
      }

      .ss-btn {
        border: none;
        cursor: pointer;
        font-family: 'Space Grotesk', sans-serif;
        font-weight: 700;
        letter-spacing: 0.06em;
        transition: transform 0.1s, background 0.15s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
      }
      .ss-btn:active {
        transform: scale(0.95);
      }

      .ss-btn-nope {
        flex: 1;
        padding: 0.65rem 1rem;
        background: var(--ss-surface-raised);
        color: var(--ss-text-muted);
        border-radius: 10px;
        font-size: 0.8rem;
        border: 1px solid var(--ss-border);
      }
      .ss-btn-nope:hover {
        background: var(--ss-nope);
        color: var(--ss-text);
        border-color: var(--ss-nope-light);
      }

      .ss-btn-yes {
        flex: 1;
        padding: 0.65rem 1rem;
        background: var(--ss-warm);
        color: var(--ss-bg);
        border-radius: 10px;
        font-size: 0.8rem;
      }
      .ss-btn-yes:hover {
        background: var(--ss-warm-light);
      }

      .ss-btn-retry {
        padding: 0.65rem 1.5rem;
        background: var(--ss-warm);
        color: var(--ss-bg);
        border-radius: 10px;
        font-size: 0.8rem;
      }
      .ss-btn-retry:hover {
        background: var(--ss-warm-light);
      }

      /* ─── Swipe Overlays ─────────────────────────────────────────── */
      .ss-swipe-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
        z-index: 10;
        border-radius: var(--ss-card-radius);
      }
      .ss-overlay-yes {
        background: rgba(212, 162, 78, 0.1);
      }
      .ss-overlay-nope {
        background: rgba(74, 61, 80, 0.15);
      }
      .ss-overlay-label {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 2.2rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .ss-label-yes {
        color: var(--ss-warm);
        transform: rotate(-12deg);
        border: 3px solid var(--ss-warm);
        padding: 0.15rem 0.75rem;
        border-radius: 6px;
        background: rgba(10, 14, 23, 0.5);
      }
      .ss-label-nope {
        color: var(--ss-nope-light);
        transform: rotate(12deg);
        border: 3px solid var(--ss-nope-light);
        padding: 0.15rem 0.75rem;
        border-radius: 6px;
        background: rgba(10, 14, 23, 0.5);
      }

      /* ─── Loading ────────────────────────────────────────────────── */
      .ss-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
      }
      .ss-spinner {
        width: 32px;
        height: 32px;
        border: 2px solid var(--ss-border);
        border-top-color: var(--ss-warm);
        border-radius: 50%;
        animation: ssSpin 0.8s linear infinite;
      }
      .ss-loading-text {
        font-size: 0.8rem;
        color: var(--ss-text-dim);
        font-family: 'Space Grotesk', sans-serif;
        letter-spacing: 0.04em;
        animation: ssPulse 1.5s ease-in-out infinite;
      }

      /* ─── Error / Empty States ───────────────────────────────────── */
      .ss-error-state,
      .ss-empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        text-align: center;
        padding: 2rem;
      }
      .ss-error {
        background: rgba(212, 162, 78, 0.08);
        color: var(--ss-warm-light);
        border: 1px solid rgba(212, 162, 78, 0.15);
        border-radius: 10px;
        padding: 0.65rem 1rem;
        font-size: 0.8rem;
      }
      .ss-empty-text {
        color: var(--ss-text-muted);
        font-size: 0.85rem;
      }

      /* ─── Footer / Skip / Hint ───────────────────────────────────── */
      .ss-footer {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.4rem;
        flex-shrink: 0;
      }

      .ss-skip {
        background: none;
        border: none;
        color: var(--ss-text-dim);
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        cursor: pointer;
        padding: 0.35rem 0.75rem;
        border-radius: 6px;
        transition: color 0.15s, background 0.15s;
      }
      .ss-skip:hover {
        color: var(--ss-text-muted);
        background: var(--ss-surface);
      }

      .ss-hint {
        text-align: center;
        font-size: 0.6rem;
        color: var(--ss-text-dim);
        letter-spacing: 0.06em;
        font-family: 'Space Grotesk', sans-serif;
        opacity: 0.6;
      }

      /* ─── Toast ──────────────────────────────────────────────────── */
      .ss-toast {
        position: fixed;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        background: var(--ss-surface-raised);
        color: var(--ss-warm);
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.8rem;
        font-weight: 600;
        padding: 0.5rem 1.25rem;
        border-radius: 8px;
        border: 1px solid var(--ss-border);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
        z-index: 100;
        animation: ssToast 2s ease-in-out forwards;
        pointer-events: none;
      }

      /* ─── Desktop: wider cards ─────────────────────────────────────── */
      @media (min-width: 600px) {
        .ss-page {
          max-width: 640px;
          padding: 0 1rem;
        }
        .ss-card-info {
          padding: 1rem 1.25rem 0.35rem;
        }
        .ss-card-actions {
          padding: 0.5rem 1.25rem 1rem;
        }
        .ss-card-title {
          font-size: 1.3rem;
        }
        .ss-card-overview {
          -webkit-line-clamp: 3;
        }
      }

      @media (min-width: 900px) {
        .ss-page {
          max-width: 760px;
        }
      }

      /* ─── Reduced Motion ─────────────────────────────────────────── */
      @media (prefers-reduced-motion: reduce) {
        .ss-card { animation: none; }
        .ss-spinner { animation: none; border-top-color: var(--ss-warm); }
        .ss-loading-text { animation: none; }
        body::after { display: none; }
      }
    </style>
  </Fragment>

  <div class="ss-page">
    <a href="#main-content" class="skip-nav">Skip to content</a>
    <header class="ss-header">
      <a href="/" class="ss-back" aria-label="Back to stanwood.dev">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 18l-6-6 6-6" />
        </svg>
        stanwood.dev
      </a>
      <span class="ss-brand">Show Swipe</span>
    </header>
    <main id="main-content" class="ss-main">
      <ShowSwipe client:idle />
    </main>
  </div>
</BaseLayout>
