---
import BaseLayout from "../layouts/BaseLayout.astro";
import ShowSwipe from "../components/ShowSwipe.tsx";
const title = "Show Swipe — stanwood.dev";
---

<BaseLayout
  title={title}
  description="Swipe through movie and TV trailers. Like a dating app, but for what to watch next."
  slug="show-swipe"
  favicon="/favicon-ss.svg"
  themeColor="#0d0d0d"
  fontsUrl="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Space+Grotesk:wght@500;700&display=swap"
  schemaCategory="EntertainmentApplication"
  schemaName="Show Swipe"
>
  <Fragment slot="head">
    <style is:global>
      /* ─── Page Theme ─────────────────────────────────────────────── */
      :root {
        --ss-bg: #0d0d0d;
        --ss-surface: #1a1a1a;
        --ss-surface-raised: #242424;
        --ss-text: #f0f0f0;
        --ss-text-muted: #999;
        --ss-text-dim: #555;
        --ss-primary: #e85d4a;
        --ss-primary-light: #ff7a6a;
        --ss-nope: #4a4a4a;
        --ss-nope-light: #666;
        --ss-star: #fbbf24;
        --ss-border: #2a2a2a;
        --ss-card-radius: 16px;
      }

      body {
        font-family: 'Inter', system-ui, sans-serif;
        background: var(--ss-bg);
        color: var(--ss-text);
        margin: 0;
        overflow-x: hidden;
      }

      /* ─── Animations ─────────────────────────────────────────────── */
      @keyframes ssFadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes ssFadeUp {
        from { opacity: 0; transform: translateY(20px) scale(0.97); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
      }
      @keyframes ssSpin {
        to { transform: rotate(360deg); }
      }
      @keyframes ssPulse {
        0%, 100% { opacity: 0.4; }
        50% { opacity: 1; }
      }

      /* ─── Layout ─────────────────────────────────────────────────── */
      .ss-page {
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        max-width: 480px;
        margin: 0 auto;
      }

      .ss-header {
        padding: 0.75rem 1rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-shrink: 0;
      }

      .ss-back {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        color: var(--ss-text-muted);
        text-decoration: none;
        font-size: 0.8rem;
        font-weight: 500;
        transition: color 0.15s;
      }
      .ss-back:hover { color: var(--ss-text); }
      .ss-back svg { width: 16px; height: 16px; }

      .ss-brand {
        font-family: 'Space Grotesk', sans-serif;
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--ss-primary);
      }

      .ss-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        padding: 0 1rem 1.5rem;
        min-height: 0;
      }

      /* ─── App Container ──────────────────────────────────────────── */
      .ss-app {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        animation: ssFadeIn 0.3s ease-out;
      }

      /* ─── Media Toggle ───────────────────────────────────────────── */
      .ss-toggle {
        display: flex;
        gap: 0;
        background: var(--ss-surface);
        border-radius: 10px;
        padding: 3px;
        flex-shrink: 0;
      }
      .ss-toggle-btn {
        flex: 1;
        padding: 0.5rem 1rem;
        border: none;
        border-radius: 8px;
        background: transparent;
        color: var(--ss-text-muted);
        font-family: 'Inter', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
      }
      .ss-toggle-btn.ss-toggle-active {
        background: var(--ss-primary);
        color: white;
      }
      .ss-toggle-btn:not(.ss-toggle-active):hover {
        color: var(--ss-text);
      }

      /* ─── Card Area ──────────────────────────────────────────────── */
      .ss-card-area {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 0;
        position: relative;
      }

      /* ─── Swipe Card ─────────────────────────────────────────────── */
      .ss-card {
        width: 100%;
        border-radius: var(--ss-card-radius);
        overflow: hidden;
        background: var(--ss-surface);
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
        touch-action: pan-y;
        user-select: none;
        will-change: transform;
        position: relative;
        animation: ssFadeUp 0.3s ease-out;
      }

      /* ─── Trailer ────────────────────────────────────────────────── */
      .ss-trailer {
        width: 100%;
        aspect-ratio: 16/9;
        background: #000;
        position: relative;
        cursor: pointer;
        overflow: hidden;
      }
      .ss-trailer-thumb {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
      .ss-trailer-iframe {
        width: 100%;
        height: 100%;
        border: none;
        display: block;
      }
      .ss-play-btn {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: rgba(0, 0, 0, 0.7);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s, transform 0.2s;
      }
      .ss-trailer:hover .ss-play-btn {
        background: var(--ss-primary);
        transform: translate(-50%, -50%) scale(1.1);
      }

      /* ─── Card Info ──────────────────────────────────────────────── */
      .ss-card-info {
        padding: 0.875rem 1rem 0.5rem;
      }
      .ss-card-title-row {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
      }
      .ss-card-title {
        font-family: 'Space Grotesk', sans-serif;
        font-weight: 700;
        font-size: 1.15rem;
        line-height: 1.2;
        margin: 0;
        flex: 1;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .ss-card-year {
        font-size: 0.8rem;
        color: var(--ss-text-muted);
        flex-shrink: 0;
      }
      .ss-card-meta {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        margin-top: 0.25rem;
        font-size: 0.8rem;
        color: var(--ss-text-muted);
      }
      .ss-card-rating {
        color: var(--ss-star);
      }
      .ss-card-dot {
        opacity: 0.4;
      }
      .ss-card-genres {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .ss-card-overview {
        font-size: 0.8rem;
        color: var(--ss-text-muted);
        line-height: 1.5;
        margin-top: 0.4rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      /* ─── Card Action Buttons ────────────────────────────────────── */
      .ss-card-actions {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        padding: 0.5rem 1rem 0.875rem;
      }

      .ss-btn {
        border: none;
        border-radius: 12px;
        cursor: pointer;
        font-family: 'Space Grotesk', sans-serif;
        font-weight: 700;
        font-size: 0.9rem;
        letter-spacing: 0.04em;
        transition: transform 0.1s, opacity 0.15s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
      }
      .ss-btn:active {
        transform: scale(0.95);
      }

      .ss-btn-nope {
        flex: 1;
        padding: 0.75rem 1rem;
        background: var(--ss-surface-raised);
        color: var(--ss-text-muted);
        border: 1px solid var(--ss-border);
      }
      .ss-btn-nope:hover {
        background: var(--ss-nope);
        color: var(--ss-text);
      }

      .ss-btn-yes {
        flex: 1;
        padding: 0.75rem 1rem;
        background: var(--ss-primary);
        color: white;
      }
      .ss-btn-yes:hover {
        background: var(--ss-primary-light);
      }

      .ss-btn-share {
        padding: 0.75rem;
        background: transparent;
        color: var(--ss-text-muted);
        border: 1px solid var(--ss-border);
        border-radius: 50%;
        width: 44px;
        height: 44px;
        flex-shrink: 0;
      }
      .ss-btn-share:hover {
        color: var(--ss-text);
        border-color: var(--ss-text-muted);
      }

      .ss-btn-retry {
        padding: 0.75rem 1.5rem;
        background: var(--ss-primary);
        color: white;
        font-size: 0.85rem;
      }
      .ss-btn-retry:hover {
        background: var(--ss-primary-light);
      }

      /* ─── Swipe Overlays ─────────────────────────────────────────── */
      .ss-swipe-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
        z-index: 10;
        border-radius: var(--ss-card-radius);
      }
      .ss-overlay-yes {
        background: rgba(232, 93, 74, 0.15);
      }
      .ss-overlay-nope {
        background: rgba(100, 100, 100, 0.15);
      }
      .ss-overlay-label {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 2.5rem;
        font-weight: 700;
        letter-spacing: 0.05em;
      }
      .ss-label-yes {
        color: var(--ss-primary);
        transform: rotate(-15deg);
        border: 3px solid var(--ss-primary);
        padding: 0.25rem 1rem;
        border-radius: 8px;
      }
      .ss-label-nope {
        color: var(--ss-nope-light);
        transform: rotate(15deg);
        border: 3px solid var(--ss-nope-light);
        padding: 0.25rem 1rem;
        border-radius: 8px;
      }

      /* ─── Loading ────────────────────────────────────────────────── */
      .ss-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
      }
      .ss-spinner {
        width: 36px;
        height: 36px;
        border: 3px solid var(--ss-border);
        border-top-color: var(--ss-primary);
        border-radius: 50%;
        animation: ssSpin 0.8s linear infinite;
      }
      .ss-loading-text {
        font-size: 0.85rem;
        color: var(--ss-text-muted);
        animation: ssPulse 1.5s ease-in-out infinite;
      }

      /* ─── Error / Empty States ───────────────────────────────────── */
      .ss-error-state,
      .ss-empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        text-align: center;
        padding: 2rem;
      }
      .ss-error {
        background: rgba(232, 93, 74, 0.1);
        color: var(--ss-primary-light);
        border: 1px solid rgba(232, 93, 74, 0.2);
        border-radius: 10px;
        padding: 0.75rem 1rem;
        font-size: 0.85rem;
      }
      .ss-empty-text {
        color: var(--ss-text-muted);
        font-size: 0.9rem;
      }

      /* ─── Hint ───────────────────────────────────────────────────── */
      .ss-hint {
        text-align: center;
        font-size: 0.7rem;
        color: var(--ss-text-dim);
        letter-spacing: 0.05em;
        font-family: 'Space Grotesk', sans-serif;
        flex-shrink: 0;
      }

      /* ─── Reduced Motion ─────────────────────────────────────────── */
      @media (prefers-reduced-motion: reduce) {
        .ss-card { animation: none; }
        .ss-spinner { animation: none; border-top-color: var(--ss-primary); }
        .ss-loading-text { animation: none; }
      }
    </style>
  </Fragment>

  <div class="ss-page">
    <a href="#main-content" class="skip-nav">Skip to content</a>
    <header class="ss-header">
      <a href="/" class="ss-back" aria-label="Back to stanwood.dev">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 18l-6-6 6-6" />
        </svg>
        stanwood.dev
      </a>
      <span class="ss-brand">Show Swipe</span>
    </header>
    <main id="main-content" class="ss-main">
      <ShowSwipe client:idle />
    </main>
  </div>
</BaseLayout>
